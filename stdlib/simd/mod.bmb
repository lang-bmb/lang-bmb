// ============================================
// 2-source shuffle family (Cycle 2311+, Task B-11.5)
//
// Cross-block cross-lane shuffles — stencil recovery and window-sliding.
//   slide_left2_TxN(a, b, shift)  — result[i] = (i+shift<N ? a[i+shift] : b[i+shift-N])
//   slide_right2_TxN(a, b, shift) — result[i] = (i<shift ? a[N-shift+i] : b[i-shift])
//   concat_lo_hi_TxN(a, b)        — [a[0..N/2-1], b[0..N/2-1]]
//   concat_hi_lo_TxN(a, b)        — [a[N/2..N-1], b[N/2..N-1]]
// ============================================


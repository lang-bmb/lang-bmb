// Count Frequency — counts occurrences of target in array.

fn main() -> i64 = {
    let target = read_int();
    let n = read_int();
    let mut count: i64 = 0;
    let mut i: i64 = 0;
    while i < n {
        let val = read_int();
        if val == target {
            set count = count + 1
        } else { () };
        set i = i + 1
    };
    let _p = println(count);
    0
};

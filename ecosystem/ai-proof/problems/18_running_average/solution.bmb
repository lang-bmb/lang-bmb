// Running Average — prints truncated average after each element.

fn main() -> i64 = {
    let n = read_int();
    let mut sum: i64 = 0;
    let mut i: i64 = 0;
    while i < n {
        let val = read_int();
        set sum = sum + val;
        let avg = sum / (i + 1);
        let _p = println(avg);
        set i = i + 1
    };
    0
};

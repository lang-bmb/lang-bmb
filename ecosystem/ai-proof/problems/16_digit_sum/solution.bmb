// Digit Sum — reads a non-negative integer, prints sum of its digits.

fn digit_sum(n: i64) -> i64 = {
    let mut num: i64 = n;
    let mut sum: i64 = 0;
    while num > 0 {
        set sum = sum + num % 10;
        set num = num / 10
    };
    sum
};

fn main() -> i64 = {
    let n = read_int();
    let result = digit_sum(n);
    let _p = println(result);
    0
};

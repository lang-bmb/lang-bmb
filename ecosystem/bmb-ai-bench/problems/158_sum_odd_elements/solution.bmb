// Sum of odd-valued elements
fn sum_odd(n: i64, i: i64, acc: i64) -> i64
  pre i >= 0
= if i >= n { acc }
  else {
    let x = read_int();
    let new_acc = if x % 2 != 0 { acc + x } else { acc };
    sum_odd(n, i + 1, new_acc)
  };

fn main() -> i64 = {
    let n = read_int();
    let _p = println(sum_odd(n, 0, 0));
    0
};

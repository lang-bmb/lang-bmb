fn scan(n: i64, cand: i64, cnt: i64) -> i64
  pre n >= 0
= if n == 0 { cand }
  else {
    let x = read_int();
    if cnt == 0 { scan(n - 1, x, 1) }
    else {
      if x == cand { scan(n - 1, cand, cnt + 1) }
      else { scan(n - 1, cand, cnt - 1) }
    }
  };

fn main() -> i64 = {
  let n = read_int();
  let r = scan(n, 0, 0);
  let _p = println(r);
  0
};

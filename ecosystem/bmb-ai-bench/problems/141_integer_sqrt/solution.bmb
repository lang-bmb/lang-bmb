// Integer Square Root — binary search for floor(sqrt(n))
fn isqrt(lo: i64, hi: i64, n: i64) -> i64
= if lo > hi { lo - 1 }
  else {
    let mid = lo + (hi - lo) / 2;
    if mid * mid <= n { isqrt(mid + 1, hi, n) }
    else { isqrt(lo, mid - 1, n) }
  };

fn main() -> i64 = {
    let n = read_int();
    println(isqrt(0, n, n));
    0
};

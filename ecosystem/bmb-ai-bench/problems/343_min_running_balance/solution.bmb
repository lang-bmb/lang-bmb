fn scan(n: i64, i: i64, bal: i64, mn: i64) -> i64
  pre i >= 0
= if i >= n { mn }
  else {
    let x = read_int();
    let nb = bal + x;
    let nm = if nb < mn { nb } else { mn };
    scan(n, i + 1, nb, nm)
  };

fn main() -> i64 = {
  let n = read_int();
  let r = scan(n, 0, 0, 0);
  let _p = println(r);
  0
};

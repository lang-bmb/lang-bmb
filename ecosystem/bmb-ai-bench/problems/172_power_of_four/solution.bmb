// Is n a power of 4? Recursively divide by 4.
fn is_pow4(n: i64) -> i64
  pre n >= 0
  post it == 0 or it == 1
= if n == 1 { 1 }
  else if n <= 0 { 0 }
  else if n % 4 != 0 { 0 }
  else { is_pow4(n / 4) };

fn main() -> i64 = {
    let n = read_int();
    if n <= 0 { println(0) }
    else { println(is_pow4(n)) };
    0
};

// Check if s[i..] is a subsequence of t[j..]
fn is_subseq(s: String, t: String, i: i64, j: i64) -> i64
  pre i >= 0 and j >= 0
  post it == 0 or it == 1
= if i >= s.len() { 1 }
  else if j >= t.len() { 0 }
  else if s.byte_at(i) == t.byte_at(j) { is_subseq(s, t, i + 1, j + 1) }
  else { is_subseq(s, t, i, j + 1) };

fn main() -> i64 = {
    let s = read_line();
    let t = read_line();
    let _p = println(is_subseq(s, t, 0, 0));
    0
};

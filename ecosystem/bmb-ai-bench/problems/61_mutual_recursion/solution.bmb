// Mutual Recursion — is_even/is_odd using mutual recursion.
fn is_even(n: i64) -> i64 = {
    if n == 0 { 1 }
    else if n < 0 { is_even(0 - n) }
    else { is_odd(n - 1) }
};
fn is_odd(n: i64) -> i64 = {
    if n == 0 { 0 }
    else if n < 0 { is_odd(0 - n) }
    else { is_even(n - 1) }
};
fn main() -> i64 = {
    let t = read_int();
    for _i in 0..t {
        let n = read_int();
        let _p = println(is_even(n))
    };
    0
};

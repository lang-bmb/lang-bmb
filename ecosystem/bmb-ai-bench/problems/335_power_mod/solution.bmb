fn main() -> i64 = {
  let base = read_int();
  let exp = read_int();
  let m = read_int();
  let mut result = 1;
  let mut b = base % m;
  let mut e = exp;
  while e > 0 {
    if (e band 1) == 1 {
      set result = (result * b) % m;
    };
    set b = (b * b) % m;
    set e = e >> 1;
  };
  let _p = println(result % m);
  0
};

// Array Rotation — reads n, k, then n integers. Prints rotated left by k.

fn main() -> i64 = {
    let n = read_int();
    let k = read_int() % n;
    let v = vec_new();
    for _i in 0..n {
        let val = read_int();
        let _p = vec_push(v, val)
    };
    for i in 0..n {
        if i > 0 { let _s = print_str(" "); () } else { () };
        let idx = (i + k) % n;
        let _p = print(vec_get(v, idx))
    };
    let _nl = println_str("");
    let _f = vec_free(v);
    0
};

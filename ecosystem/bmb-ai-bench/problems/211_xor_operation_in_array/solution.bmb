fn xor_op(start: i64, i: i64, n: i64, acc: i64) -> i64
  pre i >= 0 and n >= 0 and acc >= 0
= if i >= n { acc }
  else {
    let val = start + 2 * i;
    xor_op(start, i + 1, n, acc bxor val)
  };

fn main() -> i64 = {
    let n = read_int();
    let start = read_int();
    let result = xor_op(start, 0, n, 0);
    let _p = println(result);
    0
};

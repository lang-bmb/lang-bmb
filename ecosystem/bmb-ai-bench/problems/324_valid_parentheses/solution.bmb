fn matches(open: i64, close: i64) -> i64 =
  if open == 40 and close == 41 { 1 }
  else { if open == 91 and close == 93 { 1 }
  else { if open == 123 and close == 125 { 1 } else { 0 } } };

fn scan(s: String, stk: i64, i: i64, n: i64) -> i64
  pre i >= 0
= if i >= n { if vec_len(stk) == 0 { 1 } else { 0 } }
  else {
    let c = s.byte_at(i);
    if c == 40 or c == 91 or c == 123 {
      let _p = vec_push(stk, c);
      scan(s, stk, i + 1, n)
    } else {
      if vec_len(stk) == 0 { 0 }
      else {
        let top = vec_pop(stk);
        if matches(top, c) == 1 { scan(s, stk, i + 1, n) } else { 0 }
      }
    }
  };

fn main() -> i64 = {
  let s = read_line();
  let stk = vec_new();
  let r = scan(s, stk, 0, s.len());
  let _p = println(r);
  0
};

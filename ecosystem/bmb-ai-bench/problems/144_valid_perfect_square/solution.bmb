// Valid Perfect Square — binary search
fn isqrt_check(lo: i64, hi: i64, n: i64) -> bool
= if lo > hi { false }
  else {
    let mid = lo + (hi - lo) / 2;
    if mid * mid == n { true }
    else if mid * mid < n { isqrt_check(mid + 1, hi, n) }
    else { isqrt_check(lo, mid - 1, n) }
  };

fn main() -> i64 = {
    let n = read_int();
    if isqrt_check(1, n, n) { println(1) } else { println(0) };
    0
};

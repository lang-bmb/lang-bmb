// Climbing Stairs — count distinct ways (Fibonacci-style DP)
fn main() -> i64 = {
    let n: i64 = read_int();
    if n == 1 { println(1) }
    else if n == 2 { println(2) }
    else {
        let mut a: i64 = 1;
        let mut b: i64 = 2;
        for _i in 2..n {
            let c = a + b;
            a = b;
            b = c
        };
        println(b)
    };
    0
};

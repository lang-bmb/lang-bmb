// Chain Calls — apply f(g(h(x))) chain.
fn add1(x: i64) -> i64 = x + 1;
fn double(x: i64) -> i64 = x * 2;
fn square(x: i64) -> i64 = x * x;
fn main() -> i64 = {
    let t = read_int();
    for _i in 0..t {
        let x = read_int();
        let _p = println(add1(double(square(x))))
    };
    0
};

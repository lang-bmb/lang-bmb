fn is_alnum(b: i64) -> i64 =
  if (b >= 48 and b <= 57) or (b >= 65 and b <= 90) or (b >= 97 and b <= 122) { 1 } else { 0 };

fn lower(b: i64) -> i64 = if b >= 65 and b <= 90 { b + 32 } else { b };

fn check(s: String, i: i64, j: i64) -> i64
  pre i >= 0
= if i >= j { 1 }
  else {
    let bi = s.byte_at(i);
    if is_alnum(bi) == 0 { check(s, i + 1, j) }
    else {
      let bj = s.byte_at(j);
      if is_alnum(bj) == 0 { check(s, i, j - 1) }
      else {
        if lower(bi) == lower(bj) { check(s, i + 1, j - 1) }
        else { 0 }
      }
    }
  };

fn main() -> i64 = {
  let s = read_line();
  let n = s.len();
  let r = if n == 0 { 1 } else { check(s, 0, n - 1) };
  let _p = println(r);
  0
};

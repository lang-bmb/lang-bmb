// Check if s[lo..hi] is palindrome
fn is_pal(s: String, lo: i64, hi: i64) -> i64
  pre lo >= 0 and hi >= 0
= if lo >= hi { 1 }
  else if s.byte_at(lo) != s.byte_at(hi) { 0 }
  else { is_pal(s, lo + 1, hi - 1) };

// Two-pointer with one allowed deletion
fn check(s: String, lo: i64, hi: i64, skipped: i64) -> i64
  pre lo >= 0 and hi >= 0 and skipped >= 0
= if lo >= hi { 1 }
  else if s.byte_at(lo) == s.byte_at(hi) { check(s, lo + 1, hi - 1, skipped) }
  else if skipped == 1 { 0 }
  else {
    let skip_lo = is_pal(s, lo + 1, hi);
    let skip_hi = is_pal(s, lo, hi - 1);
    if skip_lo == 1 or skip_hi == 1 { 1 } else { 0 }
  };

fn main() -> i64 = {
    let s = read_line();
    let result = check(s, 0, s.len() - 1, 0);
    let _p = println(result);
    0
};

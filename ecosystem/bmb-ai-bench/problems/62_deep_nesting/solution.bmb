// Deep Nesting — classify number into range using nested conditions.
fn classify(n: i64) -> i64 = {
    if n < 0 { -1 }
    else if n < 10 { 0 }
    else if n < 100 { 1 }
    else if n < 1000 { 2 }
    else if n < 10000 { 3 }
    else if n < 100000 { 4 }
    else if n < 1000000 { 5 }
    else { 6 }
};
fn main() -> i64 = {
    let t = read_int();
    for _i in 0..t {
        let n = read_int();
        let _p = println(classify(n))
    };
    0
};

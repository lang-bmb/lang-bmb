// Fibonacci mod m: f(0)=0, f(1)=1, f(n) = (f(n-1)+f(n-2)) % m
fn fib_mod(n: i64, m: i64, a: i64, b: i64) -> i64
  pre n >= 0
  post it >= 0
= if n == 0 { a % m }
  else { fib_mod(n - 1, m, b, (a + b) % m) };

fn main() -> i64 = {
    let n = read_int();
    let m = read_int();
    let _p = println(fib_mod(n, m, 0, 1));
    0
};

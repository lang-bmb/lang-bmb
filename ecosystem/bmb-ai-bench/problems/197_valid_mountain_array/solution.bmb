fn read_into_vec(v: i64, n: i64) -> i64
  pre n >= 0
= if n == 0 { v }
  else {
    let x = read_int();
    let _p = vec_push(v, x);
    read_into_vec(v, n - 1)
  };

// Find the peak index
fn find_peak(v: i64, i: i64) -> i64
  pre i >= 0
= if i + 1 >= vec_len(v) { i }
  else if vec_get(v, i + 1) > vec_get(v, i) { find_peak(v, i + 1) }
  else { i };

// Check strictly decreasing from peak to end
fn check_dec(v: i64, i: i64) -> i64
  pre i >= 0
= if i + 1 >= vec_len(v) { 1 }
  else if vec_get(v, i + 1) < vec_get(v, i) { check_dec(v, i + 1) }
  else { 0 };

fn main() -> i64 = {
    let n = read_int();
    let v = vec_new();
    let _r = read_into_vec(v, n);
    let result = if n < 3 { 0 }
                 else {
                   let peak = find_peak(v, 0);
                   if peak == 0 or peak == n - 1 { 0 }
                   else { check_dec(v, peak) }
                 };
    let _p = println(result);
    0
};

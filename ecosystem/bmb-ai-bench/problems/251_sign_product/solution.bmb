fn sign_product(n: i64, sign: i64) -> i64
  pre n >= 0
= if n == 0 { sign }
  else {
    let x = read_int();
    if x == 0 { 0 }
    else {
      let new_sign = if x < 0 { 0 - sign } else { sign };
      sign_product(n - 1, new_sign)
    }
  };

fn main() -> i64 = {
  let n = read_int();
  let result = sign_product(n, 1);
  let _p = println(result);
  0
};

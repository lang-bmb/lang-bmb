// ================================================
// Base64 Encoding/Decoding
// ================================================

// bmb-base64: RFC 4648 Base64 encoding and decoding
// v0.1.0
//
// Pure BMB implementation with contract-verified correctness.
// Supports standard Base64 and URL-safe Base64 alphabets.
//
// All buffer operations use raw i64 pointers with load_i64/store_i64.
// Each element is 8 bytes (i64), storing one byte value (0-255).
//
// Usage:
//   let encoded = b64_encode_string("Hello");
//   let decoded = b64_decode_string(encoded);

// ============================================================================
// Constants
// ============================================================================

fn B64_PAD() -> i64 = 61;  // '='

// ============================================================================
// Encoding/Decoding Tables
// ============================================================================

// Map 6-bit value (0-63) to Base64 character
fn b64_encode_char(val: i64) -> i64
  pre val >= 0 and val <= 63
= if val < 26 { val + 65 }          // A-Z
  else if val < 52 { val - 26 + 97 } // a-z
  else if val < 62 { val - 52 + 48 } // 0-9
  else if val == 62 { 43 }           // +
  else { 47 };                        // /

// Map Base64 character to 6-bit value (-1 = invalid)
fn b64_decode_char(c: i64) -> i64
  post ret >= -1 and ret <= 63
= if c >= 65 and c <= 90 { c - 65 }       // A-Z -> 0-25
  else if c >= 97 and c <= 122 { c - 97 + 26 } // a-z -> 26-51
  else if c >= 48 and c <= 57 { c - 48 + 52 }   // 0-9 -> 52-61
  else if c == 43 or c == 45 { 62 }              // + or -
  else if c == 47 or c == 95 { 63 }              // / or _
  else { 0 - 1 };

// ============================================================================
// Buffer helpers (i64 pointer, 8 bytes per element)
// ============================================================================

fn buf_get(buf: i64, idx: i64) -> i64 = load_i64(buf + idx * 8);
fn buf_set(buf: i64, idx: i64, val: i64) -> i64 = { store_i64(buf + idx * 8, val); 0 };

// ============================================================================
// Encode length
// ============================================================================

fn b64_encode_len(input_len: i64) -> i64
  pre input_len >= 0
  post ret >= 0
= ((input_len + 2) / 3) * 4;

fn b64_decode_len(input_len: i64) -> i64
  pre input_len >= 0
  post ret >= 0
= (input_len / 4) * 3;

// ============================================================================
// Encode: byte buffer -> Base64 buffer
// ============================================================================

fn b64_encode_triplet(src: i64, src_idx: i64, dst: i64, dst_idx: i64, remaining: i64) -> i64 = {
    let b0 = buf_get(src, src_idx);
    let b1 = if remaining >= 2 { buf_get(src, src_idx + 1) } else { 0 };
    let b2 = if remaining >= 3 { buf_get(src, src_idx + 2) } else { 0 };

    let combined = b0 * 65536 + b1 * 256 + b2;

    let c0 = (combined / 262144) band 63;
    let c1 = (combined / 4096) band 63;
    let c2 = (combined / 64) band 63;
    let c3 = combined band 63;

    let _s0 = buf_set(dst, dst_idx, b64_encode_char(c0));
    let _s1 = buf_set(dst, dst_idx + 1, b64_encode_char(c1));
    let _s2 = buf_set(dst, dst_idx + 2, if remaining >= 2 { b64_encode_char(c2) } else { B64_PAD() });
    let _s3 = buf_set(dst, dst_idx + 3, if remaining >= 3 { b64_encode_char(c3) } else { B64_PAD() });
    0
};

fn b64_encode(src: i64, src_len: i64, dst: i64) -> i64
  pre src_len >= 0
= if src_len == 0 { 0 }
  else {
      {
          let mut si = 0;
          let mut di = 0;
          while si < src_len {
              let remaining = src_len - si;
              let chunk = if remaining >= 3 { 3 } else { remaining };
              let _w = b64_encode_triplet(src, si, dst, di, chunk);
              si = si + 3;
              di = di + 4;
              0
          };
          di
      }
  };

// ============================================================================
// Decode: Base64 buffer -> byte buffer
// ============================================================================

fn b64_decode_quartet(src: i64, src_idx: i64, dst: i64, dst_idx: i64) -> i64 = {
    let c0 = b64_decode_char(buf_get(src, src_idx));
    let c1 = b64_decode_char(buf_get(src, src_idx + 1));
    let c2_raw = buf_get(src, src_idx + 2);
    let c3_raw = buf_get(src, src_idx + 3);

    let c2 = if c2_raw == B64_PAD() { 0 } else { b64_decode_char(c2_raw) };
    let c3 = if c3_raw == B64_PAD() { 0 } else { b64_decode_char(c3_raw) };

    if c0 < 0 or c1 < 0 { 0 - 1 }
    else if c2_raw != B64_PAD() and c2 < 0 { 0 - 1 }
    else if c3_raw != B64_PAD() and c3 < 0 { 0 - 1 }
    else {
        let combined = c0 * 262144 + c1 * 4096 + c2 * 64 + c3;

        let _s0 = buf_set(dst, dst_idx, (combined / 65536) band 255);

        if c2_raw == B64_PAD() { 1 }
        else {
            let _s1 = buf_set(dst, dst_idx + 1, (combined / 256) band 255);
            if c3_raw == B64_PAD() { 2 }
            else {
                let _s2 = buf_set(dst, dst_idx + 2, combined band 255);
                3
            }
        }
    }
};

fn b64_decode(src: i64, src_len: i64, dst: i64) -> i64
  pre src_len >= 0
  post ret >= -1
= if src_len == 0 { 0 }
  else if src_len band 3 != 0 { 0 - 1 }
  else {
      {
          let mut si = 0;
          let mut di = 0;
          let mut error = false;
          let mut done = false;
          while not done {
              let _r = if si >= src_len {
                  { done = true; 0 }
              } else if si + 4 > src_len {
                  { error = true; done = true; 0 }
              } else {
                  {
                      let bytes = b64_decode_quartet(src, si, dst, di);
                      let _r2 = if bytes < 0 {
                          { error = true; done = true; 0 }
                      } else {
                          { si = si + 4; di = di + bytes; 0 }
                      };
                      0
                  }
              };
              0
          };
          if error { 0 - 1 } else { di }
      }
  };

// ============================================================================
// ASCII code to single character string
// ============================================================================

// Convert byte value to single-character string (full printable ASCII)
fn b64_chr(c: i64) -> String =
    if c == 32 { " " } else if c == 33 { "!" } else if c == 34 { "\"" }
    else if c == 35 { "#" } else if c == 36 { "$" } else if c == 37 { "%" }
    else if c == 38 { "&" } else if c == 39 { "'" } else if c == 40 { "(" }
    else if c == 41 { ")" } else if c == 42 { "*" } else if c == 43 { "+" }
    else if c == 44 { "," } else if c == 45 { "-" } else if c == 46 { "." }
    else if c == 47 { "/" }
    else if c == 48 { "0" } else if c == 49 { "1" } else if c == 50 { "2" }
    else if c == 51 { "3" } else if c == 52 { "4" } else if c == 53 { "5" }
    else if c == 54 { "6" } else if c == 55 { "7" } else if c == 56 { "8" }
    else if c == 57 { "9" }
    else if c == 58 { ":" } else if c == 59 { ";" } else if c == 60 { "<" }
    else if c == 61 { "=" } else if c == 62 { ">" } else if c == 63 { "?" }
    else if c == 64 { "@" }
    else if c == 65 { "A" } else if c == 66 { "B" } else if c == 67 { "C" }
    else if c == 68 { "D" } else if c == 69 { "E" } else if c == 70 { "F" }
    else if c == 71 { "G" } else if c == 72 { "H" } else if c == 73 { "I" }
    else if c == 74 { "J" } else if c == 75 { "K" } else if c == 76 { "L" }
    else if c == 77 { "M" } else if c == 78 { "N" } else if c == 79 { "O" }
    else if c == 80 { "P" } else if c == 81 { "Q" } else if c == 82 { "R" }
    else if c == 83 { "S" } else if c == 84 { "T" } else if c == 85 { "U" }
    else if c == 86 { "V" } else if c == 87 { "W" } else if c == 88 { "X" }
    else if c == 89 { "Y" } else if c == 90 { "Z" }
    else if c == 91 { "[" } else if c == 92 { "\\" } else if c == 93 { "]" }
    else if c == 94 { "^" } else if c == 95 { "_" } else if c == 96 { "`" }
    else if c == 97 { "a" } else if c == 98 { "b" } else if c == 99 { "c" }
    else if c == 100 { "d" } else if c == 101 { "e" } else if c == 102 { "f" }
    else if c == 103 { "g" } else if c == 104 { "h" } else if c == 105 { "i" }
    else if c == 106 { "j" } else if c == 107 { "k" } else if c == 108 { "l" }
    else if c == 109 { "m" } else if c == 110 { "n" } else if c == 111 { "o" }
    else if c == 112 { "p" } else if c == 113 { "q" } else if c == 114 { "r" }
    else if c == 115 { "s" } else if c == 116 { "t" } else if c == 117 { "u" }
    else if c == 118 { "v" } else if c == 119 { "w" } else if c == 120 { "x" }
    else if c == 121 { "y" } else if c == 122 { "z" }
    else if c == 123 { "{" } else if c == 124 { "|" } else if c == 125 { "}" }
    else if c == 126 { "~" }
    else { "?" };

// ============================================================================
// String-based convenience API
// ============================================================================

// Convert buffer of ASCII codes to string using StringBuilder
fn buf_to_string(buf: i64, len: i64) -> String = {
    let sb = sb_new();
    let _build = buf_to_string_loop(sb, buf, len);
    sb_build(sb)
};

fn buf_to_string_loop(sb: i64, buf: i64, len: i64) -> i64 = {
    let mut idx = 0;
    while idx < len {
        let _p = sb_push(sb, b64_chr(buf_get(buf, idx)));
        idx = idx + 1;
        0
    };
    0
};

// Copy string bytes into buffer
fn str_to_buf(s: String, buf: i64, len: i64) -> i64 = {
    let mut idx = 0;
    while idx < len {
        let _s = buf_set(buf, idx, s.byte_at(idx));
        idx = idx + 1;
        0
    };
    0
};

// Encode string to Base64 string
fn b64_encode_string(input: String) -> String = {
    let len = input.len();
    if len == 0 { "" }
    else {
        let src = malloc(len * 8);
        let _fill = str_to_buf(input, src, len);
        let out_len = b64_encode_len(len);
        let dst = malloc(out_len * 8);
        let _enc = b64_encode(src, len, dst);
        let result = buf_to_string(dst, out_len);
        let _f1 = free(src);
        let _f2 = free(dst);
        result
    }
};

// Decode Base64 string to string
fn b64_decode_string(input: String) -> String = {
    let len = input.len();
    if len == 0 { "" }
    else if len band 3 != 0 { "" }
    else {
        let src = malloc(len * 8);
        let _fill = str_to_buf(input, src, len);
        let max_out = b64_decode_len(len);
        let dst = malloc(max_out * 8);
        let decoded_len = b64_decode(src, len, dst);
        let result = if decoded_len < 0 { "" }
                     else { buf_to_string(dst, decoded_len) };
        let _f1 = free(src);
        let _f2 = free(dst);
        result
    }
};

// ============================================================================
// Tests (RFC 4648 Section 10 Test Vectors)
// ============================================================================

fn report(name: String, result: i64) -> i64 = {
    if result == 0 {
        let _a = print_str("  FAIL: ");
        let _b = print_str(name);
        let _c = print_str("\n");
        0
    } else { result }
};


// ============================================================================
// MD5 — RFC 1321 compliant hash
// ============================================================================

// Left rotate 32-bit value by n bits
fn md5_rotl32(x: i64, n: i64) -> i64 = {
    let m = x band MASK32();
    ((m << n) bor (m >> (32 - n))) band MASK32()
};

// MD5 auxiliary functions
fn md5_F(b: i64, c: i64, d: i64) -> i64 =
    ((b band c) bor ((b bxor MASK32()) band d)) band MASK32();

fn md5_G(b: i64, c: i64, d: i64) -> i64 =
    ((b band d) bor (c band (d bxor MASK32()))) band MASK32();

fn md5_H(b: i64, c: i64, d: i64) -> i64 =
    (b bxor c bxor d) band MASK32();

fn md5_I(b: i64, c: i64, d: i64) -> i64 =
    (c bxor (b bor (d bxor MASK32()))) band MASK32();

// MD5 per-round constants T[i] = floor(2^32 * abs(sin(i+1)))
fn md5_T(i: i64) -> i64 =
    if i == 0  { 3614090360 } else if i == 1  { 3905402710 } else if i == 2  { 606105819  }
    else if i == 3  { 3250441966 } else if i == 4  { 4118548399 } else if i == 5  { 1200080426 }
    else if i == 6  { 2821735955 } else if i == 7  { 4249261313 } else if i == 8  { 1770035416 }
    else if i == 9  { 2336552879 } else if i == 10 { 4294925233 } else if i == 11 { 2304563134 }
    else if i == 12 { 1804603682 } else if i == 13 { 4254626195 } else if i == 14 { 2792965006 }
    else if i == 15 { 1236535329 } else if i == 16 { 4129170786 } else if i == 17 { 3225465664 }
    else if i == 18 { 643717713  } else if i == 19 { 3921069994 } else if i == 20 { 3593408605 }
    else if i == 21 { 38016083   } else if i == 22 { 3634488961 } else if i == 23 { 3889429448 }
    else if i == 24 { 568446438  } else if i == 25 { 3275163606 } else if i == 26 { 4107603335 }
    else if i == 27 { 1163531501 } else if i == 28 { 2850285829 } else if i == 29 { 4243563512 }
    else if i == 30 { 1735328473 } else if i == 31 { 2368359562 } else if i == 32 { 4294588738 }
    else if i == 33 { 2272392833 } else if i == 34 { 1839030562 } else if i == 35 { 4259657740 }
    else if i == 36 { 2763975236 } else if i == 37 { 1272893353 } else if i == 38 { 4139469664 }
    else if i == 39 { 3200236656 } else if i == 40 { 681279174  } else if i == 41 { 3936430074 }
    else if i == 42 { 3572445317 } else if i == 43 { 76029189   } else if i == 44 { 3654602809 }
    else if i == 45 { 3873151461 } else if i == 46 { 530742520  } else if i == 47 { 3299628645 }
    else if i == 48 { 4096336452 } else if i == 49 { 1126891415 } else if i == 50 { 2878612391 }
    else if i == 51 { 4237533241 } else if i == 52 { 1700485571 } else if i == 53 { 2399980690 }
    else if i == 54 { 4293915773 } else if i == 55 { 2240044497 } else if i == 56 { 1873313359 }
    else if i == 57 { 4264355552 } else if i == 58 { 2734768916 } else if i == 59 { 1309151649 }
    else if i == 60 { 4149444226 } else if i == 61 { 3174756917 } else if i == 62 { 718787259  }
    else { 3951481745 };

// Round shift amounts
fn md5_S(i: i64) -> i64 =
    if i == 0  { 7  } else if i == 1  { 12 } else if i == 2  { 17 } else if i == 3  { 22 }
    else if i == 4  { 7  } else if i == 5  { 12 } else if i == 6  { 17 } else if i == 7  { 22 }
    else if i == 8  { 7  } else if i == 9  { 12 } else if i == 10 { 17 } else if i == 11 { 22 }
    else if i == 12 { 7  } else if i == 13 { 12 } else if i == 14 { 17 } else if i == 15 { 22 }
    else if i == 16 { 5  } else if i == 17 { 9  } else if i == 18 { 14 } else if i == 19 { 20 }
    else if i == 20 { 5  } else if i == 21 { 9  } else if i == 22 { 14 } else if i == 23 { 20 }
    else if i == 24 { 5  } else if i == 25 { 9  } else if i == 26 { 14 } else if i == 27 { 20 }
    else if i == 28 { 5  } else if i == 29 { 9  } else if i == 30 { 14 } else if i == 31 { 20 }
    else if i == 32 { 4  } else if i == 33 { 11 } else if i == 34 { 16 } else if i == 35 { 23 }
    else if i == 36 { 4  } else if i == 37 { 11 } else if i == 38 { 16 } else if i == 39 { 23 }
    else if i == 40 { 4  } else if i == 41 { 11 } else if i == 42 { 16 } else if i == 43 { 23 }
    else if i == 44 { 4  } else if i == 45 { 11 } else if i == 46 { 16 } else if i == 47 { 23 }
    else if i == 48 { 6  } else if i == 49 { 10 } else if i == 50 { 15 } else if i == 51 { 21 }
    else if i == 52 { 6  } else if i == 53 { 10 } else if i == 54 { 15 } else if i == 55 { 21 }
    else if i == 56 { 6  } else if i == 57 { 10 } else if i == 58 { 15 } else if i == 59 { 21 }
    else if i == 60 { 6  } else if i == 61 { 10 } else if i == 62 { 15 }
    else { 21 };

// Message schedule index for round i
fn md5_M(i: i64) -> i64 =
    if i < 16 { i }
    else if i < 32 { (5 * i + 1) - ((5 * i + 1) / 16) * 16 }
    else if i < 48 { (3 * i + 5) - ((3 * i + 5) / 16) * 16 }
    else { (7 * i) - (7 * i / 16) * 16 };

// Block buffer helpers (one byte per i64 slot)
fn md5_blk_get(blk: i64, idx: i64) -> i64 = load_i64(blk + idx * 8);
fn md5_blk_set(blk: i64, idx: i64, v: i64) -> i64 = store_i64(blk + idx * 8, v band 255);

// Read 4 bytes at byte offset off as little-endian u32
fn md5_blk_read_le32(blk: i64, off: i64) -> i64 = {
    let b0 = md5_blk_get(blk, off);
    let b1 = md5_blk_get(blk, off + 1);
    let b2 = md5_blk_get(blk, off + 2);
    let b3 = md5_blk_get(blk, off + 3);
    (b0 bor (b1 << 8) bor (b2 << 16) bor (b3 << 24)) band MASK32()
};

// Core: compress one 64-byte block
fn md5_compress(state: i64, blk: i64) -> i64 = {
    let mut a = aget(state, 0);
    let mut b = aget(state, 1);
    let mut c = aget(state, 2);
    let mut d = aget(state, 3);
    let mut i = 0;
    while i < 64 {
        let f = if i < 16 { md5_F(b, c, d) }
                else if i < 32 { md5_G(b, c, d) }
                else if i < 48 { md5_H(b, c, d) }
                else { md5_I(b, c, d) };
        let m_idx = md5_M(i);
        let m_val = md5_blk_read_le32(blk, m_idx * 4);
        let temp = add32(add32(add32(a, f), m_val), md5_T(i));
        let new_b = add32(b, md5_rotl32(temp, md5_S(i)));
        a = d;
        d = c;
        c = b;
        b = new_b;
        i = i + 1;
        0
    };
    let _sa = aput(state, 0, add32(aget(state, 0), a));
    let _sb = aput(state, 1, add32(aget(state, 1), b));
    let _sc = aput(state, 2, add32(aget(state, 2), c));
    let _sd = aput(state, 3, add32(aget(state, 3), d));
    0
};

// Little-endian hex output for MD5 (each register output byte-reversed)
fn h32_le(v: i64) -> String =
    hb(v band 255) + hb((v >> 8) band 255) + hb((v >> 16) band 255) + hb((v >> 24) band 255);

// MD5 hash a string, return 32-char hex digest
fn md5_string(inp: String) -> String = {
    let mlen = inp.len();
    let state = malloc(4 * 8);
    let blk = malloc(64 * 8);
    // Init registers
    let _s0 = aput(state, 0, 1732584193);   // 0x67452301
    let _s1 = aput(state, 1, 4023233417);   // 0xEFCDAB89
    let _s2 = aput(state, 2, 2562383102);   // 0x98BADCFE
    let _s3 = aput(state, 3, 271733878);    // 0x10325476
    // Process full 64-byte blocks
    let nfull = mlen / 64;
    let mut bi = 0;
    while bi < nfull {
        let off = bi * 64;
        let mut j = 0;
        while j < 64 {
            let _sb = md5_blk_set(blk, j, inp.byte_at(off + j));
            j = j + 1;
            0
        };
        let _comp = md5_compress(state, blk);
        bi = bi + 1;
        0
    };
    // Remaining bytes
    let rem = mlen - nfull * 64;
    let bstart = nfull * 64;
    let mut ri = 0;
    while ri < 64 {
        let _zb = md5_blk_set(blk, ri, 0);
        ri = ri + 1;
        0
    };
    let mut ci = 0;
    while ci < rem {
        let _cb = md5_blk_set(blk, ci, inp.byte_at(bstart + ci));
        ci = ci + 1;
        0
    };
    // Append 0x80
    let _pad = md5_blk_set(blk, rem, 128);
    let pos1 = rem + 1;
    let _final = if pos1 > 56 {
        // Need extra block
        let _comp1 = md5_compress(state, blk);
        let mut zi = 0;
        while zi < 64 {
            let _zb = md5_blk_set(blk, zi, 0);
            zi = zi + 1;
            0
        };
        0
    } else { 0 };
    // Write message length in bits as little-endian 64-bit at offset 56
    let bits = mlen * 8;
    let bits_lo = bits band MASK32();
    let bits_hi = (bits >> 32) band MASK32();
    let _lb0 = md5_blk_set(blk, 56, bits_lo band 255);
    let _lb1 = md5_blk_set(blk, 57, (bits_lo >> 8) band 255);
    let _lb2 = md5_blk_set(blk, 58, (bits_lo >> 16) band 255);
    let _lb3 = md5_blk_set(blk, 59, (bits_lo >> 24) band 255);
    let _lb4 = md5_blk_set(blk, 60, bits_hi band 255);
    let _lb5 = md5_blk_set(blk, 61, (bits_hi >> 8) band 255);
    let _lb6 = md5_blk_set(blk, 62, (bits_hi >> 16) band 255);
    let _lb7 = md5_blk_set(blk, 63, (bits_hi >> 24) band 255);
    let _comp2 = md5_compress(state, blk);
    // Build hex digest (little-endian register order)
    let sb = sb_new();
    let _h0 = sb_push(sb, h32_le(aget(state, 0)));
    let _h1 = sb_push(sb, h32_le(aget(state, 1)));
    let _h2 = sb_push(sb, h32_le(aget(state, 2)));
    let _h3 = sb_push(sb, h32_le(aget(state, 3)));
    let result = sb_build(sb);
    let _fs = free(state);
    let _fb = free(blk);
    result
};

// ============================================================================
// CRC32 — ISO 3309 / ITU-T V.42
// ============================================================================

// CRC-32 polynomial (reflected): 0xEDB88320
fn crc32_poly() -> i64 = 3988292384;

// Compute CRC for a single byte, updating running crc
fn crc32_byte(crc: i64, byte: i64) -> i64 = {
    let mut c = (crc bxor (byte band 255)) band MASK32();
    let mut i = 0;
    while i < 8 {
        let low_bit = c band 1;
        c = (c >> 1) band MASK32();
        if low_bit == 1 {
            c = (c bxor crc32_poly()) band MASK32();
            0
        } else { 0 };
        i = i + 1;
        0
    };
    c
};

// CRC32 of a string, return 8-char hex string
fn crc32_string(inp: String) -> String = {
    let len = inp.len();
    let mut crc = MASK32();
    let mut i = 0;
    while i < len {
        crc = crc32_byte(crc, inp.byte_at(i));
        i = i + 1;
        0
    };
    let final_crc = (crc bxor MASK32()) band MASK32();
    h32(final_crc)
};

// ============================================================================
// Base32 — RFC 4648
// ============================================================================

fn B32_PAD() -> i64 = 61;  // '='

fn b32_encode_char(val: i64) -> i64
  pre val >= 0 and val <= 31
= if val < 26 { val + 65 }    // A-Z
  else { val - 26 + 50 };      // 2-7

fn b32_decode_char(c: i64) -> i64
  post ret >= -1 and ret <= 31
= if c >= 65 and c <= 90 { c - 65 }           // A-Z
  else if c >= 97 and c <= 122 { c - 97 }     // a-z (case-insensitive)
  else if c >= 50 and c <= 55 { c - 50 + 26 } // 2-7
  else { 0 - 1 };

// Encode string to Base32 string
fn b32_encode_string(input: String) -> String = {
    let len = input.len();
    if len == 0 { "" }
    else {
        let sb = sb_new();
        let mut i = 0;
        while i < len {
            let remaining = len - i;
            let b0 = input.byte_at(i);
            let b1 = if remaining >= 2 { input.byte_at(i + 1) } else { 0 };
            let b2 = if remaining >= 3 { input.byte_at(i + 2) } else { 0 };
            let b3 = if remaining >= 4 { input.byte_at(i + 3) } else { 0 };
            let b4 = if remaining >= 5 { input.byte_at(i + 4) } else { 0 };
            // 5 bytes = 40 bits -> 8 groups of 5 bits
            let c0 = (b0 >> 3) band 31;
            let c1 = ((b0 band 7) << 2) bor ((b1 >> 6) band 3);
            let c2 = (b1 >> 1) band 31;
            let c3 = ((b1 band 1) << 4) bor ((b2 >> 4) band 15);
            let c4 = ((b2 band 15) << 1) bor ((b3 >> 7) band 1);
            let c5 = (b3 >> 2) band 31;
            let c6 = ((b3 band 3) << 3) bor ((b4 >> 5) band 7);
            let c7 = b4 band 31;
            // RFC 4648 padding rules:
            // 1 byte  → 2 chars + 6 pad    (remaining=1: c0,c1)
            // 2 bytes → 4 chars + 4 pad    (remaining=2: c0-c3)
            // 3 bytes → 5 chars + 3 pad    (remaining=3: c0-c4)
            // 4 bytes → 7 chars + 1 pad    (remaining=4: c0-c6)
            // 5 bytes → 8 chars + 0 pad    (remaining=5: c0-c7)
            let _p0 = sb_push(sb, b64_chr(b32_encode_char(c0)));
            let _p1 = sb_push(sb, b64_chr(b32_encode_char(c1)));
            let _p2 = sb_push(sb, if remaining >= 2 { b64_chr(b32_encode_char(c2)) } else { "=" });
            let _p3 = sb_push(sb, if remaining >= 2 { b64_chr(b32_encode_char(c3)) } else { "=" });
            let _p4 = sb_push(sb, if remaining >= 3 { b64_chr(b32_encode_char(c4)) } else { "=" });
            let _p5 = sb_push(sb, if remaining >= 4 { b64_chr(b32_encode_char(c5)) } else { "=" });
            let _p6 = sb_push(sb, if remaining >= 4 { b64_chr(b32_encode_char(c6)) } else { "=" });
            let _p7 = sb_push(sb, if remaining >= 5 { b64_chr(b32_encode_char(c7)) } else { "=" });
            i = i + 5;
            0
        };
        sb_build(sb)
    }
};

// Decode Base32 string to string
fn b32_decode_string(input: String) -> String = {
    let len = input.len();
    if len == 0 { "" }
    else if len - (len / 8) * 8 != 0 { "" }  // Must be multiple of 8
    else {
        let sb = sb_new();
        let mut i = 0;
        let mut ok = true;
        while i < len {
            let r0 = input.byte_at(i);
            let r1 = input.byte_at(i + 1);
            let r2 = input.byte_at(i + 2);
            let r3 = input.byte_at(i + 3);
            let r4 = input.byte_at(i + 4);
            let r5 = input.byte_at(i + 5);
            let r6 = input.byte_at(i + 6);
            let r7 = input.byte_at(i + 7);
            let v0 = b32_decode_char(r0);
            let v1 = b32_decode_char(r1);
            let _dec = if v0 < 0 or v1 < 0 {
                ok = false;
                i = len;
                0
            } else {
                // byte 0
                let byte0 = ((v0 << 3) bor ((v1 >> 2) band 7)) band 255;
                let _pb0 = sb_push(sb, b64_chr(byte0));
                let _r2 = if r2 != B32_PAD() {
                    let v2 = b32_decode_char(r2);
                    let v3 = b32_decode_char(r3);
                    let _check = if v2 < 0 or r3 == B32_PAD() { 0 }
                    else {
                        let byte1 = (((v1 band 3) << 6) bor (v2 << 1) bor ((v3 >> 4) band 1)) band 255;
                        let _pb1 = sb_push(sb, b64_chr(byte1));
                        let _r4 = if r4 != B32_PAD() {
                            let v4 = b32_decode_char(r4);
                            let _c4 = if v4 >= 0 {
                                let byte2 = (((v3 band 15) << 4) bor ((v4 >> 1) band 15)) band 255;
                                let _pb2 = sb_push(sb, b64_chr(byte2));
                                let _r5 = if r5 != B32_PAD() {
                                    let v5 = b32_decode_char(r5);
                                    let v6 = b32_decode_char(r6);
                                    let _c56 = if v5 >= 0 and r6 != B32_PAD() {
                                        let byte3 = (((v4 band 1) << 7) bor (v5 << 2) bor ((v6 >> 3) band 3)) band 255;
                                        let _pb3 = sb_push(sb, b64_chr(byte3));
                                        let _r7 = if r7 != B32_PAD() {
                                            let v7 = b32_decode_char(r7);
                                            let _c7 = if v7 >= 0 {
                                                let byte4 = (((v6 band 7) << 5) bor v7) band 255;
                                                let _pb4 = sb_push(sb, b64_chr(byte4));
                                                0
                                            } else { 0 };
                                            0
                                        } else { 0 };
                                        0
                                    } else { 0 };
                                    0
                                } else { 0 };
                                0
                            } else { 0 };
                            0
                        } else { 0 };
                        0
                    };
                    0
                } else { 0 };
                0
            };
            i = i + 8;
            0
        };
        if not ok { "" } else { sb_build(sb) }
    }
};

// ============================================================================
// @export wrappers
// ============================================================================

@export
pub fn bmb_sha256(input: String) -> String = sha256_string(input);

@export
pub fn bmb_base64_encode(input: String) -> String = b64_encode_string(input);

@export
pub fn bmb_base64_decode(input: String) -> String = b64_decode_string(input);

@export
pub fn bmb_md5(input: String) -> String = md5_string(input);

@export
pub fn bmb_crc32(input: String) -> String = crc32_string(input);

@export
pub fn bmb_base32_encode(input: String) -> String = b32_encode_string(input);

@export
pub fn bmb_base32_decode(input: String) -> String = b32_decode_string(input);

@export
pub fn bmb_hmac_sha256(key: String, msg: String) -> String = hmac_sha256_string(key, msg);

fn main() -> i64 = {
    // SHA-256
    let h = bmb_sha256("hello");
    println_str(h);
    // Base64
    let e = bmb_base64_encode("hello");
    println_str(e);
    let d = bmb_base64_decode(e);
    println_str(d);
    // MD5
    let m = bmb_md5("hello");
    println_str(m);
    // CRC32
    let c = bmb_crc32("hello");
    println_str(c);
    // Base32
    let b32 = bmb_base32_encode("hello");
    println_str(b32);
    let b32d = bmb_base32_decode(b32);
    println_str(b32d);
    // HMAC-SHA256
    let hm = bmb_hmac_sha256("key", "The quick brown fox jumps over the lazy dog");
    println_str(hm);
    0
};

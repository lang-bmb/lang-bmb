// ============================================================================
// TOML Manipulation
// ============================================================================

fn str_find(haystack: String, needle: String) -> i64 = {
    let hlen = haystack.len();
    let nlen = needle.len();
    if nlen == 0 { 0 }
    else if nlen > hlen { 0 - 1 }
    else {
        let mut i = 0;
        let limit = hlen - nlen + 1;
        let mut result = 0 - 1;
        while i < limit {
            let _r = if result < 0 {
                let sub = haystack.slice(i, i + nlen);
                if sub == needle { result = i; 0 } else { 0 }
            } else { 0 };
            i = i + 1;
            0
        };
        result
    }
};

fn find_eol(s: String, pos: i64) -> i64 = {
    let slen = s.len();
    let mut p = pos;
    while p < slen {
        let _r = if s.byte_at(p) == 10 { break } else { p = p + 1 };
        0
    };
    p
};

fn add_dep_to_content(content: String, dep_name: String, dep_ver: String) -> String = {
    let deps_pos = str_find(content, "[dependencies]");
    if deps_pos < 0 {
        let sb = sb_new();
        let _p1 = sb_push(sb, content);
        let _p2 = sb_push(sb, "\n[dependencies]\n");
        let _p3 = sb_push(sb, dep_name);
        let _p4 = sb_push(sb, " = \"");
        let _p5 = sb_push(sb, dep_ver);
        let _p6 = sb_push(sb, "\"\n");
        sb_build(sb)
    } else {
        let eol = find_eol(content, deps_pos);
        let insert_pos = if eol < content.len() { eol + 1 } else { eol };
        let before = content.slice(0, insert_pos);
        let after = content.slice(insert_pos, content.len());
        let sb = sb_new();
        let _p1 = sb_push(sb, before);
        let _p2 = sb_push(sb, dep_name);
        let _p3 = sb_push(sb, " = \"");
        let _p4 = sb_push(sb, dep_ver);
        let _p5 = sb_push(sb, "\"\n");
        let _p6 = sb_push(sb, after);
        sb_build(sb)
    }
};

fn cmd_add() -> i64 = {
    if arg_count() < 3 {
        let _e = print_str("error: missing dependency name\n");
        let _u = print_str("usage: gotgan add <package> [version]\n");
        1
    } else {
        let dep_name = get_arg(2);
        let dep_ver = if arg_count() >= 4 { get_arg(3) } else { "0.1.0" };

        let content = read_file("gotgan.toml");
        if content.len() == 0 {
            let _e = print_str("error: no gotgan.toml found in current directory\n");
            1
        } else {
            // Check if dep already exists
            let has_dep = str_find(content, dep_name) >= 0;
            if has_dep {
                let _e1 = print_str("  Dependency '");
                let _e2 = print_str(dep_name);
                let _e3 = print_str("' already exists in gotgan.toml\n");
                0
            } else {
                let new_content = add_dep_to_content(content, dep_name, dep_ver);
                let _w = write_file("gotgan.toml", new_content);
                let _p1 = print_str("  Added ");
                let _p2 = print_str(dep_name);
                let _p3 = print_str(" = \"");
                let _p4 = print_str(dep_ver);
                let _p5 = print_str("\"\n");
                0
            }
        }
    }
};

fn cmd_remove() -> i64 = {
    if arg_count() < 3 {
        let _e = print_str("error: missing dependency name\n");
        let _u = print_str("usage: gotgan remove <package>\n");
        1
    } else {
        let dep_name = get_arg(2);
        let content = read_file("gotgan.toml");
        if content.len() == 0 {
            let _e = print_str("error: no gotgan.toml found in current directory\n");
            1
        } else {
            // Find the dependency line
            let dep_pos = str_find(content, dep_name);
            if dep_pos < 0 {
                let _e1 = print_str("  Dependency '");
                let _e2 = print_str(dep_name);
                let _e3 = print_str("' not found in gotgan.toml\n");
                1
            } else {
                // Find start of line containing the dep
                let mut line_start = dep_pos;
                while line_start > 0 {
                    let _r = if content.byte_at(line_start - 1) == 10 { break }
                    else { line_start = line_start - 1 };
                    0
                };

                // Find end of line
                let line_end = find_eol(content, dep_pos);
                let next_start = if line_end < content.len() { line_end + 1 } else { line_end };

                // Rebuild content without this line
                let before = content.slice(0, line_start);
                let after = content.slice(next_start, content.len());
                let new_content = before + after;
                let _w = write_file("gotgan.toml", new_content);

                let _p1 = print_str("  Removed ");
                let _p2 = print_str(dep_name);
                let _p3 = print_str("\n");
                0
            }
        }
    }
};

fn cmd_version() -> i64 = {
    let content = read_file("gotgan.toml");
    if content.len() == 0 {
        let _e = print_str("error: no gotgan.toml found in current directory\n");
        1
    } else {
        let doc = toml_parse(content);
        let name = manifest_name(doc, content);
        let ver = manifest_version(doc, content);
        let _f = toml_free(doc);

        let _p1 = print_str(name);
        let _p2 = print_str(" v");
        let _p3 = print_str(ver);
        let _p4 = print_str("\n");
        0
    }
};

fn cmd_clean() -> i64 = {
    if is_dir("target") == 0 {
        let _e = print_str("  Nothing to clean\n");
        0
    } else {
        let _p = print_str("  Cleaning target/\n");
        // Remove target directory contents
        let result = system("rm -rf target 2>/dev/null || rmdir /s /q target 2>nul");
        if is_dir("target") == 0 {
            let _s = print_str("  Clean succeeded\n");
            0
        } else {
            let _s = print_str("  Clean failed\n");
            1
        }
    }
};

fn cmd_run() -> i64 = {
    let source = load_manifest_and_source("Running");
    if source == "" { 1 }
    else {
        let cmd = "bmb run " + source;
        system(cmd)
    }
};

fn main() -> i64 = {
    let argc = arg_count();
    if argc < 2 { print_help() }
    else {
        let cmd = get_arg(1);
        if cmd == "add" { cmd_add() }
        else if cmd == "build" { cmd_build() }
        else if cmd == "check" { cmd_check() }
        else if cmd == "clean" { cmd_clean() }
        else if cmd == "deps" { cmd_deps() }
        else if cmd == "fmt" { cmd_fmt() }
        else if cmd == "init" { cmd_init() }
        else if cmd == "lint" { cmd_lint() }
        else if cmd == "new" { cmd_new() }
        else if cmd == "remove" { cmd_remove() }
        else if cmd == "run" { cmd_run() }
        else if cmd == "test" { cmd_test() }
        else if cmd == "verify" { cmd_verify() }
        else if cmd == "version" { cmd_version() }
        else if cmd == "help" { print_help() }
        else {
            let _e1 = print_str("error: unknown command '");
            let _e2 = print_str(cmd);
            let _e3 = print_str("'\n");
            let _e4 = print_help();
            1
        }
    }
};

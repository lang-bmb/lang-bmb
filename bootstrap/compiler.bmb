// M12 Phase 6: Effect system Z3 formal verification
// Generates SMT-LIB2 encoding of effect constraints and uses Z3 to verify consistency.
// SAT = all constraints consistent (safe). UNSAT = at least one violation.

fn eff_smt_bool(eff: String, eff_name: String) -> String

  post it.len() >= 0

= if eff_contains_name(eff, eff_name) { "true" } else { "false" };

// ===================================================================
// R2 P0: by-construction VC-generation (leaf fragment)
// Translates pre/post/body AST S-expressions to SMT-LIB2 and discharges
// post obligations via Z3. Sorts: i64 => signed (_ BitVec 64) (T-BV — sound
// i64 wrap), bool => Bool, String => uninterpreted S. Bitvector arithmetic,
// comparison, and/or/not, if/let/block, byte_at/len UFs (P1). Any match/field/
// seq node (and calls outside the O2-lite/IH model) => "@UNSUP@" (honest
// abstain). Acceptance oracle: tests/verify-vc/.
// ===================================================================

fn vc_is_unsup(s: String) -> bool
  post it == (s == "@UNSUP@")
= s == "@UNSUP@";

// Skip spaces/tabs/newlines from pos.
fn vc_skip_sp(s: String, pos: i64) -> i64
  pre pos >= 0
  post it >= 0
= if pos >= s.len() { pos }
    else if s.byte_at(pos) == 32 or s.byte_at(pos) == 9 or s.byte_at(pos) == 10 { vc_skip_sp(s, pos + 1) }
    else { pos };

// From just-past an '(' at depth d, return index just after the matching ')'.
fn vc_match_paren(s: String, pos: i64, d: i64) -> i64
  pre pos >= 0
  post it >= 0
= if d == 0 { pos }
    else if pos >= s.len() { pos }
    else if s.byte_at(pos) == 40 { vc_match_paren(s, pos + 1, d + 1) }
    else if s.byte_at(pos) == 41 { vc_match_paren(s, pos + 1, d - 1) }
    else { vc_match_paren(s, pos + 1, d) };

// End index of a bare token (stops at space/tab/nl/paren).
fn vc_bare_end(s: String, pos: i64) -> i64
  pre pos >= 0
  post it >= 0
= if pos >= s.len() { pos }
    else if s.byte_at(pos) == 32 or s.byte_at(pos) == 9 or s.byte_at(pos) == 10 or s.byte_at(pos) == 40 or s.byte_at(pos) == 41 { pos }
    else { vc_bare_end(s, pos + 1) };

// Read one balanced token from s at pos: a "(...)" group or a bare token.
// Returns pack_result(end_pos, token). token=="" at end of string.
fn vc_read_tok(s: String, pos: i64) -> String
  pre pos >= 0
  post it.len() >= 2
= let p = vc_skip_sp(s, pos);
    if p >= s.len() { pack_result(p, "") }
    else if s.byte_at(p) == 40 { let e = vc_match_paren(s, p + 1, 1); pack_result(e, s.slice(p, e)) }
    else { let e = vc_bare_end(s, p); pack_result(e, s.slice(p, e)) };

// Strip <...> wrapper from a name token: "<c>" -> "c".
fn vc_strip_name(s: String) -> String
  post it.len() >= 0
= if s.len() >= 2 and s.byte_at(0) == 60 and s.byte_at(s.len() - 1) == 62 { s.slice(1, s.len() - 1) }
    else { s };

// Map a BMB return/param type to an SMT sort, or @UNSUP@.
// T-BV: integers model as signed 64-bit bitvectors (not unbounded Int) so that
// i64 wrap is sound — `acc*2`/`acc+1` overflow is faithfully a genuine `refuted`
// rather than a spurious `verified`. Comparisons/arithmetic use the signed BV
// ops (bvsge/bvadd/...); literals are `(_ bvN 64)`. See vc_emit_binop, vc_bv_lit.
fn vc_sort(ty: String) -> String
  post it.len() >= 0
= if ty == "i64" or ty == "i32" or ty == "int" { "(_ BitVec 64)" }
    else if ty == "bool" { "Bool" }
    else if ty == "String" { "S" }
    else { "@UNSUP@" };

// T-BV: emit an SMT bitvector literal for a decimal integer-literal text.
// `(_ bvN 64)` requires N to be a non-negative numeral, so a leading '-' is
// peeled and wrapped in bvneg (two's-complement negation).
fn vc_bv_lit(t: String) -> String
  post it.len() >= 0
= if t.len() > 0 and t.byte_at(0) == 45 { "(bvneg (_ bv" + t.slice(1, t.len()) + " 64))" }
    else { "(_ bv" + t + " 64)" };

// Emit SMT for a binary operator. @UNSUP@ for ops outside the leaf fragment.
fn vc_emit_binop(op: String, l: String, r: String) -> String
  post it.len() >= 0
= if op == "==" { "(= " + l + " " + r + ")" }
    else if op == "!=" { "(not (= " + l + " " + r + "))" }
    else if op == "and" { "(and " + l + " " + r + ")" }
    else if op == "or" { "(or " + l + " " + r + ")" }
    else if op == "<" { "(bvslt " + l + " " + r + ")" }
    else if op == ">" { "(bvsgt " + l + " " + r + ")" }
    else if op == "<=" { "(bvsle " + l + " " + r + ")" }
    else if op == ">=" { "(bvsge " + l + " " + r + ")" }
    // T-BV: signed 64-bit bitvector arithmetic — i64 wrap is now sound, so the
    // multiplicative ops that the machine-int abstain-guard (scope-(b)) had to
    // emit @UNSUP@ for are RE-ENABLED here as the proper fix. `acc*2` overflow to
    // a negative value is faithfully modelled (cf_pow2/parse_bin become genuine
    // verified/refuted instead of conservative abstain), and `+`/`-` overflow —
    // previously the documented idealized latent — is now sound too. div/mod use
    // bvsdiv/bvsrem (truncating toward zero, matching i64; SMT-defined total
    // functions — div-by-zero returns a value, sound for partial correctness
    // since a runtime trap is non-normal exit and vacuously satisfies post).
    else if op == "+" { "(bvadd " + l + " " + r + ")" }
    else if op == "-" { "(bvsub " + l + " " + r + ")" }
    else if op == "*" { "(bvmul " + l + " " + r + ")" }
    else if op == "/" { "(bvsdiv " + l + " " + r + ")" }
    else if op == "%" { "(bvsrem " + l + " " + r + ")" }
    // Wrapping/saturating (`*|`/`*%`/...), shifts, and bitwise ops still abstain.
    else { "@UNSUP@" };

// Look up `name` in tab-terminated `formals`; return the parallel `actuals`
// entry, or @@NONE@@ if absent. (Used to substitute callee formals by args.)
fn vc_subst_lookup(name: String, formals: String, actuals: String) -> String
  post it.len() >= 0
= if formals.len() == 0 or actuals.len() == 0 { "@@NONE@@" }
    else {
        let ft = str_find(formals, "\t");
        let at = str_find(actuals, "\t");
        if ft < 0 or at < 0 { "@@NONE@@" }
        else if formals.slice(0, ft) == name { actuals.slice(0, at) }
        else { vc_subst_lookup(name, formals.slice(ft + 1, formals.len()), actuals.slice(at + 1, actuals.len())) }
    };

// Translate one AST S-expression node to SMT-LIB2, with substitution.
// A (var <name>) whose name is in `formals` emits the matching `actuals` SMT;
// (var <it>) emits `itrepl` when itrepl != "". @UNSUP@ on any node outside the
// leaf fragment (propagates through callers). `call` stays @UNSUP@ here — calls
// are removed by the pre-pass vc_elim_calls before this runs.
fn vc_tr_s(node: String, formals: String, actuals: String, itrepl: String) -> String
  post it.len() >= 0
= let n = str_trim(node);
    if n.len() < 2 or n.byte_at(0) != 40 { "@UNSUP@" }
    else {
        let inner = n.slice(1, n.len() - 1);
        let rh = vc_read_tok(inner, 0);
        let head = unpack_ast(rh);
        let ap = unpack_pos(rh);
        if head == "int" { let r1 = vc_read_tok(inner, ap); vc_bv_lit(unpack_ast(r1)) }
        else if head == "bool" { let r1 = vc_read_tok(inner, ap); unpack_ast(r1) }
        else if head == "var" {
            let r1 = vc_read_tok(inner, ap);
            let nm = vc_strip_name(unpack_ast(r1));
            if nm == "it" and itrepl != "" { itrepl }
            else {
                let sub = if formals.len() == 0 { "@@NONE@@" } else { vc_subst_lookup(nm, formals, actuals) };
                if sub == "@@NONE@@" { nm } else { sub }
            }
        }
        else if head == "binop" {
            let ro = vc_read_tok(inner, ap);
            let rl = vc_read_tok(inner, unpack_pos(ro));
            let lt = vc_tr_s(unpack_ast(rl), formals, actuals, itrepl);
            let rr = vc_read_tok(inner, unpack_pos(rl));
            let rt = vc_tr_s(unpack_ast(rr), formals, actuals, itrepl);
            if vc_is_unsup(lt) or vc_is_unsup(rt) { "@UNSUP@" }
            else { vc_emit_binop(unpack_ast(ro), lt, rt) }
        }
        else if head == "if" {
            let rc = vc_read_tok(inner, ap);
            let ct = vc_tr_s(unpack_ast(rc), formals, actuals, itrepl);
            let rt = vc_read_tok(inner, unpack_pos(rc));
            let tt = vc_tr_s(unpack_ast(rt), formals, actuals, itrepl);
            let re = vc_read_tok(inner, unpack_pos(rt));
            let et = vc_tr_s(unpack_ast(re), formals, actuals, itrepl);
            if vc_is_unsup(ct) or vc_is_unsup(tt) or vc_is_unsup(et) { "@UNSUP@" }
            else { "(ite " + ct + " " + tt + " " + et + ")" }
        }
        else if head == "let" {
            let rn = vc_read_tok(inner, ap);
            let nm = vc_strip_name(unpack_ast(rn));
            let rv = vc_read_tok(inner, unpack_pos(rn));
            let vt = vc_tr_s(unpack_ast(rv), formals, actuals, itrepl);
            let rb = vc_read_tok(inner, unpack_pos(rv));
            let bt = vc_tr_s(unpack_ast(rb), formals, actuals, itrepl);
            if vc_is_unsup(vt) or vc_is_unsup(bt) { "@UNSUP@" }
            else { "(let ((" + nm + " " + vt + ")) " + bt + ")" }
        }
        else if head == "unop" {
            let ro = vc_read_tok(inner, ap);
            let rx = vc_read_tok(inner, unpack_pos(ro));
            let xt = vc_tr_s(unpack_ast(rx), formals, actuals, itrepl);
            if vc_is_unsup(xt) { "@UNSUP@" }
            else if unpack_ast(ro) == "not" { "(not " + xt + ")" }
            else if unpack_ast(ro) == "-" { "(bvneg " + xt + ")" }
            else { "@UNSUP@" }
        }
        else if head == "method" {
            // P1 (O1): String method calls -> uninterpreted functions.
            //   s.len()      -> (len s)        s.byte_at(i) -> (b s i)
            // Receiver/arg translate recursively; all else abstains. The b/len
            // UFs (and the len>=0 axiom) are declared by vc_build_smt's preamble.
            let rm = vc_read_tok(inner, ap);
            let rl = vc_read_tok(inner, unpack_pos(rm));
            let lt = vc_tr_s(unpack_ast(rl), formals, actuals, itrepl);
            let ra = vc_read_tok(inner, unpack_pos(rl));
            let at = if unpack_ast(ra) == "" { "" } else { vc_tr_s(unpack_ast(ra), formals, actuals, itrepl) };
            vc_tr_method(unpack_ast(rm), lt, at)
        }
        else if head == "block" { let r1 = vc_read_tok(inner, ap); vc_tr_s(unpack_ast(r1), formals, actuals, itrepl) }
        else { "@UNSUP@" }
    };

// SMT for a supported String method (P1, O1). @UNSUP@ outside {len, byte_at}
// or when receiver/arg are untranslatable.
fn vc_tr_method(mn: String, lt: String, at: String) -> String
  post it.len() >= 0
= if vc_is_unsup(lt) { "@UNSUP@" }
    else if mn == "len" { "(len " + lt + ")" }
    else if mn == "byte_at" { if vc_is_unsup(at) { "@UNSUP@" } else { "(b " + lt + " " + at + ")" } }
    else { "@UNSUP@" };

// Plain translation (no substitution): the leaf-fragment entry point.
fn vc_tr(node: String) -> String
  post it.len() >= 0
= vc_tr_s(node, "", "", "");

// Find byte b in s from pos; -1 if absent. (post >= -1: meta-circular DCE guard)
fn vc_find_byte(s: String, pos: i64, b: i64) -> i64
  pre pos >= 0
  post it >= 0 - 1
= if pos >= s.len() { 0 - 1 }
    else if s.byte_at(pos) == b { pos }
    else { vc_find_byte(s, pos + 1, b) };

// ===================================================================
// R2 O2-lite: interprocedural post-assume for NON-RECURSIVE calls.
// For each (call <f> args) in body/pre/post: discharge f's pre under the
// caller's pre (separate Z3 obligation; no path conditions), then assume
// f's post (with f's formals := args, it := fresh __vc_call_K) and replace
// the call by (var <__vc_call_K>). Sound: f total + pre discharged
// unconditionally => the equation __vc_call_K == post(args) holds for all
// inputs, so it may be asserted unconditionally (even under short-circuit).
// Self-recursion abstains (P2/IH). Reproduces golden is_hex_digit_lever1.
// ===================================================================

// Rightmost occurrence of `needle` in `s` (-1 if absent).
fn vc_rfind_from(s: String, needle: String, pos: i64, last: i64) -> i64
  pre pos >= 0
  post it >= 0 - 1
= let nx = find_pattern_noa(s, needle, pos);
    if nx < 0 { last } else { vc_rfind_from(s, needle, nx + 1, nx) };

fn vc_rfind(s: String, needle: String) -> i64
  post it >= 0 - 1
= vc_rfind_from(s, needle, 0, 0 - 1);

// Substring of `s` before the first occurrence of `sep` (whole `s` if absent).
fn vc_before(s: String, sep: String) -> String
  post it.len() >= 0
= let i = find_pattern_noa(s, sep, 0);
    if i < 0 { s } else { s.slice(0, i) };

// Substring of `s` after the first occurrence of `sep` ("" if absent).
fn vc_after(s: String, sep: String) -> String
  post it.len() >= 0
= let i = find_pattern_noa(s, sep, 0);
    if i < 0 { "" } else { s.slice(i + sep.len(), s.len()) };

// Fresh-var k-bases keeping body/pre/post call vars disjoint (< 1000 calls each).
fn vc_kbase_pre() -> i64
  post it == 1000
= 1000;

fn vc_kbase_post() -> i64
  post it == 2000
= 2000;

// Extract tab-terminated parameter names from a "n: T, n: T" param list.
fn vc_param_names(params: String, acc: String) -> String
  post it.len() >= 0
= let p = str_trim(params);
    if p.len() == 0 { acc }
    else {
        let ci = vc_find_byte(p, 0, 44);
        let first = if ci < 0 { p } else { str_trim(p.slice(0, ci)) };
        let rest = if ci < 0 { "" } else { p.slice(ci + 1, p.len()) };
        let coloni = vc_find_byte(first, 0, 58);
        let nm = if coloni < 0 { first } else { str_trim(first.slice(0, coloni)) };
        vc_param_names(rest, acc + nm + "\t")
    };

// Translate each call-argument S-expr (read from `inner` at `pos`) to SMT,
// tab-terminated. The in-scope let environment (letf/leta tab-lists, from the
// ctx) is applied so arguments that reference let-bound locals (e.g. a recursive
// arg acc*2+(c-48) with `c := byte_at(pos)`) substitute the local's definition
// instead of emitting an undeclared name. letf == "" => plain vc_tr (legacy).
// @UNSUP@ if any argument leaves the leaf fragment.
fn vc_read_actuals(inner: String, pos: i64, acc: String, letf: String, leta: String) -> String
  pre pos >= 0
  post it.len() >= 0
= let r = vc_read_tok(inner, pos);
    let tok = unpack_ast(r);
    if tok == "" { acc }
    else {
        let t = vc_tr_s(tok, letf, leta, "");
        if vc_is_unsup(t) { "@UNSUP@" }
        else { vc_read_actuals(inner, unpack_pos(r), acc + t + "\t", letf, leta) }
    };

// Conjoin tab-separated clauses, translating each with substitution.
// @UNSUP@ if any clause is untranslatable.
fn vc_conj_subst(asts: String, formals: String, actuals: String, itrepl: String, acc: String) -> String
  post it.len() >= 0
= if asts.len() == 0 { acc }
    else {
        let ti = vc_find_byte(asts, 0, 9);
        let first = if ti < 0 { asts } else { asts.slice(0, ti) };
        let rest = if ti < 0 { "" } else { asts.slice(ti + 1, asts.len()) };
        let tr = vc_tr_s(first, formals, actuals, itrepl);
        if vc_is_unsup(tr) { "@UNSUP@" }
        else {
            let newacc = if acc == "" { tr } else { "(and " + acc + " " + tr + ")" };
            vc_conj_subst(rest, formals, actuals, itrepl, newacc)
        }
    };

// Find fn `name` in `src`; return the position after its name+generics (where
// the parameter '(' begins), or -1 if not found.
fn vc_find_callee_after(src: String, name: String, pos: i64) -> i64
  pre pos >= 0
  post it >= 0 - 1
= let fn_pos = find_pattern_noa(src, "fn ", pos);
    if fn_pos < 0 { 0 - 1 }
    else {
        let name_start = skip_ws_comments(src, fn_pos + 3);
        let name_end = scan_ident_end(src, name_start);
        if name_end > name_start and src.slice(name_start, name_end) == name {
            let t2 = next_token_raw(src, name_end);
            if tok_kind(t2) == TK_LT() { skip_generic_params(src, tok_end(t2)) } else { name_end }
        } else { vc_find_callee_after(src, name, fn_pos + 3) }
    };

// ===================================================================
// R2 path-sensitivity (CT-B): a call inside a branch may assume the enclosing
// branch guard(s) when discharging its pre-obligation, and the post-assumption
// is guarded by the same path condition. Sound — the call only executes when
// the guards hold. The caller context is packed into a single `ctx` string of
// five "@@CX@@"-separated fields: cparams, cpre, pc, letf, leta. The last three
// are the call site's path condition and the in-scope let-binding environment
// (parallel tab-lists of names and their already-translated SMT definitions),
// computed by vc_pathcond_at. When all three are empty the behaviour is exactly
// the path-insensitive O2-lite/P2 model (so non-branch calls never regress).
// ===================================================================

// Pack the caller context. pc/letf/leta == "" => path-insensitive (legacy) mode.
fn vc_ctx_make(cparams: String, cpre: String, pc: String, letf: String, leta: String) -> String
  post it.len() >= 0
= cparams + "@@CX@@" + cpre + "@@CX@@" + pc + "@@CX@@" + letf + "@@CX@@" + leta;

// Extract field `idx` (0..4) from a packed ctx ("@@CX@@" is 6 bytes).
fn vc_ctx_field(ctx: String, idx: i64) -> String
  pre idx >= 0
  post it.len() >= 0
= let i = find_pattern_noa(ctx, "@@CX@@", 0);
    if idx == 0 { if i < 0 { ctx } else { ctx.slice(0, i) } }
    else if i < 0 { "" }
    else { vc_ctx_field(ctx.slice(i + 6, ctx.len()), idx - 1) };

// Descend into whichever child token (read sequentially from `p`) contains the
// absolute offset `cpos`, carrying pc/letenv unchanged. Used for every head that
// does not alter the path condition (binop/unop/method/block/call args).
fn vc_pc_findarg(target: String, inner: String, innerbase: i64, p: i64, cpos: i64, letf: String, leta: String, pc: String) -> String
  pre p >= 0
  post it.len() >= 0
= let r = vc_read_tok(inner, p);
    if unpack_ast(r) == "" { "@UNSUP@" }
    else {
        let cs = innerbase + vc_skip_sp(inner, p);
        let ce = innerbase + unpack_pos(r);
        if cpos >= cs and cpos < ce { vc_pathcond_at(target, cs, cpos, letf, leta, pc) }
        else { vc_pc_findarg(target, inner, innerbase, unpack_pos(r), cpos, letf, leta, pc) }
    };

// Compute the path condition of the call node that begins at absolute offset
// `cpos`, by structurally descending the body S-expr from the node at `ns`.
// `if` then-branch adds the (translated) guard, else-branch adds its negation;
// `let` extends the substitution env (name := translated value); all other heads
// pass through unchanged. Returns "pc@@PC1@@letf@@PC2@@leta", or "@UNSUP@" when
// any guard/value leaves the leaf fragment (caller then falls back to the
// path-insensitive model — monotone, never unsound).
fn vc_pathcond_at(target: String, ns: i64, cpos: i64, letf: String, leta: String, pc: String) -> String
  pre ns >= 0
  post it.len() >= 0
= if ns == cpos { pc + "@@PC1@@" + letf + "@@PC2@@" + leta }
    else if ns >= target.len() or target.byte_at(ns) != 40 { "@UNSUP@" }
    else {
        let ne = vc_match_paren(target, ns + 1, 1);
        let inner = target.slice(ns + 1, ne - 1);
        let innerbase = ns + 1;
        let rh = vc_read_tok(inner, 0);
        let head = unpack_ast(rh);
        let p0 = unpack_pos(rh);
        if head == "if" {
            let rc = vc_read_tok(inner, p0);
            let cs1 = innerbase + vc_skip_sp(inner, p0);
            let ce1 = innerbase + unpack_pos(rc);
            let rt = vc_read_tok(inner, unpack_pos(rc));
            let cs2 = innerbase + vc_skip_sp(inner, unpack_pos(rc));
            let ce2 = innerbase + unpack_pos(rt);
            let re = vc_read_tok(inner, unpack_pos(rt));
            let cs3 = innerbase + vc_skip_sp(inner, unpack_pos(rt));
            let ce3 = innerbase + unpack_pos(re);
            if cpos >= cs1 and cpos < ce1 { vc_pathcond_at(target, cs1, cpos, letf, leta, pc) }
            else {
                let condtr = vc_tr_s(unpack_ast(rc), letf, leta, "");
                if vc_is_unsup(condtr) { "@UNSUP@" }
                else if cpos >= cs2 and cpos < ce2 {
                    let np = if pc == "" { condtr } else { "(and " + pc + " " + condtr + ")" };
                    vc_pathcond_at(target, cs2, cpos, letf, leta, np)
                }
                else if cpos >= cs3 and cpos < ce3 {
                    let nc = "(not " + condtr + ")";
                    let np = if pc == "" { nc } else { "(and " + pc + " " + nc + ")" };
                    vc_pathcond_at(target, cs3, cpos, letf, leta, np)
                }
                else { "@UNSUP@" }
            }
        }
        else if head == "let" {
            let rn = vc_read_tok(inner, p0);
            let rv = vc_read_tok(inner, unpack_pos(rn));
            let vs = innerbase + vc_skip_sp(inner, unpack_pos(rn));
            let ve = innerbase + unpack_pos(rv);
            let rb = vc_read_tok(inner, unpack_pos(rv));
            let bs = innerbase + vc_skip_sp(inner, unpack_pos(rv));
            let be = innerbase + unpack_pos(rb);
            if cpos >= vs and cpos < ve { vc_pathcond_at(target, vs, cpos, letf, leta, pc) }
            else if cpos >= bs and cpos < be {
                let nm = vc_strip_name(unpack_ast(rn));
                let vt = vc_tr_s(unpack_ast(rv), letf, leta, "");
                if vc_is_unsup(vt) { "@UNSUP@" }
                else { vc_pathcond_at(target, bs, cpos, letf + nm + "\t", leta + vt + "\t", pc) }
            }
            else { "@UNSUP@" }
        }
        else { vc_pc_findarg(target, inner, innerbase, p0, cpos, letf, leta, pc) }
    };

// Discharge callee pre[formals:=actuals] under the caller (ctx fields cparams /
// cpre / pc): returns 1 iff caller_pre and pc and not(callee_pre) is UNSAT.
// The path condition `pc` (field 2) is asserted alongside the caller pre, so a
// pre that only holds under a branch guard is dischargeable. Empty callee pre =>
// trivially discharged (1). Any untranslatable part => 0.
fn vc_discharge_pre(ctx: String, ee_pre: String, formals: String, actuals: String) -> i64
  post it >= 0
= let csub = vc_conj_subst(ee_pre, formals, actuals, "", "");
    if vc_is_unsup(csub) { 0 }
    else if csub == "" { 1 }
    else {
        let cparams = vc_ctx_field(ctx, 0);
        let decls = vc_decl_params(cparams, "");
        if vc_is_unsup(decls) { 0 }
        else {
            let pretr = vc_assert_each(vc_ctx_field(ctx, 1), "");
            if vc_is_unsup(pretr) { 0 }
            else {
                // Standalone Z3 query: if a String param is present, decls uses
                // sort S, so declare it (+ the byte/len UFs + ground len>=0 axioms
                // per String param) here, mirroring vc_build_smt's preamble.
                // Without this, String-param recursive scanners (P2) error on an
                // undeclared sort S and spurious-abstain. (Leaf/i64 callees:
                // pre0 = "", no change.) lenax follows decls (references the names).
                let pre0 = if find_pattern_noa(decls, " S)", 0) >= 0 { "(declare-sort S 0)\n(declare-fun b (S (_ BitVec 64)) (_ BitVec 64))\n(declare-fun len (S) (_ BitVec 64))\n" } else { "" };
                let lenax = if find_pattern_noa(decls, " S)", 0) >= 0 { vc_len_axioms(cparams, "") } else { "" };
                let pc = vc_ctx_field(ctx, 2);
                let pca = if pc == "" { "" } else { "(assert " + pc + ")\n" };
                let smt = pre0 + decls + lenax + pretr + pca + "(assert (not " + csub + "))\n(check-sat)\n";
                let z = eff_z3_invoke(smt);
                if z == "unsat" { 1 } else { 0 }
            }
        }
    };

// Given a resolved callee (sort rs, pre ee_pre, post ee_post, formals) and the
// translated actuals, discharge callee pre under the caller (ctx) then emit the
// post-assumption. The post is guarded by the path condition pc (ctx field 2):
// `(assert (=> pc postsub))` — the post only holds where the call executes — so
// asserting it is sound even when pc is non-trivial. When pc == "" this is the
// legacy unconditional `(assert postsub)`. Returns
// "<decls+assume>@@SP@@(var <__vc_call_K>)" or @UNSUP@.
fn vc_assume_callee(rs: String, ee_pre: String, ee_post: String, formals: String, actuals: String, ctx: String, kk: i64) -> String
  pre kk >= 0
  post it.len() >= 0
= if vc_is_unsup(rs) or rs == "S" or ee_post.len() == 0 or vc_is_unsup(actuals) { "@UNSUP@" }
    else if vc_discharge_pre(ctx, ee_pre, formals, actuals) == 0 { "@UNSUP@" }
    else {
        let vname = "__vc_call_" + int_to_string(kk);
        let postsub = vc_conj_subst(ee_post, formals, actuals, vname, "");
        if vc_is_unsup(postsub) { "@UNSUP@" }
        else {
            let pc = vc_ctx_field(ctx, 2);
            let body = if pc == "" { postsub } else { "(=> " + pc + " " + postsub + ")" };
            "(declare-const " + vname + " " + rs + ")\n(assert " + body + ")\n@@SP@@(var <" + vname + ">)"
        }
    };

// Assume-guarantee soundness gate (R2 trusted-set T1): a callee's post may only
// be assumed if the callee is itself LEAF-VERIFIED — its contract proven from its
// own body with NO call-assumptions. This keeps the assume-guarantee relation
// well-founded (every trusted post grounds out in a call-free leaf), so no
// `verified` rests on an unproven (recursive / untranslatable) callee post.
// Conservative depth-1: any user-call in the callee body/pre/post (incl. self-
// recursion) => not leaf => untrusted (0). The `(call <` string scan rejects most
// callees Z3-free; only genuine leaves reach Z3.
fn vc_leaf_verified(src: String, cal: String, after: i64) -> i64
  pre after >= 0
  post it >= 0
= let t2 = next_token_raw(src, after);
    if tok_kind(t2) != TK_LPAREN() { 0 }
    else {
        let params_r = index_collect_params(src, tok_end(t2), "");
        let rtype = index_read_ret_type(src, unpack_pos(params_r));
        let rp = unpack_pos(rtype);
        let pre_asts = extract_pre_asts(src, rp);
        let post_asts = extract_post_asts(src, rp);
        if post_asts.len() == 0 { 0 }
        else if find_pattern_noa(pre_asts, "(call <", 0) >= 0 or find_pattern_noa(post_asts, "(call <", 0) >= 0 { 0 }
        else {
            let body_r = parse_expr(src, skip_contracts(src, rp));
            if is_error(body_r) { 0 }
            else {
                let body = unpack_ast(body_r);
                if find_pattern_noa(body, "(call <", 0) >= 0 { 0 }
                else {
                    let smt = vc_build_smt(cal, unpack_ast(params_r), unpack_ast(rtype), pre_asts, post_asts, body, src);
                    if vc_is_unsup(smt) or smt == "@RECABSTAIN@" { 0 }
                    else { if eff_z3_invoke(smt) == "unsat" { 1 } else { 0 } }
                }
            }
        }
    };

// Resolve the callee at `after` (position of its '(') and assume its post.
// Only proceeds if the callee is leaf-verified (trusted-set gate, soundness);
// untrusted callees abstain (@UNSUP@) so dependent callers degrade to
// `unsupported` rather than silently trusting an unproven post.
fn vc_proc_call2(src: String, cal: String, ctx: String, after: i64, callbody: String, rnpos: i64, kk: i64) -> String
  pre kk >= 0
  post it.len() >= 0
= let t2g = next_token_raw(src, after);
    if tok_kind(t2g) != TK_LPAREN() { "@UNSUP@" }
    else if vc_leaf_verified(src, cal, after) == 0 { "@UNSUP@" }
    else {
        let params_r = index_collect_params(src, tok_end(t2g), "");
        let rtype = index_read_ret_type(src, unpack_pos(params_r));
        let rp = unpack_pos(rtype);
        let formals = vc_param_names(unpack_ast(params_r), "");
        let actuals = vc_read_actuals(callbody, rnpos, "", vc_ctx_field(ctx, 3), vc_ctx_field(ctx, 4));
        vc_assume_callee(vc_sort(unpack_ast(rtype)), extract_pre_asts(src, rp), extract_post_asts(src, rp), formals, actuals, ctx, kk)
    };

// R2 P2: induction-hypothesis (IH) instantiation for a SELF-recursive call.
// Sound by the partial-correctness recursion rule: to prove {pre} f {post} we
// may ASSUME {pre} f {post} for the recursive call. No termination is needed
// (if the recursive call diverges so does the outer call, and partial-
// correctness post holds vacuously); and, unlike T1's external callees, NO
// leaf-verification is required, because the IH is self-justified rather than
// borrowed from a separate proof — hence the leaf gate is (correctly) bypassed.
// We DO discharge the call-site pre-obligation (own pre[actuals] under the
// caller pre, no path conditions) before assuming the post: it is a SOUNDNESS
// gate, not a completeness filter — globally asserting post[actuals] for args
// that may violate pre is unsound (see unsound3). vc_assume_callee is reused
// with the function's OWN contract. On any failure (pre not discharged / post
// untranslatable / String return) fall back to the P1 havoc + ;REC; sentinel so
// the verdict stays `unsupported_recursion`. Monotone: only genuinely-provable
// recursions flip to verified; nothing is lost or unsoundly trusted.
fn vc_proc_selfrec(src: String, cname: String, ctx: String, callbody: String, rnpos: i64, kk: i64) -> String
  pre kk >= 0
  post it.len() >= 0
= let havoc = "(declare-const __vc_rec_" + int_to_string(kk) + " @@RETSORT@@)\n;REC;\n@@SP@@(var <__vc_rec_" + int_to_string(kk) + ">)";
    let after = vc_find_callee_after(src, cname, 0);
    if after < 0 { havoc }
    else {
        let t2g = next_token_raw(src, after);
        if tok_kind(t2g) != TK_LPAREN() { havoc }
        else {
            let params_r = index_collect_params(src, tok_end(t2g), "");
            let rtype = index_read_ret_type(src, unpack_pos(params_r));
            let rp = unpack_pos(rtype);
            let formals = vc_param_names(unpack_ast(params_r), "");
            let actuals = vc_read_actuals(callbody, rnpos, "", vc_ctx_field(ctx, 3), vc_ctx_field(ctx, 4));
            let ih = vc_assume_callee(vc_sort(unpack_ast(rtype)), extract_pre_asts(src, rp), extract_post_asts(src, rp), formals, actuals, ctx, kk);
            if vc_is_unsup(ih) { havoc } else { ih }
        }
    };

// Process one "(call <f> args...)" expr. Returns
//   "<decls+assume>@@SP@@(var <__vc_call_K>)"  on success, or "@UNSUP@".
// Self-recursive calls instantiate the IH (P2, vc_proc_selfrec).
fn vc_proc_call(src: String, cname: String, ctx: String, callexpr: String, kk: i64) -> String
  pre kk >= 0
  post it.len() >= 0
= let inner = str_trim(callexpr);
    if inner.len() < 2 or inner.byte_at(0) != 40 { "@UNSUP@" }
    else {
        let callbody = inner.slice(1, inner.len() - 1);
        let rh = vc_read_tok(callbody, 0);
        if unpack_ast(rh) != "call" { "@UNSUP@" }
        else {
            let rn = vc_read_tok(callbody, unpack_pos(rh));
            let cal = vc_strip_name(unpack_ast(rn));
            if cal == cname {
                // P2: instantiate the induction hypothesis (assume the own post
                // for the recursive result, after discharging the call-site pre-
                // obligation). Falls back to the P1 havoc + ;REC; sentinel when
                // the IH can't be soundly instantiated. @@RETSORT@@ (havoc only)
                // is resolved by vc_build_smt.
                vc_proc_selfrec(src, cname, ctx, callbody, unpack_pos(rn), kk)
            }
            else {
                let after = vc_find_callee_after(src, cal, 0);
                if after < 0 { "@UNSUP@" }
                else { vc_proc_call2(src, cal, ctx, after, callbody, unpack_pos(rn), kk) }
            }
        }
    };

// Eliminate user-calls in `target` (a body / pre / post string), rightmost-first
// (so nested calls resolve inner-first). Accumulates each call's decls+assume
// into `side`. Returns "newtarget@@SP@@side"; side == "@UNSUP@" signals an
// abstain. When is_body == 1 the call's path condition + in-scope let-env are
// computed (vc_pathcond_at) and packed into the ctx so the discharge/assume can
// use the enclosing branch guards (path-sensitivity). For pre/post (is_body 0),
// and whenever pathcond computation abstains, the ctx pc/letf/leta stay empty —
// reproducing the path-insensitive O2-lite/P2 behaviour exactly (monotone).
fn vc_elim_calls(src: String, cname: String, cparams: String, cpre: String, target: String, side: String, kk: i64, is_body: i64) -> String
  pre kk >= 0
  post it.len() >= 0
= if vc_is_unsup(side) { target + "@@SP@@@UNSUP@" }
    else {
    let cpos = vc_rfind(target, "(call <");
    if cpos < 0 { target + "@@SP@@" + side }
    else {
        let endp = vc_match_paren(target, cpos + 1, 1);
        let callexpr = target.slice(cpos, endp);
        let pcr = if is_body == 1 { vc_pathcond_at(target, vc_skip_sp(target, 0), cpos, "", "", "") } else { "@UNSUP@" };
        let pc = if vc_is_unsup(pcr) { "" } else { vc_before(pcr, "@@PC1@@") };
        let lf = if vc_is_unsup(pcr) { "" } else { vc_before(vc_after(pcr, "@@PC1@@"), "@@PC2@@") };
        let la = if vc_is_unsup(pcr) { "" } else { vc_after(pcr, "@@PC2@@") };
        let ctx = vc_ctx_make(cparams, cpre, pc, lf, la);
        let proc = vc_proc_call(src, cname, ctx, callexpr, kk);
        if vc_is_unsup(proc) { target + "@@SP@@@UNSUP@" }
        else {
            let asmt = vc_before(proc, "@@SP@@");
            let repl = vc_after(proc, "@@SP@@");
            let newt = target.slice(0, cpos) + repl + target.slice(endp, target.len());
            vc_elim_calls(src, cname, cparams, cpre, newt, side + asmt, kk + 1, is_body)
        }
    }
    };

// T-BV: emit a GROUND len>=0 assertion for each String (sort-S) param, e.g.
// `(assert (bvsge (len s) (_ bv0 64)))`. Replaces the quantified
// `(forall ((__x S)) (bvsge (len __x) 0))` — quantified BV (UFBV) is undecidable
// and MBQI can blow up / hang, whereas in the P1 fragment `len`/`byte_at` only
// ever apply to String PARAMETERS (no string construction), so the ground
// instances suffice and keep every query in decidable QF_UFBV (fast + det.).
// Must be emitted AFTER the param decls (it references the declared names).
fn vc_len_axioms(params: String, acc: String) -> String
  post it.len() >= 0
= let p = str_trim(params);
    if p.len() == 0 { acc }
    else {
        let ci = vc_find_byte(p, 0, 44);
        let first = if ci < 0 { p } else { str_trim(p.slice(0, ci)) };
        let rest = if ci < 0 { "" } else { p.slice(ci + 1, p.len()) };
        let coloni = vc_find_byte(first, 0, 58);
        if coloni < 0 { acc }
        else {
            let nm = str_trim(first.slice(0, coloni));
            let ty = str_trim(first.slice(coloni + 1, first.len()));
            let newacc = if vc_sort(ty) == "S" { acc + "(assert (bvsge (len " + nm + ") (_ bv0 64)))\n" } else { acc };
            vc_len_axioms(rest, newacc)
        }
    };

// Emit (declare-const NAME SORT) lines for a "name: Type, ..." param list.
// @UNSUP@ if any param type is outside the leaf fragment.
fn vc_decl_params(params: String, acc: String) -> String
  post it.len() >= 0
= let p = str_trim(params);
    if p.len() == 0 { acc }
    else {
        let ci = vc_find_byte(p, 0, 44);
        let first = if ci < 0 { p } else { str_trim(p.slice(0, ci)) };
        let rest = if ci < 0 { "" } else { p.slice(ci + 1, p.len()) };
        let coloni = vc_find_byte(first, 0, 58);
        if coloni < 0 { "@UNSUP@" }
        else {
            let nm = str_trim(first.slice(0, coloni));
            let ty = str_trim(first.slice(coloni + 1, first.len()));
            let sort = vc_sort(ty);
            if vc_is_unsup(sort) { "@UNSUP@" }
            else { vc_decl_params(rest, acc + "(declare-const " + nm + " " + sort + ")\n") }
        }
    };

// T-CX: space-separated get-value TERMS for the params, for the refuted
// counterexample. Int params -> the name; String params -> `(len nm)` (the
// opaque sort-S const itself is not an informative witness, but its length is).
// Non-{Int,S} params are skipped. Used only to enrich a `refuted` verdict.
// (Named vc_cex_terms — vc_param_names already exists for tab-separated formals.)
fn vc_cex_terms(params: String, acc: String) -> String
  post it.len() >= 0
= let p = str_trim(params);
    if p.len() == 0 { acc }
    else {
        let ci = vc_find_byte(p, 0, 44);
        let first = if ci < 0 { p } else { str_trim(p.slice(0, ci)) };
        let rest = if ci < 0 { "" } else { p.slice(ci + 1, p.len()) };
        let coloni = vc_find_byte(first, 0, 58);
        if coloni < 0 { acc }
        else {
            let nm = str_trim(first.slice(0, coloni));
            let ty = str_trim(first.slice(coloni + 1, first.len()));
            let sort = vc_sort(ty);
            let term = if sort == "S" { "(len " + nm + ")" } else if sort == "(_ BitVec 64)" { nm } else { "" };
            let sep = if acc.len() == 0 { "" } else { " " };
            vc_cex_terms(rest, if term == "" { acc } else { acc + sep + term })
        }
    };

// Emit (assert TR) for each tab-separated clause. @UNSUP@ if any untranslatable.
fn vc_assert_each(asts: String, acc: String) -> String
  post it.len() >= 0
= if asts.len() == 0 { acc }
    else {
        let ti = vc_find_byte(asts, 0, 9);
        let first = if ti < 0 { asts } else { asts.slice(0, ti) };
        let rest = if ti < 0 { "" } else { asts.slice(ti + 1, asts.len()) };
        let tr = vc_tr(first);
        if vc_is_unsup(tr) { "@UNSUP@" }
        else { vc_assert_each(rest, acc + "(assert " + tr + ")\n") }
    };

// Conjoin tab-separated post clauses into one SMT formula. @UNSUP@ if any fails.
fn vc_conj_each(asts: String, acc: String) -> String
  post it.len() >= 0
= if asts.len() == 0 { acc }
    else {
        let ti = vc_find_byte(asts, 0, 9);
        let first = if ti < 0 { asts } else { asts.slice(0, ti) };
        let rest = if ti < 0 { "" } else { asts.slice(ti + 1, asts.len()) };
        let tr = vc_tr(first);
        if vc_is_unsup(tr) { "@UNSUP@" }
        else {
            let newacc = if acc == "" { tr } else { "(and " + acc + " " + tr + ")" };
            vc_conj_each(rest, newacc)
        }
    };

// Build the full VC SMT for one function (one combined post obligation):
//   decls; <call-assumes>; (assert pre_i); (assert (= it body)); (assert (not (and post_j))); (check-sat)
// UNSAT => post verified. @UNSUP@ if anything leaves the leaf fragment.
// Non-recursive calls in body/pre/post are eliminated (O2-lite) into side decls
// + assumptions via vc_elim_calls; distinct k-bases keep fresh vars unique.
fn vc_build_smt(cname: String, params: String, rty: String, pre_asts: String, post_asts: String, body: String, src: String) -> String
  post it.len() >= 0
= let retsort = vc_sort(rty);
    // P1: String params translate (sort S), but String-RETURN abstains — the
    // ubiquitous `post it.len() >= 0` idiom would spurious-refute under an
    // unconstrained len UF. Formal String-return support (it-len axiom) is a
    // named follow-up.
    if vc_is_unsup(retsort) or retsort == "S" { "@UNSUP@" }
    else {
        let decls = vc_decl_params(params, "");
        if vc_is_unsup(decls) { "@UNSUP@" }
        else {
            // Preamble (only when a String param is present, i.e. decls uses S):
            // declare the uninterpreted byte/len UFs + the sound len>=0 axiom so
            // i64 functions over String params (relative bounds, absolute len)
            // verify without spurious refutation. Leaf fragment is untouched.
            let pre0 = if find_pattern_noa(decls, " S)", 0) >= 0 { "(declare-sort S 0)\n(declare-fun b (S (_ BitVec 64)) (_ BitVec 64))\n(declare-fun len (S) (_ BitVec 64))\n" } else { "" };
            let lenax = if find_pattern_noa(decls, " S)", 0) >= 0 { vc_len_axioms(params, "") } else { "" };
            let r1 = vc_elim_calls(src, cname, params, pre_asts, body, "", 0, 1);
            let nb = vc_before(r1, "@@SP@@");
            let r2 = vc_elim_calls(src, cname, params, pre_asts, pre_asts, vc_after(r1, "@@SP@@"), vc_kbase_pre(), 0);
            let npre = vc_before(r2, "@@SP@@");
            let r3 = vc_elim_calls(src, cname, params, pre_asts, post_asts, vc_after(r2, "@@SP@@"), vc_kbase_post(), 0);
            let npost = vc_before(r3, "@@SP@@");
            let side3 = vc_after(r3, "@@SP@@").replace("@@RETSORT@@", retsort);
            let bodytr = vc_tr(nb);
            let pretr = vc_assert_each(npre, "");
            let postconj = vc_conj_each(npost, "");
            if vc_is_unsup(side3) or vc_is_unsup(bodytr) or vc_is_unsup(pretr) or vc_is_unsup(postconj) { "@UNSUP@" }
            else if find_pattern_noa(side3, ";REC;", 0) >= 0 { "@RECABSTAIN@" }
            else { pre0 + decls + lenax + side3 + "(declare-const it " + retsort + ")\n" + pretr + "(assert (= it " + bodytr + "))\n(assert (not " + postconj + "))\n(check-sat)\n" }
        }
    };

// Compute and emit the JSON verdict for one function. Returns new isfirst flag.
// prepost packs pre and post AST clause-lists as "<pre>@@PP@@<post>".
fn vc_emit_verdict(fname: String, params: String, ret_str: String, body: String, prepost: String, src: String, sb: i64, isfirst: i64) -> i64
  post it >= 0
= let pre_asts = vc_before(prepost, "@@PP@@");
    let post_asts = vc_after(prepost, "@@PP@@");
    if post_asts.len() == 0 {
        let sep = if isfirst == 1 { "" } else { "," };
        let _j = sb_push(sb, sep + "{\"function\":\"" + json_esc(fname) + "\",\"verdict\":\"no_postcondition\"}");
        0
    }
    else {
        let smt = if body == "@PARSEERR@" { "@PARSEERR@" }
            else { vc_build_smt(fname, params, ret_str, pre_asts, post_asts, body, src) };
        let verdict = if smt == "@PARSEERR@" { "parse_error" }
            else if smt == "@RECABSTAIN@" { "unsupported_recursion" }
            else if vc_is_unsup(smt) { "unsupported" }
            else {
                let z = eff_z3_invoke(smt);
                if z == "unsat" { "verified" }
                else if z == "sat" { "refuted" }
                else if z == "unavailable" { "z3_unavailable" }
                else { "unknown" }
            };
        // T-CX: enrich a `refuted` verdict with the Z3 counterexample (the input
        // assignment that violates the contract) — actionable signal for the
        // AI-authored-contract loop (which precondition to add). smt already ends
        // in (check-sat); append a (get-value ...) over `it` + the param terms.
        let cex = if verdict == "refuted" {
                let names = vc_cex_terms(params, "");
                let gvline = if names.len() == 0 { "(get-value (it))\n" } else { "(get-value (it " + names + "))\n" };
                let m = eff_z3_model(smt + gvline);
                if m == "" { "" } else { ",\"counterexample\":\"" + json_esc(m) + "\"" }
            } else { "" };
        let sep = if isfirst == 1 { "" } else { "," };
        let _j = sb_push(sb, sep + "{\"function\":\"" + json_esc(fname) + "\",\"verdict\":\"" + verdict + "\"" + cex + "}");
        0
    };

// Process one fn header (at `after_gen` = position after name+generics):
// extract params/ret/contracts/body and emit its verdict. Returns new isfirst.
fn vc_scan_fn(src: String, fname: String, after_gen: i64, sb: i64, isfirst: i64) -> i64
  pre after_gen >= 0
  post it >= 0
= let t2g = next_token_raw(src, after_gen);
    if tok_kind(t2g) == TK_LPAREN() {
        let params_r = index_collect_params(src, tok_end(t2g), "");
        let rtype = index_read_ret_type(src, unpack_pos(params_r));
        let rp = unpack_pos(rtype);
        let pre_asts = extract_pre_asts(src, rp);
        let post_asts = extract_post_asts(src, rp);
        let body = if post_asts.len() == 0 { "" } else { let body_r = parse_expr(src, skip_contracts(src, rp)); if is_error(body_r) { "@PARSEERR@" } else { unpack_ast(body_r) } };
        let prepost = pre_asts + "@@PP@@" + post_asts;
        vc_emit_verdict(fname, unpack_ast(params_r), unpack_ast(rtype), body, prepost, src, sb, isfirst)
    } else { isfirst };

// Walk every fn in src, emitting a verify-vc verdict object into sb. Returns isfirst.
fn vc_scan(src: String, pos: i64, sb: i64, isfirst: i64) -> i64
  pre pos >= 0
  post it >= 0
= let fn_pos = find_pattern_noa(src, "fn ", pos);
    if fn_pos < 0 { isfirst }
    else {
        let prev_ok = if fn_pos == 0 { true }
            else { let prev = src.byte_at(fn_pos - 1); prev == 10 or prev == 13 or prev == 32 or prev == 59 or prev == 9 };
        let not_comment = if prev_ok { let sol = lint_find_sol(src, fn_pos); not (find_pattern_noa_range(src, "//", sol, fn_pos) >= 0) } else { false };
        if prev_ok and not_comment {
            let name_start = skip_ws_comments(src, fn_pos + 3);
            let name_end = scan_ident_end(src, name_start);
            let fname = src.slice(name_start, name_end);
            let nf = if fname != "" and name_end > name_start {
                let t2 = next_token_raw(src, name_end);
                let after_gen = if tok_kind(t2) == TK_LT() { skip_generic_params(src, tok_end(t2)) } else { name_end };
                vc_scan_fn(src, fname, after_gen, sb, isfirst)
            } else { isfirst };
            vc_scan(src, fn_pos + 3, sb, nf)
        } else { vc_scan(src, fn_pos + 3, sb, isfirst) }
    };

// `verify-vc <file>` entry: emit a JSON array of per-function post verdicts.
fn verify_vc_file(input: String) -> i64
  post it >= 0
= let src = read_file(input);
    if src.len() == 0 { err_no_file(input) }
    else {
        let sb = sb_new();
        let _o = sb_push(sb, "{\"command\":\"verify-vc\",\"file\":\"" + json_esc(input) + "\",\"results\":[");
        let _s = vc_scan(src, 0, sb, 1);
        let _c = sb_push(sb, "]}");
        let _p = println_str(sb_build(sb));
        0
    };

fn eff_z3_gen_fn_decls(eff_map: String, pos: i64, sb: i64) -> i64

  pre pos >= 0

  post it >= -1

= if pos >= eff_map.len() { 0 }

    else {

        let eol = callers_find_eol(eff_map, pos);

        let line = eff_map.slice(pos, eol);

        if line.len() == 0 { eff_z3_gen_fn_decls(eff_map, eol + 1, sb) }

        else {

            let tab = str_find(line, "\t");

            if tab < 0 { eff_z3_gen_fn_decls(eff_map, eol + 1, sb) }

            else {

                let fn_name = line.slice(0, tab);

                let raw_eff = line.slice(tab + 1, line.len());

                let eff = if str_find(raw_eff, "PLAT:") == 0 { raw_eff.slice(5, raw_eff.len()) } else { raw_eff };

                let io_v = eff_smt_bool(eff, "IO");

                let net_v = eff_smt_bool(eff, "Net");

                let file_v = eff_smt_bool(eff, "File");

                let sys_v = eff_smt_bool(eff, "Sys");

                let _d1 = sb_push(sb, "(declare-const |" + fn_name + "_io| Bool)\n");

                let _d2 = sb_push(sb, "(assert (= |" + fn_name + "_io| " + io_v + "))\n");

                let _d3 = sb_push(sb, "(declare-const |" + fn_name + "_net| Bool)\n");

                let _d4 = sb_push(sb, "(assert (= |" + fn_name + "_net| " + net_v + "))\n");

                let _d5 = sb_push(sb, "(declare-const |" + fn_name + "_file| Bool)\n");

                let _d6 = sb_push(sb, "(assert (= |" + fn_name + "_file| " + file_v + "))\n");

                let _d7 = sb_push(sb, "(declare-const |" + fn_name + "_sys| Bool)\n");

                let _d8 = sb_push(sb, "(assert (= |" + fn_name + "_sys| " + sys_v + "))\n");

                eff_z3_gen_fn_decls(eff_map, eol + 1, sb)

            }

        }

    };

fn eff_z3_gen_call_edge(caller_name: String, callee_name: String, eff_map: String, sb: i64) -> i64

  post it >= 0

= {

    let caller_eff = eff_map_get(eff_map, caller_name, 0);

    let callee_eff = eff_map_get(eff_map, callee_name, 0);

    if caller_eff == "" or callee_eff == "" or caller_eff == "*" or callee_eff == "*" { 0 }

    else {

        let _e1 = sb_push(sb, "(assert (=> |" + callee_name + "_io| |" + caller_name + "_io|))\n");

        let _e2 = sb_push(sb, "(assert (=> |" + callee_name + "_net| |" + caller_name + "_net|))\n");

        let _e3 = sb_push(sb, "(assert (=> |" + callee_name + "_file| |" + caller_name + "_file|))\n");

        let _e4 = sb_push(sb, "(assert (=> |" + callee_name + "_sys| |" + caller_name + "_sys|))\n");

        0

    }

};

fn eff_z3_gen_calls(caller_name: String, calls: String, eff_map: String, pos: i64, sb: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= calls.len() { 0 }

    else {

        let end = index_find_comma_or_end(calls, pos);

        let callee = calls.slice(pos, end);

        let _x = eff_z3_gen_call_edge(caller_name, callee, eff_map, sb);

        if end >= calls.len() { 0 }

        else { eff_z3_gen_calls(caller_name, calls, eff_map, end + 2, sb) }

    };

fn eff_z3_gen_edges(entries: String, eff_map: String, pos: i64, sb: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= entries.len() { 0 }

    else {

        let eol = callers_find_eol(entries, pos);

        let line = entries.slice(pos, eol);

        if line.len() == 0 { eff_z3_gen_edges(entries, eff_map, eol + 1, sb) }

        else {

            let fn_name = callers_get_field(line, 0, 0, 0);

            let calls = callers_get_field(line, 1, 0, 0);

            // Skip platform-declared functions (PLAT: prefix) — they are trusted providers, not checked
            let raw_eff = eff_map_get_raw(eff_map, fn_name, 0);

            let is_plat = str_find(raw_eff, "PLAT:") == 0;

            let _x = if is_plat { 0 } else { eff_z3_gen_calls(fn_name, calls, eff_map, 0, sb) };

            eff_z3_gen_edges(entries, eff_map, eol + 1, sb)

        }

    };

// M12 Phase 6d: Add @pure/@const functions as Z3 pure-effect constraints.
// Pure functions have all effects false, so calls from them to effectful fns → UNSAT.
fn eff_z3_gen_pure_decls(entries: String, eff_map: String, pos: i64, sb: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= entries.len() { 0 }

    else {

        let eol = callers_find_eol(entries, pos);

        let line = entries.slice(pos, eol);

        if line.len() == 0 { eff_z3_gen_pure_decls(entries, eff_map, eol + 1, sb) }

        else {

            let fn_name = callers_get_field(line, 0, 0, 0);

            let sig = callers_get_field(line, 2, 0, 0);

            let calls = callers_get_field(line, 1, 0, 0);

            let is_pure = str_find(sig, "@pure fn") >= 0 or str_find(sig, "@const fn") >= 0;

            // Only add pure functions that actually call something in eff_map (otherwise useless)
            let has_eff_callee = is_pure and eff_pure_has_eff_callee(calls, eff_map, 0);

            let _x = if has_eff_callee {

                // Declare pure fn with all effects = false
                let _d1 = sb_push(sb, "(declare-const |" + fn_name + "_io| Bool)\n");

                let _d2 = sb_push(sb, "(assert (= |" + fn_name + "_io| false))\n");

                let _d3 = sb_push(sb, "(declare-const |" + fn_name + "_net| Bool)\n");

                let _d4 = sb_push(sb, "(assert (= |" + fn_name + "_net| false))\n");

                let _d5 = sb_push(sb, "(declare-const |" + fn_name + "_file| Bool)\n");

                let _d6 = sb_push(sb, "(assert (= |" + fn_name + "_file| false))\n");

                let _d7 = sb_push(sb, "(declare-const |" + fn_name + "_sys| Bool)\n");

                let _d8 = sb_push(sb, "(assert (= |" + fn_name + "_sys| false))\n");

                // Generate direct constraints for pure fn → effectful callees (bypassing caller_eff check)
                eff_z3_gen_pure_edges(fn_name, calls, eff_map, 0, sb)

            } else { 0 };

            eff_z3_gen_pure_decls(entries, eff_map, eol + 1, sb)

        }

    };

// Generate direct edge assertions for a pure fn calling effectful callees.
// Unlike eff_z3_gen_call_edge, this doesn't require caller to be in eff_map.
fn eff_z3_gen_pure_edge(caller_name: String, callee_name: String, eff_map: String, sb: i64) -> i64

  post it >= 0

= {

    let callee_eff = eff_map_get(eff_map, callee_name, 0);

    if callee_eff == "" or callee_eff == "*" { 0 }

    else {

        // For each effect in callee, assert: (=> callee_X caller_X)
        // Since caller_X = false (pure), this creates contradiction if callee_X = true
        let _e1 = sb_push(sb, "(assert (=> |" + callee_name + "_io| |" + caller_name + "_io|))\n");

        let _e2 = sb_push(sb, "(assert (=> |" + callee_name + "_net| |" + caller_name + "_net|))\n");

        let _e3 = sb_push(sb, "(assert (=> |" + callee_name + "_file| |" + caller_name + "_file|))\n");

        let _e4 = sb_push(sb, "(assert (=> |" + callee_name + "_sys| |" + caller_name + "_sys|))\n");

        0

    }

};

fn eff_z3_gen_pure_edges(caller_name: String, calls: String, eff_map: String, pos: i64, sb: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= calls.len() { 0 }

    else {

        let end = index_find_comma_or_end(calls, pos);

        let callee = calls.slice(pos, end);

        let _x = eff_z3_gen_pure_edge(caller_name, callee, eff_map, sb);

        if end >= calls.len() { 0 }

        else { eff_z3_gen_pure_edges(caller_name, calls, eff_map, end + 2, sb) }

    };

// Check if any callee in calls list has a declared effect in eff_map.
fn eff_pure_has_eff_callee(calls: String, eff_map: String, pos: i64) -> bool

  pre pos >= 0

  post not it or (calls.len() > 0 and eff_map.len() >= 0)

= if pos >= calls.len() { false }

    else {

        let end = index_find_comma_or_end(calls, pos);

        let callee = calls.slice(pos, end);

        let callee_eff = eff_map_get(eff_map, callee, 0);

        if callee_eff != "" and callee_eff != "*" { true }

        else if end >= calls.len() { false }

        else { eff_pure_has_eff_callee(calls, eff_map, end + 2) }

    };

// M12 P2: For each unannotated function with transitive effects, emit a Z3
// contradiction pair: (assert X) + (assert (not X)). Z3 reports UNSAT when
// any such function exists, formally certifying missing annotation violations.
fn eff_z3_gen_missing_anno_sb(entries: String, direct_map: String, transitive_map: String, pos: i64, sb: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= entries.len() { 0 }

  else {

    let eol = callers_find_eol(entries, pos);

    let line = entries.slice(pos, eol);

    if line.len() == 0 { eff_z3_gen_missing_anno_sb(entries, direct_map, transitive_map, eol + 1, sb) }

    else {

      let fn_name = callers_get_field(line, 0, 0, 0);

      let sig = callers_get_field(line, 2, 0, 0);

      let direct_raw = eff_map_get_raw(direct_map, fn_name, 0);

      let is_plat = str_find(direct_raw, "PLAT:") == 0;

      let is_pure = str_find(sig, "@pure fn") >= 0 or str_find(sig, "@const fn") >= 0;

      let is_main = fn_name == "main";

      let _x = if direct_raw == "" and not is_plat and not is_pure and not is_main {

        let trans_eff = eff_map_get(transitive_map, fn_name, 0);

        if trans_eff != "" and trans_eff != "pure" and trans_eff != "*" {

          let vname = "|missing_anno_" + fn_name + "|";

          let _d = sb_push(sb, "(declare-const " + vname + " Bool)\n");

          let _a = sb_push(sb, "(assert " + vname + ")\n");

          sb_push(sb, "(assert (not " + vname + "))\n")

        } else { 0 }

      } else { 0 };

      eff_z3_gen_missing_anno_sb(entries, direct_map, transitive_map, eol + 1, sb)

    }

  };

fn eff_z3_gen_smt(entries: String, eff_map: String, transitive_map: String) -> String

  post it.len() >= 0

= {

    let sb = sb_new();

    let _h = sb_push(sb, "; BMB M12 Phase 6: Effect System Verification\n");

    let _d = eff_z3_gen_fn_decls(eff_map, 0, sb);

    let _p = eff_z3_gen_pure_decls(entries, eff_map, 0, sb);

    let _e = eff_z3_gen_edges(entries, eff_map, 0, sb);

    // M12 P2: formal missing annotation check via contradiction pairs
    let _m = eff_z3_gen_missing_anno_sb(entries, eff_map, transitive_map, 0, sb);

    let _c = sb_push(sb, "(check-sat)\n");

    sb_build(sb)

};

fn eff_z3_invoke(smt: String) -> String

  post it.len() >= 0

= {

    // T-BV: soft per-query timeout (ms). Bitvector + quantifier (the len axiom)
    // can make a query intractable where unbounded-Int was fast; without a
    // timeout one hard corpus function hangs the whole run. On timeout z3 emits
    // `unknown`, which degrades to the honest `unknown` verdict / no counterexample.
    let raw = exec_with_stdin("z3", "-smt2 -in -t:10000", smt);

    let t = str_trim(raw);

    if t == "sat" { "sat" }

    else if t == "unsat" { "unsat" }

    else if t == "" { "unavailable" }

    else { "unknown" }

};

// T-CX: run a model query (smt ending in check-sat + a get-value line) and
// return the witness text after the leading "sat\n", whitespace-collapsed to a
// compact one-liner (e.g. `((it 4) (pos 4))`). Returns "" if not sat / no model.
fn eff_z3_model(smt: String) -> String

  post it.len() >= 0

= {

    // T-BV: soft per-query timeout (ms). Bitvector + quantifier (the len axiom)
    // can make a query intractable where unbounded-Int was fast; without a
    // timeout one hard corpus function hangs the whole run. On timeout z3 emits
    // `unknown`, which degrades to the honest `unknown` verdict / no counterexample.
    let raw = exec_with_stdin("z3", "-smt2 -in -t:10000", smt);

    let t = str_trim(raw);

    let nl = str_find(t, "\n");

    if nl < 0 { "" }

    else { str_trim(t.slice(nl + 1, t.len())).replace("\r", "").replace("\n", " ") }

};

fn eff_emit_viol_pair(caller_name: String, caller_eff: String, callee_name: String, callee_eff: String, sb: i64, isfirst: i64) -> i64

  post it >= 0

= {

    let io_v = eff_contains_name(callee_eff, "IO") and not eff_contains_name(caller_eff, "IO");

    let net_v = eff_contains_name(callee_eff, "Net") and not eff_contains_name(caller_eff, "Net");

    let file_v = eff_contains_name(callee_eff, "File") and not eff_contains_name(caller_eff, "File");

    let sys_v = eff_contains_name(callee_eff, "Sys") and not eff_contains_name(caller_eff, "Sys");

    if io_v or net_v or file_v or sys_v {

        let _sep = if isfirst == 1 { 0 } else { sb_push(sb, ",") };

        let _j = sb_push(sb, "{\"type\":\"effect_mismatch\",\"function\":\"" + json_esc(caller_name) + "\",\"callee\":\"" + json_esc(callee_name) + "\",\"caller_effect\":\"" + json_esc(caller_eff) + "\",\"callee_effect\":\"" + json_esc(callee_eff) + "\",\"message\":\"function " + json_esc(caller_name) + " declares <" + json_esc(caller_eff) + "> but calls " + json_esc(callee_name) + " which uses <" + json_esc(callee_eff) + ">\",\"fix_suggestion\":\"add <" + json_esc(callee_eff) + "> to " + json_esc(caller_name) + " annotation: fn " + json_esc(caller_name) + "(): <" + json_esc(caller_eff) + ", " + json_esc(callee_eff) + ">\"}");

        0

    } else { isfirst }

};

fn eff_collect_viol_calls(caller_name: String, calls: String, eff_map: String, pos: i64, sb: i64, isfirst: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= calls.len() { isfirst }

    else {

        let caller_eff = eff_map_get(eff_map, caller_name, 0);

        let end = index_find_comma_or_end(calls, pos);

        let callee = calls.slice(pos, end);

        let callee_eff = eff_map_get(eff_map, callee, 0);

        let new_isfirst = if callee_eff != "" and callee_eff != "*" and caller_eff != "*" {

            eff_emit_viol_pair(caller_name, caller_eff, callee, callee_eff, sb, isfirst)

        } else { isfirst };

        if end >= calls.len() { new_isfirst }

        else { eff_collect_viol_calls(caller_name, calls, eff_map, end + 2, sb, new_isfirst) }

    };

fn eff_collect_violations(entries: String, eff_map: String, pos: i64, sb: i64, isfirst: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= entries.len() { isfirst }

    else {

        let eol = callers_find_eol(entries, pos);

        let line = entries.slice(pos, eol);

        if line.len() == 0 { eff_collect_violations(entries, eff_map, eol + 1, sb, isfirst) }

        else {

            let fn_name = callers_get_field(line, 0, 0, 0);

            let calls = callers_get_field(line, 1, 0, 0);

            let raw_eff = eff_map_get_raw(eff_map, fn_name, 0);

            let is_plat = str_find(raw_eff, "PLAT:") == 0;

            let caller_eff = if is_plat { "" } else { eff_map_get(eff_map, fn_name, 0) };

            let new_isfirst = if caller_eff != "" and caller_eff != "*" and calls.len() > 0 {

                eff_collect_viol_calls(fn_name, calls, eff_map, 0, sb, isfirst)

            } else { isfirst };

            eff_collect_violations(entries, eff_map, eol + 1, sb, new_isfirst)

        }

    };

// M12 Phase 6b: Check @pure/@const fn calling a function with declared effects.
// Emits JSON violation objects into sb; returns new isfirst.
fn eff_collect_pure_calls(fn_name: String, calls: String, eff_map: String, pos: i64, sb: i64, isfirst: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= calls.len() { isfirst }

    else {

        let end = index_find_comma_or_end(calls, pos);

        let callee = calls.slice(pos, end);

        let callee_eff = eff_map_get(eff_map, callee, 0);

        let new_isfirst = if callee_eff != "" and callee_eff != "*" {

            let _sep = if isfirst == 1 { 0 } else { sb_push(sb, ",") };

            let _j = sb_push(sb, "{\"type\":\"pure_violation\",\"function\":\"" + json_esc(fn_name) + "\",\"callee\":\"" + json_esc(callee) + "\",\"callee_effect\":\"" + json_esc(callee_eff) + "\",\"message\":\"@pure function " + json_esc(fn_name) + " calls " + json_esc(callee) + " which uses <" + json_esc(callee_eff) + ">\",\"fix_suggestion\":\"remove @pure from " + json_esc(fn_name) + ", or ensure " + json_esc(callee) + " is also @pure\"}");


            0

        } else { isfirst };

        if end >= calls.len() { new_isfirst }

        else { eff_collect_pure_calls(fn_name, calls, eff_map, end + 2, sb, new_isfirst) }

    };

// Scan all entries for @pure/@const fn calling effectful callees.
fn eff_collect_pure_violations(entries: String, eff_map: String, pos: i64, sb: i64, isfirst: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= entries.len() { isfirst }

    else {

        let eol = callers_find_eol(entries, pos);

        let line = entries.slice(pos, eol);

        if line.len() == 0 { eff_collect_pure_violations(entries, eff_map, eol + 1, sb, isfirst) }

        else {

            let fn_name = callers_get_field(line, 0, 0, 0);

            let calls = callers_get_field(line, 1, 0, 0);

            let sig = callers_get_field(line, 2, 0, 0);

            let is_pure = str_find(sig, "@pure fn") >= 0 or str_find(sig, "@const fn") >= 0;

            let new_isfirst = if is_pure and calls.len() > 0 {

                eff_collect_pure_calls(fn_name, calls, eff_map, 0, sb, isfirst)

            } else { isfirst };

            eff_collect_pure_violations(entries, eff_map, eol + 1, sb, new_isfirst)

        }

    };

// M12 Phase 6c: Missing effect annotation violations for effect_verify output.
// Emits JSON violation objects for functions with inferred effects but no explicit declaration.
fn eff_collect_missing_annot(entries: String, direct_map: String, transitive_map: String, pos: i64, sb: i64, isfirst: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= entries.len() { isfirst }

    else {

        let eol = callers_find_eol(entries, pos);

        let line = entries.slice(pos, eol);

        if line.len() == 0 { eff_collect_missing_annot(entries, direct_map, transitive_map, eol + 1, sb, isfirst) }

        else {

            let fn_name = callers_get_field(line, 0, 0, 0);

            let sig = callers_get_field(line, 2, 0, 0);

            let direct_raw = eff_map_get_raw(direct_map, fn_name, 0);

            let is_plat = str_find(direct_raw, "PLAT:") == 0;

            // Skip pure/const (already covered by eff_collect_pure_violations) and main
            let is_pure_fn = str_find(sig, "@pure fn") >= 0 or str_find(sig, "@const fn") >= 0;

            let is_main = fn_name == "main";

            let new_isfirst = if direct_raw != "" or is_plat or is_pure_fn or is_main { isfirst }

            else {

                let trans_eff = eff_map_get(transitive_map, fn_name, 0);

                if trans_eff == "" or trans_eff == "pure" or trans_eff == "*" { isfirst }

                else {

                    let _sep = if isfirst == 1 { 0 } else { sb_push(sb, ",") };

                    let _j = sb_push(sb, "{\"type\":\"missing_annotation\",\"function\":\"" + json_esc(fn_name) + "\",\"missing_effect\":\"" + json_esc(trans_eff) + "\",\"message\":\"function " + json_esc(fn_name) + " uses <" + json_esc(trans_eff) + "> transitively but has no effect annotation\",\"fix_suggestion\":\"annotate as fn " + json_esc(fn_name) + "(): <" + json_esc(trans_eff) + ">\"}");


                    0

                }

            };

            eff_collect_missing_annot(entries, direct_map, transitive_map, eol + 1, sb, new_isfirst)

        }

    };

// Build effect_verify JSON string (without printing). Used by effect_verify_run and diagnose_file.
fn eff_verify_build_json(input: String, entries: String, eff_map: String, transitive_map: String) -> String

  post it.len() >= 1

= {

    let smt = eff_z3_gen_smt(entries, eff_map, transitive_map);

    let z3_result = eff_z3_invoke(smt);

    let viol_sb = sb_new();

    let isfirst_after = eff_collect_violations(entries, eff_map, 0, viol_sb, 1);

    let isfirst_after2 = eff_collect_pure_violations(entries, eff_map, 0, viol_sb, isfirst_after);

    let isfirst_after3 = eff_collect_missing_annot(entries, eff_map, transitive_map, 0, viol_sb, isfirst_after2);

    let has_violation = isfirst_after3 == 0;

    let status = if z3_result == "unsat" { "violation" }

    else if has_violation { "violation" }

    else if z3_result == "unavailable" { "safe" }

    else { "safe" };

    let viol_str = sb_build(viol_sb);

    let viol_count = count_caller_entries(viol_str, 0);

    let out_sb = sb_new();

    let _h1 = sb_push(out_sb, "{\"type\":\"effect_verify\",\"file\":\"");

    let _h2 = sb_push(out_sb, json_esc(input));

    let _h3 = sb_push(out_sb, "\",\"status\":\"" + status + "\",\"z3\":\"" + z3_result + "\",\"violations_count\":" + int_to_string(viol_count));

    let _h4 = if status == "violation" {

        let _vb = sb_push(out_sb, ",\"violations\":[");

        let _vc = sb_push(out_sb, viol_str);

        sb_push(out_sb, "]")

    } else { 0 };

    let _h5 = sb_push(out_sb, "}");

    sb_build(out_sb)

};

fn effect_verify_run(input: String, src: String) -> i64

  post it >= 0

= {

    let entries = callers_collect_source(src, 0, "");

    let eff_map = build_fn_effect_map(src, 0, "");

    let transitive_map = build_full_transitive_effect_map(entries, eff_map, 5);

    let json = eff_verify_build_json(input, entries, eff_map, transitive_map);

    let _p = println_str(json);

    0

};

fn effect_verify_file(input: String) -> i64

  post it >= 0

= let src = read_file(input);

    if src.len() == 0 { err_no_file(input) }

    else { effect_verify_run(input, src) };

// M13 Phase 5: Session-persistent contracts (.bmb-contracts)
// Loads project-level invariants from .bmb-contracts and checks a BMB file against them.
// Format: lines of "key = value" (# comments, blank lines ignored).
// Supported keys:
//   require_postcondition = true/false
//   require_effect_annotation = true/false
//   max_params = N
//   forbid_effect = EffectName (IO|Net|File|Sys)

// Parse a single line of .bmb-contracts: returns "key\tvalue" or ""
fn bc_parse_line(line: String) -> String

  post it.len() >= 0

= if line.len() == 0 { "" }

    else if line.byte_at(0) == 35 { "" }  // # comment

    else {

        let eq = str_find(line, "=");

        if eq < 0 { "" }

        else {

            let key = str_trim(line.slice(0, eq));

            let val = str_trim(line.slice(eq + 1, line.len()));

            if key == "" or val == "" { "" }

            else { key + "\t" + val }

        }

    };

// Scan .bmb-contracts content, collect "key\tvalue\n" map
fn bc_parse_contracts(src: String, pos: i64, acc: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= src.len() { acc }

    else {

        let eol = lint_find_eol(src, pos);

        let line = str_trim(src.slice(pos, eol));

        let entry = bc_parse_line(line);

        let new_acc = if entry == "" { acc } else { acc + entry + "\n" };

        bc_parse_contracts(src, eol + 1, new_acc)

    };

// Look up a key in contracts map ("key\tvalue\n" format)
fn bc_get(contracts: String, key: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= contracts.len() { "" }

    else {

        let eol = lint_find_eol(contracts, pos);

        let line = contracts.slice(pos, eol);

        let tab = str_find(line, "\t");

        if tab < 0 { bc_get(contracts, key, eol + 1) }

        else if line.slice(0, tab) == key { line.slice(tab + 1, line.len()) }

        else { bc_get(contracts, key, eol + 1) }

    };

// Count commas at depth 0 (ignoring commas inside <>). Used for max_params check.
fn count_top_commas(s: String, pos: i64, depth: i64) -> i64

  pre pos >= 0 and pos <= s.len()

  post it >= 0 and it <= s.len() - pos

= if pos >= s.len() { 0 }

  else {

    let c = s.byte_at(pos);

    if c == 60 { count_top_commas(s, pos + 1, depth + 1) }

    else if c == 62 { count_top_commas(s, pos + 1, depth - 1) }

    else if c == 44 and depth == 0 { 1 + count_top_commas(s, pos + 1, depth) }

    else { count_top_commas(s, pos + 1, depth) }

  };

// Count parameters in a function sig string "fn name(params) -> RetType".
fn count_sig_params(sig: String) -> i64

  post it >= 0

= let lp = str_find(sig, "(");

  if lp < 0 { 0 }

  else {

    let inner_start = lp + 1;

    let rp = str_find(sig.slice(inner_start, sig.len()), ")");

    let params_str = if rp >= 0 { str_trim(sig.slice(inner_start, inner_start + rp)) } else { "" };

    if params_str == "" { 0 }

    else { count_top_commas(params_str, 0, 0) + 1 }

  };

// Check max_params: scan entries for functions exceeding the parameter limit.
fn bc_check_max_params_scan(entries: String, max_n: i64, sb: i64, isfirst: i64, pos: i64) -> i64

  pre pos >= 0 and max_n >= 0

  post it >= 0

= if pos >= entries.len() { isfirst }

  else {

    let eol = callers_find_eol(entries, pos);

    let line = entries.slice(pos, eol);

    if line.len() == 0 { bc_check_max_params_scan(entries, max_n, sb, isfirst, eol + 1) }

    else {

      let fn_name = callers_get_field(line, 0, 0, 0);

      let sig = callers_get_field(line, 2, 0, 0);

      let param_count = count_sig_params(sig);

      let new_isfirst = if param_count > max_n {

        let _sep = if isfirst == 1 { 0 } else { sb_push(sb, ",") };

        let _j = sb_push(sb, "{\"type\":\"max_params\",\"function\":\"" + json_esc(fn_name) + "\",\"params\":" + int_to_string(param_count) + ",\"max\":" + int_to_string(max_n) + ",\"message\":\"function " + json_esc(fn_name) + " has " + int_to_string(param_count) + " params (max=" + int_to_string(max_n) + ")\",\"fix_suggestion\":\"split " + json_esc(fn_name) + " into smaller helper functions (current: " + int_to_string(param_count) + " params, max: " + int_to_string(max_n) + ")\"}");

        0

      } else { isfirst };

      bc_check_max_params_scan(entries, max_n, sb, new_isfirst, eol + 1)

    }

  };

// Return the appropriate post condition suggestion string for a given return type
fn bc_post_suggest(ret_type: String) -> String

  post it.len() >= 0

= if ret_type == "bool" { "post it or not it" }
    else if ret_type == "String" { "post it.len() >= 0" }
    else { "post it >= 0" };

// Extract return type text from a function position in source
fn bc_ret_type_for_pos(src: String, fn_pos: i64) -> String

  pre fn_pos >= 0
  post it.len() >= 0

= let ns = skip_ws_comments(src, fn_pos + 3);
    let ne = scan_ident_end(src, ns);
    let t_after = next_token_raw(src, ne);
    let after_gen = if tok_kind(t_after) == TK_LT() { skip_generic_params(src, tok_end(t_after)) } else { ne };
    let t_lp = next_token_raw(src, after_gen);
    if tok_kind(t_lp) == TK_LPAREN() {
        let rp = vr_after_params_pos(src, tok_end(t_lp));
        let rtype = index_read_ret_type(src, rp);
        unpack_ast(rtype)
    } else { "" };

// Check require_postcondition: scan entries for user functions without post clause
fn bc_check_post_scan(entries: String, src: String, eff_map: String, pos: i64, sb: i64, isfirst: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= entries.len() { isfirst }

    else {

        let eol = callers_find_eol(entries, pos);

        let line = entries.slice(pos, eol);

        if line.len() == 0 { bc_check_post_scan(entries, src, eff_map, eol + 1, sb, isfirst) }

        else {

            let fn_name = callers_get_field(line, 0, 0, 0);

            let raw_eff = eff_map_get_raw(eff_map, fn_name, 0);

            let is_plat = str_find(raw_eff, "PLAT:") == 0;

            let is_skip = fn_name == "main" or is_plat;

            let fn_pos = if is_skip { -1 } else { find_pattern_noa(src, "fn " + fn_name + "(", 0) };

            let post_texts = if fn_pos < 0 { "ok" }

                             else {

                                 let ns = skip_ws_comments(src, fn_pos + 3);

                                 let ne = scan_ident_end(src, ns);

                                 let t_after = next_token_raw(src, ne);

                                 let after_gen = if tok_kind(t_after) == TK_LT() { skip_generic_params(src, tok_end(t_after)) } else { ne };

                                 let t_lp = next_token_raw(src, after_gen);

                                 if tok_kind(t_lp) == TK_LPAREN() {

                                     let rp = vr_after_params_pos(src, tok_end(t_lp));

                                     extract_post_texts(src, rp)

                                 } else { "ok" }

                             };

            let ret_str = if fn_pos >= 0 { bc_ret_type_for_pos(src, fn_pos) } else { "" };

            let new_isfirst = if post_texts == "" {

                let _sep = if isfirst == 1 { 0 } else { sb_push(sb, ",") };

                let fix_sug = "add postcondition to " + fn_name + ": " + bc_post_suggest(ret_str);

                let _j = sb_push(sb, "{\"type\":\"require_postcondition\",\"function\":\"" + json_esc(fn_name) + "\",\"message\":\"function " + json_esc(fn_name) + " has no postcondition\",\"fix_suggestion\":\"" + json_esc(fix_sug) + "\"}");

                0

            } else { isfirst };

            bc_check_post_scan(entries, src, eff_map, eol + 1, sb, new_isfirst)

        }

    };

// Check forbid_effect: find user functions using a specific forbidden effect
fn bc_check_forbid_eff(entries: String, transitive_map: String, forbidden: String, sb: i64, isfirst: i64, pos: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= entries.len() { isfirst }

    else {

        let eol = callers_find_eol(entries, pos);

        let line = entries.slice(pos, eol);

        if line.len() == 0 { bc_check_forbid_eff(entries, transitive_map, forbidden, sb, isfirst, eol + 1) }

        else {

            let fn_name = callers_get_field(line, 0, 0, 0);

            let trans_eff = eff_map_get(transitive_map, fn_name, 0);

            let new_isfirst = if eff_contains_name(trans_eff, forbidden) {

                let _sep = if isfirst == 1 { 0 } else { sb_push(sb, ",") };

                let _j = sb_push(sb, "{\"type\":\"forbid_effect\",\"function\":\"" + json_esc(fn_name) + "\",\"message\":\"function " + json_esc(fn_name) + " uses <" + json_esc(forbidden) + "> (forbidden by project contracts)\",\"fix_suggestion\":\"refactor " + json_esc(fn_name) + " to avoid using <" + json_esc(forbidden) + "> effect\"}");

                0

            } else { isfirst };

            bc_check_forbid_eff(entries, transitive_map, forbidden, sb, new_isfirst, eol + 1)

        }

    };

// Check forbid_function: find functions that directly call a forbidden function.
fn bc_check_forbid_fn(entries: String, forbidden_fn: String, sb: i64, isfirst: i64, pos: i64) -> i64

  pre pos >= 0 and forbidden_fn.len() >= 1

  post it >= 0

= if pos >= entries.len() { isfirst }

    else {

        let eol = callers_find_eol(entries, pos);

        let line = entries.slice(pos, eol);

        if line.len() == 0 { bc_check_forbid_fn(entries, forbidden_fn, sb, isfirst, eol + 1) }

        else {

            let fn_name = callers_get_field(line, 0, 0, 0);

            let calls = callers_get_field(line, 1, 0, 0);

            let new_isfirst = if fn_name != forbidden_fn and callers_calls_contain(calls, forbidden_fn, 0) {

                let _sep = if isfirst == 1 { 0 } else { sb_push(sb, ",") };

                let _j = sb_push(sb, "{\"type\":\"forbid_function\",\"function\":\"" + json_esc(fn_name) + "\",\"forbidden\":\"" + json_esc(forbidden_fn) + "\",\"message\":\"function " + json_esc(fn_name) + " calls forbidden function " + json_esc(forbidden_fn) + "\",\"fix_suggestion\":\"replace call to " + json_esc(forbidden_fn) + " in " + json_esc(fn_name) + " with an approved alternative\"}");

                0

            } else { isfirst };

            bc_check_forbid_fn(entries, forbidden_fn, sb, new_isfirst, eol + 1)

        }

    };

// Check require_effect_annotation: find functions with transitive effects but no declaration.
// Emits JSON violation objects per function.
fn bc_check_missing_eff_anno(entries: String, direct_map: String, transitive_map: String, pos: i64, sb: i64, isfirst: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= entries.len() { isfirst }

    else {

        let eol = callers_find_eol(entries, pos);

        let line = entries.slice(pos, eol);

        if line.len() == 0 { bc_check_missing_eff_anno(entries, direct_map, transitive_map, eol + 1, sb, isfirst) }

        else {

            let fn_name = callers_get_field(line, 0, 0, 0);

            let sig = callers_get_field(line, 2, 0, 0);

            let direct_raw = eff_map_get_raw(direct_map, fn_name, 0);

            let is_plat = str_find(direct_raw, "PLAT:") == 0;

            let is_pure_fn = str_find(sig, "@pure fn") >= 0 or str_find(sig, "@const fn") >= 0;

            let is_main = fn_name == "main";

            let new_isfirst = if direct_raw != "" or is_plat or is_pure_fn or is_main { isfirst }

            else {

                let trans_eff = eff_map_get(transitive_map, fn_name, 0);

                if trans_eff == "" or trans_eff == "pure" or trans_eff == "*" { isfirst }

                else {

                    let _sep = if isfirst == 1 { 0 } else { sb_push(sb, ",") };

                    let _j = sb_push(sb, "{\"type\":\"require_effect_annotation\",\"function\":\"" + json_esc(fn_name) + "\",\"message\":\"function " + json_esc(fn_name) + " has inferred effects <" + json_esc(trans_eff) + "> but no explicit annotation\"}");

                    0

                }

            };

            bc_check_missing_eff_anno(entries, direct_map, transitive_map, eol + 1, sb, new_isfirst)

        }

    };

// Check enforce_module_caps: emit violation for each effect not covered by module requires.
// Returns new isfirst value after emitting violations.
fn bc_check_module_cap_fn(fn_name: String, trans_eff: String, module_caps: String, sb: i64, isfirst: i64, pos: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= trans_eff.len() { isfirst }

    else {

        let end = eff_find_space_or_end(trans_eff, pos);

        let cap = trans_eff.slice(pos, end);

        let new_isfirst = if cap.len() > 0 and not eff_contains_name(module_caps, cap) {

            let _sep = if isfirst == 1 { 0 } else { sb_push(sb, ",") };

            let _j = sb_push(sb, "{\"type\":\"module_capability\",\"function\":\"" + json_esc(fn_name) + "\",\"effect\":\"" + json_esc(cap) + "\",\"declared\":[" + ms_caps_to_json(module_caps, 0, 1) + "],\"message\":\"function " + json_esc(fn_name) + " uses <" + json_esc(cap) + "> not declared in module requires\",\"fix_suggestion\":\"add " + json_esc(cap) + " to module requires declaration\"}");

            0

        } else { isfirst };

        if end >= trans_eff.len() { new_isfirst }

        else { bc_check_module_cap_fn(fn_name, trans_eff, module_caps, sb, new_isfirst, end + 1) }

    };

fn bc_check_module_caps_scan(entries: String, transitive_map: String, module_caps: String, sb: i64, isfirst: i64, pos: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= entries.len() or module_caps == "" { isfirst }

    else {

        let eol = callers_find_eol(entries, pos);

        let line = entries.slice(pos, eol);

        if line.len() == 0 { bc_check_module_caps_scan(entries, transitive_map, module_caps, sb, isfirst, eol + 1) }

        else {

            let fn_name = callers_get_field(line, 0, 0, 0);

            let trans_eff = eff_map_get(transitive_map, fn_name, 0);

            let new_isfirst = if trans_eff == "" or trans_eff == "pure" or trans_eff == "*" { isfirst }

            else { bc_check_module_cap_fn(fn_name, trans_eff, module_caps, sb, isfirst, 0) };

            bc_check_module_caps_scan(entries, transitive_map, module_caps, sb, new_isfirst, eol + 1)

        }

    };

// Build contracts_check JSON string (without printing). Used by contracts_check_run and diagnose_file.
fn cc_build_json(input: String, src: String, entries: String, eff_map: String, transitive_map: String, contracts: String) -> String

  post it.len() >= 1

= {

    let req_post = bc_get(contracts, "require_postcondition", 0);

    let req_eff_anno = bc_get(contracts, "require_effect_annotation", 0);

    let forbid_eff = bc_get(contracts, "forbid_effect", 0);

    let forbid_fn = bc_get(contracts, "forbid_function", 0);

    let max_params_str = bc_get(contracts, "max_params", 0);

    let viol_sb = sb_new();

    let f1 = 1;

    // require_postcondition check
    let f2 = if req_post == "true" { bc_check_post_scan(entries, src, eff_map, 0, viol_sb, f1) } else { f1 };

    // forbid_effect check
    let f3 = if forbid_eff != "" {

        bc_check_forbid_eff(entries, transitive_map, forbid_eff, viol_sb, f2, 0)

    } else { f2 };

    // forbid_function check
    let f3b = if forbid_fn != "" {

        bc_check_forbid_fn(entries, forbid_fn, viol_sb, f3, 0)

    } else { f3 };

    // require_effect_annotation: report missing annotations as JSON violations
    let f4 = if req_eff_anno == "true" {

        bc_check_missing_eff_anno(entries, eff_map, transitive_map, 0, viol_sb, f3b)

    } else { f3b };

    // max_params check
    let f5 = if max_params_str != "" {

        let max_n = str_to_int(max_params_str);

        if max_n > 0 { bc_check_max_params_scan(entries, max_n, viol_sb, f4, 0) } else { f4 }

    } else { f4 };

    let has_viol = f5 == 0;

    let status = if has_viol { "violation" } else { "safe" };

    let viol_str = sb_build(viol_sb);

    let viol_count = count_rule_entries(viol_str, 0);

    let out_sb = sb_new();

    let _h1 = sb_push(out_sb, "{\"type\":\"contracts_check\",\"file\":\"");

    let _h2 = sb_push(out_sb, json_esc(input));

    let _h3 = sb_push(out_sb, "\",\"status\":\"" + status + "\",\"violations_count\":" + int_to_string(viol_count));

    let _h4 = if has_viol {

        let _vb = sb_push(out_sb, ",\"violations\":[");

        let _vc = sb_push(out_sb, viol_str);

        sb_push(out_sb, "]")

    } else { 0 };

    let _h5 = sb_push(out_sb, "}");

    sb_build(out_sb)

};

// Copy chars from s[0..limit) into sb, then append mc_suffix and return 0.
fn cc_json_prefix_sb(s: String, pos: i64, limit: i64, sb: i64) -> i64

  pre pos >= 0

  post it == 0

= if pos >= limit { 0 }

    else {

        let _p = sb_push_char(sb, s.byte_at(pos));

        cc_json_prefix_sb(s, pos + 1, limit, sb)

    };

// Combine contracts_check JSON with module_capability: strip closing "}" and embed mc_json.
fn cc_combine_mc(cc_json: String, mc_json: String) -> String

  post it.len() >= 1

= {

    let sb = sb_new();

    let _c = cc_json_prefix_sb(cc_json, 0, cc_json.len() - 1, sb);

    let _m = sb_push(sb, ",\"module_capability\":" + mc_json + "}");

    sb_build(sb)

};

// Build module_capability JSON section (separate from contracts_check).
// Returns {"type":"module_capability","status":"...","total_violations":N,"violations":[...]}
// Status "skipped" when enforce_module_caps not set or no module requires clause.
fn mc_build_json(input: String, src: String, entries: String, transitive_map: String, contracts: String) -> String

  post it.len() >= 1

= {

    let enforce_caps = bc_get(contracts, "enforce_module_caps", 0);

    if enforce_caps != "true" {

        "{\"type\":\"module_capability\",\"input\":\"" + json_esc(input) + "\",\"status\":\"skipped\",\"total_violations\":0}"

    } else {

        let module_caps = scan_module_requires(src, 0);

        if module_caps == "" {

            "{\"type\":\"module_capability\",\"input\":\"" + json_esc(input) + "\",\"status\":\"skipped\",\"total_violations\":0}"

        } else {

            let mc_sb = sb_new();

            let last_isfirst = bc_check_module_caps_scan(entries, transitive_map, module_caps, mc_sb, 1, 0);

            let viol_str = sb_build(mc_sb);

            let viol_count = count_rule_entries(viol_str, 0);

            let has_viol = last_isfirst == 0;

            let status = if has_viol { "violation" } else { "safe" };

            let out_sb = sb_new();

            let _h1 = sb_push(out_sb, "{\"type\":\"module_capability\",\"input\":\"" + json_esc(input) + "\",\"status\":\"" + status + "\",\"total_violations\":" + int_to_string(viol_count));

            let _h2 = if has_viol {

                let _vb = sb_push(out_sb, ",\"violations\":[");

                let _vc = sb_push(out_sb, viol_str);

                sb_push(out_sb, "]")

            } else { 0 };

            let _h3 = sb_push(out_sb, "}");

            sb_build(out_sb)

        }

    }

};

fn contracts_check_run(input: String, src: String, contracts: String) -> i64

  post it >= 0

= {

    let entries = callers_collect_source(src, 0, "");

    let eff_map = build_fn_effect_map(src, 0, "");

    let transitive_map = build_full_transitive_effect_map(entries, eff_map, 5);

    let cc_json = cc_build_json(input, src, entries, eff_map, transitive_map, contracts);

    let mc_json = mc_build_json(input, src, entries, transitive_map, contracts);

    let combined = cc_combine_mc(cc_json, mc_json);

    let _p = println_str(combined);

    0

};

// Phase 6c: Module capability enforcement at build time.
// When .bmb-contracts has enforce_module_caps=true, the build command refuses
// to produce a binary if the source has module capability violations.
// Returns 0 (no violation, build proceeds) or 1 (violation, build aborted).
fn build_check_module_caps(input: String, source: String) -> i64

  post it >= 0

= let contracts_src = read_file(".bmb-contracts");

    if contracts_src.len() == 0 { 0 }

    else {

        let contracts = bc_parse_contracts(contracts_src, 0, "");

        let enforce_caps = bc_get(contracts, "enforce_module_caps", 0);

        if enforce_caps != "true" { 0 }

        else {

            let module_caps = scan_module_requires(source, 0);

            if module_caps == "" { 0 }

            else {

                let entries = callers_collect_source(source, 0, "");

                let eff_map = build_fn_effect_map(source, 0, "");

                let transitive_map = build_full_transitive_effect_map(entries, eff_map, 5);

                let mc_json = mc_build_json(input, source, entries, transitive_map, contracts);

                let is_viol = has_pattern(mc_json, "\"status\":\"violation\"", 0);

                if is_viol {

                    let err_json = "{\"type\":\"build_error\",\"file\":\"" + json_esc(input) + "\",\"reason\":\"module_capability\",\"module_capability\":" + mc_json + "}";

                    let _p = println_str(err_json);

                    1

                } else { 0 }

            }

        }

    };

fn contracts_check_file(input: String) -> i64

  post it >= 0

= let src = read_file(input);

    if src.len() == 0 { err_no_file(input) }

    else {

        let contracts_src = read_file(".bmb-contracts");

        let contracts = if contracts_src.len() > 0 {

            bc_parse_contracts(contracts_src, 0, "")

        } else { "" };

        contracts_check_run(input, src, contracts)

    };

// M14 Phase 4: SemanticDuplicate — detect functions with identical call sets
// Finds pairs of functions with same callee set (≥3 calls), indicating potential duplication.
// Conservative threshold: exact call set overlap (shared == max(count_a, count_b)).

fn semdp_call_count(calls: String, pos: i64, count: i64) -> i64

  pre pos >= 0

  post it >= 0

= if calls == "" { 0 }

    else if pos >= calls.len() { count + 1 }

    else if calls.byte_at(pos) == 44 { semdp_call_count(calls, pos + 2, count + 1) }

    else { semdp_call_count(calls, pos + 1, count) };

// Check one pair (a, b): returns "fn_a\tfn_b\tshared\tcount_a\tcount_b\n" if duplicate
fn semdp_check_pair(name_a: String, calls_a: String, name_b: String, calls_b: String) -> String

  post it.len() >= 0

= {

    let cnt_a = semdp_call_count(calls_a, 0, 0);

    let cnt_b = semdp_call_count(calls_b, 0, 0);

    if cnt_a < 8 or cnt_b < 8 { "" }

    else {

        let shared = sim_count_shared(calls_a, calls_b, 0, 0);

        let max_cnt = if cnt_a > cnt_b { cnt_a } else { cnt_b };

        // Exact overlap: shared == max (all calls of one are in the other)
        if shared == max_cnt {

            name_a + "\t" + name_b + "\t" + int_to_string(shared) + "\t" + int_to_string(cnt_a) + "\t" + int_to_string(cnt_b) + "\n"

        } else { "" }

    }

};

// Inner loop: compare fn_a against all subsequent entries
fn semdp_inner(name_a: String, calls_a: String, entries: String, pos: i64, sb: i64, isfirst: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= entries.len() { isfirst }

    else {

        let eol = callers_find_eol(entries, pos);

        let line = entries.slice(pos, eol);

        if line.len() == 0 { semdp_inner(name_a, calls_a, entries, eol + 1, sb, isfirst) }

        else {

            let name_b = callers_get_field(line, 0, 0, 0);

            let calls_b = callers_get_field(line, 1, 0, 0);

            let pair = if name_a != name_b { semdp_check_pair(name_a, calls_a, name_b, calls_b) } else { "" };

            let new_isfirst = if pair != "" {

                let tab1 = str_find(pair, "\t");

                let tab2 = str_find(pair.slice(tab1 + 1, pair.len()), "\t");

                let name_b_from = pair.slice(tab1 + 1, tab1 + 1 + tab2);

                let rest = pair.slice(tab1 + 1 + tab2 + 1, pair.len() - 1);

                let tab3 = str_find(rest, "\t");

                let shared_s = rest.slice(0, tab3);

                let rest2 = rest.slice(tab3 + 1, rest.len());

                let tab4 = str_find(rest2, "\t");

                let cnt_a_s = rest2.slice(0, tab4);

                let cnt_b_s = rest2.slice(tab4 + 1, rest2.len());

                let _sep = if isfirst == 1 { 0 } else { sb_push(sb, ",") };

                let _j = sb_push(sb, "{\"type\":\"semantic_duplicate\",\"function\":\"" + json_esc(name_a) + "\",\"similar_to\":\"" + json_esc(name_b_from) + "\",\"shared_calls\":" + shared_s + ",\"total_a\":" + cnt_a_s + ",\"total_b\":" + cnt_b_s + "}");

                0

            } else { isfirst };

            semdp_inner(name_a, calls_a, entries, eol + 1, sb, new_isfirst)

        }

    };

// Outer loop: for each function, check against all subsequent functions
fn semdp_outer(entries: String, all_entries: String, pos: i64, sb: i64, isfirst: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= entries.len() { isfirst }

    else {

        let eol = callers_find_eol(entries, pos);

        let line = entries.slice(pos, eol);

        if line.len() == 0 { semdp_outer(entries, all_entries, eol + 1, sb, isfirst) }

        else {

            let name_a = callers_get_field(line, 0, 0, 0);

            let calls_a = callers_get_field(line, 1, 0, 0);

            // Only compare against entries AFTER current position to avoid duplicate pairs
            let new_isfirst = semdp_inner(name_a, calls_a, entries, eol + 1, sb, isfirst);

            semdp_outer(entries, all_entries, eol + 1, sb, new_isfirst)

        }

    };

// Build semantic_duplicate JSON string (without printing). Used by semantic_duplicate_run and diagnose_file.
fn semdp_build_json(input: String, entries: String) -> String

  post it.len() >= 1

= {

    let viol_sb = sb_new();

    let _f = semdp_outer(entries, entries, 0, viol_sb, 1);

    let pairs_str = sb_build(viol_sb);

    let pairs_count = count_fn_a_entries(pairs_str, 0);

    let out_sb = sb_new();

    let _h1 = sb_push(out_sb, "{\"type\":\"semantic_duplicate\",\"file\":\"");

    let _h2 = sb_push(out_sb, json_esc(input));

    let _h3 = sb_push(out_sb, "\",\"pairs_count\":" + int_to_string(pairs_count) + ",\"pairs\":[");

    let _h4 = sb_push(out_sb, pairs_str);

    let _h5 = sb_push(out_sb, "]}");

    sb_build(out_sb)

};

fn semantic_duplicate_run(input: String, src: String) -> i64

  post it >= 0

= {

    let entries = callers_collect_source(src, 0, "");

    let json = semdp_build_json(input, entries);

    let _p = println_str(json);

    0

};

fn semantic_duplicate_file(input: String) -> i64

  post it >= 0

= let src = read_file(input);

    if src.len() == 0 { err_no_file(input) }

    else { semantic_duplicate_run(input, src) };

// Extract an integer field from a JSON string: "field":N  (returns 0 if not found).
fn json_extract_int_field(json: String, field: String) -> i64

  pre field.len() >= 1

  post it >= 0

= {

    let needle = "\"" + field + "\":";

    let p = find_substr_pos(json, needle, 0);

    if p < 0 { 0 } else { parse_int_from(json, p + needle.len(), 0) }

};

// Count newlines from pos=0 to limit (exclusive) in src.
fn count_newlines(src: String, pos: i64, count: i64, limit: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= limit or pos >= src.len() { count }

    else if src.byte_at(pos) == 10 { count_newlines(src, pos + 1, count + 1, limit) }

    else { count_newlines(src, pos + 1, count, limit) };

// Find position of "fn fn_name(" definition. Returns -1 if not found.
// Verifies preceding char is whitespace to avoid partial-name matches.
fn find_fn_def_pos(src: String, fn_name: String, pos: i64) -> i64

  pre pos >= 0

  post it >= -1

= if pos >= src.len() { 0 - 1 }

    else {

        let pattern = "fn " + fn_name + "(";

        let found = find_pattern_at_slow(src, pattern, pos);

        if found < 0 { 0 - 1 }

        else {

            let pre_char = if found == 0 { 10 } else { src.byte_at(found - 1) };

            if pre_char == 32 or pre_char == 10 or pre_char == 9 {

                found

            } else {

                find_fn_def_pos(src, fn_name, found + 1)

            }

        }

    };

// Get 1-based line number for a function definition (0 = not found).
fn get_fn_line(src: String, fn_name: String) -> i64

  post it >= 0

= let pos = find_fn_def_pos(src, fn_name, 0);

    if pos < 0 { 0 }

    else { count_newlines(src, 0, 0, pos) + 1 };

// Inject "line":N into each "function":"NAME" occurrence in json_text.
// Used to enrich violation JSON with source location.
fn enrich_violations_with_lines(json: String, src: String, pos: i64, acc: String) -> String

  pre pos >= 0

  post it.len() >= 0

= let pat_pos = find_pattern_at_slow(json, "\"function\":\"", pos);

    if pat_pos < 0 {

        acc + json.slice(pos, json.len())

    } else {

        let name_start = pat_pos + 12;

        let name_end = find_char(json, name_start, 34);

        let fn_name = json.slice(name_start, name_end);

        let line = get_fn_line(src, fn_name);

        let inject = if line > 0 { ",\"line\":" + int_to_string(line) } else { "" };

        let new_acc = acc + json.slice(pos, name_end + 1) + inject;

        enrich_violations_with_lines(json, src, name_end + 1, new_acc)

    };

// Check if "fn " at fn_pos is a real top-level function declaration (not in a comment).
fn lmp_is_real_fn(src: String, fn_pos: i64) -> bool

  pre fn_pos >= 0

  post it or not it

= let prev_ok = if fn_pos == 0 { true }

      else { let prev = src.byte_at(fn_pos - 1); prev == 10 or prev == 13 or prev == 32 or prev == 59 or prev == 9 };

    if not prev_ok { false }

    else {

        let sol = lint_find_sol(src, fn_pos);

        not (find_pattern_noa_range(src, "//", sol, fn_pos) >= 0)

    };

// Check one function for missing postcondition, emit JSON to sb if violation found.
fn lmp_check_fn_sb(src: String, fn_pos: i64, sb: i64, isfirst: i64) -> i64

  pre fn_pos >= 0

  post it >= 0

= let name_start = skip_ws_comments(src, fn_pos + 3);

    let name_end = scan_ident_end(src, name_start);

    let fname = src.slice(name_start, name_end);

    if fname == "" or name_end <= name_start { isfirst }

    else {

        let t2 = next_token_raw(src, name_end);

        let after_gen = if tok_kind(t2) == TK_LT() { skip_generic_params(src, tok_end(t2)) } else { name_end };

        let t2g = next_token_raw(src, after_gen);

        if tok_kind(t2g) != TK_LPAREN() { isfirst }

        else {

            let params = index_collect_params(src, tok_end(t2g), "");

            let rtype = index_read_ret_type(src, unpack_pos(params));

            let ret_str = unpack_ast(rtype);

            let rp = unpack_pos(rtype);

            let is_unit = ret_str == "()" or ret_str == "?" or fname == "main";

            let post_asts = extract_post_asts(src, rp);

            if not is_unit and post_asts == "" {

                let _comma = if isfirst == 0 { sb_push(sb, ",") } else { 0 };

                let line_num = count_line_at(src, fn_pos, 0, 1);

                let fix_sug = bc_post_suggest(ret_str);

                let _j = sb_push(sb, "{\"type\":\"missing_postcondition\",\"function\":\"" + json_esc(fname) + "\",\"line\":" + int_to_string(line_num) + ",\"ret_type\":\"" + json_esc(ret_str) + "\",\"message\":\"non-unit return with no post condition\",\"fix_suggestion\":\"" + fix_sug + "\"}");

                0

            } else { isfirst }

        }

    };

// Scan source for functions missing postconditions, emit JSON violation objects into sb.
fn lmp_scan_fn_sb(src: String, pos: i64, sb: i64, isfirst: i64) -> i64

  pre pos >= 0

  post it >= 0

= let fn_pos = find_pattern_noa(src, "fn ", pos);

    if fn_pos < 0 { isfirst }

    else {

        let is_real = lmp_is_real_fn(src, fn_pos);

        let new_isfirst = if is_real { lmp_check_fn_sb(src, fn_pos, sb, isfirst) } else { isfirst };

        lmp_scan_fn_sb(src, fn_pos + 3, sb, new_isfirst)

    };

// Build JSON section for missing postcondition violations.
fn lmp_build_json(input: String, src: String) -> String

  post it.len() >= 1

= {

    let warn_sb = sb_new();

    let _f = lmp_scan_fn_sb(src, 0, warn_sb, 1);

    let warnings_str = sb_build(warn_sb);

    let count = count_rule_entries(warnings_str, 0);

    let out_sb = sb_new();

    let _h1 = sb_push(out_sb, "{\"type\":\"lint_missing_postcondition\",\"file\":\"");

    let _h2 = sb_push(out_sb, json_esc(input));

    let _h3 = sb_push(out_sb, "\",\"count\":");

    let _hc = sb_push(out_sb, int_to_string(count));

    let _h4 = sb_push(out_sb, ",\"violations\":[");

    let _h5 = sb_push(out_sb, warnings_str);

    let _h6 = sb_push(out_sb, "]}");

    sb_build(out_sb)

};

// M12/M13 diagnose: unified effect-verify + contracts-check in one JSON.
// Computes entries/eff_map/transitive_map once, reuses for both checks.
fn diagnose_file(input: String) -> i64

  post it >= 0

= let src = read_file(input);

    if src.len() == 0 { err_no_file(input) }

    else {

        let entries = callers_collect_source(src, 0, "");

        let eff_map = build_fn_effect_map(src, 0, "");

        let transitive_map = build_full_transitive_effect_map(entries, eff_map, 5);

        let ev_json_raw = eff_verify_build_json(input, entries, eff_map, transitive_map);

        let ev_json = enrich_violations_with_lines(ev_json_raw, src, 0, "");

        let contracts_src = read_file(".bmb-contracts");

        let contracts = if contracts_src.len() > 0 {

            bc_parse_contracts(contracts_src, 0, "")

        } else { "" };

        let cc_json_raw = cc_build_json(input, src, entries, eff_map, transitive_map, contracts);

        let cc_json = enrich_violations_with_lines(cc_json_raw, src, 0, "");

        let mc_json_raw = mc_build_json(input, src, entries, transitive_map, contracts);

        let mc_json = enrich_violations_with_lines(mc_json_raw, src, 0, "");

        let le_json_raw = lint_effects_build_json(input, entries, eff_map, transitive_map);

        let le_json = enrich_violations_with_lines(le_json_raw, src, 0, "");

        let sd_json = semdp_build_json(input, entries);

        let lmp_json = lmp_build_json(input, src);

        let ev_count = json_extract_int_field(ev_json, "violations_count");

        let cc_count = json_extract_int_field(cc_json, "violations_count");

        let mc_count = json_extract_int_field(mc_json, "total_violations");

        let le_count = json_extract_int_field(le_json, "count");

        let sd_count = json_extract_int_field(sd_json, "pairs_count");

        let lmp_count = json_extract_int_field(lmp_json, "count");

        let total_issues = ev_count + cc_count + mc_count + le_count + sd_count + lmp_count;

        let summary_json = "{\"total_issues\":" + int_to_string(total_issues) + ",\"effect_issues\":" + int_to_string(ev_count) + ",\"contract_issues\":" + int_to_string(cc_count) + ",\"module_cap_issues\":" + int_to_string(mc_count) + ",\"lint_issues\":" + int_to_string(le_count) + ",\"duplicate_pairs\":" + int_to_string(sd_count) + ",\"missing_postcondition\":" + int_to_string(lmp_count) + "}";

        let out_sb = sb_new();

        let _h1 = sb_push(out_sb, "{\"type\":\"diagnose\",\"file\":\"");

        let _h2 = sb_push(out_sb, json_esc(input));

        let _h3 = sb_push(out_sb, "\",\"effect_verify\":" + ev_json);

        let _h4 = sb_push(out_sb, ",\"contracts_check\":" + cc_json);

        let _h4b = sb_push(out_sb, ",\"module_capability\":" + mc_json);

        let _h5 = sb_push(out_sb, ",\"lint_effects\":" + le_json);

        let _h6 = sb_push(out_sb, ",\"semantic_duplicate\":" + sd_json);

        let _h6b = sb_push(out_sb, ",\"lint_missing_postcondition\":" + lmp_json);

        let _h7 = sb_push(out_sb, ",\"summary\":" + summary_json + "}");

        let _p = println_str(sb_build(out_sb));

        0

    };

// M13 Phase 6b: Session log — track repair iterations across multiple diagnose runs.
// Each invocation appends one compact JSON line to <input>.session-log, then outputs
// the full history so AI agents can see convergence across repair rounds.

// Count existing rounds in session log (one "round": per entry)
fn sl_rounds_from(s: String, pos: i64, n: i64) -> i64

  pre pos >= 0 and n >= 0

  post it >= 0

= if pos >= s.len() { n }

    else {

        let at = str_find(s.slice(pos, s.len()), "\"round\":");

        if at < 0 { n }

        else { sl_rounds_from(s, pos + at + 8, n + 1) }

    };

fn sl_count_rounds(log_src: String) -> i64

  post it >= 0

= sl_rounds_from(log_src, 0, 0);

// Build one session-log entry line (compact JSON, no trailing newline)
fn sl_build_entry(round: i64, ts: i64, total: i64, ev: i64, cc: i64, mc: i64, le: i64, sd: i64) -> String

  post it.len() > 0

= "{\"round\":" + int_to_string(round) + ",\"ts\":" + int_to_string(ts) + ",\"total\":" + int_to_string(total) + ",\"ev\":" + int_to_string(ev) + ",\"cc\":" + int_to_string(cc) + ",\"mc\":" + int_to_string(mc) + ",\"le\":" + int_to_string(le) + ",\"sd\":" + int_to_string(sd) + "}";

// Convert JSONL log content to JSON array (each non-empty line is one array element)
fn sl_lines_to_array(log_src: String, pos: i64, sb: i64, isfirst: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= log_src.len() { 0 }

    else {

        let nl = find_char_from(log_src, pos, 10);

        let line_end = if nl >= log_src.len() { log_src.len() } else { nl };

        let line = log_src.slice(pos, line_end);

        if line.len() > 2 {

            let _sep = if isfirst > 0 { 0 } else { sb_push(sb, ",") };

            let _e = sb_push(sb, line);

            if nl >= log_src.len() { 0 }

            else { sl_lines_to_array(log_src, nl + 1, sb, 0) }

        } else {

            if nl >= log_src.len() { 0 }

            else { sl_lines_to_array(log_src, nl + 1, sb, isfirst) }

        }

    };

// Main session-log logic: runs diagnose, appends to log file, outputs JSON
fn sl_build_output(input: String, updated_log: String, cur_entry: String) -> i64

  post it == 0

= let out_sb = sb_new();

    let _h1 = sb_push(out_sb, "{\"type\":\"session_log\",\"file\":\"");

    let _h2 = sb_push(out_sb, json_esc(input));

    let _h3 = sb_push(out_sb, "\",\"rounds\":[");

    let _scan = sl_lines_to_array(updated_log, 0, out_sb, 1);

    let _h4 = sb_push(out_sb, "],\"current\":" + cur_entry + "}");

    let _p = println_str(sb_build(out_sb));

    0;

fn session_log_run(input: String, src: String) -> i64

  post it >= 0

= {

    let log_path = input + ".session-log";

    let entries = callers_collect_source(src, 0, "");

    let eff_map = build_fn_effect_map(src, 0, "");

    let transitive_map = build_full_transitive_effect_map(entries, eff_map, 5);

    let ev_json = eff_verify_build_json(input, entries, eff_map, transitive_map);

    let contracts_src = read_file(".bmb-contracts");

    let contracts = if contracts_src.len() > 0 { bc_parse_contracts(contracts_src, 0, "") } else { "" };

    let cc_json = cc_build_json(input, src, entries, eff_map, transitive_map, contracts);

    let mc_json = mc_build_json(input, src, entries, transitive_map, contracts);

    let le_json = lint_effects_build_json(input, entries, eff_map, transitive_map);

    let sd_json = semdp_build_json(input, entries);

    let ev_count = json_extract_int_field(ev_json, "violations_count");

    let cc_count = json_extract_int_field(cc_json, "violations_count");

    let mc_count = json_extract_int_field(mc_json, "total_violations");

    let le_count = json_extract_int_field(le_json, "count");

    let sd_count = json_extract_int_field(sd_json, "pairs_count");

    let total = ev_count + cc_count + mc_count + le_count + sd_count;

    let log_src = read_file(log_path);

    let round = sl_count_rounds(log_src) + 1;

    let ts = time_ns() / ns_per_ms();

    let entry = sl_build_entry(round, ts, total, ev_count, cc_count, mc_count, le_count, sd_count);

    let updated_log = log_src + entry + "\n";

    let _w = write_file(log_path, updated_log);

    sl_build_output(input, updated_log, entry)

};

fn session_log_file(input: String) -> i64

  post it >= 0

= let src = read_file(input);

    if src.len() == 0 { err_no_file(input) }

    else { session_log_run(input, src) };

fn main() -> i64

  post it >= 0

= let _arena = arena_mode(1);

    let argc = arg_count();

    if argc < 2 { show_help() } else {

        let cmd = get_arg(1);

        if cmd == "--version" or cmd == "version" {

            if argc >= 3 and get_arg(2) == "--json" {

                println_str("{\"compiler\":\"bmb\",\"version\":\"0.96.30\",\"variant\":\"bootstrap\",\"backend\":\"llvm-text\"}")

            } else { println_str("BMB Bootstrap Compiler v0.96.30") };

            0

        } else if cmd == "--help" or cmd == "help" { show_help() }

        else if cmd == "run" or cmd == "build" or cmd == "emit-ir" or cmd == "check" or cmd == "fmt" or cmd == "lint" or cmd == "test" or cmd == "repl" {

            main_cmd_build(cmd, argc)

        } else if cmd == "index" or cmd == "query" or cmd == "callers" or cmd == "deps" or cmd == "context" or cmd == "outline" or cmd == "xref" or cmd == "impact" or cmd == "stats" or cmd == "unused" or cmd == "complexity" or cmd == "similar" or cmd == "layers" or cmd == "hotspots" or cmd == "changelog" {

            main_cmd_analysis_a(cmd, argc)

        } else if cmd == "body" or cmd == "scope" or cmd == "suggest" or cmd == "interface" or cmd == "chain" or cmd == "inline-candidates" or cmd == "split-candidates" or cmd == "graph" or cmd == "siblings" or cmd == "summary" or cmd == "clusters" or cmd == "rename-check" or cmd == "coverage" or cmd == "pattern" or cmd == "export" or cmd == "diff-calls" or cmd == "classify" {

            main_cmd_analysis_b(cmd, argc)

        } else if cmd == "repair-hint" or cmd == "verify-repair" or cmd == "diagnose" or cmd == "effect-verify" or cmd == "contracts-check" or cmd == "semantic-duplicate" or cmd == "module-suggest" or cmd == "session-log" or cmd == "verify-vc" {

            main_cmd_ai(cmd, argc)

        } else if argc >= 3 { compile_file_to(get_arg(1), get_arg(2)) }

        else { show_help() }

    };

fn main_cmd_build(cmd: String, argc: i64) -> i64

  pre argc >= 2

  post it >= 0

= if cmd == "run" and argc >= 3 {

        let runtime = parse_build_runtime(argc);

        run_file(get_arg(2), runtime)

    } else if cmd == "build" and argc >= 3 {

        let input = get_arg(2);

        let output = parse_build_output(argc, input);

        let fast = parse_build_fast(argc);

        let runtime = parse_build_runtime(argc);

        let stats = check_arg_flag(argc, 3, "--stats");

        let safe = if check_arg_flag(argc, 3, "--safe") { 1 } else { 0 };

        build_file_ex(input, output, fast, runtime, stats, safe)

    } else if cmd == "emit-ir" and argc >= 4 {

        emit_ir(get_arg(2), get_arg(3))

    } else if cmd == "emit-ir" and argc >= 3 {

        let input = get_arg(2);

        let output = if input.len() > 4 and input.slice(input.len() - 4, input.len()) == ".bmb" {

            input.slice(0, input.len() - 4) + ".ll"

        } else { input + ".ll" };

        emit_ir(input, output)

    } else if cmd == "check" and argc >= 3 { check_entry(get_arg(2)) }

    else if cmd == "fmt" and argc >= 3 {

        let check = argc >= 4 and get_arg(3) == "--check";

        fmt_entry(get_arg(2), check)

    } else if cmd == "lint" and argc >= 3 { lint_entry(get_arg(2)) }

    else if cmd == "test" and argc >= 3 {

        let runtime = parse_build_runtime(argc);

        test_entry(get_arg(2), runtime)

    } else {

        let runtime = parse_build_runtime(argc);

        repl_start(runtime)

    };

fn main_cmd_analysis_a(cmd: String, argc: i64) -> i64

  pre argc >= 2

  post it >= 0

= if cmd == "index" and argc >= 3 { index_file(get_arg(2)) }

    else if cmd == "query" and argc >= 4 { query_file(get_arg(2), get_arg(3)) }

    else if cmd == "callers" and argc >= 4 { callers_file(get_arg(2), get_arg(3)) }

    else if cmd == "deps" and argc >= 4 { deps_file(get_arg(2), get_arg(3)) }

    else if cmd == "context" and argc >= 4 { context_file(get_arg(2), get_arg(3)) }

    else if cmd == "outline" and argc >= 3 { outline_file(get_arg(2)) }

    else if cmd == "xref" and argc >= 4 { xref_file(get_arg(2), get_arg(3)) }

    else if cmd == "impact" and argc >= 4 { impact_file(get_arg(2), get_arg(3)) }

    else if cmd == "stats" and argc >= 3 { stats_file(get_arg(2)) }

    else if cmd == "unused" and argc >= 3 { unused_file(get_arg(2)) }

    else if cmd == "complexity" and argc >= 3 { complexity_file(get_arg(2)) }

    else if cmd == "similar" and argc >= 4 { similar_file(get_arg(2), get_arg(3)) }

    else if cmd == "layers" and argc >= 3 { layers_file(get_arg(2)) }

    else if cmd == "hotspots" and argc >= 3 { hotspots_file(get_arg(2)) }

    else { changelog_file(get_arg(2), get_arg(3)) };


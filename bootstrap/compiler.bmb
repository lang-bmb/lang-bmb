  post it == 2000000000 + 900

= 2000000000 + 900;

// v0.96: Token kind to human-readable name for error messages

fn tok_kind_name(kind: i64) -> String

  pre kind >= 0

  post it.len() >= 1

= if kind == TK_IDENT() { "identifier" }
    else if kind == TK_STRING_LIT() { "string literal" }
    else if kind == TK_FLOAT_LIT() { "float literal" }
    else if kind == TK_CHAR_LIT() { "char literal" }
    else if kind == TK_COLON() { "':'" }
    else if kind == TK_EQ() { "'='" }
    else if kind == TK_SEMI() { "';'" }
    else if kind == TK_COMMA() { "','" }
    else if kind == TK_LPAREN() { "'('" }
    else if kind == TK_RPAREN() { "')'" }
    else if kind == TK_LBRACE() { "'{'" }
    else if kind == TK_RBRACE() { "'}'" }
    else if kind == TK_LBRACKET() { "'['" }
    else if kind == TK_RBRACKET() { "']'" }
    else if kind == TK_ARROW() { "'->'" }
    else if kind == TK_DOT() { "'.'" }
    else if kind == TK_DOTDOT() { "'..'" }
    else if kind == TK_FAT_ARROW() { "'=>'" }
    else { tok_kind_name_op(kind) };

fn tok_kind_name_op(kind: i64) -> String

  pre kind >= 0

  post it.len() >= 1

= if kind == TK_PLUS() { "'+'" }
    else if kind == TK_MINUS() { "'-'" }
    else if kind == TK_STAR() { "'*'" }
    else if kind == TK_SLASH() { "'/'" }
    else if kind == TK_PERCENT() { "'%'" }
    else if kind == TK_LT() { "'<'" }
    else if kind == TK_GT() { "'>'" }
    else if kind == TK_EQEQ() { "'=='" }
    else if kind == TK_NEQ() { "'!='" }
    else if kind == TK_PIPE() { "'|'" }
    else if kind == TK_CARET() { "'^'" }
    else if kind == TK_DCOLON() { "'::'" }
    else if kind == TK_EOF() { "end of file" }
    else { "integer literal" };

// ============================================================================

// SECTION 3: Lexer (from pipeline.bmb)

// ============================================================================

fn skip_to_eol(s: String, pos: i64) -> i64

    post it >= 0

= if pos >= s.len() { pos } else if s.byte_at(pos) == 10 { pos + 1 } else { skip_to_eol(s, pos + 1) };

// v0.46: Support both -- (legacy) and // (v0.32) comment styles

fn skip_comment(s: String, pos: i64) -> i64

    post it >= 0

= if pos + 1 < s.len() and s.byte_at(pos) == 45 and s.byte_at(pos + 1) == 45 { skip_comment(s, skip_to_eol(s, pos + 2)) }

    else if pos + 1 < s.len() and s.byte_at(pos) == 47 and s.byte_at(pos + 1) == 47 { skip_comment(s, skip_to_eol(s, pos + 2)) }

    else if pos + 1 < s.len() and s.byte_at(pos) == 47 and s.byte_at(pos + 1) == 42 { skip_comment(s, skip_block_comment(s, pos + 2)) }

    else { pos };

// Skip block comment: find */ (byte 42 + byte 47)

fn skip_block_comment(s: String, pos: i64) -> i64

    post it >= 0

= if pos + 1 >= s.len() { s.len() }

    else if s.byte_at(pos) == 42 and s.byte_at(pos + 1) == 47 { pos + 2 }

    else { skip_block_comment(s, pos + 1) };

fn skip_ws_comments(s: String, pos: i64) -> i64

  pre pos >= 0

  post it >= pos

= let p1 = skip_ws(s, pos);

    let p2 = skip_comment(s, p1);

    if p2 == p1 { p1 } else { skip_ws_comments(s, p2) };

// Actual value is reconstructed from source text in parse_int_lit

// Cycle 2711 (M5-bootstrap): scale 1e6 -> 5e6 to support source > 1MB

// Safe max: 1.844e12 * 5e6 = 9.22e18 < i64 MAX (9.22e18)

fn scan_int(s: String, pos: i64, acc: i64) -> i64

  pre pos >= 0 and acc >= 0

  post it >= 0

= if pos >= s.len() { pack_int_tok(acc, pos) } else {

        let c = s.byte_at(pos);

        if is_digit(c) {

            let new_acc = if acc < int_parse_max() { acc * 10 + (c - 48) } else { int_overflow_val() };

            scan_int(s, pos + 1, new_acc)

        } else if c == 95 { scan_int(s, pos + 1, acc) }

        else { pack_int_tok(acc, pos) }

    };

fn pack_int_tok(acc: i64, pos: i64) -> i64

  pre acc >= 0 and pos >= 0

  post it >= 0

= if acc >= int_parse_max() { int_overflow_val() * tok_pack_mul() + pos }

    else { acc * tok_pack_mul() + pos };

// v0.91: Scan number - detects float if '.' followed by digit

fn scan_hex_int(s: String, pos: i64, acc: i64) -> i64

  pre pos >= 0 and acc >= 0

  post it >= 0

= if pos >= s.len() { pack_int_tok(acc, pos) } else {

        let c = s.byte_at(pos);

        if is_hex_digit(c) {

            let new_acc = if acc < int_parse_max() { acc * 16 + hex_digit_val(c) } else { int_overflow_val() };

            scan_hex_int(s, pos + 1, new_acc)

        } else if c == 95 { scan_hex_int(s, pos + 1, acc) }

        else { pack_int_tok(acc, pos) }

    };

fn scan_bin_int(s: String, pos: i64, acc: i64) -> i64

  pre pos >= 0 and acc >= 0

  post it >= 0

= if pos >= s.len() { pack_int_tok(acc, pos) } else {

        let c = s.byte_at(pos);

        if c == 48 or c == 49 {

            let new_acc = if acc < int_parse_max() { acc * 2 + (c - 48) } else { int_overflow_val() };

            scan_bin_int(s, pos + 1, new_acc)

        } else if c == 95 { scan_bin_int(s, pos + 1, acc) }

        else { pack_int_tok(acc, pos) }

    };

// v0.95: Scan octal integer literal (0o...)

fn scan_oct_int(s: String, pos: i64, acc: i64) -> i64

  pre pos >= 0 and acc >= 0

  post it >= 0

= if pos >= s.len() { pack_int_tok(acc, pos) } else {

        let c = s.byte_at(pos);

        if c >= 48 and c <= 55 {

            let new_acc = if acc < int_parse_max() { acc * 8 + (c - 48) } else { int_overflow_val() };

            scan_oct_int(s, pos + 1, new_acc)

        } else if c == 95 { scan_oct_int(s, pos + 1, acc) }

        else { pack_int_tok(acc, pos) }

    };

// Returns packed int token OR TK_FLOAT_LIT token

fn scan_number(s: String, pos: i64) -> i64

    post it >= 0

= if pos + 1 < s.len() and s.byte_at(pos) == 48 and (s.byte_at(pos + 1) == 120 or s.byte_at(pos + 1) == 88) {

        scan_hex_int(s, pos + 2, 0)

    } else if pos + 1 < s.len() and s.byte_at(pos) == 48 and (s.byte_at(pos + 1) == 98 or s.byte_at(pos + 1) == 66) {

        scan_bin_int(s, pos + 2, 0)

    } else if pos + 1 < s.len() and s.byte_at(pos) == 48 and (s.byte_at(pos + 1) == 111 or s.byte_at(pos + 1) == 79) {

        scan_oct_int(s, pos + 2, 0)

    } else {

        let int_result = scan_int(s, pos, 0);

        let int_end = tok_end(int_result);

        // Check for '.' followed by digit (float literal)

        if int_end + 1 < s.len() and s.byte_at(int_end) == 46 and is_digit(s.byte_at(int_end + 1)) {

            let frac_end = scan_digits_end(s, int_end + 1);

            let exp_end = scan_exponent(s, frac_end);

            make_tok(TK_FLOAT_LIT(), exp_end)

        } else { int_result }

    };

// v0.91: Scan digits to end (helper for float fractional part)

fn scan_digits_end(s: String, pos: i64) -> i64

  pre pos >= 0

  post it >= pos

= if pos >= s.len() { pos } else if is_digit(s.byte_at(pos)) { scan_digits_end(s, pos + 1) } else { pos };

fn scan_exponent(s: String, pos: i64) -> i64

  pre pos >= 0

  post it >= pos

= if pos >= s.len() { pos }

    else if s.byte_at(pos) == 101 or s.byte_at(pos) == 69 {

        // 'e' (101) or 'E' (69)

        let after_e = pos + 1;

        if after_e >= s.len() { pos }

        else {

            let sign_end = if s.byte_at(after_e) == 43 or s.byte_at(after_e) == 45 { after_e + 1 } else { after_e };

            if sign_end >= s.len() { pos }

            else if is_digit(s.byte_at(sign_end)) { scan_digits_end(s, sign_end) }

            else { pos }

        }

    } else { pos };

fn scan_ident_end(s: String, pos: i64) -> i64

  pre pos >= 0

  post it >= pos

= if pos >= s.len() { pos } else if is_alnum_or_underscore(s.byte_at(pos)) { scan_ident_end(s, pos + 1) } else { pos };

// Returns position after closing quote, or s.len() if not found

fn scan_string_end(s: String, pos: i64) -> i64

  pre pos >= 0

  post it >= pos

= if pos >= s.len() { s.len() }

    else if s.byte_at(pos) == 92 and pos + 1 < s.len() { scan_string_end(s, pos + 2) }

    else if s.byte_at(pos) == 34 { pos + 1 }

    else { scan_string_end(s, pos + 1) };

// Char literal scanner: expects pos right after opening quote

// Handles: 'a', '\n', '\t', '\r', '\\', '\0', '\''

fn scan_char_end(s: String, pos: i64) -> i64

  pre pos >= 0

  post it >= pos

= if pos >= s.len() { s.len() }

    else if s.byte_at(pos) == 92 { pos + 3 }

    else { pos + 2 };

// Get the ASCII value of a char literal (pos points to opening quote)

fn get_char_value(s: String, pos: i64) -> i64

  pre pos >= 0

  post it >= 0

= let p = skip_ws_comments(s, pos);

    let inner = p + 1;

    if inner < s.len() and s.byte_at(inner) == 92 {

        // Escape sequence

        let esc = s.byte_at(inner + 1);

        match esc { 110 => 10, 116 => 9, 114 => 13, 48 => 0, 92 => 92, 39 => 39, _ => esc }

    } else {

        s.byte_at(inner)

    };

fn tok_val(r: i64) -> i64

  pre r >= 0

  post it >= 0

= r / tok_pack_mul();

fn tok_end(r: i64) -> i64

  pre r >= 0

  post it >= 0 and it < 5000000

= r - (r / tok_pack_mul()) * tok_pack_mul();

fn tok_kind(r: i64) -> i64

  pre r >= 0

  post it >= 0

= tok_val(r);

fn make_tok(kind: i64, endpos: i64) -> i64

  pre kind >= 0 and endpos >= 0 and endpos < 5000000

  post it >= 0

= kind * tok_pack_mul() + endpos;

// Reduces average comparisons from 9.5 to ~2-3 by checking length first

fn keyword_or_ident(s: String, start: i64, endpos: i64) -> i64

    pre start >= 0

    post it >= 0

= 

    let word = s.slice(start, endpos);

    let len = endpos - start;

    match len { 2 => keyword_len2(word, endpos), 3 => keyword_len3(word, endpos), 4 => keyword_len4(word, endpos), 5 => keyword_len5(word, endpos), 6 => keyword_len6(word, endpos), 7 => keyword_len7(word, endpos), 8 => keyword_len8(word, endpos), 10 => keyword_len10(word, endpos), _ => make_tok(TK_IDENT(), endpos) };

fn keyword_len2(word: String, endpos: i64) -> i64

    pre endpos >= 0

    post it >= 0

= 

    match word { "fn" => make_tok(TK_FN(), endpos), "if" => make_tok(TK_IF(), endpos), "or" => make_tok(TK_OR(), endpos), "in" => make_tok(TK_IN(), endpos), "as" => make_tok(TK_AS(), endpos), _ => make_tok(TK_IDENT(), endpos) };

fn keyword_len3(word: String, endpos: i64) -> i64

    pre endpos >= 0

    post it >= 0

= 

    match word { "let" => make_tok(TK_LET(), endpos), "and" => make_tok(TK_AND(), endpos), "not" => make_tok(TK_NOT(), endpos), "pre" => make_tok(TK_PRE(), endpos), "mut" => make_tok(TK_MUT(), endpos), "for" => make_tok(TK_FOR(), endpos), "i32" => make_tok(TK_I32(), endpos), "i64" => make_tok(TK_I64(), endpos), "f64" => make_tok(TK_F64(), endpos), "bor" => make_tok(TK_BOR(), endpos), "set" => make_tok(TK_SET(), endpos), "pub" => make_tok(TK_PUB(), endpos), _ => make_tok(TK_IDENT(), endpos) };

fn keyword_len4(word: String, endpos: i64) -> i64

    pre endpos >= 0

    post it >= 0

= 

    match word { "then" => make_tok(TK_THEN(), endpos), "else" => make_tok(TK_ELSE(), endpos), "true" => make_tok(TK_TRUE(), endpos), "bool" => make_tok(TK_BOOL(), endpos), "post" => make_tok(TK_POST(), endpos), "band" => make_tok(TK_BAND(), endpos), "bnot" => make_tok(TK_BNOT(), endpos), "null" => make_tok(TK_NULL(), endpos), "bxor" => make_tok(TK_BXOR(), endpos), "loop" => make_tok(TK_LOOP(), endpos), "type" => make_tok(TK_TYPE(), endpos), "enum" => make_tok(TK_ENUM(), endpos), "impl" => make_tok(TK_IMPL(), endpos), _ => make_tok(TK_IDENT(), endpos) };

fn keyword_len5(word: String, endpos: i64) -> i64

    pre endpos >= 0

    post it >= 0

= 

    match word { "false" => make_tok(TK_FALSE(), endpos), "while" => make_tok(TK_WHILE(), endpos), "break" => make_tok(TK_BREAK(), endpos), "const" => make_tok(TK_CONST(), endpos), "trait" => make_tok(TK_TRAIT(), endpos), "where" => make_tok(TK_WHERE(), endpos), "async" => make_tok(TK_ASYNC(), endpos), "await" => make_tok(TK_AWAIT(), endpos), "Mutex" => make_tok(TK_MUTEX(), endpos), "Scope" => make_tok(TK_SCOPE(), endpos), "match" => make_tok(TK_MATCH(), endpos), _ => make_tok(TK_IDENT(), endpos) };

fn keyword_len6(word: String, endpos: i64) -> i64

    pre endpos >= 0

    post it >= 0

= 

    match word { "String" => make_tok(TK_STRING_TYPE(), endpos), "select" => make_tok(TK_SELECT(), endpos), "Future" => make_tok(TK_FUTURE(), endpos), "Atomic" => make_tok(TK_ATOMIC(), endpos), "Sender" => make_tok(TK_SENDER(), endpos), "RwLock" => make_tok(TK_RWLOCK(), endpos), "struct" => make_tok(TK_STRUCT(), endpos), "extern" => make_tok(TK_EXTERN(), endpos), "return" => make_tok(TK_RETURN(), endpos), _ => make_tok(TK_IDENT(), endpos) };

// v0.88: Concurrency type keywords

fn keyword_len7(word: String, endpos: i64) -> i64

    pre endpos >= 0

    post it >= 0

= 

    if word == "Channel" { make_tok(TK_CHANNEL(), endpos) }

    else if word == "implies" { make_tok(TK_OR(), endpos) }

    else { make_tok(TK_IDENT(), endpos) };

fn keyword_len8(word: String, endpos: i64) -> i64

    pre endpos >= 0

    post it >= 0

= 

    if word == "continue" { make_tok(TK_CONTINUE(), endpos) }  // v0.90.31

    else if word == "Receiver" { make_tok(TK_RECEIVER(), endpos) }

    else { make_tok(TK_IDENT(), endpos) };

fn keyword_len10(word: String, endpos: i64) -> i64

    pre endpos >= 0

    post it >= 0

= 

    if word == "ThreadPool" { make_tok(TK_THREADPOOL(), endpos) }

    else { make_tok(TK_IDENT(), endpos) };

fn next_token_raw(s: String, pos: i64) -> i64

  pre pos >= 0

  post it >= 0

= let p = skip_ws_comments(s, pos);

    if p >= s.len() { make_tok(TK_EOF(), p) } else {

        let c = s.byte_at(p);

        if is_digit(c) { scan_number(s, p) }

        else if is_ident_start(c) {

            let ident_end = scan_ident_end(s, p + 1);

            keyword_or_ident(s, p, ident_end)

        } else if c == 34 or c == 39 { next_token_str_char(c, s, p) }

        else if c == 43 or c == 45 or c == 42 or c == 47 or c == 37 { next_token_arith(c, s, p) }

        else if c == 60 or c == 62 or c == 33 or c == 46 { next_token_cmp(c, s, p) }

        else { next_token_sym(c, s, p) }

    };

fn next_token_str_char(c: i64, s: String, p: i64) -> i64

  pre p >= 0

  post it >= 0

= if c == 34 {


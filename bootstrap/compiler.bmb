fn emit_fn_hint(fname: String, pctexts: String, qctexts: String,
    meta: String, sb: i64, isfirst: i64) -> i64

  post it == 0

= let _sep = if isfirst > 0 { 0 } else { sb_push(sb, ",") };

    let _o1 = sb_push(sb, "{\"name\":\"");

    let _n1 = sb_push(sb, json_esc(fname));

    let _c1 = sb_push(sb, "\"");

    let meta_tab = str_find(meta, "\t");

    let intent_txt = if meta_tab < 0 { meta } else { meta.slice(0, meta_tab) };

    let eff_txt = if meta_tab < 0 { "" } else { meta.slice(meta_tab + 1, meta.len()) };

    let _eff = if eff_txt != "" {

        let _a = sb_push(sb, ",\"effect\":\"");

        let _b = sb_push(sb, json_esc(eff_txt));

        sb_push(sb, "\"")

    } else { 0 };

    let _int = if intent_txt != "" {

        let _a = sb_push(sb, ",\"intent\":\"");

        let _b = sb_push(sb, json_esc(intent_txt));

        sb_push(sb, "\"")

    } else { 0 };

    let _pci = if pctexts != "" {

        let _a = sb_push(sb, ",\"pre\":[");

        let _b = emit_contract_json(pctexts, sb, 0);

        sb_push(sb, "]")

    } else { 0 };

    let _qci = if qctexts != "" {

        let _a = sb_push(sb, ",\"post\":[");

        let _b = emit_contract_json(qctexts, sb, 0);

        sb_push(sb, "]")

    } else { 0 };

    let _fin = sb_push(sb, "}");

    0;

// M13 Phase 3: Scan source, emit repair hints for contracted functions
fn repair_hint_scan(src: String, scanpos: i64, sb: i64, isfirst: i64) -> i64

  pre scanpos >= 0

  post it >= 0

= let fn_pos = find_pattern_noa(src, "fn ", scanpos);

    if fn_pos < 0 { 0 }

    else {

        let is_real = if fn_pos == 0 { true }

                      else { let prev = src.byte_at(fn_pos - 1); prev == 10 or prev == 13 or prev == 32 or prev == 59 or prev == 9 };

        if is_real {

            let ns = skip_ws_comments(src, fn_pos + 3);

            let ne = scan_ident_end(src, ns);

            let fname = src.slice(ns, ne);

            if fname != "" and ne > ns {

                let t2 = next_token_raw(src, ne);

                let after_gen = if tok_kind(t2) == TK_LT() { skip_generic_params(src, tok_end(t2)) } else { ne };

                let t2g = next_token_raw(src, after_gen);

                if tok_kind(t2g) == TK_LPAREN() {

                    let prams_r = index_collect_params(src, tok_end(t2g), "");

                    let after_rp = unpack_pos(prams_r);

                    let rtype_r = index_read_ret_type(src, after_rp);

                    let rp = unpack_pos(rtype_r);

                    let eff_r = scan_fn_effect_entry(src, fn_pos + 3);

                    let eff_entry = unpack_ast(eff_r);

                    let eff_txt = if eff_entry == "" { "" }

                                  else {

                                      let tab = str_find(eff_entry, "\t");

                                      if tab >= 0 { eff_entry.slice(tab + 1, eff_entry.len()) } else { "" }

                                  };

                    let pctexts = extract_pre_texts(src, rp);

                    let qctexts = extract_post_texts(src, rp);

                    let intent_txt = extract_intent_tok(src, rp);

                    let has_c = pctexts != "" or qctexts != "" or intent_txt != "";

                    let newisfirst = if has_c {

                        let meta_str = intent_txt + "\t" + eff_txt;

                        let _e = emit_fn_hint(fname, pctexts, qctexts, meta_str, sb, isfirst);

                        0

                    } else { isfirst };

                    repair_hint_scan(src, fn_pos + 3, sb, newisfirst)

                } else { repair_hint_scan(src, fn_pos + 3, sb, isfirst) }

            } else { repair_hint_scan(src, fn_pos + 3, sb, isfirst) }

        } else { repair_hint_scan(src, fn_pos + 3, sb, isfirst) }

    };

// M13 Phase 3: JSON escape helper
fn json_esc_sb(s: String, pos: i64, sb: i64) -> i64

  pre pos >= 0

  post it == 0

= if pos >= s.len() { 0 }

    else {

        let ch = s.byte_at(pos);

        let _p = match ch { 34 => let _a = sb_push_char(sb, 92); sb_push_char(sb, 34),
            92 => let _a = sb_push_char(sb, 92); sb_push_char(sb, 92),
            10 => let _a = sb_push_char(sb, 92); sb_push_char(sb, 110),
            _ => sb_push_char(sb, ch) };

        json_esc_sb(s, pos + 1, sb)

    };

fn json_esc(s: String) -> String


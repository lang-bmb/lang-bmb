    else { lint_file(input) };

// ===================================================================

// REPL - Read-Eval-Print Loop (v0.96.3)

// Compile-and-run approach: each expression compiled to native + executed

// ===================================================================

fn repl_help() -> i64

  post it >= 0

= {

    println_str("BMB REPL Commands:");

    println_str("  :help, :h, :?   Show this help");

    println_str("  :quit, :q       Exit the REPL");

    println_str("");

    println_str("Enter BMB expressions to evaluate:");

    println_str("  1 + 2                           Arithmetic");

    println_str("  if 3 > 2 { 1 } else { 0 }      Conditionals");

    println_str("  let x = 5; x * x                Let bindings");

    0

};

// Try to compile an expression, returning IR or error

// Heuristic: if starts with " it's likely a string expression

fn repl_try_compile(line: String) -> String

  post it.len() >= 1

= let dq = chr(34);

    let is_str = line.len() > 0 and line.slice(0, 1) == dq;

    if is_str {

        repl_try_str_first(line, dq)

    } else {

        repl_try_int_first(line, dq)

    };

fn repl_try_int_first(line: String, dq: String) -> String

  post it.len() >= 1

= // Strategy 1: wrap as print(expr) to show i64 result

    let src1 = "fn main() -> i64 = let _r = print(" + line + "); let _nl = println_str(" + dq + dq + "); 0;";

    let llvm1 = compile_program(src1, 0);

    if is_compile_error(llvm1) {

        // Strategy 2: wrap as println_str(expr) to show String result

        let src2 = "fn main() -> i64 = let _r = println_str(" + line + "); 0;";

        let llvm2 = compile_program(src2, 0);

        if is_compile_error(llvm2) { repl_try_fallback(line) }

        else { llvm2 }

    } else { llvm1 };

fn repl_try_str_first(line: String, dq: String) -> String

  post it.len() >= 1

= // Strategy 1: wrap as println_str(expr) for String result

    let src1 = "fn main() -> i64 = let _r = println_str(" + line + "); 0;";

    let llvm1 = compile_program(src1, 0);

    if is_compile_error(llvm1) {

        // Strategy 2: wrap as print(expr) for i64 result

        let src2 = "fn main() -> i64 = let _r = print(" + line + "); let _nl = println_str(" + dq + dq + "); 0;";

        let llvm2 = compile_program(src2, 0);

        if is_compile_error(llvm2) { repl_try_fallback(line) }

        else { llvm2 }

    } else { llvm1 };

fn repl_try_fallback(line: String) -> String

  post it.len() >= 1

= // Strategy A: wrap as statement (for void/side-effect expressions)

    let src1 = "fn main() -> i64 = let _r = " + line + "; 0;";

    let llvm1 = compile_program(src1, 0);

    if is_compile_error(llvm1) {

        // Strategy B: try as full program (fn definitions etc)

        compile_program(line, 0)

    } else { llvm1 };

// Compile IR to executable, run it, clean up

fn repl_run_ir(llvm: String, runtime: String) -> i64

  post it >= 0

=

    let ir_file = "__repl_tmp.ll";

    let exe = "__repl_tmp.exe";

    let _w = write_file_newlines(ir_file, llvm);

    let runtime_lib = runtime + "/libbmb_runtime.a";

    let link_cmd = "clang -w -O0 " + ir_file + " " + runtime_lib + " -o " + exe + " -lm -lws2_32";

    let lr = system(link_cmd);

    if lr != 0 {

        let link_cmd2 = "clang -w -O0 " + ir_file + " " + runtime_lib + " -o " + exe + " -lm -lpthread";

        let lr2 = system(link_cmd2);

        if lr2 != 0 {

            { println_str("Error: linking failed"); 1 }

        } else {

            repl_exec(exe)

        }

    } else {

        repl_exec(exe)

    };

fn repl_exec(exe: String) -> i64

  post it >= 0

=

    let cmd = "." + chr(92) + exe;

    let _r = system(cmd);

    0;

// Evaluate a single line of input

fn repl_eval(line: String, runtime: String) -> i64

  post it >= 0

=

    let llvm = repl_try_compile(line);

    if is_compile_error(llvm) {

        let _e = { println_str("Error: could not compile expression"); 0 };

        1

    } else {

        repl_run_ir(llvm, runtime)

    };

// Main REPL loop (recursive)

fn repl_loop_inner(runtime: String) -> i64

  post it >= 0

=

    let _p = print_str("> ");

    let line = read_line();

    if line == "__EOF__" {

        { println_str(""); println_str("Goodbye!"); 0 }

    } else if line.len() == 0 {

        repl_loop_inner(runtime)

    } else if line == ":quit" or line == ":q" or line == ":exit" {

        { println_str("Goodbye!"); 0 }

    } else if line == ":help" or line == ":h" or line == ":?" {

        let _h = repl_help();

        repl_loop_inner(runtime)

    } else {

        let _r = repl_eval(line, runtime);

        repl_loop_inner(runtime)

    };

fn repl_start(runtime: String) -> i64

  post it >= 0

= {

    println_str("BMB REPL v0.96.5");

    println_str("Type :help for help, :quit to exit.");

    println_str("");

    repl_loop_inner(runtime)

};

// v0.96.3: Test command - compile, run, and compare output against .bmb.out

fn test_file(input: String, runtime_path: String) -> i64

  post it >= 0

=

    let source = load_source(input);

    if source.len() == 0 {

        err_no_file(input)

    } else {

        let expected_file = input + ".out";

        let expected = read_file(expected_file);

        if expected.len() == 0 {

            { let _r10 = print_str("SKIP: no expected output: "); println_str(expected_file); 0 }

        } else {

            let llvm = compile_program(source, 0);

            if is_compile_error(llvm) {

                { let _r11 = print_str("FAIL: "); let _r12 = print_compile_err(input, llvm); 1 }

            } else {

                let exe = "__bmb_test_tmp.exe";

                let ir_file = "__bmb_test_tmp.ll";

                let _w = write_file_newlines(ir_file, llvm);

                let runtime_lib = runtime_path + "/libbmb_runtime.a";

                let out_file = "__bmb_test_tmp.txt";

                let link_cmd = "clang -w -O2 " + ir_file + " " + runtime_lib + " -o " + exe + " -lm -lws2_32";

                let lr = system(link_cmd);

                let link_ok = if lr != 0 {

                    let link_cmd2 = "clang -w -O2 " + ir_file + " " + runtime_lib + " -o " + exe + " -lm -lpthread";

                    let lr2 = system(link_cmd2);

                    if lr2 != 0 { 0 } else { 1 }

                } else { 1 };

                if link_ok == 0 {

                    let _c1 = remove_file(ir_file);

                    { let _r13 = print_str("FAIL: linking failed: "); println_str(input); 1 }

                } else {

                    let bs = chr(92);

                    let run_cmd = "." + bs + exe + " > " + out_file + " 2>&1";

                    let _r = system(run_cmd);

                    let actual = read_file(out_file);

                    let _c1 = remove_file(ir_file);

                    let _c2 = remove_file(exe);

                    let _c3 = remove_file(out_file);

                    let pass = compare_test_output(expected, actual);

                    if pass {

                        { let _r14 = print_str("PASS: "); println_str(input); 0 }

                    } else {

                        { let _r15 = print_str("FAIL: "); println_str(input);

                          let _r16 = print_str("  expected: "); println_str(trim_trailing_newlines(expected));

                          let _r17 = print_str("  actual:   "); println_str(trim_trailing_newlines(actual)); 1 }

                    }

                }

            }

        }

    };

// Compare test output: strip CR (Windows CRLF -> LF) + trim trailing newlines

fn compare_test_output(expected: String, actual: String) -> bool

  post it == (trim_trailing_newlines(strip_cr(expected)) == trim_trailing_newlines(strip_cr(actual)))

= let norm_exp = trim_trailing_newlines(strip_cr(expected));

    let norm_act = trim_trailing_newlines(strip_cr(actual));

    norm_exp == norm_act;

// Strip all carriage return (CR, byte 13) characters from a string

// Chunk-based: copy segments between \r characters (avoids per-byte recursion)

fn strip_cr(s: String) -> String

  post it.len() <= s.len()

= let cr_pos = find_char(s, 0, 13);

    if cr_pos >= s.len() { s }

    else {

        let sb = sb_new();

        let _w = strip_cr_chunks(s, 0, sb);

        let result = sb_build(sb);

        let _f = sb_free(sb);

        result

    };

fn strip_cr_chunks(s: String, pos: i64, sb: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= s.len() { 0 }

    else {

        let cr = find_char(s, pos, 13);

        let chunk_end = if cr >= s.len() { s.len() } else { cr };

        let _w = if chunk_end > pos { sb_push(sb, s.slice(pos, chunk_end)) } else { 0 };

        if cr >= s.len() { 0 }

        else { strip_cr_chunks(s, cr + 1, sb) }

    };

fn trim_trailing_newlines(s: String) -> String

  post it.len() <= s.len()

= if s.len() == 0 { s }

    else {

        let last = s.byte_at(s.len() - 1);

        if last == 10 or last == 13 { trim_trailing_newlines(s.slice(0, s.len() - 1)) }

        else { s }

    };

// v0.96.3: Batch test - run all .bmb files in a directory


    else if fn_name == "@malloc" { "i" }
    else if fn_name == "@calloc" { "ii" }
    else if fn_name == "@free" { "p" }
    // v0.96: sin/cos/tan/atan/log/exp/pow_f64/fmod now LLVM intrinsics (handled in special cases)
    // v0.96: f64 floor/ceil/round/sqrt/abs/min/max now use LLVM intrinsics (handled in special cases)

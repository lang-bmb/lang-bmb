    let _w20 = sco_push_line(sb, "}");

    let result = sb_build(sb);

    let _f = sb_free(sb);

    result;

// Process a single function block in the IR

fn lr2l_process_fn(fn_ir: String) -> String

  post it.len() >= 0

= let first_sep = find_pipe_skip_quotes(fn_ir, 0);

    let def_line = fn_ir.slice(0, first_sep);

    let is_define = find_substr_pos(def_line, "define ", 0) >= 0;

    if is_define {


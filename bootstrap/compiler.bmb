    } else if fn_name == "@atan2" {
        let args = line.slice(paren_pos + 1, close_pos);
        let comma = find_char(args, 0, 44);
        let left = trim_end(args.slice(0, comma));
        let right = trim(args.slice(comma + 1, args.len()));
        "  " + dest + " = call double @llvm.atan2.f64(double " + left + ", double " + right + ")"
    } else if fn_name == "@log" {
        let arg = trim_end(line.slice(paren_pos + 1, close_pos));
        "  " + dest + " = call double @llvm.log.f64(double " + arg + ")"
    } else if fn_name == "@log2" {
        let arg = trim_end(line.slice(paren_pos + 1, close_pos));
        "  " + dest + " = call double @llvm.log2.f64(double " + arg + ")"
    } else if fn_name == "@log10" {

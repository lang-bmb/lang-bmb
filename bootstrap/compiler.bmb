    let pos = [0; 1];

    let _init = if s.len() >= pat.len() and match_bytes(s, pat, 0, 0) { set count[0] = 1 } else { set count[0] = 0 };

    while pos[0] < s.len() {

        let _c = if s.byte_at(pos[0]) == 31 and pos[0] + 1 + pat.len() <= s.len() and match_bytes(s, pat, pos[0] + 1, 0) {

            set count[0] = count[0] + 1

        } else {

            set count[0] = count[0]

        };

        set pos[0] = pos[0] + 1;

    };

    count[0]

};

// v0.96.5: Count all occurrences of a pattern using while loop

fn count_substr_loop(s: String, pat: String) -> i64

    post it >= 0

= {

    let count = [0; 1];

    let pos = [0; 1];

    while pos[0] + pat.len() <= s.len() {

        let _c = if match_bytes(s, pat, pos[0], 0) {

            set count[0] = count[0] + 1;

            set pos[0] = pos[0] + pat.len()

        } else {

            set pos[0] = pos[0] + 1

        };

    };

    count[0]

};

// v0.96.5: Print compile statistics

fn print_compile_stats(llvm: String) -> i64

  post it >= 0

=

    if llvm.len() > llvm_ir_warn_size() {

        // Large IR: only show byte size to avoid arena exhaustion

        let _h = println_str("  stats:");

        let _p1 = print_str("    IR bytes: ");

        let _p2 = println(llvm.len());

        0

    } else {

        let lines = count_ir_lines_loop(llvm);

        let functions = count_line_pattern(llvm, "define ");

        let declares = count_line_pattern(llvm, "declare ");

        let globals = count_substr_loop(llvm, "@__str_");

        let _h = println_str("  stats:");

        let _p1 = print_str("    functions: ");

        let _p2 = print(functions);

        let _p3 = print_str(", declarations: ");

        let _p4 = print(declares);

        let _p5 = print_str(", string constants: ");

        let _p6 = print(globals);

        let _p7 = print_str(", IR lines: ");

        let _p8 = println(lines);

        0

    };

// Build with full optimization: opt -O3 then clang

fn build_native_opt(ir_file: String, output: String, runtime_lib: String) -> i64

  post it >= 0

=

    let opt_file = output + "_opt.ll";

    // Step 1: Optimize IR

    let dq = chr(34);

    let opt_cmd = "opt --mcpu=native -passes=" + dq + "default<O3>,scalarizer" + dq + " " + ir_file + " -S -o " + opt_file;

    let opt_result = system(opt_cmd);

    if opt_result != 0 {

        // Fallback: try without scalarizer

        let opt_cmd2 = "opt -O3 " + ir_file + " -S -o " + opt_file;

        let opt_result2 = system(opt_cmd2);

        if opt_result2 != 0 {

            { println_str("Error: opt failed. Falling back to direct compilation."); build_native_direct(ir_file, output, runtime_lib) }

        } else {

            build_link(opt_file, output, runtime_lib, ir_file)

        }

    } else {

        build_link(opt_file, output, runtime_lib, ir_file)

    };

// Build fast: skip opt, use clang -O2 directly

fn build_native_fast(ir_file: String, output: String, runtime_lib: String) -> i64

  post it >= 0

=

    build_link(ir_file, output, runtime_lib, "");

// Build without opt: direct clang on IR

fn build_native_direct(ir_file: String, output: String, runtime_lib: String) -> i64

  post it >= 0

=

    build_link(ir_file, output, runtime_lib, "");

// Link step: clang IR + runtime -> executable

// v0.96.30: Add -march=native for CPU-specific codegen (matches opt --mcpu=native)

fn build_link(ir_file: String, output: String, runtime_lib: String, cleanup_file: String) -> i64

  post it >= 0

=

    let link_cmd = "clang -w -O3 -march=native -ffunction-sections -fdata-sections -Wl,--gc-sections -Wl,--stack,268435456 " + ir_file + " " + runtime_lib + " -o " + output + " -lm -lws2_32";

    let link_result = system(link_cmd);

    if link_result != 0 {

        // Try without ws2_32 (Linux/macOS)

        let link_cmd2 = "clang -w -O3 -march=native -ffunction-sections -fdata-sections -Wl,--gc-sections " + ir_file + " " + runtime_lib + " -o " + output + " -lm -lpthread";

        let link_result2 = system(link_cmd2);

        if link_result2 != 0 {

            { println_str("Error: linking failed"); 1 }

        } else {

            build_cleanup(output, cleanup_file)

        }

    } else {

        build_cleanup(output, cleanup_file)

    };

// Report success and optionally clean temp files

fn build_cleanup(output: String, _cleanup_file: String) -> i64

  post it >= 0

=

    { let _r20 = print_str("{"); let _r21 = print_str(chr(34)); let _r22 = print_str("type"); let _r23 = print_str(chr(34)); let _r24 = print_str(":"); let _r25 = print_str(chr(34)); let _r26 = print_str("build_success"); let _r27 = print_str(chr(34)); let _r28 = print_str(","); let _r29 = print_str(chr(34)); let _r30 = print_str("output"); let _r31 = print_str(chr(34)); let _r32 = print_str(":"); let _r33 = print_str(chr(34)); let _r34 = print_str(output); let _r35 = print_str(chr(34)); println_str("}"); 0 };

// v0.96.3: Run command - compile, execute, and clean up

fn run_file(input: String, runtime_path: String) -> i64

  post it >= 0

=

    let t0 = time_ns() / ns_per_ms();

    let source = load_source(input);

    if source.len() == 0 {

        err_no_file(input)

    } else {

        let llvm = compile_program(source, 0);

        let t1 = time_ns() / ns_per_ms();

        if is_compile_error(llvm) {

            print_compile_err(input, llvm)

        } else {

            let exe = "__bmb_run_tmp.exe";

            let ir_file = "__bmb_run_tmp.ll";

            let _w = write_file_newlines(ir_file, llvm);

            let runtime_lib = runtime_path + "/libbmb_runtime.a";

            let link_cmd = "clang -w -O2 " + ir_file + " " + runtime_lib + " -o " + exe + " -lm -lws2_32";

            let lr = system(link_cmd);

            let link_ok = if lr != 0 {

                let link_cmd2 = "clang -w -O2 " + ir_file + " " + runtime_lib + " -o " + exe + " -lm -lpthread";

                let lr2 = system(link_cmd2);

                if lr2 != 0 { 0 } else { 1 }

            } else { 1 };

            let t2 = time_ns() / ns_per_ms();

            if link_ok == 0 { println_str("Error: linking failed"); 1 }

            else {

                let _t = print_build_timing(t1 - t0, t2 - t1);

                let bs = chr(92);

                let _r = system("." + bs + exe);

                let _c1 = remove_file(ir_file);

                let _c2 = remove_file(exe);

                0

            }

        }

    };

// Derive output name from input: foo.bmb -> foo (or foo.exe on Windows)

fn derive_output_name(input: String) -> String

  post it.len() <= input.len() + 4

= if input.len() > 4 and input.slice(input.len() - 4, input.len()) == ".bmb" {

        input.slice(0, input.len() - 4)

    } else { input + ".out" };

// Bootstrap version - extended CLI

// M13 Phase 3: Extract pre-condition source texts
fn extract_pre_texts(src: String, rp: i64) -> String

  pre rp >= 0

  post it.len() >= 0

= let t = next_token_raw(src, rp);

    let k = tok_kind(t);

    if k == TK_EQ() or k == TK_EOF() or k == TK_LBRACE() { "" }

    else if k == TK_PRE() {

        let expr_start = tok_end(t);

        let re = parse_expr(src, expr_start);

        if is_error(re) { "" }

        else {

            let txt = str_trim(src.slice(expr_start, unpack_pos(re)));

            let rest = extract_pre_texts(src, unpack_pos(re));

            if rest == "" { txt } else { txt + chr(9) + rest }

        }

    }

    else if k == TK_POST() or k == TK_WHERE() {

        let re2 = parse_expr(src, tok_end(t));

        if is_error(re2) { extract_pre_texts(src, tok_end(t)) }

        else { extract_pre_texts(src, unpack_pos(re2)) }

    }

    else if k == TK_IDENT() and get_ident_text(src, rp, t) == "intent" {

        let t2 = next_token_raw(src, tok_end(t));

        if tok_kind(t2) == TK_COLON() {

            let t3 = next_token_raw(src, tok_end(t2));

            if tok_kind(t3) == TK_STRING_LIT() { extract_pre_texts(src, tok_end(t3)) }

            else { "" }

        } else { "" }

    }

    else { "" };

// M13 Phase 3: Extract post-condition source texts
fn extract_post_texts(src: String, rp: i64) -> String

  pre rp >= 0

  post it.len() >= 0

= let t = next_token_raw(src, rp);

    let k = tok_kind(t);

    if k == TK_EQ() or k == TK_EOF() or k == TK_LBRACE() { "" }

    else if k == TK_POST() {

        let expr_start = tok_end(t);

        let re = parse_expr(src, expr_start);

        if is_error(re) { "" }

        else {

            let txt = str_trim(src.slice(expr_start, unpack_pos(re)));

            let rest = extract_post_texts(src, unpack_pos(re));

            if rest == "" { txt } else { txt + chr(9) + rest }

        }

    }

    else if k == TK_PRE() or k == TK_WHERE() {

        let re2 = parse_expr(src, tok_end(t));

        if is_error(re2) { extract_post_texts(src, tok_end(t)) }

        else { extract_post_texts(src, unpack_pos(re2)) }

    }

    else if k == TK_IDENT() and get_ident_text(src, rp, t) == "intent" {

        let t2 = next_token_raw(src, tok_end(t));

        if tok_kind(t2) == TK_COLON() {

            let t3 = next_token_raw(src, tok_end(t2));

            if tok_kind(t3) == TK_STRING_LIT() { extract_post_texts(src, tok_end(t3)) }

            else { "" }

        } else { "" }

    }

    else { "" };

// M13 Phase 3: Extract intent: "..." text
fn extract_intent_tok(src: String, rp: i64) -> String

  pre rp >= 0

  post it.len() >= 0

= let t = next_token_raw(src, rp);

    let k = tok_kind(t);

    if k == TK_EQ() or k == TK_EOF() or k == TK_LBRACE() { "" }

    else if k == TK_IDENT() and get_ident_text(src, rp, t) == "intent" {

        let t2 = next_token_raw(src, tok_end(t));

        if tok_kind(t2) == TK_COLON() {

            let t3 = next_token_raw(src, tok_end(t2));

            if tok_kind(t3) == TK_STRING_LIT() {

                let raw_start = skip_ws_comments(src, tok_end(t2));

                src.slice(raw_start + 1, tok_end(t3) - 1)

            } else { "" }

        } else { "" }

    }

    else if k == TK_PRE() or k == TK_POST() {

        let re2 = parse_expr(src, tok_end(t));

        if is_error(re2) { extract_intent_tok(src, tok_end(t)) }

        else { extract_intent_tok(src, unpack_pos(re2)) }

    }

    else if k == TK_WHERE() { extract_intent_tok(src, skip_where_clause(src, tok_end(t))) }

    else { "" };

// M13 Phase 3: Find tab or end for contract text iteration
fn rh_find_tab_or_end(s: String, idx: i64) -> i64

  pre idx >= 0

  post it >= idx

= if idx >= s.len() { s.len() }

    else if s.byte_at(idx) == 9 { idx }

    else { rh_find_tab_or_end(s, idx + 1) };

// M13 Phase 3: Emit contract texts as JSON array entries into sb
fn emit_contract_json(texts: String, sb: i64, idx: i64) -> i64

  pre idx >= 0

  post it == 0

= if idx >= texts.len() { 0 }

    else {

        let eot = rh_find_tab_or_end(texts, idx);


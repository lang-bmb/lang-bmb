        let result = sb_build(result_sb);

        let _f2 = sb_free(result_sb);

        result

    };

// ============================================================================

// SECTION 13: Unified Compiler Entry Point (v0.10.9)

// ============================================================================

// Compile BMB source code to LLVM IR module

// Returns complete LLVM IR module text with:

// - Module header

// - Runtime declarations

// - Function definitions

fn compile_program(source: String, safe: i64) -> String

  pre safe >= 0

  post it.len() >= 1

= let ast_raw = parse_source(source);

    if is_error(ast_raw) { ast_raw } else {

        let enum_reg = build_enum_registry(source);

        let ast1 = resolve_enum_variants_in_ast(ast_raw, enum_reg);

        let ast = resolve_payload_calls_in_ast(ast1, enum_reg);

        let struct_reg = build_struct_registry(source);

        let mir_raw = lower_program_sb(ast, safe);

        if mir_raw == "" { "ERR:lowering produced empty MIR" } else {

            let mir1 = optimize_const_inlining(mir_raw);

            -- Cycle 3250: fixed-point const inlining loop.
            -- Replaces the former 2-pass approach (Cycle 3248) with a loop that handles
            -- multi-level compound consts of arbitrary depth, e.g.:
            --   const A = 3; const B = A + 1; const C = B * 2;
            -- Each iteration: CF/DCE folds arithmetic, then re-register newly-simple consts.
            -- Terminates when IR stops changing (bounded by const declaration depth).
            let mir2 = optimize_const_inlining_loop(mir1, "");

            let mir3 = optimize_tail_recursive_to_loop(mir2);

            let mir = optimize_licm(mir3);

            let module_ir = compile_gen_ir(mir, struct_reg);

            compile_transform_ir(module_ir, source)

        }

    };

fn compile_gen_ir(mir: String, struct_reg: String) -> String

  post it.len() >= 1

= let header = gen_module_header();

  let decls_raw = gen_runtime_decls();

  let strings = collect_strings_from_mir(mir);

  let string_globals = gen_string_globals(strings);

  let string_fns = collect_string_fns_from_mir(mir);

  let code = gen_program_sb_with_strings_fns_structs(mir, strings, string_fns, struct_reg);

  let decls = filter_conflicting_decls(decls_raw, code);

  let base = header + SEP();

  let base2 = base + decls;

  let base3 = base2 + SEP();

  let base4 = base3 + string_globals;

  let with_globals = if string_globals == "" { base2 } else { base4 };

  let final1 = with_globals + DSEP();

  let tbaa_meta = "!0 = !{}" + SEP() +

      "; TBAA metadata" + SEP() +

      "!900 = !{!\"BMB TBAA\"}" + SEP() +

      "!901 = !{!\"omnipotent char\", !900, i64 0}" + SEP() +

      "!902 = !{!\"long long\", !901, i64 0}" + SEP() +

      "!903 = !{!902, !902, i64 0}" + SEP() +

      "!904 = !{!\"double\", !901, i64 0}" + SEP() +

      "!905 = !{!904, !904, i64 0}" + SEP() +

      "!906 = !{!901, !901, i64 0}" + SEP() +

      "; Branch weights: loop body likely (2000:1)" + SEP() +

      "!907 = !{!\"branch_weights\", i32 2000, i32 1}";

  final1 + code + DSEP() + tbaa_meta;

fn compile_transform_ir(module_ir: String, source: String) -> String

  post it.len() >= 1

= let concat_opt_ir = optimize_ir_string_concat(module_ir);

  let lr2l_ir = optimize_ir_linear_recurrence(concat_opt_ir);

  let cleaned_ir = eliminate_dead_functions_ir(lr2l_ir);

  let contracts_map = build_contracts_map(source);

  let assumed_ir = inject_contract_assumes_all(cleaned_ir, contracts_map);

  let post_map = build_post_contracts_map(source);

  let post_assumed_ir = inject_post_assumes_all(assumed_ir, post_map);

  let range_ir = annotate_return_ranges(post_assumed_ir, post_map);

  let mem_ir = annotate_memory_read_interprocedural(range_ir);

  let spec_ir = annotate_speculatable(mem_ir);

  let inline_ir = annotate_inlining(spec_ir);

  let nofree_ir = annotate_nofree(inline_ir);

  let cont_ir = optimize_cont_loop_exits(nofree_ir);

  let tail_ir = annotate_tailcalls(cont_ir);

  let pruned_ir = prune_unused_decls(tail_ir);

  pruned_ir + DSEP() + "; v0.96.46: Inline main wrapper with runtime init" + SEP() + "declare void @bmb_init_runtime(i32, ptr)" + SEP() + "declare void @bmb_arena_destroy()" + SEP() + "define noundef i32 @main(i32 %argc, ptr %argv) nounwind uwtable \"no-trapping-math\"=\"true\" {" + SEP() + "  call void @bmb_init_runtime(i32 %argc, ptr %argv)" + SEP() + "  %r = call i64 @bmb_user_main()" + SEP() + "  call void @bmb_arena_destroy()" + SEP() + "  %rv = trunc i64 %r to i32" + SEP() + "  ret i32 %rv" + SEP() + "}";

// Compile single function source to LLVM IR

fn is_compile_error(result: String) -> bool

  post it == (result.starts_with("ERR:"))

= result.len() >= 4 and result.slice(0, 4) == "ERR:";

fn err_no_file(input: String) -> i64

  post it >= 0

= { let _r0 = print_str("Error: Cannot read file: "); println_str(input); 1 };

fn print_compile_err(input: String, llvm: String) -> i64

  post it >= 0

= let end = if llvm.len() > 500 { 500 } else { llvm.len() };

    let err_detail = llvm.slice(4, end);

    let category = classify_error(err_detail);

    { let _r1 = print_str("error["); let _r2 = print_str(category); let _r3 = print_str("]["); let _r4 = print_str(input); let _r5 = print_str("]: "); println_str(err_detail); 1 };

// v0.96.3: Classify error by category for diagnostics

fn classify_error(msg: String) -> String

  post it.len() <= 7

= if has_pattern(msg, "unexpected token", 0) or has_pattern(msg, "expected", 0) or has_pattern(msg, "parse", 0) or has_pattern(msg, "missing", 0) { "parse" }

    else if has_pattern(msg, "undefined variable", 0) or has_pattern(msg, "undefined function", 0) or has_pattern(msg, "not found", 0) { "resolve" }

    else if has_pattern(msg, "type mismatch", 0) or has_pattern(msg, "requires", 0) or has_pattern(msg, "must be", 0) or has_pattern(msg, "branches must", 0) or has_pattern(msg, "expects", 0) { "type" }

    else if has_pattern(msg, "body type", 0) or has_pattern(msg, "!= ", 0) { "type" }

    else { "compile" };


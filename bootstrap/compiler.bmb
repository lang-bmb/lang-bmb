    } else if fn_name == "@bswap" {
        let arg = trim_end(line.slice(paren_pos + 1, close_pos));
        "  " + dest + " = call i64 @llvm.bswap.i64(i64 " + arg + ")"
    } else if fn_name == "@rotate_left" and call_has_two_args(line, paren_pos, close_pos) and find_substr_pos(registry, fn_name + ":", 0) < 0 {
        // Built-in rotate_left(x, n) — NOT user-defined (not in registry)
        let args = line.slice(paren_pos + 1, close_pos);
        let comma = find_char(args, 0, 44);
        let value = trim_end(args.slice(0, comma));
        let amount = trim(args.slice(comma + 1, args.len()));
        "  " + dest + " = call i64 @llvm.fshl.i64(i64 " + value + ", i64 " + value + ", i64 " + amount + ")"
    } else if fn_name == "@rotate_right" and call_has_two_args(line, paren_pos, close_pos) and find_substr_pos(registry, fn_name + ":", 0) < 0 {
        // Built-in rotate_right(x, n) — NOT user-defined (not in registry)
        let args = line.slice(paren_pos + 1, close_pos);
        let comma = find_char(args, 0, 44);
        let value = trim_end(args.slice(0, comma));
        let amount = trim(args.slice(comma + 1, args.len()));
        "  " + dest + " = call i64 @llvm.fshr.i64(i64 " + value + ", i64 " + value + ", i64 " + amount + ")"
    } else if fn_name == "@rotate_left" or fn_name == "@rotate_right" {
        emit_regular_i64_call(line, paren_pos, close_pos, fn_name, dest)
    } else if fn_name == "@fabs" or fn_name == "@bmb_f64_abs" {
        let arg = trim_end(line.slice(paren_pos + 1, close_pos));
        "  " + dest + " = call double @llvm.fabs.f64(double " + arg + ")"
    } else if fn_name == "@floor" or fn_name == "@bmb_f64_floor" {
        let arg = trim_end(line.slice(paren_pos + 1, close_pos));
        "  " + dest + " = call double @llvm.floor.f64(double " + arg + ")"
    } else if fn_name == "@ceil" or fn_name == "@bmb_f64_ceil" {
        let arg = trim_end(line.slice(paren_pos + 1, close_pos));
        "  " + dest + " = call double @llvm.ceil.f64(double " + arg + ")"
    } else if fn_name == "@round" or fn_name == "@bmb_f64_round" {
        let arg = trim_end(line.slice(paren_pos + 1, close_pos));
        "  " + dest + " = call double @llvm.round.f64(double " + arg + ")"
    } else if fn_name == "@sqrt" or fn_name == "@bmb_f64_sqrt" {
        let arg = trim_end(line.slice(paren_pos + 1, close_pos));
        "  " + dest + " = call double @llvm.sqrt.f64(double " + arg + ")"
    } else if fn_name == "@f64_min" or fn_name == "@bmb_f64_min" {
        let args = line.slice(paren_pos + 1, close_pos);
        let comma = find_char(args, 0, 44);
        let left = trim_end(args.slice(0, comma));
        let right = trim(args.slice(comma + 1, args.len()));
        "  " + dest + " = call double @llvm.minnum.f64(double " + left + ", double " + right + ")"
    } else if fn_name == "@f64_max" or fn_name == "@bmb_f64_max" {
        let args = line.slice(paren_pos + 1, close_pos);
        let comma = find_char(args, 0, 44);
        let left = trim_end(args.slice(0, comma));
        let right = trim(args.slice(comma + 1, args.len()));
        "  " + dest + " = call double @llvm.maxnum.f64(double " + left + ", double " + right + ")"
    } else if fn_name == "@sin" {
        let arg = trim_end(line.slice(paren_pos + 1, close_pos));
        "  " + dest + " = call double @llvm.sin.f64(double " + arg + ")"
    } else if fn_name == "@cos" {
        let arg = trim_end(line.slice(paren_pos + 1, close_pos));
        "  " + dest + " = call double @llvm.cos.f64(double " + arg + ")"
    } else if fn_name == "@tan" {
        let arg = trim_end(line.slice(paren_pos + 1, close_pos));
        "  " + dest + " = call double @llvm.tan.f64(double " + arg + ")"
    } else if fn_name == "@atan" {

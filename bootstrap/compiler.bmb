    println_str("  module-suggest <file>         Suggest module capability declarations");

    println_str("  semantic-duplicate <file>     Find functionally similar functions");

    0

};

// v0.46: Compile with output file

fn compile_file_to(input: String, output: String) -> i64

  post it >= 0

=

    let source = load_source(input);

    if source.len() == 0 {

        err_no_file(input)

    } else {

        let llvm = compile_program(source, 0);

        if is_compile_error(llvm) {

            print_compile_err(input, llvm)

        } else {

            let _w2 = write_file_newlines(output, llvm);

            0

        }

    };


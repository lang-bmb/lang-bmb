fn llvm_gen_call_reg(line: String, pos: i64, dest: String, registry: String) -> String =
    let at_pos = find_char(line, pos, 64);
    let paren_pos = find_char(line, at_pos, 40);
    let close_pos = find_char(line, paren_pos, 41);
    let fn_name = line.slice(at_pos, paren_pos);
    if fn_name == "@store_u8" {
        let args = line.slice(paren_pos + 1, close_pos);
        let comma = find_char(args, 0, 44);
        let addr = trim_end(args.slice(0, comma));
        let value = trim(args.slice(comma + 1, args.len()));
        "  " + dest + "_p = inttoptr i64 " + addr + " to ptr" + SEP() + "  " + dest + "_v = trunc i64 " + value + " to i8" + SEP() + "  store i8 " + dest + "_v, ptr " + dest + "_p, align 1" + SEP() + "  " + dest + " = add nsw i64 0, 0"
    } else if fn_name == "@load_u8" {
        let addr = trim_end(line.slice(paren_pos + 1, close_pos));
        "  " + dest + "_p = inttoptr i64 " + addr + " to ptr" + SEP() + "  " + dest + "_b = load i8, ptr " + dest + "_p, align 1" + SEP() + "  " + dest + " = zext i8 " + dest + "_b to i64"
    } else if fn_name == "@store_i64" {
        let args = line.slice(paren_pos + 1, close_pos);
        let comma = find_char(args, 0, 44);
        let addr = trim_end(args.slice(0, comma));
        let value = trim(args.slice(comma + 1, args.len()));
        "  " + dest + "_p = inttoptr i64 " + addr + " to ptr" + SEP() + "  store i64 " + value + ", ptr " + dest + "_p, align 8" + SEP() + "  " + dest + " = add nsw i64 0, 0"
    } else if fn_name == "@load_i64" {
        let addr = trim_end(line.slice(paren_pos + 1, close_pos));
        "  " + dest + "_p = inttoptr i64 " + addr + " to ptr" + SEP() + "  " + dest + " = load i64, ptr " + dest + "_p, align 8"
    } else if fn_name == "@ord" {
        let arg = trim_end(line.slice(paren_pos + 1, close_pos));
        "  " + dest + " = add nsw i64 0, " + arg
    } else if fn_name == "@i64_to_f64" {
        let arg = trim_end(line.slice(paren_pos + 1, close_pos));
        "  " + dest + " = sitofp i64 " + arg + " to double"
    } else if fn_name == "@f64_to_i64" {
        let arg = trim_end(line.slice(paren_pos + 1, close_pos));
        "  " + dest + " = fptosi double " + arg + " to i64"
    } else if fn_name == "@bmb_string_char_at" {
        let args = line.slice(paren_pos + 1, close_pos);
        let comma = find_char(args, 0, 44);
        let str_arg = trim_end(args.slice(0, comma));
        let idx_arg = trim(args.slice(comma + 1, args.len()));
        // v0.95: !invariant.load on string struct loads — BMB strings are immutable
        "  " + dest + "_str = inttoptr i64 " + str_arg + " to ptr" + SEP() + "  " + dest + "_dpp = getelementptr {ptr, i64, i64}, ptr " + dest + "_str, i32 0, i32 0" + SEP() + "  " + dest + "_dp = load ptr, ptr " + dest + "_dpp, !invariant.load !0" + SEP() + "  " + dest + "_bp = getelementptr i8, ptr " + dest + "_dp, i64 " + idx_arg + SEP() + "  " + dest + "_b = load i8, ptr " + dest + "_bp" + SEP() + "  " + dest + " = zext i8 " + dest + "_b to i64"
    } else if fn_name == "@bmb_string_len" {
        let str_arg = trim_end(line.slice(paren_pos + 1, close_pos));
        "  " + dest + "_str = inttoptr i64 " + str_arg + " to ptr" + SEP() + "  " + dest + "_lp = getelementptr {ptr, i64, i64}, ptr " + dest + "_str, i32 0, i32 1" + SEP() + "  " + dest + " = load i64, ptr " + dest + "_lp, !invariant.load !0"
    } else if fn_name == "@popcount" {
        let arg = trim_end(line.slice(paren_pos + 1, close_pos));
        "  " + dest + " = call i64 @llvm.ctpop.i64(i64 " + arg + ")"
    } else if fn_name == "@clz" {
        let arg = trim_end(line.slice(paren_pos + 1, close_pos));
        "  " + dest + " = call i64 @llvm.ctlz.i64(i64 " + arg + ", i1 false)"
    } else if fn_name == "@ctz" {
        let arg = trim_end(line.slice(paren_pos + 1, close_pos));
        "  " + dest + " = call i64 @llvm.cttz.i64(i64 " + arg + ", i1 false)"
    } else if fn_name == "@bit_reverse" {
        let arg = trim_end(line.slice(paren_pos + 1, close_pos));
        "  " + dest + " = call i64 @llvm.bitreverse.i64(i64 " + arg + ")"
    } else if fn_name == "@abs" or fn_name == "@bmb_abs" {
        let arg = trim_end(line.slice(paren_pos + 1, close_pos));
        "  " + dest + " = call i64 @llvm.abs.i64(i64 " + arg + ", i1 false)"
    } else if fn_name == "@min" or fn_name == "@bmb_min" {
        let args = line.slice(paren_pos + 1, close_pos);
        let comma = find_char(args, 0, 44);
        let left = trim_end(args.slice(0, comma));
        let right = trim(args.slice(comma + 1, args.len()));
        "  " + dest + " = call i64 @llvm.smin.i64(i64 " + left + ", i64 " + right + ")"
    } else if fn_name == "@max" or fn_name == "@bmb_max" {

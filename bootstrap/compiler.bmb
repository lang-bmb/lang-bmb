  pre p >= 0

  post it >= 0

= match c { 60 => if p + 1 < s.len() and s.byte_at(p + 1) == 61 { make_tok(TK_LTEQ(), p + 2) } else if p + 1 < s.len() and s.byte_at(p + 1) == 60 { if p + 2 < s.len() and s.byte_at(p + 2) == 61 { make_tok(TK_SHLEQ(), p + 3) } else { make_tok(TK_SHL(), p + 2) } } else { make_tok(TK_LT(), p + 1) }, 62 => if p + 1 < s.len() and s.byte_at(p + 1) == 61 { make_tok(TK_GTEQ(), p + 2) } else if p + 1 < s.len() and s.byte_at(p + 1) == 62 { if p + 2 < s.len() and s.byte_at(p + 2) == 62 { make_tok(TK_LSHR(), p + 3) } else if p + 2 < s.len() and s.byte_at(p + 2) == 61 { make_tok(TK_SHREQ(), p + 3) } else { make_tok(TK_SHR(), p + 2) } } else { make_tok(TK_GT(), p + 1) }, 33 => if p + 1 < s.len() and s.byte_at(p + 1) == 61 { make_tok(TK_NEQ(), p + 2) } else { make_tok(TK_EOF(), p) }, _ => if p + 1 < s.len() and s.byte_at(p + 1) == 46 { if p + 2 < s.len() and s.byte_at(p + 2) == 61 { make_tok(TK_DOTDOTEQ(), p + 3) } else { make_tok(TK_DOTDOT(), p + 2) } } else { make_tok(TK_DOT(), p + 1) } };


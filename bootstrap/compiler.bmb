            let fn_name = code.slice(at + 1, paren);

            let _w1 = sb_push(sb, ";");

            let _w2 = sb_push(sb, fn_name);

            sb_push(sb, ";")

        } else { 0 };

        collect_defined_fn_names(code, def_pos + 7, sb)

    };

// Check if a declaration line conflicts with a user-defined function

fn decl_has_conflict(decl_line: String, user_fn_names: String) -> bool

  post not it or user_fn_names.len() > 0

= let at = find_char(decl_line, 0, 64);

    let paren = find_char(decl_line, at, 40);


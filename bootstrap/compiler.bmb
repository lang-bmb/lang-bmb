            let fn_start = unpack_pos(span);

            let fn_end = parse_int_simple(unpack_ast(span), 0, 0);

            let _body = println_str(source.slice(fn_start, fn_end));

            // Callees

            let _c1 = println_str("## Calls");

            let _callees = if calls == "" { let _n = println_str("    (none)"); 0 }

                           else { scope_print_callees(entries, calls, 0) };

            // Callers

            let _cr1 = println_str("");

            let _cr2 = println_str("## Called by");

            let _callers = if callers_count == 0 { let _n = println_str("    (none)"); 0 }

                           else { scope_print_callers(entries, 0, target) };

            let _end = println_str("---");

            0

        }

    };

// v0.95: Changelog command - diff function signatures between two files

// Check if name exists in entries

fn cl_has_name(entries: String, pos: i64, target: String) -> bool

  pre pos >= 0

  post it or not it

= if pos >= entries.len() { false }

    else {

        let eol = callers_find_eol(entries, pos);

        let line = entries.slice(pos, eol);

        if line.len() == 0 { cl_has_name(entries, eol + 1, target) }

        else {

            let name = callers_get_field(line, 0, 0, 0);

            if name == target { true }

            else { cl_has_name(entries, eol + 1, target) }

        }

    };

// Get signature for a function name from entries

fn cl_get_sig(entries: String, pos: i64, target: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= entries.len() { "" }

    else {

        let eol = callers_find_eol(entries, pos);

        let line = entries.slice(pos, eol);

        if line.len() == 0 { cl_get_sig(entries, eol + 1, target) }

        else {

            let name = callers_get_field(line, 0, 0, 0);

            if name == target { callers_get_field(line, 2, 0, 0) }

            else { cl_get_sig(entries, eol + 1, target) }

        }

    };

// Print added functions (in new but not in old)

fn cl_print_added(new_entries: String, pos: i64, old_entries: String, count: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= new_entries.len() { count }

    else {

        let eol = callers_find_eol(new_entries, pos);

        let line = new_entries.slice(pos, eol);

        if line.len() == 0 { cl_print_added(new_entries, eol + 1, old_entries, count) }

        else {

            let name = callers_get_field(line, 0, 0, 0);

            if cl_has_name(old_entries, 0, name) {

                cl_print_added(new_entries, eol + 1, old_entries, count)

            } else {

                let sig = callers_get_field(line, 2, 0, 0);

                let _p = println_str("  + " + sig);

                cl_print_added(new_entries, eol + 1, old_entries, count + 1)

            }

        }

    };

// Print removed functions (in old but not in new)

fn cl_print_removed(old_entries: String, pos: i64, new_entries: String, count: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= old_entries.len() { count }

    else {

        let eol = callers_find_eol(old_entries, pos);

        let line = old_entries.slice(pos, eol);

        if line.len() == 0 { cl_print_removed(old_entries, eol + 1, new_entries, count) }

        else {

            let name = callers_get_field(line, 0, 0, 0);

            if cl_has_name(new_entries, 0, name) {

                cl_print_removed(old_entries, eol + 1, new_entries, count)

            } else {

                let sig = callers_get_field(line, 2, 0, 0);

                let _p = println_str("  - " + sig);

                cl_print_removed(old_entries, eol + 1, new_entries, count + 1)

            }

        }

    };

// Print changed functions (same name, different signature)

fn cl_print_changed(new_entries: String, pos: i64, old_entries: String, count: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= new_entries.len() { count }

    else {

        let eol = callers_find_eol(new_entries, pos);

        let line = new_entries.slice(pos, eol);

        if line.len() == 0 { cl_print_changed(new_entries, eol + 1, old_entries, count) }

        else {

            let name = callers_get_field(line, 0, 0, 0);

            let new_sig = callers_get_field(line, 2, 0, 0);

            let old_sig = cl_get_sig(old_entries, 0, name);

            if old_sig == "" { cl_print_changed(new_entries, eol + 1, old_entries, count) }

            else if new_sig == old_sig { cl_print_changed(new_entries, eol + 1, old_entries, count) }

            else {

                let _p1 = println_str("  ~ " + name + ":");

                let _p2 = println_str("    old: " + old_sig);

                let _p3 = println_str("    new: " + new_sig);

                cl_print_changed(new_entries, eol + 1, old_entries, count + 1)

            }

        }

    };

fn changelog_file(old_input: String, new_input: String) -> i64

  post it >= 0

=

    let old_source = read_file(old_input);

    let new_source = read_file(new_input);

    if old_source.len() == 0 {

        err_no_file(old_input)

    } else if new_source.len() == 0 {

        err_no_file(new_input)

    } else {

        let old_entries = callers_collect_source(old_source, 0, "");

        let new_entries = callers_collect_source(new_source, 0, "");

        let old_count = outline_count_entries(old_entries, 0, 0);

        let new_count = outline_count_entries(new_entries, 0, 0);

        let _header = println_str("# Changelog: " + old_input + " -> " + new_input);

        let _counts = println_str("  Old: " + int_to_string(old_count) + " functions, New: " + int_to_string(new_count) + " functions");

        let _ah = println_str("");

        let _a1 = println_str("## Added:");

        let added = cl_print_added(new_entries, 0, old_entries, 0);

        let _rh = println_str("");

        let _r1 = println_str("## Removed:");

        let removed = cl_print_removed(old_entries, 0, new_entries, 0);

        let _ch = println_str("");

        let _c1 = println_str("## Changed:");

        let changed = cl_print_changed(new_entries, 0, old_entries, 0);

        let _sep = println_str("---");

        let _summary = println_str("  Added: " + int_to_string(added) + " | Removed: " + int_to_string(removed) + " | Changed: " + int_to_string(changed));

        0

    };

// ============================================================================

// SECTION: Format command - source-level code formatter (v0.96.3)

// ============================================================================

// Find end of line starting at pos

fn fmt_eol(src: String, pos: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= src.len() { src.len() }

    else if src.byte_at(pos) == 10 { pos }

    else { fmt_eol(src, pos + 1) };

// Trim trailing whitespace from a line (spaces and tabs)

fn fmt_rtrim(line: String, end: i64) -> String

  pre end >= 0

  post it.len() >= 0

= if end <= 0 { "" }

    else {

        let b = line.byte_at(end - 1);

        if b == 32 or b == 9 or b == 13 { fmt_rtrim(line, end - 1) }

        else { line.slice(0, end) }

    };

// Count leading whitespace (spaces) in a line

fn fmt_leading_ws(line: String, pos: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= line.len() { pos }

    else if line.byte_at(pos) == 32 { fmt_leading_ws(line, pos + 1) }

    else { pos };

// Check if a line is empty or whitespace-only

fn fmt_is_blank(line: String) -> bool

  post it == (fmt_leading_ws(line, 0) >= line.len())

= fmt_leading_ws(line, 0) >= line.len();

// Check if line starts with "fn " (top-level function declaration)

fn fmt_is_fn_decl(line: String) -> bool

  post it == (line.starts_with("fn "))

= line.len() >= 3 and line.byte_at(0) == 102 and line.byte_at(1) == 110 and line.byte_at(2) == 32;

// Check if line starts with "struct " (top-level struct declaration)

fn fmt_is_struct(line: String) -> bool

  post it == (line.starts_with("struct "))

= line.len() >= 7 and line.slice(0, 7) == "struct ";

// Check if line starts with "enum " (top-level enum declaration)

fn fmt_is_enum(line: String) -> bool

  post it == (line.starts_with("enum "))

= line.len() >= 5 and line.slice(0, 5) == "enum ";

// Check if line starts with "@" (annotation)

fn fmt_is_annotation(line: String) -> bool

  post it == (line.starts_with("@"))

= line.len() > 0 and line.byte_at(0) == 64;

// Check if line starts with "//" (comment)

fn fmt_is_comment(line: String) -> bool

  post it == (line.starts_with("//"))

= line.len() >= 2 and line.byte_at(0) == 47 and line.byte_at(1) == 47;

// Count open braces/parens in a line (incrementing nesting)

fn fmt_count_opens(line: String, pos: i64, count: i64, in_str: bool) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= line.len() { count }

    else {

        let b = line.byte_at(pos);

        if b == 34 { fmt_count_opens(line, pos + 1, count, not in_str) }

        else if in_str { fmt_count_opens(line, pos + 1, count, in_str) }

        else if b == 123 or b == 40 { fmt_count_opens(line, pos + 1, count + 1, false) }

        else if b == 125 or b == 41 { fmt_count_opens(line, pos + 1, count - 1, false) }

        else { fmt_count_opens(line, pos + 1, count, false) }

    };

// Generate N spaces of indentation

fn fmt_indent(n: i64) -> String

  pre n >= 0

  post it.len() >= 0

= if n <= 0 { "" }

    else { match n { 1 => "    ", 2 => "        ", 3 => "            ", 4 => "                ", _ => "                    " } };

// Check if trimmed line starts with closing brace/paren

fn fmt_starts_close(line: String) -> bool

  post it == (fmt_leading_ws(line, 0) < line.len() and (line.byte_at(fmt_leading_ws(line, 0)) == 125 or line.byte_at(fmt_leading_ws(line, 0)) == 41))

= let ws = fmt_leading_ws(line, 0);

    if ws >= line.len() { false }

    else {

        let b = line.byte_at(ws);

        b == 125 or b == 41

    };

// Format source: process line by line

// Check if content ends with '=' (function body start), ignoring trailing whitespace

fn fmt_ends_eq(line: String) -> bool

  post it == fmt_rtrim(line, line.len()).ends_with("=")

= let t = fmt_rtrim(line, line.len());

    if t.len() == 0 { false }

    else { t.byte_at(t.len() - 1) == 61 };

// Check if content ends with ';' (statement terminator)

fn fmt_ends_semi(line: String) -> bool

  post it == fmt_rtrim(line, line.len()).ends_with(";")

= let t = fmt_rtrim(line, line.len());

    if t.len() == 0 { false }

    else { t.byte_at(t.len() - 1) == 59 };

// Check if line is a contract (pre/post) - only valid between fn sig and body

fn fmt_is_contract(content: String) -> bool

  post it == (content.starts_with("pre ") or content.starts_with("post "))

= (content.len() >= 4 and content.slice(0, 4) == "pre ") or (content.len() >= 5 and content.slice(0, 5) == "post ");

// Check if line starts with '=' (body start after contracts)

fn fmt_starts_eq(content: String) -> bool

  post it == (content.starts_with("="))

= content.len() > 0 and content.byte_at(0) == 61;

// State encoding: 0 = normal, 1 = in_body, 2 = in_signature (between fn and =)

// Tracks nesting depth for indentation, ensures blank lines between top-level items

fn fmt_lines(src: String, pos: i64, depth: i64, state: i64, prev_blank: bool, prev_toplevel: bool, acc: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= src.len() { acc }

    else {

        let eol = fmt_eol(src, pos);

        let raw_line = src.slice(pos, eol);

        let trimmed = fmt_rtrim(raw_line, raw_line.len());

        if fmt_is_blank(trimmed) {

            // Blank line: keep at most 1

            if prev_blank { fmt_lines(src, eol + 1, depth, state, true, false, acc) }

            else { fmt_lines(src, eol + 1, depth, state, true, false, acc + "\n") }

        } else {

            let content = trimmed.slice(fmt_leading_ws(trimmed, 0), trimmed.len());

            let in_body = state == 1;

            let in_sig = state == 2;

            // Handle contract lines (pre/post between fn sig and body)

            if in_sig and fmt_is_contract(content) {

                // Contract line: indent 2 spaces

                fmt_lines(src, eol + 1, depth, 2, false, false, acc + "  " + content + "\n")

            } else if in_sig and fmt_starts_eq(content) {

                // Body start after contracts: = at col 0, body follows

                let _body_content = content.slice(2, content.len());

                let opens = fmt_count_opens(content, 0, 0, false);

                let new_depth = if opens > 0 { opens } else { 0 };

                fmt_lines(src, eol + 1, new_depth, 1, false, false, acc + content + "\n")

            } else {

                // Determine if this is a top-level declaration

                let is_top = fmt_is_fn_decl(content) or fmt_is_struct(content) or fmt_is_enum(content) or fmt_is_annotation(content);

                let is_top_comment = fmt_is_comment(content) and not in_body;

                let is_toplevel = is_top or is_top_comment;

                let sep = if is_toplevel and not prev_blank and acc.len() > 0 and not prev_toplevel { "\n" } else { "" };

                if is_toplevel {

                    let opens = fmt_count_opens(content, 0, 0, false);

                    // fn decl ending with '=' = multi-line body; without '=' = has contracts

                    let ends_with_eq = fmt_ends_eq(content);

                    let ends_with_semi = fmt_ends_semi(content);

                    let new_state = if ends_with_eq { 1 } else if ends_with_semi { 0 } else if is_top { 2 } else { 0 };

                    let new_depth = if opens > 0 { opens } else { 0 };

                    fmt_lines(src, eol + 1, new_depth, new_state, false, true, acc + sep + content + "\n")

                } else {

                    // Non-top-level content: indent

                    let base = if in_body and depth == 0 { 1 } else { if depth == 0 { 1 } else { depth } };

                    let closes_first = fmt_starts_close(content);

                    let use_depth = if closes_first and base > 1 { base - 1 } else { base };

                    let indented = fmt_indent(use_depth) + content;

                    let net = fmt_count_opens(content, 0, 0, false);

                    let next_depth = use_depth + net;

                    let safe_depth = if next_depth < 0 { 0 } else { next_depth };

                    let body_done = fmt_ends_semi(content) and safe_depth == 0 and not closes_first;

                    let new_state = if body_done { 0 } else { state };

                    fmt_lines(src, eol + 1, safe_depth, new_state, false, false, acc + sep + indented + "\n")

                }

            }

        }

    };

// Format a source string

fn fmt_source(source: String) -> String

  post it.len() >= 0

= fmt_lines(source, 0, 0, 0, true, true, "");

// Format a single file

fn fmt_file(input: String, check: bool) -> i64

  post it >= 0

=

    let source = read_file(input);

    if source.len() == 0 {

        err_no_file(input)

    } else {

        let formatted = fmt_source(source);

        if check {

            if source == formatted {

                { println_str("OK: " + input); 0 }

            } else {

                { println_str("NEEDS FORMAT: " + input); 1 }

            }

        } else {

            if source == formatted {

                { println_str("OK: " + input + " (unchanged)"); 0 }

            } else {

                let _w = write_file(input, formatted);

                { println_str("Formatted: " + input); 0 }

            }

        }

    };

// Format all .bmb files in a directory

fn fmt_dir_each(bmb_files: String, pos: i64, dir: String, check: bool, changed: i64, total: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= bmb_files.len() {

        let _s = println_str("=== Fmt summary: " + int_to_string(total) + " files, " + int_to_string(changed) + " changed ===");

        changed

    } else {

        let eol = lint_find_eol(bmb_files, pos);

        let name = bmb_files.slice(pos, eol);

        if name.len() == 0 { fmt_dir_each(bmb_files, eol + 1, dir, check, changed, total) }

        else {

            let path = dir + "/" + name;

            let result = fmt_file(path, check);

            let new_changed = if result > 0 { changed + 1 } else { changed };

            fmt_dir_each(bmb_files, eol + 1, dir, check, new_changed, total + 1)

        }

    };

fn fmt_dir(dir: String, check: bool) -> i64

  post it >= 0

=

    let files = list_dir(dir);

    if files.len() == 0 {

        { println_str("No files in: " + dir); 0 }

    } else {

        let bmb_files = lint_find_bmb(files, 0);

        if bmb_files.len() == 0 {

            { println_str("No .bmb files in: " + dir); 0 }

        } else {

            fmt_dir_each(bmb_files, 0, dir, check, 0, 0)

        }

    };

// Fmt entry point: file or directory, with optional --check flag

fn fmt_entry(input: String, check: bool) -> i64

  post it >= 0

=

    if is_dir(input) == 1 { fmt_dir(input, check) }

    else { fmt_file(input, check) };

// ============================================================================

// SECTION: Lint command - aggregated static analysis (v0.96.3)

// ============================================================================

// Check for unused functions (not called by anyone, not main)

fn lint_check_unused(entries: String, pos: i64, all: String, count: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= entries.len() { count }

    else {

        let eol = callers_find_eol(entries, pos);

        let line = entries.slice(pos, eol);

        if line.len() == 0 { lint_check_unused(entries, eol + 1, all, count) }

        else {

            let name = callers_get_field(line, 0, 0, 0);

            let caller_count = outline_count_callers(all, 0, name, 0);

            if caller_count == 0 and name != "main" {

                let sig = callers_get_field(line, 2, 0, 0);

                let _w = println_str("  [unused] " + sig);

                lint_check_unused(entries, eol + 1, all, count + 1)

            } else {

                lint_check_unused(entries, eol + 1, all, count)

            }

        }

    };

// Check for functions with too many parameters (> 6)

fn lint_check_many_params(entries: String, pos: i64, count: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= entries.len() { count }

    else {

        let eol = callers_find_eol(entries, pos);

        let line = entries.slice(pos, eol);

        if line.len() == 0 { lint_check_many_params(entries, eol + 1, count) }

        else {

            let name = callers_get_field(line, 0, 0, 0);

            let sig = callers_get_field(line, 2, 0, 0);

            let params_text = cx_extract_params(sig, 0);

            let param_count = if params_text == "" { 0 } else { cx_count_params(params_text, 0, 1) };

            if param_count > 8 {

                let _w = println_str("  [params] " + name + ": " + int_to_string(param_count) + " parameters (max 8)");

                lint_check_many_params(entries, eol + 1, count + 1)

            } else {

                lint_check_many_params(entries, eol + 1, count)

            }

        }

    };

// Check for naming convention: detect uppercase letters (should be snake_case)

fn lint_has_upper(name: String, pos: i64) -> bool

  pre pos >= 0

  post not it or pos < name.len()

= if pos >= name.len() { false }

    else {

        let b = name.byte_at(pos);

        if b >= 65 and b <= 90 { true }

        else { lint_has_upper(name, pos + 1) }

    };

// Returns true if name contains at least one lowercase letter (a-z)
fn lint_has_lower(name: String, pos: i64) -> bool

  pre pos >= 0

  post not it or (pos < name.len() and name.len() >= 0)

= if pos >= name.len() { false }

    else {

        let b = name.byte_at(pos);

        if b >= 97 and b <= 122 { true }

        else { lint_has_lower(name, pos + 1) }

    };

fn lint_check_naming(entries: String, pos: i64, count: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= entries.len() { count }

    else {

        let eol = callers_find_eol(entries, pos);

        let line = entries.slice(pos, eol);

        if line.len() == 0 { lint_check_naming(entries, eol + 1, count) }

        else {

            let name = callers_get_field(line, 0, 0, 0);

            if lint_has_upper(name, 0) and lint_has_lower(name, 0) {

                let _w = println_str("  [naming] " + name + ": use snake_case");

                lint_check_naming(entries, eol + 1, count + 1)

            } else {

                lint_check_naming(entries, eol + 1, count)

            }

        }

    };

// Check for functions with high outgoing call count (> 20 = too complex)

fn lint_check_complexity(entries: String, pos: i64, count: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= entries.len() { count }

    else {

        let eol = callers_find_eol(entries, pos);

        let line = entries.slice(pos, eol);

        if line.len() == 0 { lint_check_complexity(entries, eol + 1, count) }

        else {

            let name = callers_get_field(line, 0, 0, 0);

            let calls = callers_get_field(line, 1, 0, 0);

            let call_count = outline_count_calls(calls, 0, 0);

            if call_count > 20 {

                let _w = println_str("  [complex] " + name + ": " + int_to_string(call_count) + " calls (max 20)");

                lint_check_complexity(entries, eol + 1, count + 1)

            } else {

                lint_check_complexity(entries, eol + 1, count)

            }

        }

    };

// Check for recursive functions (flag for performance awareness)

fn lint_check_recursive(entries: String, pos: i64, count: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= entries.len() { count }

    else {

        let eol = callers_find_eol(entries, pos);

        let line = entries.slice(pos, eol);

        if line.len() == 0 { lint_check_recursive(entries, eol + 1, count) }

        else {

            let name = callers_get_field(line, 0, 0, 0);

            let calls = callers_get_field(line, 1, 0, 0);

            if cx_is_recursive(name, calls) {

                let _w = println_str("  [recursive] " + name);

                lint_check_recursive(entries, eol + 1, count + 1)

            } else {

                lint_check_recursive(entries, eol + 1, count)

            }

        }

    };

// Lint a single file: static analysis on source

// M13 Phase 2: Warn if function has intent: annotation but no pre/post contracts.
// M12 Phase 2c: Check if calls string contains any known IO function.
// IO functions are those that have side effects beyond pure computation.

fn calls_has_io_fn(calls: String) -> i64

  post it == 0 or it == 1

= if calls == "" { 0 }

    else if index_has_name(calls, "println") { 1 }

    else if index_has_name(calls, "println_str") or index_has_name(calls, "print_str") { 1 }

    else if index_has_name(calls, "read_file") or index_has_name(calls, "write_file") { 1 }

    else if index_has_name(calls, "system") or index_has_name(calls, "exec_with_stdin") { 1 }

    else if index_has_name(calls, "getcwd") or index_has_name(calls, "make_dir") { 1 }

    else if index_has_name(calls, "remove_file") or index_has_name(calls, "list_dir") { 1 }

    else if index_has_name(calls, "getenv") or index_has_name(calls, "read_line") { 1 }

    else if index_has_name(calls, "exit") { 1 }

    else { 0 };

// M12 Phase 2c: Warn if @pure or @const function calls IO functions.
// Rule: pure/const functions must have no side effects.

fn lint_check_effect_violations(entries: String, pos: i64, count: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= entries.len() { count }

    else {

        let eol = callers_find_eol(entries, pos);

        let line = entries.slice(pos, eol);

        if line.len() == 0 { lint_check_effect_violations(entries, eol + 1, count) }

        else {

            let fn_name = callers_get_field(line, 0, 0, 0);

            let calls = callers_get_field(line, 1, 0, 0);

            let sig = callers_get_field(line, 2, 0, 0);

            let is_pure = str_find(sig, "@pure fn") >= 0 or str_find(sig, "@const fn") >= 0;

            let has_io = if is_pure { calls_has_io_fn(calls) } else { 0 };

            let new_count = if has_io > 0 {

                let _w = println_str("  [effect_pure_violation] " + fn_name + ": pure function calls IO function");

                count + 1

            } else { count };

            lint_check_effect_violations(entries, eol + 1, new_count)

        }

    };

// M12 Phase 3: Effect callee propagation — detect undeclared capability use.
// Rule: if fn A declares <IO> and calls fn B which declares <IO, Net>, A must also declare Net.

// Extract "IO Net" from "(eff IO Net)" sexp.
fn eff_clean(eff_sexp: String) -> String

  post it.len() >= 0

= if eff_sexp.len() < 5 { "" }

    else {

        let inner = extract_paren_content(eff_sexp);

        str_trim(inner.slice(3, inner.len()))

    };

// Check if space-separated effect list 'eff' contains name 'name'.
fn eff_contains_name(eff: String, name: String) -> bool

  post it or not it

= if eff == name { true }

    else if eff == "" { false }

    else { eff_contains_search(eff, name, 0) };

fn eff_contains_search(eff: String, name: String, pos: i64) -> bool

  pre pos >= 0

  post it or not it

= if pos >= eff.len() { false }

    else {

        let end = eff_find_space_or_end(eff, pos);

        let segment = eff.slice(pos, end);

        if segment == name { true }

        else if end >= eff.len() { false }

        else { eff_contains_search(eff, name, end + 1) }

    };

// Check that every cap in space-separated `a` is present in `b`.
fn eff_subset(a: String, b: String, pos: i64) -> bool

  pre pos >= 0

  post it or not it

= if a == "" { true }

    else if pos >= a.len() { true }

    else {

        let end = eff_find_space_or_end(a, pos);

        let cap = a.slice(pos, end);

        if eff_contains_name(b, cap) {

            if end >= a.len() { true }

            else { eff_subset(a, b, end + 1) }

        } else { false }

    };

// Set-equality for space-separated effect cap strings: order-independent comparison.
// "IO File" == "File IO" → true
fn eff_set_equals(a: String, b: String) -> bool

  post it or not it

= eff_subset(a, b, 0) and eff_subset(b, a, 0);

fn eff_find_space_or_end(s: String, pos: i64) -> i64

  pre pos >= 0

  post it >= pos

= if pos >= s.len() { s.len() }

    else if s.byte_at(pos) == 32 { pos }

    else { eff_find_space_or_end(s, pos + 1) };

// Look up function name in effect map ("name\teff\nname2\teff2\n...") -> effect row string.
// Strips "PLAT:" prefix from platform declarations so callee checks work uniformly.
fn eff_map_get(map: String, name: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= map.len() { "" }

    else {

        let eol = callers_find_eol(map, pos);

        let line = map.slice(pos, eol);

        let tab = str_find(line, "\t");

        if tab >= 0 {

            let entry_name = line.slice(0, tab);

            if entry_name == name {

                let raw = line.slice(tab + 1, line.len());

                // Strip PLAT: prefix so callee effect lookups work
                if str_find(raw, "PLAT:") == 0 { raw.slice(5, raw.len()) }

                else { raw }

            }

            else { eff_map_get(map, name, eol + 1) }

        } else { eff_map_get(map, name, eol + 1) }

    };

// Look up raw effect (with PLAT: prefix if platform-declared).
fn eff_map_get_raw(map: String, name: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= map.len() { "" }

    else {

        let eol = callers_find_eol(map, pos);

        let line = map.slice(pos, eol);

        let tab = str_find(line, "\t");

        if tab >= 0 {

            let entry_name = line.slice(0, tab);

            if entry_name == name { line.slice(tab + 1, line.len()) }

            else { eff_map_get_raw(map, name, eol + 1) }

        } else { eff_map_get_raw(map, name, eol + 1) }

    };

// Check if callee's declared effects are covered by caller's declared effects.
// Returns count of warnings emitted.
fn check_callee_missing_effects(callee_eff: String, caller_eff: String,
    fn_name: String, callee_name: String, pos: i64, count: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= callee_eff.len() { count }

    else {

        let end = eff_find_space_or_end(callee_eff, pos);

        let cap = callee_eff.slice(pos, end);

        let new_count = if cap.len() > 0 and not eff_contains_name(caller_eff, cap) {

            let _w = println_str("  [effect_propagation] " + fn_name + ": declares <" + caller_eff + "> but calls " + callee_name + " which uses <" + cap + ">");

            count + 1

        } else { count };

        if end >= callee_eff.len() { new_count }

        else { check_callee_missing_effects(callee_eff, caller_eff, fn_name, callee_name, end + 1, new_count) }

    };

// Check one callee's effect against caller's declared effect.
fn check_one_callee_effect(callee_name: String, caller_eff: String, fn_name: String, eff_map: String) -> i64

  post it >= 0

= let callee_eff = eff_map_get(eff_map, callee_name, 0);

    if callee_eff == "" or callee_eff == "pure" or callee_eff == "*" { 0 }

    else if caller_eff == "*" { 0 }

    else { check_callee_missing_effects(callee_eff, caller_eff, fn_name, callee_name, 0, 0) };

// Iterate over calls (comma+space separated) and check each against eff_map.
fn check_calls_for_effects(calls: String, caller_eff: String,
    fn_name: String, eff_map: String, pos: i64, count: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= calls.len() { count }

    else {

        let end = index_find_comma_or_end(calls, pos);

        let callee = calls.slice(pos, end);

        let new_count = count + check_one_callee_effect(callee, caller_eff, fn_name, eff_map);

        if end >= calls.len() { new_count }

        else { check_calls_for_effects(calls, caller_eff, fn_name, eff_map, end + 2, new_count) }

    };

// Main effect propagation lint pass: for each effect-annotated function,
// check that all callees' effects are covered by the caller's declared effect row.
fn lint_check_effect_propagation(entries: String, eff_map: String, pos: i64, count: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= entries.len() { count }

    else {

        let eol = callers_find_eol(entries, pos);

        let line = entries.slice(pos, eol);

        if line.len() == 0 { lint_check_effect_propagation(entries, eff_map, eol + 1, count) }

        else {

            let fn_name = callers_get_field(line, 0, 0, 0);

            let calls = callers_get_field(line, 1, 0, 0);

            // Look up this function's declared effect; use raw to detect platform declarations
            let raw_caller_eff = eff_map_get_raw(eff_map, fn_name, 0);

            let is_platform = str_find(raw_caller_eff, "PLAT:") == 0;

            let caller_eff = if is_platform { raw_caller_eff.slice(5, raw_caller_eff.len()) }

                             else { raw_caller_eff };

            // Only check non-platform functions with non-empty, non-pure, non-star effects
            let should_check = not is_platform and caller_eff != "" and caller_eff != "pure" and caller_eff != "*";

            let new_count = if should_check and calls.len() > 0 {

                check_calls_for_effects(calls, caller_eff, fn_name, eff_map, 0, count)

            } else { count };

            lint_check_effect_propagation(entries, eff_map, eol + 1, new_count)

        }

    };

// Scan source for effect-annotated functions, building "name\tIO Net\n" map.
// M15 Phase 2: Scan inside a platform block for fn declarations with effect rows.
// Platform-declared functions are marked with "PLAT:" prefix in their effect map entry
// so they inform callee lookups but are not themselves checked (no real body).
// Returns pack_result(pos_after_rbrace, updated_acc).
fn scan_platform_effects(src: String, pos: i64, acc: String) -> String

  pre pos >= 0

  post it.len() >= 1

= let t = next_token_raw(src, pos);

    let k = tok_kind(t);

    if k == TK_EOF() { pack_result(pos, acc) }

    else if k == TK_RBRACE() { pack_result(tok_end(t), acc) }

    else if k == TK_FN() {

        let result = scan_fn_effect_entry(src, tok_end(t));

        let raw_entry = unpack_ast(result);

        // Mark platform entries with "PLAT:" prefix on the effect value
        let entry = if raw_entry == "" { "" }

                    else {

                        let tab = str_find(raw_entry, "\t");

                        if tab < 0 { "" }

                        else { raw_entry.slice(0, tab + 1) + "PLAT:" + raw_entry.slice(tab + 1, raw_entry.len()) }

                    };

        let new_acc = if entry == "" { acc } else { acc + entry + "\n" };

        scan_platform_effects(src, unpack_pos(result), new_acc)

    }

    else { scan_platform_effects(src, tok_end(t), acc) };

fn build_fn_effect_map(src: String, pos: i64, acc: String) -> String

  pre pos >= 0

  post it.len() >= 0

= let t = next_token_raw(src, pos);

    let k = tok_kind(t);

    if k == TK_EOF() { acc }

    else if k == TK_FN() {

        let result = scan_fn_effect_entry(src, tok_end(t));

        let entry = unpack_ast(result);

        let new_acc = if entry == "" { acc } else { acc + entry + "\n" };

        build_fn_effect_map(src, unpack_pos(result), new_acc)

    }

    else if k == TK_IDENT() {

        // M15 Phase 2: Detect 'platform Name { ... }' and scan for fn effect declarations
        let ident = get_ident_text(src, pos, t);

        if ident == "platform" {

            let t_name = next_token_raw(src, tok_end(t));

            let after_name = if tok_kind(t_name) == TK_IDENT() { tok_end(t_name) } else { tok_end(t) };

            let t_brace = next_token_raw(src, after_name);

            if tok_kind(t_brace) == TK_LBRACE() {

                let scan_r = scan_platform_effects(src, tok_end(t_brace), acc);

                build_fn_effect_map(src, unpack_pos(scan_r), unpack_ast(scan_r))

            } else { build_fn_effect_map(src, after_name, acc) }

        } else { build_fn_effect_map(src, tok_end(t), acc) }

    }

    else { build_fn_effect_map(src, tok_end(t), acc) };

// After 'fn', try to extract "name\tIO Net" for effect-annotated functions.
fn scan_fn_effect_entry(src: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 1

= let t1 = next_token_raw(src, pos);

    if tok_kind(t1) != TK_IDENT() { pack_result(tok_end(t1), "") }

    else {

        let name_start = skip_ws_comments(src, pos);

        let name_end = scan_ident_end(src, name_start);

        let name = src.slice(name_start, name_end);

        let t2 = next_token_raw(src, name_end);

        if tok_kind(t2) != TK_LPAREN() { pack_result(tok_end(t2), "") }

        else {

            // Skip params using index_collect_params
            let params_r = index_collect_params(src, tok_end(t2), "");

            let after_rparen = unpack_pos(params_r);

            let t3 = next_token_raw(src, after_rparen);

            if tok_kind(t3) != TK_COLON() { pack_result(after_rparen, "") }

            else {

                let t_lt = next_token_raw(src, tok_end(t3));

                if tok_kind(t_lt) != TK_LT() { pack_result(tok_end(t_lt), "") }

                else {

                    let eff_r = parse_effect_row(src, tok_end(t_lt));

                    let eff_sexp = unpack_ast(eff_r);

                    let clean = eff_clean(eff_sexp);

                    // Only record non-pure, non-star, non-empty effects
                    let entry = if clean == "" or clean == "pure" or clean == "*" { "" }

                                else { name + "\t" + clean };

                    pack_result(unpack_pos(eff_r), entry)

                }

            }

        }

    };

// --- M12 Phase 4: Transitive Effect Propagation ---

// Add effect cap to space-separated set eff if not already present.
fn eff_add_if_new(eff: String, cap: String) -> String

  post it.len() >= 0

= if cap == "" or cap == "pure" or cap == "*" { eff }

    else if eff_contains_name(eff, cap) { eff }

    else if eff == "" { cap }

    else { eff + " " + cap };

// Merge all space-separated effects from b into a (recursive helper).
fn eff_merge_effects_pos(a: String, b: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= b.len() { a }

    else {

        let end = eff_find_space_or_end(b, pos);

        let cap = b.slice(pos, end);

        let new_a = eff_add_if_new(a, cap);

        if end >= b.len() { new_a }

        else { eff_merge_effects_pos(new_a, b, end + 1) }

    };

// Merge all effects from b into a.
fn eff_merge_effects(a: String, b: String) -> String

  post it.len() >= 0

= if b == "" { a }

    else { eff_merge_effects_pos(a, b, 0) };

// Expand caller_eff by merging effects of each callee from transmap.
fn expand_calls_effects_trans(calls: String, caller_eff: String, transmap: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= calls.len() { caller_eff }

    else {

        let end = index_find_comma_or_end(calls, pos);

        let callee = calls.slice(pos, end);

        let callee_eff = eff_map_get(transmap, callee, 0);

        let new_eff = eff_merge_effects(caller_eff, callee_eff);

        if end >= calls.len() { new_eff }

        else { expand_calls_effects_trans(calls, new_eff, transmap, end + 2) }

    };

// Process all entries once to build transitive effect map.
// Functions WITH explicit effects (in direct_map): keep direct effect unchanged.
// Functions WITHOUT explicit effects: expand from callee transitive effects.
fn build_transitive_pass(entries: String, direct_map: String, old_transmap: String, pos: i64, acc: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= entries.len() { acc }

    else {

        let eol = callers_find_eol(entries, pos);

        let line = entries.slice(pos, eol);

        if line.len() == 0 { build_transitive_pass(entries, direct_map, old_transmap, eol + 1, acc) }

        else {

            let fn_name = callers_get_field(line, 0, 0, 0);

            let calls = callers_get_field(line, 1, 0, 0);

            let direct_raw = eff_map_get_raw(direct_map, fn_name, 0);

            let is_plat = str_find(direct_raw, "PLAT:") == 0;

            let has_direct = direct_raw != "";

            let new_acc = if is_plat {

                acc + fn_name + "\tPLAT:" + direct_raw.slice(5, direct_raw.len()) + "\n"

            } else if has_direct {

                // Keep explicit declaration unchanged (don't expand with callee effects)
                acc + fn_name + "\t" + direct_raw + "\n"

            } else {

                // No explicit declaration: propagate callee transitive effects
                let new_eff = expand_calls_effects_trans(calls, "", old_transmap, 0);

                if new_eff == "" { acc } else { acc + fn_name + "\t" + new_eff + "\n" }

            };

            build_transitive_pass(entries, direct_map, old_transmap, eol + 1, new_acc)

        }

    };

// Iterate transitive expansion until stable (max iter passes).
fn build_transitive_effect_map_iter(entries: String, direct_map: String, transmap: String, iter: i64) -> String

  pre iter >= 0

  post it.len() >= 0

= let new_map = build_transitive_pass(entries, direct_map, transmap, 0, "");

    if iter <= 0 { new_map }

    else if new_map.len() == transmap.len() { new_map }

    else { build_transitive_effect_map_iter(entries, direct_map, new_map, iter - 1) };

// Build transitive effect map: explicit-effect functions keep declared effects;
// undeclared functions get computed transitive effects from callees.
fn build_transitive_effect_map(entries: String, direct_map: String, iter: i64) -> String

  pre iter >= 0

  post it.len() >= 0

= build_transitive_effect_map_iter(entries, direct_map, direct_map, iter);

// --- M15 Phase 4: Full Transitive Effect Map (all functions expanded) ---
// Unlike build_transitive_effect_map, this expands ALL functions (even explicitly declared)
// by merging callee effects. Used for module capability check only.

fn build_full_transitive_pass(entries: String, old_transmap: String, pos: i64, acc: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= entries.len() { acc }

    else {

        let eol = callers_find_eol(entries, pos);

        let line = entries.slice(pos, eol);

        if line.len() == 0 { build_full_transitive_pass(entries, old_transmap, eol + 1, acc) }

        else {

            let fn_name = callers_get_field(line, 0, 0, 0);

            let calls = callers_get_field(line, 1, 0, 0);

            let raw_eff = eff_map_get_raw(old_transmap, fn_name, 0);

            let is_plat = str_find(raw_eff, "PLAT:") == 0;

            let new_acc = if is_plat {

                acc + fn_name + "\tPLAT:" + raw_eff.slice(5, raw_eff.len()) + "\n"

            } else {

                // Expand ALL functions (even explicitly declared) with callee transitive effects
                let cur_eff = eff_map_get(old_transmap, fn_name, 0);

                let new_eff = expand_calls_effects_trans(calls, cur_eff, old_transmap, 0);

                if new_eff == "" { acc } else { acc + fn_name + "\t" + new_eff + "\n" }

            };

            build_full_transitive_pass(entries, old_transmap, eol + 1, new_acc)

        }

    };

fn build_full_transitive_map_iter(entries: String, transmap: String, iter: i64) -> String

  pre iter >= 0

  post it.len() >= 0

= let new_map = build_full_transitive_pass(entries, transmap, 0, "");

    if iter <= 0 { new_map }

    else if new_map.len() == transmap.len() { new_map }

    else { build_full_transitive_map_iter(entries, new_map, iter - 1) };

// Build full transitive effect map (all functions expanded, for module cap check).
fn build_full_transitive_effect_map(entries: String, direct_map: String, iter: i64) -> String

  pre iter >= 0

  post it.len() >= 0

= build_full_transitive_map_iter(entries, direct_map, iter);

// --- M12 Phase 5: Missing Effect Annotation ---

// Check one entry: if it has transitive effects but no explicit declaration, warn.
fn lint_check_one_missing_effect(fn_name: String, direct_map: String, transitive_map: String) -> i64

  post it >= 0

= let direct_raw = eff_map_get_raw(direct_map, fn_name, 0);

    let is_plat = str_find(direct_raw, "PLAT:") == 0;

    let has_direct = direct_raw != "";

    if has_direct or is_plat { 0 }

    else {

        let trans_eff = eff_map_get(transitive_map, fn_name, 0);

        if trans_eff == "" or trans_eff == "pure" or trans_eff == "*" { 0 }

        else {

            let _w = println_str("  [missing_effect_annotation] " + fn_name + ": inferred effects <" + trans_eff + "> but no explicit annotation");

            1

        }

    };

// Scan all entries, warn for functions with transitive effects but no declaration.
fn lint_check_missing_effect_annotations(entries: String, direct_map: String, transitive_map: String, pos: i64, count: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= entries.len() { count }

    else {

        let eol = callers_find_eol(entries, pos);

        let line = entries.slice(pos, eol);

        if line.len() == 0 { lint_check_missing_effect_annotations(entries, direct_map, transitive_map, eol + 1, count) }

        else {

            let fn_name = callers_get_field(line, 0, 0, 0);

            let new_count = count + lint_check_one_missing_effect(fn_name, direct_map, transitive_map);

            lint_check_missing_effect_annotations(entries, direct_map, transitive_map, eol + 1, new_count)

        }

    };

// ─── diagnose: lint_effects JSON builders ──────────────────────────────────

// Count {"type": occurrences in a violations/warnings JSON array string (unified format).
fn count_rule_entries(s: String, pos: i64) -> i64

  pre pos >= 0

  post it >= 0

= let found = find_pattern_noa(s, "{\"type\":", pos);

  if found < 0 { 0 }

  else { 1 + count_rule_entries(s, found + 8) };

// Aliases delegating to count_rule_entries (same implementation, unified).
fn count_caller_entries(s: String, pos: i64) -> i64

  pre pos >= 0

  post it >= 0

= count_rule_entries(s, pos);

fn count_fn_a_entries(s: String, pos: i64) -> i64

  pre pos >= 0

  post it >= 0

= count_rule_entries(s, pos);

// JSON builder for effect_pure_violation: collects violations into sb array.
fn lint_eff_pure_viol_sb(entries: String, pos: i64, sb: i64, isfirst: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= entries.len() { isfirst }

    else {

        let eol = callers_find_eol(entries, pos);

        let line = entries.slice(pos, eol);

        if line.len() == 0 { lint_eff_pure_viol_sb(entries, eol + 1, sb, isfirst) }

        else {

            let fn_name = callers_get_field(line, 0, 0, 0);

            let calls = callers_get_field(line, 1, 0, 0);

            let sig = callers_get_field(line, 2, 0, 0);

            let is_pure = str_find(sig, "@pure fn") >= 0 or str_find(sig, "@const fn") >= 0;

            let has_io = if is_pure { calls_has_io_fn(calls) } else { 0 };

            let new_isfirst = if has_io > 0 {

                let _comma = if isfirst == 0 { sb_push(sb, ",") } else { 0 };

                let _j = sb_push(sb, "{\"type\":\"effect_pure_violation\",\"function\":\"" + json_esc(fn_name) + "\",\"message\":\"pure function calls IO function\",\"fix_suggestion\":\"remove @pure annotation from " + json_esc(fn_name) + ", or ensure all called functions have no side effects\"}");

                0

            } else { isfirst };

            lint_eff_pure_viol_sb(entries, eol + 1, sb, new_isfirst)

        }

    };

// JSON builder for check_callee_missing_effects.
fn check_callee_missing_effects_sb(callee_eff: String, caller_eff: String,
    fn_name: String, callee_name: String, pos: i64, sb: i64, isfirst: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= callee_eff.len() { isfirst }

    else {

        let end = eff_find_space_or_end(callee_eff, pos);

        let cap = callee_eff.slice(pos, end);

        let new_isfirst = if cap.len() > 0 and not eff_contains_name(caller_eff, cap) {

            let _comma = if isfirst == 0 { sb_push(sb, ",") } else { 0 };

            let _j = sb_push(sb, "{\"type\":\"effect_propagation\",\"function\":\"" + json_esc(fn_name) + "\",\"callee\":\"" + json_esc(callee_name) + "\",\"caller_effect\":\"" + caller_eff + "\",\"missing_cap\":\"" + cap + "\",\"fix_suggestion\":\"add <" + cap + "> to " + json_esc(fn_name) + " annotation: fn " + json_esc(fn_name) + "(): <" + caller_eff + ", " + cap + ">\"}");

            0

        } else { isfirst };

        if end >= callee_eff.len() { new_isfirst }

        else { check_callee_missing_effects_sb(callee_eff, caller_eff, fn_name, callee_name, end + 1, sb, new_isfirst) }

    };

fn check_one_callee_effect_sb(callee_name: String, caller_eff: String,
    fn_name: String, eff_map: String, sb: i64, isfirst: i64) -> i64

  post it >= 0

= let callee_eff = eff_map_get(eff_map, callee_name, 0);

    if callee_eff == "" or callee_eff == "pure" or callee_eff == "*" { isfirst }

    else if caller_eff == "*" { isfirst }

    else { check_callee_missing_effects_sb(callee_eff, caller_eff, fn_name, callee_name, 0, sb, isfirst) };

fn check_calls_for_effects_sb(calls: String, caller_eff: String,
    fn_name: String, eff_map: String, pos: i64, sb: i64, isfirst: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= calls.len() { isfirst }

    else {

        let end = index_find_comma_or_end(calls, pos);

        let callee = calls.slice(pos, end);

        let new_isfirst = check_one_callee_effect_sb(callee, caller_eff, fn_name, eff_map, sb, isfirst);

        if end >= calls.len() { new_isfirst }

        else { check_calls_for_effects_sb(calls, caller_eff, fn_name, eff_map, end + 2, sb, new_isfirst) }

    };

// JSON builder for effect_propagation lint warnings.
fn lint_eff_propagation_sb(entries: String, eff_map: String, pos: i64, sb: i64, isfirst: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= entries.len() { isfirst }

    else {

        let eol = callers_find_eol(entries, pos);

        let line = entries.slice(pos, eol);

        if line.len() == 0 { lint_eff_propagation_sb(entries, eff_map, eol + 1, sb, isfirst) }

        else {

            let fn_name = callers_get_field(line, 0, 0, 0);

            let calls = callers_get_field(line, 1, 0, 0);

            let raw_caller_eff = eff_map_get_raw(eff_map, fn_name, 0);

            let is_platform = str_find(raw_caller_eff, "PLAT:") == 0;

            let caller_eff = if is_platform { raw_caller_eff.slice(5, raw_caller_eff.len()) }

                             else { raw_caller_eff };

            let should_check = not is_platform and caller_eff != "" and caller_eff != "pure" and caller_eff != "*";

            let new_isfirst = if should_check and calls.len() > 0 {

                check_calls_for_effects_sb(calls, caller_eff, fn_name, eff_map, 0, sb, isfirst)

            } else { isfirst };

            lint_eff_propagation_sb(entries, eff_map, eol + 1, sb, new_isfirst)

        }

    };

// JSON builder for missing_effect_annotation warnings.
fn lint_missing_eff_sb(entries: String, direct_map: String, transitive_map: String,
    pos: i64, sb: i64, isfirst: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= entries.len() { isfirst }

    else {

        let eol = callers_find_eol(entries, pos);

        let line = entries.slice(pos, eol);

        if line.len() == 0 { lint_missing_eff_sb(entries, direct_map, transitive_map, eol + 1, sb, isfirst) }

        else {

            let fn_name = callers_get_field(line, 0, 0, 0);

            let direct_raw = eff_map_get_raw(direct_map, fn_name, 0);

            let is_plat = str_find(direct_raw, "PLAT:") == 0;

            let has_direct = direct_raw != "";

            let new_isfirst = if has_direct or is_plat { isfirst }

            else {

                let trans_eff = eff_map_get(transitive_map, fn_name, 0);

                if trans_eff == "" or trans_eff == "pure" or trans_eff == "*" { isfirst }

                else {

                    let _comma = if isfirst == 0 { sb_push(sb, ",") } else { 0 };

                    let _j = sb_push(sb, "{\"type\":\"missing_effect_annotation\",\"function\":\"" + json_esc(fn_name) + "\",\"inferred_effect\":\"" + trans_eff + "\",\"fix_suggestion\":\"annotate as fn " + json_esc(fn_name) + "(): <" + trans_eff + ">\"}");

                    0

                }

            };

            lint_missing_eff_sb(entries, direct_map, transitive_map, eol + 1, sb, new_isfirst)

        }

    };

// Build lint_effects JSON string: combines all three effect lint checks.
fn lint_effects_build_json(input: String, entries: String, eff_map: String, transitive_map: String) -> String

  post it.len() >= 1

= {

    let warn_sb = sb_new();

    let f1 = lint_eff_pure_viol_sb(entries, 0, warn_sb, 1);

    let f2 = lint_eff_propagation_sb(entries, eff_map, 0, warn_sb, f1);

    let _f3 = lint_missing_eff_sb(entries, eff_map, transitive_map, 0, warn_sb, f2);

    let warnings_str = sb_build(warn_sb);

    let count = count_rule_entries(warnings_str, 0);

    let out_sb = sb_new();

    let _h1 = sb_push(out_sb, "{\"type\":\"lint_effects\",\"file\":\"");

    let _h2 = sb_push(out_sb, json_esc(input));

    let _h3 = sb_push(out_sb, "\",\"count\":");

    let _hc = sb_push(out_sb, int_to_string(count));

    let _h4 = sb_push(out_sb, ",\"warnings\":[");

    let _h5 = sb_push(out_sb, warnings_str);

    let _h6 = sb_push(out_sb, "]}");

    sb_build(out_sb)

};

// --- M15 Phase 3: Module Capability Declaration ---
// Syntax: module X requires [IO, Net, File]
// Parses module-level capability requirements for lint checking.

// Scan 'module Name requires [cap1, cap2...]' returning "cap1 cap2..." string.
fn scan_module_caps_list(src: String, pos: i64, acc: String) -> String

  pre pos >= 0

  post it.len() >= 0

= let t = next_token_raw(src, pos);

    let k = tok_kind(t);

    if k == TK_EOF() or k == TK_RBRACKET() { acc }

    else if k == TK_IDENT() {

        let cap = src.slice(skip_ws_comments(src, pos), scan_ident_end(src, skip_ws_comments(src, pos)));

        let new_acc = if acc == "" { cap } else { acc + " " + cap };

        scan_module_caps_list(src, tok_end(t), new_acc)

    }

    else { scan_module_caps_list(src, tok_end(t), acc) };

// After 'module Name', parse 'requires [...]' and return capability list.
fn scan_module_requires_entry(src: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= let t1 = next_token_raw(src, pos);

    if tok_kind(t1) != TK_IDENT() { "" }

    else {

        // Check if next keyword is 'requires'
        let req_pos = skip_ws_comments(src, tok_end(t1));

        let req_end = scan_ident_end(src, req_pos);

        let kw = src.slice(req_pos, req_end);

        if kw != "requires" { "" }

        else {

            let t_lb = next_token_raw(src, req_end);

            if tok_kind(t_lb) != TK_LBRACKET() { "" }

            else { scan_module_caps_list(src, tok_end(t_lb), "") }

        }

    };

// Scan source for 'module X requires [...]' declarations.
// Returns space-separated capability list (from first module declaration found).
fn scan_module_requires(src: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= let ident_pos = find_pattern_noa(src, "module ", pos);

    if ident_pos < 0 { "" }

    else {

        let is_real = if ident_pos == 0 { true }

                      else { let prev = src.byte_at(ident_pos - 1); prev == 10 or prev == 13 };

        if is_real {

            let caps = scan_module_requires_entry(src, ident_pos + 7);

            if caps != "" { caps }

            else { scan_module_requires(src, ident_pos + 7) }

        }

        else { scan_module_requires(src, ident_pos + 7) }

    };

// Check if one effect cap from fn_eff is covered by module_caps, emitting warning if not.
fn check_fn_vs_module_caps(fn_name: String, fn_eff: String, module_caps: String, pos: i64, count: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= fn_eff.len() { count }

    else {

        let end = eff_find_space_or_end(fn_eff, pos);

        let cap = fn_eff.slice(pos, end);

        let new_count = if cap.len() > 0 and not eff_contains_name(module_caps, cap) {

            let _w = println_str("  [module_capability] " + fn_name + ": uses <" + cap + "> not declared in module requires [" + module_caps + "]");

            count + 1

        } else { count };

        if end >= fn_eff.len() { new_count }

        else { check_fn_vs_module_caps(fn_name, fn_eff, module_caps, end + 1, new_count) }

    };

// Check if all transitive effects in entries are covered by module capability list.
// Warns: [module_capability] fn X has effect <Y> not declared in module requires.
fn lint_check_module_caps_fn(fn_name: String, transitive_map: String, module_caps: String) -> i64

  post it >= 0

= let trans_eff = eff_map_get(transitive_map, fn_name, 0);

    if trans_eff == "" or trans_eff == "pure" or trans_eff == "*" { 0 }

    else { check_fn_vs_module_caps(fn_name, trans_eff, module_caps, 0, 0) };

fn lint_check_module_capabilities(entries: String, transitive_map: String, module_caps: String, pos: i64, count: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= entries.len() or module_caps == "" { count }

    else {

        let eol = callers_find_eol(entries, pos);

        let line = entries.slice(pos, eol);

        if line.len() == 0 { lint_check_module_capabilities(entries, transitive_map, module_caps, eol + 1, count) }

        else {

            let fn_name = callers_get_field(line, 0, 0, 0);

            let new_count = count + lint_check_module_caps_fn(fn_name, transitive_map, module_caps);

            lint_check_module_capabilities(entries, transitive_map, module_caps, eol + 1, new_count)

        }

    };

// --- M15 Phase 5: Module Capability Suggestion ---
// Analyzes actual platform capability usage and suggests the correct 'module X requires [...]'.

// Gather all transitive capabilities used by non-platform, non-main functions.
fn ms_gather_used_caps(entries: String, transitive_map: String, pos: i64, acc: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= entries.len() { acc }

    else {

        let eol = callers_find_eol(entries, pos);

        let line = entries.slice(pos, eol);

        if line.len() == 0 { ms_gather_used_caps(entries, transitive_map, eol + 1, acc) }

        else {

            let fn_name = callers_get_field(line, 0, 0, 0);

            let raw_eff = eff_map_get_raw(transitive_map, fn_name, 0);

            let is_plat = str_find(raw_eff, "PLAT:") == 0;

            let new_acc = if is_plat or fn_name == "main" { acc }

            else {

                let trans_eff = eff_map_get(transitive_map, fn_name, 0);

                if trans_eff == "" or trans_eff == "pure" or trans_eff == "*" { acc }

                else { eff_merge_effects(acc, trans_eff) }

            };

            ms_gather_used_caps(entries, transitive_map, eol + 1, new_acc)

        }

    };

// Find any declared 'module X requires [...]' in src, return module name.
fn scan_module_name(src: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= let ident_pos = find_pattern_noa(src, "module ", pos);

    if ident_pos < 0 { "" }

    else {

        let is_real = if ident_pos == 0 { true }

                      else { let prev = src.byte_at(ident_pos - 1); prev == 10 or prev == 13 };

        if is_real {

            let name_start = skip_ws_comments(src, ident_pos + 7);

            let name_end = scan_ident_end(src, name_start);

            if name_end > name_start { src.slice(name_start, name_end) }

            else { scan_module_name(src, ident_pos + 7) }

        }

        else { scan_module_name(src, ident_pos + 7) }

    };

// Main entry for module-suggest command.
fn module_suggest_file(input: String) -> i64

  post it >= 0

= let src = read_file(input);

    if src.len() == 0 { err_no_file(input) }

    else {

        let entries = callers_collect_source(src, 0, "");

        let eff_map = build_fn_effect_map(src, 0, "");

        let transitive_map = build_full_transitive_effect_map(entries, eff_map, 5);

        let used_caps = ms_gather_used_caps(entries, transitive_map, 0, "");

        let declared_caps = scan_module_requires(src, 0);

        let module_name = scan_module_name(src, 0);

        let out_sb = sb_new();

        let _h1 = sb_push(out_sb, "{\"type\":\"module_suggest\",\"file\":\"");

        let _h2 = sb_push(out_sb, json_esc(input));

        let _h3 = sb_push(out_sb, "\",\"module\":\"" + json_esc(module_name) + "\"");

        let _h4 = sb_push(out_sb, ",\"declared\":[");

        let _h5 = sb_push(out_sb, ms_caps_to_json(declared_caps, 0, 1));

        let _h6 = sb_push(out_sb, "],\"suggested\":[");

        let _h7 = sb_push(out_sb, ms_caps_to_json(used_caps, 0, 1));

        let _h8 = sb_push(out_sb, "],\"status\":\"");

        let _h9 = sb_push(out_sb, if eff_set_equals(declared_caps, used_caps) { "ok" }

                                   else if declared_caps == "" { "needs_module" }

                                   else { "mismatch" });

        let _h10 = sb_push(out_sb, "\"}");

        let _p = println_str(sb_build(out_sb));

        0

    };

// Convert space-separated caps list to JSON array of strings.
fn ms_caps_to_json(caps: String, pos: i64, isfirst: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= caps.len() { "" }

    else {

        let end = eff_find_space_or_end(caps, pos);

        let cap = caps.slice(pos, end);

        let this = if cap.len() == 0 { "" }

            else if isfirst == 1 { "\"" + json_esc(cap) + "\"" }

            else { ",\"" + json_esc(cap) + "\"" };

        let rest = if end >= caps.len() { "" }

            else { ms_caps_to_json(caps, end + 1, if cap.len() == 0 { isfirst } else { 0 }) };

        this + rest

    };

// Rule: intent documents intent; contracts verify it. If you write intent, also write contracts.

// v0.101: Detect `else { () }` which is always redundant — use `if cond { expr }` instead.
// In BMB, if-without-else is valid since Cycle 2822. `else { () }` adds no information.

fn lint_check_redundant_else_unit(src: String, pos: i64, count: i64) -> i64

  pre pos >= 0

  post it >= 0

= let p = find_pattern_noa(src, "} else { () }", pos);

    if p < 0 { count }

    else {

        // Skip if inside a string literal: character before } is '"'
        let prev_char = if p > 0 { src.byte_at(p - 1) } else { 0 };

        let is_in_string = prev_char == 34;

        if is_in_string {

            lint_check_redundant_else_unit(src, p + 13, count)

        } else {

            let line_num = count_line_at(src, p + 2, 0, 1);

            let _w = println_str("  [redundant_else_unit] line " + int_to_string(line_num) + ": use 'if cond { ... }' directly (no else needed)");

            lint_check_redundant_else_unit(src, p + 13, count + 1)

        }

    };

fn lint_check_intent_scan(src: String, pos: i64, count: i64) -> i64

  pre pos >= 0

  post it >= 0

= let fn_pos = find_pattern_noa(src, "fn ", pos);

    if fn_pos < 0 { count } else {

        let is_real_fn = if fn_pos == 0 { true }

            else { let prev = src.byte_at(fn_pos - 1); prev == 10 or prev == 13 or prev == 32 or prev == 59 or prev == 9 };

        if is_real_fn {

            let name_start = skip_ws_comments(src, fn_pos + 3);

            let name_end = scan_ident_end(src, name_start);

            let fname = src.slice(name_start, name_end);

            if fname != "" and name_end > name_start {

                let t2 = next_token_raw(src, name_end);

                let after_gen = if tok_kind(t2) == TK_LT() { skip_generic_params(src, tok_end(t2)) } else { name_end };

                let t2g = next_token_raw(src, after_gen);

                if tok_kind(t2g) == TK_LPAREN() {

                    let params = index_collect_params(src, tok_end(t2g), "");

                    let rtype = index_read_ret_type(src, unpack_pos(params));

                    let rp = unpack_pos(rtype);

                    let has_intent = has_intent_annotation(src, rp);

                    let pre_asts = extract_pre_asts(src, rp);

                    let post_asts = extract_post_asts(src, rp);

                    let no_contracts = pre_asts == "" and post_asts == "";

                    let new_count = if has_intent == 1 and no_contracts {

                        let _w = println_str("  [intent_no_contract] " + fname + ": has intent annotation but no pre/post contracts");

                        count + 1

                    } else { count };

                    lint_check_intent_scan(src, fn_pos + 3, new_count)

                } else { lint_check_intent_scan(src, fn_pos + 3, count) }

            } else { lint_check_intent_scan(src, fn_pos + 3, count) }

        } else { lint_check_intent_scan(src, fn_pos + 3, count) }

    };

// Scan backward from pos to find start of current line (first char after preceding \n)
fn lint_find_sol(src: String, pos: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos == 0 { 0 }

    else if src.byte_at(pos - 1) == 10 { pos }

    else { lint_find_sol(src, pos - 1) };

// Check for non-unit functions with no post condition (regression prevention for M9)
fn lint_check_missing_post(src: String, pos: i64, count: i64) -> i64

  pre pos >= 0

  post it >= 0

= let fn_pos = find_pattern_noa(src, "fn ", pos);

    if fn_pos < 0 { count } else {

        let prev_ok = if fn_pos == 0 { true }

            else { let prev = src.byte_at(fn_pos - 1); prev == 10 or prev == 13 or prev == 32 or prev == 59 or prev == 9 };

        let not_in_comment = if prev_ok {

            let sol = lint_find_sol(src, fn_pos);

            not (find_pattern_noa_range(src, "//", sol, fn_pos) >= 0)

        } else { false };

        let is_real_fn = prev_ok and not_in_comment;

        if is_real_fn {

            let name_start = skip_ws_comments(src, fn_pos + 3);

            let name_end = scan_ident_end(src, name_start);

            let fname = src.slice(name_start, name_end);

            if fname != "" and name_end > name_start {

                let t2 = next_token_raw(src, name_end);

                let after_gen = if tok_kind(t2) == TK_LT() { skip_generic_params(src, tok_end(t2)) } else { name_end };

                let t2g = next_token_raw(src, after_gen);

                if tok_kind(t2g) == TK_LPAREN() {

                    let params = index_collect_params(src, tok_end(t2g), "");

                    let rtype = index_read_ret_type(src, unpack_pos(params));

                    let ret_str = unpack_ast(rtype);

                    let rp = unpack_pos(rtype);

                    let is_unit = ret_str == "()" or ret_str == "?" or fname == "main";

                    let post_asts = extract_post_asts(src, rp);

                    let new_count = if not is_unit and post_asts == "" {

                        let _w = println_str("  [missing_postcondition] " + fname + ": non-unit return with no post condition");

                        count + 1

                    } else { count };

                    lint_check_missing_post(src, fn_pos + 3, new_count)

                } else { lint_check_missing_post(src, fn_pos + 3, count) }

            } else { lint_check_missing_post(src, fn_pos + 3, count) }

        } else { lint_check_missing_post(src, fn_pos + 3, count) }

    };

// Check if params text contains exactly 'n: i64' or 'count: i64' as a param name
// Returns 1 if found, 0 otherwise
fn lpr_has_n_or_count_param(params: String) -> i64
  post it == 0 or it == 1
= if params.starts_with("n: i64") { 1 }
  else if params.contains(", n: i64") { 1 }
  else if params.starts_with("count: i64") { 1 }
  else if params.contains(", count: i64") { 1 }
  else { 0 };

// Check [missing_precondition]: function has n: i64 or count: i64 param but no pre condition
fn lint_check_missing_pre(src: String, pos: i64, count: i64) -> i64

  pre pos >= 0

  post it >= 0

= let fn_pos = find_pattern_noa(src, "fn ", pos);

    if fn_pos < 0 { count } else {

        let prev_ok = if fn_pos == 0 { true }

            else { let prev = src.byte_at(fn_pos - 1); prev == 10 or prev == 13 or prev == 32 or prev == 59 or prev == 9 };

        let not_in_comment = if prev_ok {

            let sol = lint_find_sol(src, fn_pos);

            not (find_pattern_noa_range(src, "//", sol, fn_pos) >= 0)

        } else { false };

        let is_real_fn = prev_ok and not_in_comment;

        if is_real_fn {

            let name_start = skip_ws_comments(src, fn_pos + 3);

            let name_end = scan_ident_end(src, name_start);

            let fname = src.slice(name_start, name_end);

            if fname != "" and fname != "main" and name_end > name_start {

                let t2 = next_token_raw(src, name_end);

                let after_gen = if tok_kind(t2) == TK_LT() { skip_generic_params(src, tok_end(t2)) } else { name_end };

                let t2g = next_token_raw(src, after_gen);

                if tok_kind(t2g) == TK_LPAREN() {

                    let params = index_collect_params(src, tok_end(t2g), "");

                    let params_str = unpack_ast(params);

                    let rtype = index_read_ret_type(src, unpack_pos(params));

                    let rp = unpack_pos(rtype);

                    let pre_asts = extract_pre_asts(src, rp);

                    let new_count = if lpr_has_n_or_count_param(params_str) == 1 and pre_asts == "" {

                        let _w = println_str("  [missing_precondition] " + fname + ": n/count param has no pre condition");

                        count + 1

                    } else { count };

                    lint_check_missing_pre(src, fn_pos + 3, new_count)

                } else { lint_check_missing_pre(src, fn_pos + 3, count) }

            } else { lint_check_missing_pre(src, fn_pos + 3, count) }

        } else { lint_check_missing_pre(src, fn_pos + 3, count) }

    };

// Return the minimum non-negative position, or -1 if both are negative
fn lint_todo_min_pos(p_todo: i64, p_fixme: i64) -> i64

  post it >= -1

= if p_todo >= 0 and (p_fixme < 0 or p_todo <= p_fixme) { p_todo }
    else { p_fixme };

// Advance past the TODO/FIXME marker found at position p
fn lint_todo_next_pos(src: String, p: i64) -> i64

  pre p >= 0

  post it >= 0

= let is_fixme = src.len() >= p + 8 and match_bytes(src, "// FIXME", p, 0);
    if is_fixme { p + 8 } else { p + 7 };

// Check for TODO and FIXME markers in line comments (unresolved work items)
fn lint_check_todo_comment(src: String, pos: i64, count: i64) -> i64

  pre pos >= 0

  post it >= 0

= let p_todo = find_pattern_noa(src, "// TODO", pos);

    let p_fixme = find_pattern_noa(src, "// FIXME", pos);

    let p = lint_todo_min_pos(p_todo, p_fixme);

    if p < 0 { count }

    else {

        // Skip if inside a string literal: character before "//" is '"'
        let prev_char = if p > 0 { src.byte_at(p - 1) } else { 0 };

        let is_in_string = prev_char == 34;

        let next_p = lint_todo_next_pos(src, p);

        if is_in_string {

            lint_check_todo_comment(src, next_p, count)

        } else {

            let line_num = count_line_at(src, p, 0, 1);

            let eol = lint_find_eol(src, p);

            let snippet = src.slice(p + 3, eol);

            let _w = println_str("  [todo_comment] line " + int_to_string(line_num) + ": " + snippet);

            lint_check_todo_comment(src, next_p, count + 1)

        }

    };

// Count '"' chars between sol and pos (exclusive) to detect string literal context
fn lint_mn_count_quotes(src: String, p: i64, end: i64, count: i64) -> i64

  pre p <= end

  post it >= 0

= if p >= end { count }
    else if src.byte_at(p) == 34 { lint_mn_count_quotes(src, p + 1, end, count + 1) }
    else { lint_mn_count_quotes(src, p + 1, end, count) };

// Find end position of digit run starting at pos
fn lint_mn_run_end(src: String, p: i64) -> i64

  pre p >= 0

  post it >= p

= if p >= src.len() { src.len() }
    else if is_digit(src.byte_at(p)) { lint_mn_run_end(src, p + 1) }
    else { p };

// Report magic number if not in contract/const-body context; return updated count
fn lint_mn_check_candidate(src: String, pos: i64, num_end: i64, sol: i64, count: i64) -> i64

  pre pos >= 0 and num_end >= pos and sol >= 0
  post it >= count

= let in_comment = find_pattern_noa_range(src, "//", sol, pos) >= 0
                or find_pattern_noa_range(src, "--", sol, pos) >= 0;
    if in_comment { count }
    else {
        let q_count = lint_mn_count_quotes(src, sol, pos, 0);
        let in_string = (q_count % 2) == 1;
        if in_string { count }
        else {
            let has_post = find_pattern_noa_range(src, "post ", sol, sol + 12) >= 0;
            let has_pre  = find_pattern_noa_range(src, "pre ", sol, sol + 10) >= 0;
            let is_const_body = src.len() > sol and src.byte_at(sol) == 61
                             and src.len() > sol + 2 and is_digit(src.byte_at(sol + 2));
            if has_post or has_pre or is_const_body { count }
            else {
                let line_num = count_line_at(src, pos, 0, 1);
                let snippet = src.slice(pos, num_end);
                let _w = println_str("  [magic_number] line " + int_to_string(line_num) + ": " + snippet);
                count + 1
            }
        }
    };

// Check for integer literals >= 4 digits outside strings/contracts/comments
fn lint_check_magic_number(src: String, pos: i64, count: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos + 2 >= src.len() { count }
    else if is_digit(src.byte_at(pos))
         and is_digit(src.byte_at(pos + 1))
         and is_digit(src.byte_at(pos + 2)) {

        let prev = if pos > 0 { src.byte_at(pos - 1) } else { 0 };
        let is_continuation = is_alnum_or_underscore(prev);

        if is_continuation {
            lint_check_magic_number(src, pos + 1, count)
        } else {
            let num_end = lint_mn_run_end(src, pos);
            let num_len = num_end - pos;
            if num_len < 4 {
                lint_check_magic_number(src, num_end, count)
            } else {
                let sol = lint_find_sol(src, pos);
                let new_count = lint_mn_check_candidate(src, pos, num_end, sol, count);
                lint_check_magic_number(src, num_end, new_count)
            }
        }
    } else { lint_check_magic_number(src, pos + 1, count) };

// Check if everything after pos (until newline) is whitespace or starts a comment
fn lint_dn_is_eol(src: String, pos: i64) -> bool

  pre pos >= 0
  post it or not it

= if pos >= src.len() { true }
    else {
        let c = src.byte_at(pos);
        if c == 10 { true }
        else if c == 13 { true }
        else if c == 32 { lint_dn_is_eol(src, pos + 1) }
        else if c == 9 { lint_dn_is_eol(src, pos + 1) }
        else if c == 47 and src.len() > pos + 1 and src.byte_at(pos + 1) == 47 { true }
        else { false }
    };

// Check for deeply nested block openers ({ at EOL with depth > 5)
fn lint_check_deep_nesting(src: String, pos: i64, depth: i64, in_str: i64, count: i64) -> i64

  pre pos >= 0 and depth >= 0
  post it >= 0

= if pos >= src.len() { count }
    else {
        let c = src.byte_at(pos);
        if in_str == 1 {
            if c == 92 { lint_check_deep_nesting(src, pos + 2, depth, 1, count) }
            else if c == 34 { lint_check_deep_nesting(src, pos + 1, depth, 0, count) }
            else { lint_check_deep_nesting(src, pos + 1, depth, 1, count) }
        } else if c == 34 { lint_check_deep_nesting(src, pos + 1, depth, 1, count) }
        else if c == 47 and src.len() > pos + 1 and src.byte_at(pos + 1) == 47 {
            let eol = lint_find_eol(src, pos);
            lint_check_deep_nesting(src, eol + 1, depth, 0, count)
        } else if c == 45 and src.len() > pos + 1 and src.byte_at(pos + 1) == 45 {
            let eol = lint_find_eol(src, pos);
            lint_check_deep_nesting(src, eol + 1, depth, 0, count)
        } else if c == 123 {
            let new_depth = depth + 1;
            if new_depth > 5 and lint_dn_is_eol(src, pos + 1) {
                let line_num = count_line_at(src, pos, 0, 1);
                let _w = println_str("  [deep_nesting] line " + int_to_string(line_num) + ": depth " + int_to_string(new_depth));
                lint_check_deep_nesting(src, pos + 1, new_depth, 0, count + 1)
            } else { lint_check_deep_nesting(src, pos + 1, new_depth, 0, count) }
        } else if c == 125 {
            let new_depth = if depth > 0 { depth - 1 } else { 0 };
            lint_check_deep_nesting(src, pos + 1, new_depth, 0, count)
        } else { lint_check_deep_nesting(src, pos + 1, depth, in_str, count) }
    };

// Find matching close paren starting from pos (depth=0 means at the current nesting level)
fn lint_nc_find_close(src: String, pos: i64, depth: i64) -> i64

  pre pos >= 0 and depth >= 0

  post it >= -1

= if pos >= src.len() { -1 }
    else {
        let c = src.byte_at(pos);
        if c == 40 { lint_nc_find_close(src, pos + 1, depth + 1) }
        else if c == 41 {
            if depth == 0 { pos }
            else { lint_nc_find_close(src, pos + 1, depth - 1) }
        }
        else { lint_nc_find_close(src, pos + 1, depth) }
    };

// Check if inner expression is simple X == Y (no compound and/or/not operators)
fn lint_nc_is_simple_eq(inner: String) -> i64

  post it == 0 or it == 1

= if find_pattern_noa_range(inner, " and ", 0, inner.len()) >= 0 { 0 }
    else if find_pattern_noa_range(inner, " or ", 0, inner.len()) >= 0 { 0 }
    else if find_pattern_noa_range(inner, "not (", 0, inner.len()) >= 0 { 0 }
    else if find_pattern_noa_range(inner, "==", 0, inner.len()) >= 0 { 1 }
    else { 0 };

// Check [negated_condition]: not (X == Y) can be simplified to X != Y
fn lint_check_negated_condition(src: String, pos: i64, count: i64) -> i64

  pre pos >= 0 and count >= 0

  post it >= 0

= let nt_pos = find_pattern_noa(src, "not (", pos);
    if nt_pos < 0 { count } else {
        let inner_start = nt_pos + 5;
        let inner_end = lint_nc_find_close(src, inner_start, 0);
        let new_count = if inner_end > 0 and inner_end > inner_start {
            let inner = src.slice(inner_start, inner_end);
            if lint_nc_is_simple_eq(inner) == 1 {
                let sol = lint_find_sol(src, nt_pos);
                let in_comment = find_pattern_noa_range(src, "//", sol, nt_pos) >= 0;
                if not in_comment {
                    let line_num = count_line_at(src, nt_pos, 0, 1);
                    let _w = println_str("  [negated_condition] line " + int_to_string(line_num) + ": not (" + inner + ") use != instead");
                    count + 1
                } else { count }
            } else { count }
        } else { count };
        lint_check_negated_condition(src, nt_pos + 5, new_count)
    };

fn brwp_body_window() -> i64
  post it == 1500
= 1500;

// Check [bool_return_without_post]: -> i64 fn with { 1 } else { 0 } pattern but no 'post it == 0 or it == 1'
fn lint_brwp_next_fn(src: String, pos: i64) -> i64

  pre pos >= 0

  post it >= -1

= let p = find_pattern_noa(src, "\nfn ", pos);

    if p < 0 { p } else { p + 1 };

fn lint_brwp_check_fn(src: String, fn_pos: i64, fname: String, rp: i64, count: i64) -> i64

  pre fn_pos >= 0 and rp >= 0 and count >= 0

  post it >= 0

= let next_fn = lint_brwp_next_fn(src, rp);

    let body_end = if next_fn > rp { next_fn }
                   else if rp + brwp_body_window() < src.len() { rp + brwp_body_window() }
                   else { src.len() };

    let window = src.slice(rp, body_end);

    let has_bool_post = find_pattern_noa(window, "post it == 0 or it == 1", 0) >= 0
                    or find_pattern_noa(window, "post it == 1 or it == 0", 0) >= 0;

    let tail_off = if window.len() > 100 { window.len() - 100 } else { 0 };
    let win_tail = window.slice(tail_off, window.len());
    let has_bool_pat = find_pattern_noa(win_tail, "{ 1 } else { 0 };\n\n", 0) >= 0
                    or find_pattern_noa(win_tail, "{ 0 } else { 1 };\n\n", 0) >= 0;

    if not has_bool_post and has_bool_pat {

        let line_num = count_line_at(src, fn_pos, 0, 1);

        let _w = println_str("  [bool_return_without_post] line " + int_to_string(line_num) + ": " + fname + ": returns bool-as-i64 without 'post it == 0 or it == 1'");

        count + 1

    } else { count };

// Check [bool_return_without_post]: -> i64 fn with { 1 } else { 0 } pattern but no 'post it == 0 or it == 1'
fn lint_check_bool_return_without_post(src: String, pos: i64, count: i64) -> i64

  pre pos >= 0

  post it >= 0

= let fn_pos = find_pattern_noa(src, "fn ", pos);

    if fn_pos < 0 { count } else {

        let prev_ok = if fn_pos == 0 { true }
            else { let prev = src.byte_at(fn_pos - 1); prev == 10 or prev == 13 or prev == 32 or prev == 59 or prev == 9 };

        let sol = lint_find_sol(src, fn_pos);

        let not_in_comment = not (find_pattern_noa_range(src, "//", sol, fn_pos) >= 0);

        let is_real_fn = prev_ok and not_in_comment;

        if is_real_fn {

            let name_start = skip_ws_comments(src, fn_pos + 3);

            let name_end = scan_ident_end(src, name_start);

            let fname = src.slice(name_start, name_end);

            if fname != "" and name_end > name_start {

                let t2 = next_token_raw(src, name_end);

                let after_gen = if tok_kind(t2) == TK_LT() { skip_generic_params(src, tok_end(t2)) } else { name_end };

                let t2g = next_token_raw(src, after_gen);

                if tok_kind(t2g) == TK_LPAREN() {

                    let params = index_collect_params(src, tok_end(t2g), "");

                    let rtype = index_read_ret_type(src, unpack_pos(params));

                    let new_count = if unpack_ast(rtype) == "i64" {

                        lint_brwp_check_fn(src, fn_pos, fname, unpack_pos(rtype), count)

                    } else { count };

                    lint_check_bool_return_without_post(src, fn_pos + 3, new_count)

                } else { lint_check_bool_return_without_post(src, fn_pos + 3, count) }

            } else { lint_check_bool_return_without_post(src, fn_pos + 3, count) }

        } else { lint_check_bool_return_without_post(src, fn_pos + 3, count) }

    };

// Bundle source-level lint checks (intent, redundant_else_unit, missing_postcondition, todo_comment, magic_number, deep_nesting, missing_precondition, negated_condition, bool_return_without_post)
fn lint_source_checks(source: String) -> i64

  post it >= 0

= let w6 = lint_check_intent_scan(source, 0, 0);

    let w11 = lint_check_redundant_else_unit(source, 0, 0);

    let w12 = lint_check_missing_post(source, 0, 0);

    let w13 = lint_check_todo_comment(source, 0, 0);

    let w14 = lint_check_magic_number(source, 0, 0);

    let w15 = lint_check_deep_nesting(source, 0, 0, 0, 0);

    let w16 = lint_check_missing_pre(source, 0, 0);

    let w17 = lint_check_negated_condition(source, 0, 0);

    let w18 = lint_check_bool_return_without_post(source, 0, 0);

    w6 + w11 + w12 + w13 + w14 + w15 + w16 + w17 + w18;

fn lint_file(input: String) -> i64

  post it >= 0

=

    let source = read_file(input);

    if source.len() == 0 {

        err_no_file(input)

    } else {

        let entries = callers_collect_source(source, 0, "");

        let _header = println_str("# Lint: " + input);

        let w1 = lint_check_unused(entries, 0, entries, 0);

        let w2 = lint_check_many_params(entries, 0, 0);

        let w3 = lint_check_naming(entries, 0, 0);

        let w4 = lint_check_complexity(entries, 0, 0);

        let w5 = lint_check_recursive(entries, 0, 0);

        let wsrc = lint_source_checks(source);

        let w7 = lint_check_effect_violations(entries, 0, 0);

        let eff_map = build_fn_effect_map(source, 0, "");

        let transitive_map = build_transitive_effect_map(entries, eff_map, 5);

        let w8 = lint_check_effect_propagation(entries, transitive_map, 0, 0);

        let w9 = lint_check_missing_effect_annotations(entries, eff_map, transitive_map, 0, 0);

        let module_caps = scan_module_requires(source, 0);

        let full_trans_map = if module_caps != "" { build_full_transitive_effect_map(entries, eff_map, 5) } else { "" };

        let w10 = lint_check_module_capabilities(entries, full_trans_map, module_caps, 0, 0);

        let total = w1 + w2 + w3 + w4 + wsrc + w7 + w8 + w9 + w10;

        let _sep = println_str("---");

        if total == 0 {

            { println_str("OK: " + input + " - no warnings (" + int_to_string(w5) + " recursive)"); 0 }

        } else {

            { println_str("Warnings: " + int_to_string(total) + " (" + int_to_string(w5) + " recursive)"); total }

        }

    };

// Lint all .bmb files in a directory

fn lint_find_bmb(files: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= files.len() { "" }

    else {

        let eol = lint_find_eol(files, pos);

        let name = files.slice(pos, eol);

        let rest = lint_find_bmb(files, eol + 1);

        if name.len() > 4 and name.slice(name.len() - 4, name.len()) == ".bmb" {

            if rest == "" { name } else { name + "\n" + rest }

        } else { rest }

    };

fn lint_find_eol(s: String, pos: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= s.len() { s.len() }

    else if s.byte_at(pos) == 10 { pos }

    else { lint_find_eol(s, pos + 1) };

fn lint_dir_each(bmb_files: String, pos: i64, dir: String, total_warn: i64, file_count: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= bmb_files.len() {

        let _s = println_str("=== Lint summary: " + int_to_string(file_count) + " files, " + int_to_string(total_warn) + " warnings ===");

        total_warn

    } else {

        let eol = lint_find_eol(bmb_files, pos);

        let name = bmb_files.slice(pos, eol);

        if name.len() == 0 { lint_dir_each(bmb_files, eol + 1, dir, total_warn, file_count) }

        else {

            let path = dir + "/" + name;

            let warns = lint_file(path);

            let _blank = println_str("");

            lint_dir_each(bmb_files, eol + 1, dir, total_warn + warns, file_count + 1)

        }

    };

fn lint_dir(dir: String) -> i64


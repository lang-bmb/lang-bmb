        let _r = if txt.len() > 0 {

            let _q1 = sb_push(sb, "\"");

            let _esc = sb_push(sb, json_esc(txt));

            let _q2 = sb_push(sb, "\"");

            if eot < texts.len() { sb_push(sb, ",") } else { 0 }

        } else { 0 };

        emit_contract_json(texts, sb, eot + 1)

    };

// M13 Phase 3: Emit one function's repair hint JSON.

 "@vec_remove" => "pi", "@vec_reverse" => "p", "@vec_set" => "pii", "@vec_slice" => "pii", "@vec_sort" => "p", "@vec_sum" => "p", "@vec_swap" => "pii", "@vec_with_capacity" => "i", "@write_file_newlines" => "pp", _ => "" };

// Returns pair: (conversions_string, formatted_args_string)

// Uses separator "###" to split conversions from args

fn format_call_args_typed(args: String, types: String, pos: i64, idx: i64, conv_acc: String, arg_acc: String) -> String

  pre pos >= 0

  post it.len() >= 1

= let p = low_skip_ws(args, pos);

    if p >= args.len() { conv_acc + "###" + arg_acc } else {

        let comma = find_comma_or_end(args, p);

        let arg = trim_end(args.slice(p, comma));

        let typ = if idx < types.len() { types.byte_at(idx) } else { 105 };

        let pair = match typ { 112 => let ptr_name = arg + "_p" + int_to_string(idx); let conv = "  " + ptr_name + " = inttoptr i64 " + arg + " to ptr" + SEP(); let typed_arg = "ptr " + ptr_name; pack_conv_arg(conv, typed_arg), 100 => pack_conv_arg("", "double " + arg), 115 => let i32_name = arg + "_s" + int_to_string(idx); let conv = "  " + i32_name + " = trunc i64 " + arg + " to i32" + SEP(); let typed_arg = "i32 " + i32_name; pack_conv_arg(conv, typed_arg), _ => pack_conv_arg("", "i64 " + arg) };





























        let new_conv = conv_acc + unpack_conv(pair);

        let typed_arg = unpack_arg(pair);

        let new_arg = if arg_acc == "" { typed_arg } else { arg_acc + ", " + typed_arg };

        if comma >= args.len() { new_conv + "###" + new_arg } else { format_call_args_typed(args, types, comma + 1, idx + 1, new_conv, new_arg) }

    };

// Helper to pack conversion and arg into a pair string

fn pack_conv_arg(conv: String, arg: String) -> String

  post it.len() == conv.len() + 3 + arg.len()

= conv + "###" + arg;

// Helper to unpack conversion from pair

fn unpack_conv(pair: String) -> String

  post it.len() <= pair.len()

= let sep = find_separator(pair, 0);

    pair.slice(0, sep);

// Helper to unpack arg from pair

fn unpack_arg(pair: String) -> String

  post it.len() <= pair.len()

= let sep = find_separator(pair, 0);

    pair.slice(sep + 3, pair.len());

// Find "###" separator

fn find_separator(s: String, pos: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos + 2 >= s.len() { s.len() }

    else if s.byte_at(pos) == 35 and s.byte_at(pos + 1) == 35 and s.byte_at(pos + 2) == 35 { pos }

    else { find_separator(s, pos + 1) };

fn call_arg_conversions(formatted: String) -> String

  post it.len() <= formatted.len()

= let sep = find_separator(formatted, 0);

    formatted.slice(0, sep);

fn call_arg_formatted(formatted: String) -> String

  post it.len() <= formatted.len()

= let sep = find_separator(formatted, 0);

    formatted.slice(sep + 3, formatted.len());

fn find_comma(s: String, pos: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= s.len() { pos } else if s.byte_at(pos) == 44 { pos } else { find_comma(s, pos + 1) };

fn find_comma_or_end(s: String, pos: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= s.len() { pos } else if s.byte_at(pos) == 44 { pos } else { find_comma_or_end(s, pos + 1) };

fn find_char(s: String, pos: i64, ch: i64) -> i64

  pre pos >= 0 and ch >= 0

  post it >= 0

= if pos >= s.len() { pos } else if s.byte_at(pos) == ch { pos } else { find_char(s, pos + 1, ch) };

fn trim_end(s: String) -> String

  post it.len() <= s.len()

= trim_end_at(s, s.len() - 1);

fn trim_end_at(s: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos < 0 { "" } else if is_whitespace(s.byte_at(pos)) { trim_end_at(s, pos - 1) } else { s.slice(0, pos + 1) };

// v0.46: Trim both leading and trailing whitespace

fn trim(s: String) -> String

  post it.len() <= s.len()

= let start = low_skip_ws(s, 0);

    if start >= s.len() { "" } else { trim_end(s.slice(start, s.len())) };

fn llvm_gen_return_typed(line: String, pos: i64, ret_type: String) -> String

  pre pos >= 0

  post it.len() >= 1

= let val_start = low_skip_ws(line, pos + 6);

    let val_raw = line.slice(val_start, line.len());

    let val = trim(val_raw);

    // Cycle 2375: `= todo` and `= ()` function bodies produce raw integer 0

    // (from unit lowering) in a typed return slot. Substitute a type-

    // appropriate literal so the emitted IR type-checks.

    let vlen = val.len();

    let is_zero = if vlen == 1 { val.byte_at(0) == 48 } else { false };

    let is_todo = if vlen == 5 { val.byte_at(0) == 37 and val.byte_at(1) == 116 and val.byte_at(2) == 111 and val.byte_at(3) == 100 and val.byte_at(4) == 111 } else { false };

    let needs_fix = is_zero or is_todo;

    match ret_type { "f64" => if needs_fix { "  ret double 0.0" } else { "  ret double " + val }, "ptr" => if needs_fix { "  ret ptr null" } else { "  ret ptr " + val }, "i32" => if is_todo { "  ret i32 0" } else { "  " + val + "_i32r = trunc i64 " + val + " to i32" + SEP() + "  ret i32 " + val + "_i32r" }, _ => if is_todo { "  ret i64 0" } else { "  ret i64 " + val } };

















fn llvm_gen_branch(line: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 1

= let after = low_skip_ws(line, pos + 6);

    let comma1 = find_comma(line, after);

    let cond = trim_end(line.slice(after, comma1));

    let after1 = low_skip_ws(line, comma1 + 1);

    let comma2 = find_comma(line, after1);

    let then_label = line.slice(after1, comma2);

    let after2 = low_skip_ws(line, comma2 + 1);

    let else_label = trim_end(line.slice(after2, line.len()));

    // v0.96.46: Add branch weights for loop conditions (2000:1 body:exit)

    let is_loop_branch = has_pattern(then_label, "for_body", 0) or has_pattern(then_label, "while_body", 0) or has_pattern(then_label, "loop_body", 0);

    let prof = if is_loop_branch { ", !prof !907" } else { "" };

    "  " + cond + "_i1 = trunc i64 " + cond + " to i1" + SEP() + "  br i1 " + cond + "_i1, label %" + trim_end(then_label) + ", label %" + else_label + prof;

fn llvm_gen_goto(line: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 1

= let label_start = low_skip_ws(line, pos + 4);

    let label = line.slice(label_start, line.len());

    "  br label %" + trim_end(label);

// v0.92: Float binary operation

// MIR: f+ %a, %b -> LLVM: fadd double %a, %b

fn llvm_gen_float_binop(op: String, line: String, pos: i64, dest: String) -> String

  pre pos >= 0

  post it.len() >= 1

= let p1 = low_skip_ws(line, pos);

    let comma = find_comma(line, p1);

    let left = line.slice(p1, comma);

    let p2 = low_skip_ws(line, comma + 1);

    let right = line.slice(p2, line.len());

    "  " + dest + " = " + op + " double " + trim_end(left) + ", " + trim_end(right);

// v0.92: Float comparison operation

// MIR: f< %a, %b -> LLVM: fcmp olt double %a, %b + zext i1 to i64

fn llvm_gen_float_cmp(pred: String, line: String, pos: i64, dest: String) -> String

  pre pos >= 0

  post it.len() >= 1

= let p1 = low_skip_ws(line, pos);

    let comma = find_comma(line, p1);

    let left = line.slice(p1, comma);

    let p2 = low_skip_ws(line, comma + 1);

    let right = line.slice(p2, line.len());

    "  " + dest + "_cmp = fcmp " + pred + " double " + trim_end(left) + ", " + trim_end(right) + SEP() + "  " + dest + " = zext i1 " + dest + "_cmp to i64";

// v0.92: Alloca for mutable variables - emit LLVM alloca and mark in mapping

// MIR: alloca %name -> LLVM: %name = alloca i64 + mapping[%name] = ALLOCA

fn llvm_gen_alloca(line: String, pos: i64, mapping: String) -> String

  pre pos >= 0

  post it.len() >= 1

= let name_start = low_skip_ws(line, pos + 6);

    let name = trim_end(line.slice(name_start, line.len()));

    let new_mapping = add_mapping(mapping, name, "ALLOCA");

    changed_mapping(new_mapping, "  " + name + " = alloca i64");

// v0.92: Store for mutable variables

// MIR: store %name, %_tN -> LLVM: store i64 %resolved_src, ptr %name

fn llvm_gen_store_sb(line: String, pos: i64, mapping: String, str_sb: i64) -> String

  pre pos >= 0

  post it.len() >= 1

= let after_store = low_skip_ws(line, pos + 5);

    let comma_pos = find_comma(line, after_store);

    let dest_name = trim_end(line.slice(after_store, comma_pos));

    let src_start = low_skip_ws(line, comma_pos + 1);

    let src = trim_end(line.slice(src_start, line.len()));

    let resolved_src = resolve_variable(src, mapping);

    let src_is_double = is_double_var_sb(src, str_sb);

    let src_is_string = is_string_var_sb(src, str_sb);

    let src_is_f64_ptr = is_f64_ptr_sb(src, str_sb);

    let src_is_str_ptr = is_str_ptr_sb(src, str_sb);

    let src_is_i32 = is_i32_var_sb(src, str_sb);

    // v0.95: Propagate closure marker from source to dest

    let src_is_closure = is_closure_var_sb(src, str_sb);

    let _w_cl = if src_is_closure {

        let cap_count = get_closure_cap_count_sb(src, str_sb);

        push_closure_marker(str_sb, dest_name, cap_count)

    } else { 0 };

    let _w1 = if src_is_string { push_string_marker(str_sb, dest_name) }

        else if src_is_f64_ptr { push_f64_ptr_marker(str_sb, dest_name) }

        else if src_is_str_ptr { push_str_ptr_marker(str_sb, dest_name) }

        else if src_is_i32 { push_i32_marker(str_sb, dest_name) }

        else { 0 };

    if src_is_double {

        let _w = push_double_marker(str_sb, dest_name);

        same_mapping("  store double " + resolved_src + ", ptr " + dest_name)

    } else {

        same_mapping("  store i64 " + resolved_src + ", ptr " + dest_name)

    };

fn eliminate_identity_copies_ir(ir: String) -> String

  post it.len() <= ir.len()

= {

    let aliases = build_ir_copy_aliases(ir, 0, "");

    if aliases.len() == 0 { ir }

    else {

        let sb = sb_new();

        let _w = rebuild_ir_no_copies(ir, 0, sb, aliases);

        sb_build(sb)

    }

};

// Cycle 2375: Walk lines, replace `  ret double 0` with `  ret double 0.0`,

// `  ret float 0` with `  ret float 0.0`, `  ret ptr 0` with `  ret ptr null`.

// Arises when `= todo` or `= ()` body's unit constant `0` propagates through

// eliminate_identity_copies_ir into a typed ret slot.

fn fix_typed_ret_placeholders_ir(ir: String) -> String

  post it.len() >= 0

= {

    let sb = sb_new();

    let _w = fix_ret_scan(ir, 0, sb);

    let result = sb_build(sb);

    let _f = sb_free(sb);

    result

};

fn fix_ret_scan(ir: String, pos: i64, sb: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= ir.len() { 0 }

    else {

        let pipe_pos = find_pipe_skip_quotes(ir, pos);

        let line = ir.slice(pos, pipe_pos);

        let fixed = fix_ret_line(line);

        let len = sb_len(sb);

        let _w1 = if len > 0 { sb_push(sb, SEP()) } else { 0 };

        let _w2 = sb_push(sb, fixed);

        if pipe_pos >= ir.len() { 0 }

        else { fix_ret_scan(ir, pipe_pos + 1, sb) }

    };

fn fix_ret_line(line: String) -> String

  post it.len() >= 0

= let p = low_skip_ws(line, 0);

    if p >= line.len() { line }

    else if low_starts_with_at(line, p, "ret double 0") and p + 12 == line.len() { "  ret double 0.0" }

    else if low_starts_with_at(line, p, "ret float 0") and p + 11 == line.len() { "  ret float 0.0" }

    else if low_starts_with_at(line, p, "ret ptr 0") and p + 9 == line.len() { "  ret ptr null" }

    else { line };

// Pass 1: Scan LLVM IR lines for identity copy patterns, build alias table

// Alias table format: ",dest=src,dest2=src2" (comma-prefixed for safe lookup)

fn build_ir_copy_aliases(ir: String, pos: i64, aliases: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= ir.len() { aliases }

    else {

        let pipe_pos = find_pipe_skip_quotes(ir, pos);

        let ws_start = low_skip_ws(ir, pos);

        let new_aliases = if ws_start < pipe_pos and ir.byte_at(ws_start) == 37 {

            let line = ir.slice(pos, pipe_pos);

            try_add_ir_copy_alias(line, aliases)

        } else { aliases };

        if pipe_pos >= ir.len() { new_aliases }

        else { build_ir_copy_aliases(ir, pipe_pos + 1, new_aliases) }

    };

// Check if line is an identity copy, add alias if so

fn try_add_ir_copy_alias(line: String, aliases: String) -> String

  post it.len() >= aliases.len()

= {

    let p = low_skip_ws(line, 0);

    if p >= line.len() { aliases }

    else if line.byte_at(p) != 37 { aliases }

    else {

        let eq_pos = find_eq(line, p);

        if eq_pos >= line.len() { aliases }

        else {

            let dest = trim(line.slice(p, eq_pos));

            let rhs = trim(line.slice(eq_pos + 1, line.len()));

            if rhs == "add nsw i64 0, 0" {

                aliases + "," + dest + "=0"

            } else if starts_with(rhs, "add nsw i64 0, ", 0) {

                let src = rhs.slice(15, rhs.len());

                let resolved = resolve_ir_alias_d(aliases, src, 0);

                aliases + "," + dest + "=" + resolved

            } else if starts_with(rhs, "fadd nsz double 0.0, ", 0) {

                let src = rhs.slice(21, rhs.len());

                let resolved = resolve_ir_alias_d(aliases, src, 0);

                aliases + "," + dest + "=" + resolved

            } else { aliases }

        }

    }

};

// Searches for ",name=" in aliases string, returns position of value (after '=')

// or -1 if not found. Avoids creating "," + name + "=" key string.

fn find_alias_entry_noa(aliases: String, name: String, pos: i64) -> i64

    post it >= -1

= 

    if pos >= aliases.len() { 0 - 1 }

    else {

        let comma = find_char(aliases, pos, 44);

        if comma >= aliases.len() { 0 - 1 }

        else {

            let entry_start = comma + 1;

            let eq_after = entry_start + name.len();

            if eq_after < aliases.len()

               and match_bytes(aliases, name, entry_start, 0)

               and aliases.byte_at(eq_after) == 61 {

                eq_after + 1

            } else {

                find_alias_entry_noa(aliases, name, comma + 1)

            }

        }

    };

// Resolve alias transitively with depth limit

fn resolve_ir_alias_d(aliases: String, name: String, depth: i64) -> String

  pre depth >= 0

  post it.len() >= 0

= if depth > 20 { name }

    else {

        let val_start = find_alias_entry_noa(aliases, name, 0);

        if val_start < 0 { name }

        else {

            let comma_pos = find_char(aliases, val_start, 44);

            let target = if comma_pos >= aliases.len() { aliases.slice(val_start, aliases.len()) }

                         else { aliases.slice(val_start, comma_pos) };

            resolve_ir_alias_d(aliases, target, depth + 1)

        }

    };

// Check if LLVM IR line is an identity copy

fn is_identity_copy_ir(line: String) -> bool

  post not it or line.contains("add nsw i64 0, ") or line.contains("fadd nsz double 0.0, ")

= {

    let p = low_skip_ws(line, 0);

    if p >= line.len() { false }

    else if line.byte_at(p) != 37 { false }

    else {

        let eq_pos = find_eq(line, p);

        if eq_pos >= line.len() { false }

        else {

            let rhs = trim(line.slice(eq_pos + 1, line.len()));

            rhs == "add nsw i64 0, 0" or starts_with(rhs, "add nsw i64 0, ", 0) or starts_with(rhs, "fadd nsz double 0.0, ", 0)

        }

    }

};

// Pass 2: Rebuild IR without identity copies, substituting aliases

fn rebuild_ir_no_copies(ir: String, pos: i64, sb: i64, aliases: String) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= ir.len() { 0 }

    else {

        let pipe_pos = find_pipe_skip_quotes(ir, pos);

        let line = ir.slice(pos, pipe_pos);

        let _w = if is_identity_copy_ir(line) {

            0

        } else {

            let len = sb_len(sb);

            let _w1 = if len > 0 { sb_push(sb, SEP()) } else { 0 };

            subst_ir_aliases_to_sb(line, aliases, sb)

        };

        if pipe_pos >= ir.len() { 0 }

        else { rebuild_ir_no_copies(ir, pipe_pos + 1, sb, aliases) }

    };

// Substitute aliased %names in a single LLVM IR line

fn subst_ir_aliases_to_sb(line: String, aliases: String, outer_sb: i64) -> i64

  post it >= 0

= subst_ir_scan(line, 0, aliases, outer_sb);

// Scan line for % tokens and substitute aliases

fn subst_ir_scan(line: String, pos: i64, aliases: String, sb: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= line.len() { 0 }

    else if line.byte_at(pos) == 37 {

        let name_end = scan_ident_end(line, pos + 1);

        let name = line.slice(pos, name_end);

        let resolved = resolve_ir_alias_d(aliases, name, 0);

        let _w1 = sb_push(sb, resolved);

        subst_ir_scan(line, name_end, aliases, sb)

    } else {

        let next_pct = find_char(line, pos + 1, 37);

        let chunk_end = if next_pct >= line.len() { line.len() } else { next_pct };

        let _w1 = sb_push_range(sb, line, pos, chunk_end);

        if chunk_end >= line.len() { 0 }

        else { subst_ir_scan(line, chunk_end, aliases, sb) }

    };

// ============================================================================

// Pattern: %X = zext i1 %cmp to i64 ... %Y = trunc i64 %X to i1

// Since %Y == %cmp, replace %Y with %cmp and remove the trunc line

// The zext line stays (may have other uses); LLVM DCEs if unused

// ============================================================================

// Entry point: eliminate redundant trunc(zext(i1)) roundtrips

fn eliminate_zext_trunc_ir(ir: String) -> String

  post it.len() <= ir.len()

= {

    let zext_map = build_zext_map(ir, 0, "");

    if zext_map.len() == 0 { ir }

    else {

        let aliases = build_trunc_aliases(ir, 0, zext_map, "");

        if aliases.len() == 0 { ir }

        else {

            let sb = sb_new();

            let _w = rebuild_ir_no_truncs(ir, 0, sb, aliases);

            sb_build(sb)

        }

    }

};

// Pass A: Build zext map — records which %vars are zext of i1 values

// Format: ",dest=i1_src,dest2=i1_src2"

fn build_zext_map(ir: String, pos: i64, zmap: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= ir.len() { zmap }

    else {

        let pipe_pos = find_pipe_skip_quotes(ir, pos);

        let ws_start = low_skip_ws(ir, pos);

        let new_zmap = if ws_start < pipe_pos and ir.byte_at(ws_start) == 37 {

            let line = ir.slice(pos, pipe_pos);

            try_add_zext(line, zmap)

        } else { zmap };

        if pipe_pos >= ir.len() { new_zmap }

        else { build_zext_map(ir, pipe_pos + 1, new_zmap) }

    };

// Check if line is "zext i1 %X to i64", record dest -> X in zext map

fn try_add_zext(line: String, zmap: String) -> String

  post it.len() >= zmap.len()

= {

    let p = low_skip_ws(line, 0);

    if p >= line.len() { zmap }

    else if line.byte_at(p) != 37 { zmap }

    else {

        let eq_pos = find_eq(line, p);

        if eq_pos >= line.len() { zmap }

        else {

            let dest = trim(line.slice(p, eq_pos));

            let rhs = trim(line.slice(eq_pos + 1, line.len()));

            if starts_with(rhs, "zext i1 ", 0) {

                let to_pos = find_pattern_at_slow(rhs, " to ", 8);

                if to_pos < 0 { zmap }

                else {

                    let src = trim(rhs.slice(8, to_pos));

                    zmap + "," + dest + "=" + src

                }

            } else { zmap }

        }

    }

};

// Pass B: Find truncs whose source is in zext map, build alias table

fn build_trunc_aliases(ir: String, pos: i64, zmap: String, aliases: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= ir.len() { aliases }

    else {

        let pipe_pos = find_pipe_skip_quotes(ir, pos);

        let ws_start = low_skip_ws(ir, pos);

        let new_aliases = if ws_start < pipe_pos and ir.byte_at(ws_start) == 37 {

            let line = ir.slice(pos, pipe_pos);

            try_add_trunc_alias(line, zmap, aliases)

        } else { aliases };

        if pipe_pos >= ir.len() { new_aliases }

        else { build_trunc_aliases(ir, pipe_pos + 1, zmap, new_aliases) }

    };

// Check if line is "trunc i64 %X to i1" where %X is a zext, add alias
// IMPORTANT: Only matches "to i1" (round-trip elimination), NOT "to i8" or "to i32"
// trunc to i8/i32 narrows to 8/32 bits (different semantics — must keep the trunc)

fn try_add_trunc_alias(line: String, zmap: String, aliases: String) -> String

  post it.len() >= aliases.len()

= {

    let p = low_skip_ws(line, 0);

    if p >= line.len() { aliases }

    else if line.byte_at(p) != 37 { aliases }

    else {

        let eq_pos = find_eq(line, p);

        if eq_pos >= line.len() { aliases }

        else {

            let dest = trim(line.slice(p, eq_pos));

            let rhs = trim(line.slice(eq_pos + 1, line.len()));

            if starts_with(rhs, "trunc i64 ", 0) {

                // Only eliminate zext i1 -> trunc to i1 round-trips (not to i8/i32)

                let to_pos = find_pattern_at_slow(rhs, " to i1", 10);

                if to_pos < 0 { aliases }

                else {

                    let src = trim(rhs.slice(10, to_pos));

                    let zext_src = lookup_zext_src(zmap, src);

                    if zext_src == "" { aliases }

                    else { aliases + "," + dest + "=" + zext_src }

                }

            } else { aliases }

        }

    }

};

// Lookup i1 source for a zext result

fn lookup_zext_src(zmap: String, name: String) -> String

  post it.len() <= zmap.len()

= {

    let val_start = find_alias_entry_noa(zmap, name, 0);

    if val_start < 0 { "" }

    else {

        let comma_pos = find_char(zmap, val_start, 44);

        if comma_pos >= zmap.len() { zmap.slice(val_start, zmap.len()) }

        else { zmap.slice(val_start, comma_pos) }

    }

};

// Check if line is a trunc that was aliased

fn is_aliased_trunc_ir(line: String, aliases: String) -> bool

  post not it or line.contains("trunc i64 ")

= {

    let p = low_skip_ws(line, 0);

    if p >= line.len() { false }

    else if line.byte_at(p) != 37 { false }

    else {

        let eq_pos = find_eq(line, p);

        if eq_pos >= line.len() { false }

        else {

            let dest = trim(line.slice(p, eq_pos));

            let rhs = trim(line.slice(eq_pos + 1, line.len()));

            if starts_with(rhs, "trunc i64 ", 0) {

                find_alias_entry_noa(aliases, dest, 0) >= 0

            } else { false }

        }

    }

};

// Pass C: Rebuild IR without aliased truncs, substitute aliases

fn rebuild_ir_no_truncs(ir: String, pos: i64, sb: i64, aliases: String) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= ir.len() { 0 }

    else {

        let pipe_pos = find_pipe_skip_quotes(ir, pos);

        let line = ir.slice(pos, pipe_pos);

        let _w = if is_aliased_trunc_ir(line, aliases) {

            0

        } else {

            let len = sb_len(sb);

            let _w1 = if len > 0 { sb_push(sb, SEP()) } else { 0 };

            subst_ir_aliases_to_sb(line, aliases, sb)

        };

        if pipe_pos >= ir.len() { 0 }

        else { rebuild_ir_no_truncs(ir, pipe_pos + 1, sb, aliases) }

    };

fn eliminate_dead_zexts_ir(ir: String) -> String

  post it.len() <= ir.len()

= {

    let dead = build_dead_zext_set(ir, 0, "");

    if dead.len() == 0 { ir }

    else {

        let sb = sb_new();

        let _w = rebuild_ir_no_dead_zexts(ir, 0, sb, dead);

        sb_build(sb)

    }

};

// Scan IR for zext i1 lines, check if their results are unused

fn build_dead_zext_set(ir: String, pos: i64, dead: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= ir.len() { dead }

    else {

        let pipe_pos = find_pipe_skip_quotes(ir, pos);

        let ws_start = low_skip_ws(ir, pos);

        let new_dead = if ws_start < pipe_pos and ir.byte_at(ws_start) == 37 {

            let line = ir.slice(pos, pipe_pos);

            try_mark_dead_zext(ir, line, dead)

        } else { dead };

        if pipe_pos >= ir.len() { new_dead }

        else { build_dead_zext_set(ir, pipe_pos + 1, new_dead) }

    };

// If line is a zext i1 and its dest is unused, add to dead set

fn try_mark_dead_zext(ir: String, line: String, dead: String) -> String

  post it.len() >= dead.len()

= {

    let p = low_skip_ws(line, 0);

    if p >= line.len() { dead }

    else if line.byte_at(p) != 37 { dead }

    else {

        let eq_pos = find_eq(line, p);

        if eq_pos >= line.len() { dead }

        else {

            let rhs = trim(line.slice(eq_pos + 1, line.len()));

            if starts_with(rhs, "zext i1 ", 0) {

                let dest = trim(line.slice(p, eq_pos));

                if is_var_unused_in_ir(ir, dest) {

                    dead + SEP() + dest + SEP()

                } else { dead }

            } else { dead }

        }

    }

};

// Check if a variable has only one occurrence (its definition) in the IR

fn is_var_unused_in_ir(ir: String, name: String) -> bool

  post it or not it

= {

    let first = find_var_use_wb(ir, name, 0);

    if first < 0 { true }

    else {

        let second = find_var_use_wb(ir, name, first + name.len());

        second < 0

    }

};

// Find next occurrence of name with word boundary check

fn find_var_use_wb(ir: String, name: String, start: i64) -> i64

    pre start >= 0

    post it >= -1

=  {

    let pos = find_pattern_at_slow(ir, name, start);

    if pos < 0 { -1 }

    else {

        let end_pos = pos + name.len();

        if end_pos >= ir.len() { pos }

        else {

            let ch = ir.byte_at(end_pos);

            if is_alnum_or_underscore(ch) {

                find_var_use_wb(ir, name, pos + 1)

            } else { pos }

        }

    }

};

// Check if a line is a dead zext (in the dead set)

fn is_dead_zext_range(ir: String, start: i64, end: i64, dead: String) -> bool

  pre start >= 0

  post not it or start < end

= {

    let p = low_skip_ws(ir, start);

    if p >= end { false }

    else if ir.byte_at(p) != 37 { false }

    else {

        let eq_pos = find_char_in_range(ir, p, end, 61);

        if eq_pos >= end { false }

        else {

            let rhs_start = low_skip_ws(ir, eq_pos + 1);

            if rhs_start + 8 <= end and match_bytes(ir, "zext i1 ", rhs_start, 0) {

                let dest_end = trim_end_pos(ir, p, eq_pos);

                let dest = ir.slice(p, dest_end);

                let key = SEP() + dest + SEP();

                find_pattern_noa(dead, key, 0) >= 0

            } else { false }

        }

    }

};

fn find_char_in_range(s: String, start: i64, end: i64, ch: i64) -> i64

    pre start >= 0

    post it >= -1

= 

    if start >= end { end }

    else if s.byte_at(start) == ch { start }

    else { find_char_in_range(s, start + 1, end, ch) };

fn trim_end_pos(s: String, start: i64, end: i64) -> i64

  pre start >= 0

  post it >= 0

= if end <= start { start }

    else if s.byte_at(end - 1) == 32 or s.byte_at(end - 1) == 9 { trim_end_pos(s, start, end - 1) }

    else { end };

// Rebuild IR excluding dead zext lines

// v0.95.7: Uses sb_push_range to avoid line slice allocation for non-dead lines

fn rebuild_ir_no_dead_zexts(ir: String, pos: i64, sb: i64, dead: String) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= ir.len() { 0 }

    else {

        let pipe_pos = find_pipe_skip_quotes(ir, pos);

        let _w = if is_dead_zext_range(ir, pos, pipe_pos, dead) {

            0

        } else {

            let len = sb_len(sb);

            let _w1 = if len > 0 { sb_push(sb, SEP()) } else { 0 };

            sb_push_range(sb, ir, pos, pipe_pos)

        };

        if pipe_pos >= ir.len() { 0 }

        else { rebuild_ir_no_dead_zexts(ir, pipe_pos + 1, sb, dead) }

    };

// Pattern: %a = ptrtoint ptr %P to i64 ... %b = inttoptr i64 %a to ptr -> %b aliases %P

fn eliminate_inttoptr_roundtrips_ir(ir: String) -> String

  post it.len() <= ir.len()

= {

    let pmap = build_ptrtoint_map(ir, 0, "");

    if pmap.len() == 0 { ir }

    else {

        let direct_aliases = build_inttoptr_aliases(ir, 0, pmap, "");

        // Extend: cross-BB alloca+store+load chains
        let alloca_ptr_map = build_alloca_ptr_map(ir, pmap, 0, "", "");

        let load_pmap = if alloca_ptr_map.len() == 0 { "" }

            else { build_load_pmap(ir, alloca_ptr_map, 0, "") };

        let aliases = if load_pmap.len() == 0 { direct_aliases }

            else { build_inttoptr_aliases(ir, 0, load_pmap, direct_aliases) };

        if aliases.len() == 0 { ir }

        else {

            let sb = sb_new();

            let _w = rebuild_ir_no_inttoptrs(ir, 0, sb, aliases);

            sb_build(sb)

        }

    }

};

// Update candidates/excluded when alloca_name is not yet excluded.
// Returns updated "candidates|excluded" pair joined by "|".
fn apm_merge_candidate(candidates: String, excluded: String, alloca_name: String, ptr_src: String) -> String

  post it.len() >= 1

= let existing = lookup_ptr_src(candidates, alloca_name);
    if existing == "" { (candidates + "," + alloca_name + "=" + ptr_src) + "|" + excluded }
    else if existing == ptr_src { candidates + "|" + excluded }
    else { candidates + "|" + (excluded + "," + alloca_name + "=!") };

// Build map of single-write alloca i64 vars that hold exactly one ptrtoint value.
// Scans all store instructions; tracks candidates and excludes multi-write allocas.
// Returns ",alloca_name=ptr_src," format (same as pmap).
fn build_alloca_ptr_map(ir: String, pmap: String, pos: i64, candidates: String, excluded: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= ir.len() { apm_filter(candidates, excluded, 0, "") }

    else {

        let pipe_pos = find_pipe_skip_quotes(ir, pos);

        let trimmed = trim(ir.slice(pos, pipe_pos));

        // Detect "store i64 %X, ptr %v" where %X in pmap
        let new_cand_excl = if starts_with(trimmed, "store i64 %", 0) {

            let sep_pos = find_pattern_at_slow(trimmed, ", ptr %", 11);

            if sep_pos > 11 {

                let val_name = trimmed.slice(10, sep_pos);

                let alloca_name = trim_end(trimmed.slice(sep_pos + 7, trimmed.len()));

                let ptr_src = lookup_ptr_src(pmap, val_name);

                if ptr_src != "" {

                    let in_excl = find_alias_entry_noa(excluded, alloca_name, 0) >= 0;

                    if in_excl { candidates + "|" + excluded }
                    else { apm_merge_candidate(candidates, excluded, alloca_name, ptr_src) }

                } else { candidates + "|" + excluded }

            } else { candidates + "|" + excluded }

        } else { candidates + "|" + excluded };

        let sep_at = str_find(new_cand_excl, "|");

        let new_cand = if sep_at >= 0 { new_cand_excl.slice(0, sep_at) } else { new_cand_excl };

        let new_excl = if sep_at >= 0 { new_cand_excl.slice(sep_at + 1, new_cand_excl.len()) } else { excluded };

        build_alloca_ptr_map(ir, pmap, pipe_pos + 1, new_cand, new_excl)

    };

// Filter alloca_ptr_map candidates by removing excluded entries.
// candidates format: ",name1=src1,name2=src2" — iterate by comma positions.
fn apm_filter(candidates: String, excluded: String, pos: i64, acc: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= candidates.len() { acc }

    else if candidates.byte_at(pos) != 44 {

        apm_filter(candidates, excluded, pos + 1, acc)

    } else {

        let eq_pos = find_char(candidates, pos + 1, 61);

        if eq_pos >= candidates.len() { acc }

        else {

            let alloca_name = candidates.slice(pos + 1, eq_pos);

            let next_comma = find_char(candidates, eq_pos + 1, 44);

            let val_end = next_comma;

            let val = candidates.slice(eq_pos + 1, val_end);

            let in_excl = find_alias_entry_noa(excluded, alloca_name, 0) >= 0;

            let new_acc = if in_excl { acc } else { acc + "," + alloca_name + "=" + val };

            apm_filter(candidates, excluded, val_end, new_acc)

        }

    };

// Build pmap from loads: for each "load i64, ptr %alloca" where alloca is in alloca_ptr_map,
// records load_dest -> ptr_src. This pmap feeds build_inttoptr_aliases for cross-BB chains.
fn build_load_pmap(ir: String, alloca_ptr_map: String, pos: i64, acc: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= ir.len() { acc }

    else {

        let pipe_pos = find_pipe_skip_quotes(ir, pos);

        let ws_start = low_skip_ws(ir, pos);

        let new_acc = if ws_start < pipe_pos and ir.byte_at(ws_start) == 37 {

            let trimmed = trim(ir.slice(pos, pipe_pos));

            // Detect "  %dest = load i64, ptr %alloca_name"
            let eq_pos = find_pattern_at(trimmed, "= load i64, ptr %", 0);

            if eq_pos > 0 {

                let dest = trim(trimmed.slice(0, eq_pos));

                let alloca_name = trim_end(trimmed.slice(eq_pos + 17, trimmed.len()));

                let ptr_src = lookup_ptr_src(alloca_ptr_map, alloca_name);

                if ptr_src != "" { acc + "," + dest + "=" + ptr_src }

                else { acc }

            } else { acc }

        } else { acc };

        if pipe_pos >= ir.len() { new_acc }

        else { build_load_pmap(ir, alloca_ptr_map, pipe_pos + 1, new_acc) }

    };

// Pass 1: Build ptrtoint map — records which i64 vars came from ptrtoint

// Format: ",i64_dest=ptr_src,..."

fn build_ptrtoint_map(ir: String, pos: i64, pmap: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= ir.len() { pmap }

    else {

        let pipe_pos = find_pipe_skip_quotes(ir, pos);

        let ws_start = low_skip_ws(ir, pos);

        let new_pmap = if ws_start < pipe_pos and ir.byte_at(ws_start) == 37 {

            let line = ir.slice(pos, pipe_pos);

            try_add_ptrtoint(line, pmap)

        } else { pmap };

        if pipe_pos >= ir.len() { new_pmap }

        else { build_ptrtoint_map(ir, pipe_pos + 1, new_pmap) }

    };

// Check if line is "%X = ptrtoint ptr %P to i64", add to map

fn try_add_ptrtoint(line: String, pmap: String) -> String

  post it.len() >= pmap.len()

= {

    let p = low_skip_ws(line, 0);

    if p >= line.len() { pmap }

    else if line.byte_at(p) != 37 { pmap }

    else {

        let eq_pos = find_eq(line, p);

        if eq_pos >= line.len() { pmap }

        else {

            let dest = trim(line.slice(p, eq_pos));

            let rhs = trim(line.slice(eq_pos + 1, line.len()));

            if starts_with(rhs, "ptrtoint ptr ", 0) {

                let to_pos = find_pattern_at_slow(rhs, " to ", 13);

                if to_pos < 0 { pmap }

                else {

                    let src = trim(rhs.slice(13, to_pos));

                    pmap + "," + dest + "=" + src

                }

            } else { pmap }

        }

    }

};

// Pass 2: Find inttoptr whose i64 source is in ptrtoint map

fn build_inttoptr_aliases(ir: String, pos: i64, pmap: String, aliases: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= ir.len() { aliases }

    else {

        let pipe_pos = find_pipe_skip_quotes(ir, pos);

        let ws_start = low_skip_ws(ir, pos);

        let new_aliases = if ws_start < pipe_pos and ir.byte_at(ws_start) == 37 {

            let line = ir.slice(pos, pipe_pos);

            try_add_inttoptr_alias(line, pmap, aliases)

        } else { aliases };

        if pipe_pos >= ir.len() { new_aliases }

        else { build_inttoptr_aliases(ir, pipe_pos + 1, pmap, new_aliases) }

    };

// Check if line is "%Y = inttoptr i64 %X to ptr" where %X is in ptrtoint map

fn try_add_inttoptr_alias(line: String, pmap: String, aliases: String) -> String

  post it.len() >= aliases.len()

= {

    let p = low_skip_ws(line, 0);

    if p >= line.len() { aliases }

    else if line.byte_at(p) != 37 { aliases }

    else {

        let eq_pos = find_eq(line, p);

        if eq_pos >= line.len() { aliases }

        else {

            let dest = trim(line.slice(p, eq_pos));

            let rhs = trim(line.slice(eq_pos + 1, line.len()));

            if starts_with(rhs, "inttoptr i64 ", 0) {

                let to_pos = find_pattern_at_slow(rhs, " to ", 13);

                if to_pos < 0 { aliases }

                else {

                    let src = trim(rhs.slice(13, to_pos));

                    let ptr_src = lookup_ptr_src(pmap, src);

                    if ptr_src == "" { aliases }

                    else { aliases + "," + dest + "=" + ptr_src }

                }

            } else { aliases }

        }

    }

};

// Lookup original ptr source for a ptrtoint result

fn lookup_ptr_src(pmap: String, name: String) -> String

  post it.len() <= pmap.len()

= {

    let val_start = find_alias_entry_noa(pmap, name, 0);

    if val_start < 0 { "" }

    else {

        let comma_pos = find_char(pmap, val_start, 44);

        if comma_pos >= pmap.len() { pmap.slice(val_start, pmap.len()) }

        else { pmap.slice(val_start, comma_pos) }

    }

};

// Check if line is an inttoptr that was aliased

fn is_aliased_inttoptr(line: String, aliases: String) -> bool

  post not it or line.contains("inttoptr i64 ")

= {

    let p = low_skip_ws(line, 0);

    if p >= line.len() { false }

    else if line.byte_at(p) != 37 { false }

    else {

        let eq_pos = find_eq(line, p);

        if eq_pos >= line.len() { false }

        else {

            let dest = trim(line.slice(p, eq_pos));

            let rhs = trim(line.slice(eq_pos + 1, line.len()));

            if starts_with(rhs, "inttoptr i64 ", 0) {

                find_alias_entry_noa(aliases, dest, 0) >= 0

            } else { false }

        }

    }

};

// Pass 3: Rebuild IR without aliased inttoptrs, substitute aliases

fn rebuild_ir_no_inttoptrs(ir: String, pos: i64, sb: i64, aliases: String) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= ir.len() { 0 }

    else {

        let pipe_pos = find_pipe_skip_quotes(ir, pos);

        let line = ir.slice(pos, pipe_pos);

        let _w = if is_aliased_inttoptr(line, aliases) {

            0

        } else {

            let len = sb_len(sb);

            let _w1 = if len > 0 { sb_push(sb, SEP()) } else { 0 };

            subst_ir_aliases_to_sb(line, aliases, sb)

        };

        if pipe_pos >= ir.len() { 0 }

        else { rebuild_ir_no_inttoptrs(ir, pipe_pos + 1, sb, aliases) }

    };

fn eliminate_dead_ptrtoints_ir(ir: String) -> String

  post it.len() <= ir.len()

= {

    let dead = build_dead_ptrtoint_set(ir, 0, "");

    if dead.len() == 0 { ir }

    else {

        let sb = sb_new();

        let _w = rebuild_ir_no_dead_ptrtoints(ir, 0, sb, dead);

        sb_build(sb)

    }

};

// ============================================================================

// IR Memory Attribute Pass

// For pure functions (no calls, no loads, no stores, no pointer ops),

// add memory(none) to the function header to enable LLVM optimizations.

// ============================================================================

// v0.93.4: Check if a call target is a known memory(none) function

fn mn_is_pure_call(line: String) -> bool

  post not it or line.contains("@llvm.") or line.contains("@bmb_f64_")

= let at_pos = find_byte_in_range(line, 64, 0, line.len());

    if at_pos < 0 { false }

    else {

        let paren_pos = find_char(line, at_pos, 40);

        if paren_pos <= at_pos { false }

        else {

            let fn_name = line.slice(at_pos + 1, paren_pos);

            // v0.96: LLVM intrinsics (zero overhead — single hardware instructions)

            fn_name == "llvm.abs.i64" or fn_name == "llvm.smin.i64" or fn_name == "llvm.smax.i64"

            or fn_name == "llvm.ctpop.i64" or fn_name == "llvm.ctlz.i64" or fn_name == "llvm.cttz.i64" or fn_name == "llvm.bitreverse.i64"

            or fn_name == "llvm.bswap.i64" or fn_name == "llvm.fshl.i64" or fn_name == "llvm.fshr.i64"

            // v0.96: Math LLVM intrinsics (trig, log, exp, pow)

            or fn_name == "llvm.sin.f64" or fn_name == "llvm.cos.f64" or fn_name == "llvm.tan.f64"

            or fn_name == "llvm.atan.f64" or fn_name == "llvm.atan2.f64"

            or fn_name == "llvm.log.f64" or fn_name == "llvm.log2.f64" or fn_name == "llvm.log10.f64"

            or fn_name == "llvm.exp.f64" or fn_name == "llvm.pow.f64"

            // v0.96: Float LLVM intrinsics (single hardware instructions)

            or fn_name == "llvm.fabs.f64" or fn_name == "llvm.floor.f64" or fn_name == "llvm.ceil.f64"

            or fn_name == "llvm.round.f64" or fn_name == "llvm.sqrt.f64"

            or fn_name == "llvm.minnum.f64" or fn_name == "llvm.maxnum.f64"

            // Float operations still using C runtime

            or fn_name == "bmb_f64_is_nan" or fn_name == "bmb_f64_to_int"

        }

    };

fn mn_has_memory_op(ir: String, pos: i64) -> bool

  pre pos >= 0

  post not it or pos < ir.len()

= if pos >= ir.len() { false }

    else {

        let pipe_pos = find_pipe_skip_quotes(ir, pos);

        let line = ir.slice(pos, pipe_pos);

        // Check for non-call memory operations first

        let has_mem = find_pattern_at(line, "store ", 0) >= 0

            or find_pattern_at(line, "load ", 0) >= 0

            or find_pattern_at(line, "inttoptr", 0) >= 0

            or find_pattern_at(line, "ptrtoint", 0) >= 0

            or find_pattern_at(line, "getelementptr", 0) >= 0;

        if has_mem { true }

        else {

            // v0.93.4: For calls, check if target is a known pure function

            let has_call = find_pattern_at(line, "call ", 0) >= 0;

            let has_impure_call = has_call and not mn_is_pure_call(line);

            if has_impure_call { true }

            else if pipe_pos >= ir.len() { false }

            else { mn_has_memory_op(ir, pipe_pos + 1) }

        }

    };

// Check if a call target is a known read-only function (reads memory but does not write)

fn mn_is_readonly_call(line: String) -> bool

  post not it or line.contains("@bmb_") or line.contains("@llvm.")

= if mn_is_pure_call(line) { true }

    else {

        let at_pos = find_byte_in_range(line, 64, 0, line.len());

        if at_pos < 0 { false }

        else {

            let paren_pos = find_char(line, at_pos, 40);

            if paren_pos <= at_pos { false }

            else {

                let fn_name = line.slice(at_pos + 1, paren_pos);

                fn_name == "bmb_array_len" or fn_name == "bmb_string_len"

                or fn_name == "bmb_string_char_at" or fn_name == "bmb_string_eq"

                or fn_name == "bmb_string_cmp" or fn_name == "bmb_string_hash"

                or fn_name == "bmb_string_starts_with" or fn_name == "bmb_string_ends_with"

                or fn_name == "bmb_string_contains" or fn_name == "bmb_string_index_of"

                or fn_name == "bmb_string_is_empty" or fn_name == "bmb_string_count"

                or fn_name == "bmb_string_last_index_of" or fn_name == "bmb_ord"

                or fn_name == "bmb_f64_is_nan"

                or fn_name == "bmb_parse_int" or fn_name == "bmb_parse_f64"

            }

        }

    };

// Check if a function body has write operations (stores or write-capable calls)

fn mn_has_write_op(ir: String, pos: i64) -> bool

  pre pos >= 0

  post it or not it

= if pos >= ir.len() { false }

    else {

        let pipe_pos = find_pipe_skip_quotes(ir, pos);

        let line = ir.slice(pos, pipe_pos);

        let has_write = find_pattern_at(line, "store ", 0) >= 0;

        if has_write { true }

        else {

            let has_call = find_pattern_at(line, "call ", 0) >= 0;

            let has_write_call = has_call and not mn_is_readonly_call(line);

            if has_write_call { true }

            else if pipe_pos >= ir.len() { false }

            else { mn_has_write_op(ir, pipe_pos + 1) }

        }

    };

fn annotate_memory_none_ir(ir: String) -> String

  post it.len() >= ir.len()

= // Only annotate functions that have nosync and don't already have memory(

    let pipe = find_pipe_skip_quotes(ir, 0);

    let header = ir.slice(0, pipe);

    if find_pattern_at(header, "nosync", 0) < 0 { ir }

    else if find_pattern_at(header, "memory(", 0) >= 0 { ir }

    else if mn_has_memory_op(ir, pipe + 1) { ir }

    else {

        // Add memory(none) before the opening brace

        let brace = find_char(header, 0, 123);

        if brace >= header.len() { ir }

        else {

            let before_brace = header.slice(0, brace);

            let rest = if pipe >= ir.len() { "" } else { ir.slice(pipe, ir.len()) };

            before_brace + "memory(none) {" + rest

        }

    };

// Annotate read-only functions with memory(read): has loads/GEPs but no stores/write-calls

fn annotate_memory_read_ir(ir: String) -> String

  post it.len() >= ir.len()

= let pipe = find_pipe_skip_quotes(ir, 0);

    let header = ir.slice(0, pipe);

    // Skip if already annotated or not a normal function

    if find_pattern_at(header, "memory(", 0) >= 0 { ir }

    else if find_pattern_at(header, "nosync", 0) < 0 { ir }

    else if mn_has_write_op(ir, pipe + 1) { ir }

    else {

        // Has reads but no writes -> memory(read)

        let brace = find_char(header, 0, 123);

        if brace >= header.len() { ir }

        else {

            let before_brace = header.slice(0, brace);

            let rest = if pipe >= ir.len() { "" } else { ir.slice(pipe, ir.len()) };

            before_brace + "memory(read) {" + rest

        }

    };

// v0.96.8: Interprocedural memory(read) annotation

// Collects known readonly function names from module IR, then annotates

// functions whose calls all target known readonly functions.

// Collect readonly function names from declare/define headers in module IR

// Extract @name from a line: find @ then find ( to get the name

fn ipr_extract_at_name(line: String) -> String

  post it.len() <= line.len()

= {

    let at_pos = find_byte_in_range(line, 64, 0, line.len());

    if at_pos < 0 { "" }

    else {

        let paren = find_char(line, at_pos, 40);

        if paren <= at_pos + 1 { "" }

        else { line.slice(at_pos + 1, paren) }

    }

};

// Collect readonly names from declarations in the header section (line by line)

fn ipr_collect_decl_names(ir: String, pos: i64, end: i64, acc: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= end { acc }

    else {

        let pipe = find_pipe_in_range(ir, pos, end);

        let line = ir.slice(pos, pipe);

        let new_acc = if find_pattern_at(line, "memory(", 0) >= 0 {

            let name = ipr_extract_at_name(line);

            if name.len() > 0 { acc + name + "," } else { acc }

        } else { acc };

        if pipe + 1 >= end { new_acc }

        else { ipr_collect_decl_names(ir, pipe + 1, end, new_acc) }

    };

fn ipr_collect_readonly_names(ir: String, pos: i64, acc: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= ir.len() { acc }

    else {

        let fn_end = find_double_pipe(ir, pos);

        // First section: collect from declare lines too

        let acc1 = ipr_collect_decl_names(ir, pos, fn_end, acc);

        // Also check define header for memory( annotation

        let pipe = find_pipe_in_range(ir, pos, fn_end);

        let header = ir.slice(pos, pipe);

        let has_mem = find_pattern_noa_range(header, "memory(", 0, header.len()) >= 0;

        let has_def = find_pattern_noa_range(header, "define ", 0, header.len()) >= 0;

        let new_acc = if has_mem and has_def {

            let name = extract_define_name_fast(ir, pos, fn_end);

            if name.len() > 0 { acc1 + name + "," } else { acc1 }

        } else { acc1 };

        if fn_end + 2 >= ir.len() { new_acc }

        else { ipr_collect_readonly_names(ir, fn_end + 2, new_acc) }

    };

// Find first pipe (byte 31) in range [pos, end)

fn find_pipe_in_range(s: String, pos: i64, end: i64) -> i64

    post it >= -1

= 

    if pos >= end { end }

    else if s.byte_at(pos) == 31 { pos }

    else if s.byte_at(pos) == 34 { find_pipe_in_range(s, skip_quoted_string(s, pos + 1), end) }

    else { find_pipe_in_range(s, pos + 1, end) };

// Check if an LLVM intrinsic function name refers to a memory-writing operation.
// Used to exclude memset/memcpy/memmove from "readonly" and "pure" classifications.
// Future additions: llvm.memcpy.inline, llvm.memmove.element.unordered.atomic, etc.

fn llvm_intrinsic_is_memory_write(fn_name: String) -> bool

  post it or not it

= find_pattern_at(fn_name, "llvm.memset", 0) >= 0
  or find_pattern_at(fn_name, "llvm.memcpy", 0) >= 0
  or find_pattern_at(fn_name, "llvm.memmove", 0) >= 0;

// Check if a function body (from pos to end) has stores

fn ipr_has_store(ir: String, pos: i64, end: i64) -> bool

  pre pos >= 0

  post not it or pos < end

= if pos >= end { false }

    else {

        let pipe = find_pipe_in_range(ir, pos, end);

        let line = ir.slice(pos, pipe);

        let is_write = find_pattern_at(line, "store ", 0) >= 0
            or (find_pattern_at(line, "call ", 0) >= 0 and (find_pattern_at(line, "@llvm.memset", 0) >= 0 or find_pattern_at(line, "@llvm.memcpy", 0) >= 0 or find_pattern_at(line, "@llvm.memmove", 0) >= 0));

        if is_write { true }

        else if pipe + 1 >= end { false }

        else { ipr_has_store(ir, pipe + 1, end) }

    };

// Check if a function body has any memory operation (load, store, gep, inttoptr, ptrtoint)

fn ipr_has_mem_op(ir: String, pos: i64, end: i64) -> bool

  pre pos >= 0

  post it or not it

= if pos >= end { false }

    else {

        let pipe = find_pipe_in_range(ir, pos, end);

        let line = ir.slice(pos, pipe);

        let has_op = find_pattern_at(line, "store ", 0) >= 0

            or find_pattern_at(line, "load ", 0) >= 0

            or find_pattern_at(line, "getelementptr", 0) >= 0

            or find_pattern_at(line, "inttoptr", 0) >= 0

            or find_pattern_at(line, "ptrtoint", 0) >= 0;

        if has_op { true }

        else if pipe + 1 >= end { false }

        else { ipr_has_mem_op(ir, pipe + 1, end) }

    };

// Collect pure (memory(none)) function names from declarations and definitions

fn ipr_collect_pure_decl_names(ir: String, pos: i64, end: i64, acc: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= end { acc }

    else {

        let pipe = find_pipe_in_range(ir, pos, end);

        let line = ir.slice(pos, pipe);

        let new_acc = if find_pattern_at(line, "memory(none)", 0) >= 0 {

            let name = ipr_extract_at_name(line);

            if name.len() > 0 { acc + name + "," } else { acc }

        } else { acc };

        if pipe + 1 >= end { new_acc }

        else { ipr_collect_pure_decl_names(ir, pipe + 1, end, new_acc) }

    };

fn ipr_collect_pure_names(ir: String, pos: i64, acc: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= ir.len() { acc }

    else {

        let fn_end = find_double_pipe(ir, pos);

        let acc1 = ipr_collect_pure_decl_names(ir, pos, fn_end, acc);

        let pipe = find_pipe_in_range(ir, pos, fn_end);

        let header = ir.slice(pos, pipe);

        let has_none = find_pattern_noa_range(header, "memory(none)", 0, header.len()) >= 0;

        let has_def = find_pattern_noa_range(header, "define ", 0, header.len()) >= 0;

        let new_acc = if has_none and has_def {

            let name = extract_define_name_fast(ir, pos, fn_end);

            if name.len() > 0 { acc1 + name + "," } else { acc1 }

        } else { acc1 };

        if fn_end + 2 >= ir.len() { new_acc }

        else { ipr_collect_pure_names(ir, fn_end + 2, new_acc) }

    };

// Check if all call targets are in the pure (memory(none)) set

fn ipr_all_calls_pure(ir: String, pos: i64, end: i64, known_pure: String) -> bool

  pre pos >= 0

  post it or not it

= if pos >= end { true }

    else {

        let pipe = find_pipe_in_range(ir, pos, end);

        let line = ir.slice(pos, pipe);

        let has_call = find_pattern_at(line, "call ", 0) >= 0;

        let ok = if has_call {

            let at_pos = find_byte_in_range(line, 64, 0, line.len());

            if at_pos < 0 { false }

            else {

                let paren = find_char(line, at_pos, 40);

                if paren <= at_pos { false }

                else {

                    let fn_name = line.slice(at_pos + 1, paren);

                    // LLVM intrinsics are pure (memory(none)) EXCEPT memory-writing ones
                    if find_pattern_at(fn_name, "llvm.", 0) >= 0 {
                        not llvm_intrinsic_is_memory_write(fn_name)
                    }

                    // @free and @realloc modify allocator state — never pure
                    else if fn_name == "free" or fn_name == "realloc" { false }

                    else {

                        // Use comma-bounded matching: ",fn_name," to prevent substring false positives
                        // e.g. "free" must NOT match inside "array_free" in the known set
                        let key = "," + fn_name + ",";

                        find_pattern_noa(known_pure, key, 0) >= 0

                    }

                }

            }

        } else { true };

        if ok { if pipe + 1 >= end { true } else { ipr_all_calls_pure(ir, pipe + 1, end, known_pure) } }

        else { false }

    };

// Check if all call targets in a function body are in the known readonly set

fn ipr_all_calls_readonly(ir: String, pos: i64, end: i64, known: String) -> bool

  pre pos >= 0

  post it or not it

= if pos >= end { true }

    else {

        let pipe = find_pipe_in_range(ir, pos, end);

        let line = ir.slice(pos, pipe);

        let has_call = find_pattern_at(line, "call ", 0) >= 0;

        let ok = if has_call {

            // Extract call target name

            let at_pos = find_byte_in_range(line, 64, 0, line.len());

            if at_pos < 0 { false }

            else {

                let paren = find_char(line, at_pos, 40);

                if paren <= at_pos { false }

                else {

                    let fn_name = line.slice(at_pos + 1, paren);

                    // LLVM intrinsics are readonly EXCEPT memory-writing ones
                    if find_pattern_at(fn_name, "llvm.", 0) >= 0 { not llvm_intrinsic_is_memory_write(fn_name) }

                    // @free and @realloc modify allocator state — never readonly regardless of name matching
                    else if fn_name == "free" or fn_name == "realloc" { false }

                    else {

                        // Use comma-bounded matching: ",fn_name," to prevent substring false positives
                        // e.g. "free" must NOT match inside "array_free" in the known set
                        let key = "," + fn_name + ",";

                        find_pattern_noa(known, key, 0) >= 0

                    }

                }

            }

        } else { true };

        if ok { if pipe + 1 >= end { true } else { ipr_all_calls_readonly(ir, pipe + 1, end, known) } }

        else { false }

    };

// Try to annotate one function section with memory(none) or memory(read)

fn ipr_try_annotate_section(ir: String, pos: i64, fn_end: i64, known: String, known_pure: String) -> String

  pre pos >= 0

  post it.len() >= 0

= {

    let pipe = find_pipe_in_range(ir, pos, fn_end);

    let header = ir.slice(pos, pipe);

    // Skip if already has memory( or no nosync

    if find_pattern_noa_range(header, "memory(", 0, header.len()) >= 0 { ir.slice(pos, fn_end) }

    else if find_pattern_noa_range(header, "nosync", 0, header.len()) < 0 { ir.slice(pos, fn_end) }

    else if find_pattern_noa_range(header, "define ", 0, header.len()) < 0 { ir.slice(pos, fn_end) }

    else {

        let body_start = pipe + 1;

        // v0.96.30: Extract function name for self-recursive call support

        let at_pos = find_byte_in_range(header, 64, 0, header.len());

        let self_paren = if at_pos >= 0 { find_char(header, at_pos, 40) } else { header.len() };

        let self_name = if at_pos >= 0 and self_paren < header.len() { header.slice(at_pos + 1, self_paren) } else { "" };

        // Add self name to known sets (enables self-recursive pure function detection)

        let known_self = if self_name != "" { known + self_name + "," } else { known };

        let known_pure_self = if self_name != "" { known_pure + self_name + "," } else { known_pure };

        // Check: no stores AND all calls are readonly (including self-calls)

        if ipr_has_store(ir, body_start, fn_end) { ir.slice(pos, fn_end) }

        else if ipr_all_calls_readonly(ir, body_start, fn_end, known_self) {

            // Determine: memory(none) if no memory ops + all calls pure; else memory(read)

            let is_pure = not ipr_has_mem_op(ir, body_start, fn_end)

                and ipr_all_calls_pure(ir, body_start, fn_end, known_pure_self);

            let attr = if is_pure { "memory(none) " } else { "memory(read) " };

            let brace = find_byte_in_range(header, 123, 0, header.len());

            if brace < 0 { ir.slice(pos, fn_end) }

            else {

                let before = header.slice(0, brace);

                let rest = if pipe >= fn_end { "" } else { ir.slice(pipe, fn_end) };

                before + attr + "{" + rest

            }

        } else { ir.slice(pos, fn_end) }

    }

};

// Rebuild module IR with interprocedural memory annotations

fn ipr_rebuild(ir: String, pos: i64, sb: i64, known: String, known_pure: String, count: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= ir.len() { count }

    else {

        let fn_end = find_double_pipe(ir, pos);

        let pipe = find_pipe_in_range(ir, pos, fn_end);

        let header = ir.slice(pos, pipe);

        let has_mem = find_pattern_noa_range(header, "memory(", 0, header.len()) >= 0;

        let has_define = find_pattern_noa_range(header, "define ", 0, header.len()) >= 0;

        let has_nosync = find_pattern_noa_range(header, "nosync", 0, header.len()) >= 0;

        // Only try to annotate unannotated define functions with nosync

        let section = if has_define and has_nosync and not has_mem {

            ipr_try_annotate_section(ir, pos, fn_end, known, known_pure)

        } else { ir.slice(pos, fn_end) };

        let was_annotated = section.len() != (fn_end - pos);

        let new_count = if was_annotated { count + 1 } else { count };

        let len = sb_len(sb);

        let _w1 = if len > 0 { sb_push(sb, DSEP()) } else { 0 };

        let _w2 = sb_push(sb, section);

        if fn_end + 2 >= ir.len() { new_count }

        else { ipr_rebuild(ir, fn_end + 2, sb, known, known_pure, new_count) }

    };

// Main interprocedural memory annotation pass with fixpoint iteration

fn annotate_memory_read_interprocedural(module_ir: String) -> String

  post it.len() >= module_ir.len()

= {

    let ir = module_ir;

    for _iter in 0..5 {

        // Collect known readonly and pure function names

        let known = ipr_collect_readonly_names(ir, 0, ",");

        let known_pure = ipr_collect_pure_names(ir, 0, ",");

        // Rebuild with new annotations

        let sb = sb_new();

        let new_count = ipr_rebuild(ir, 0, sb, known, known_pure, 0);

        ir = sb_build(sb);

        if new_count == 0 { break };

    };

    ir

};

// v0.96.9: Check if function body has sdiv/udiv/srem/urem (can trap -> no speculatable)

fn ipr_has_div_rem(ir: String, pos: i64, end: i64) -> bool

  pre pos >= 0

  post it or not it

= if pos >= end { false }

    else {

        let pipe = find_pipe_in_range(ir, pos, end);

        let line = ir.slice(pos, pipe);

        let has_op = find_pattern_at(line, " sdiv ", 0) >= 0

            or find_pattern_at(line, " udiv ", 0) >= 0

            or find_pattern_at(line, " srem ", 0) >= 0

            or find_pattern_at(line, " urem ", 0) >= 0;

        if has_op { true }

        else if pipe + 1 >= end { false }

        else { ipr_has_div_rem(ir, pipe + 1, end) }

    };

// Rebuild IR adding speculatable to memory(none) functions without div/rem

fn spec_rebuild(ir: String, pos: i64, sb: i64, count: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= ir.len() { count }

    else {

        let fn_end = find_double_pipe(ir, pos);

        let pipe = find_pipe_in_range(ir, pos, fn_end);

        let header = ir.slice(pos, pipe);

        let has_mem_none = find_pattern_noa_range(header, "memory(none)", 0, header.len()) >= 0;

        let has_spec = find_pattern_noa_range(header, "speculatable", 0, header.len()) >= 0;

        let has_define = find_pattern_noa_range(header, "define ", 0, header.len()) >= 0;

        // v0.96.41: Don't add speculatable to non-leaf functions (LLVM may speculate past base case)

        let fn_body = if pipe < fn_end { ir.slice(pipe, fn_end) } else { "" };

        let has_call = find_pattern_noa_range(fn_body, " call ", 0, fn_body.len()) >= 0;

        let section = if has_define and has_mem_none and not has_spec and not has_call {

            let body_start = pipe + 1;

            if ipr_has_div_rem(ir, body_start, fn_end) { ir.slice(pos, fn_end) }

            else {

                // Insert speculatable before memory(none)

                let mem_pos = find_pattern_noa_range(header, "memory(none)", 0, header.len());

                let before = header.slice(0, mem_pos);

                let after = header.slice(mem_pos, header.len());

                let new_header = before + "speculatable " + after;

                let rest = if pipe >= fn_end { "" } else { ir.slice(pipe, fn_end) };

                new_header + rest

            }

        } else { ir.slice(pos, fn_end) };

        let was_annotated = section.len() != (fn_end - pos);

        let new_count = if was_annotated { count + 1 } else { count };

        let len = sb_len(sb);

        let _w1 = if len > 0 { sb_push(sb, DSEP()) } else { 0 };

        let _w2 = sb_push(sb, section);

        if fn_end + 2 >= ir.len() { new_count }

        else { spec_rebuild(ir, fn_end + 2, sb, new_count) }

    };

// Add speculatable attribute to memory(none) functions that cannot trap

fn annotate_speculatable(module_ir: String) -> String

  post it.len() >= module_ir.len()

= {

    let sb = sb_new();

    let count = spec_rebuild(module_ir, 0, sb, 0);

    if count == 0 { module_ir }

    else { sb_build(sb) }

};

// v0.96.13: Count pipe-separated lines in function body (from pos to end)

fn inline_count_lines(ir: String, pos: i64, end: i64, count: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= end { count }

    else {

        let pipe = find_pipe_in_range(ir, pos, end);

        inline_count_lines(ir, pipe + 1, end, count + 1)

    };

// v0.96.13: Check if function body has back edges (loops via br to earlier label)

fn inline_has_back_edge(ir: String, pos: i64, end: i64) -> bool

  pre pos >= 0

  post it or not it

= if pos >= end { false }

    else {

        let pipe = find_pipe_in_range(ir, pos, end);

        let line = trim(ir.slice(pos, pipe));

        // Look for "br label %" or "br i1 %" which could indicate loops

        // A simple heuristic: if there's a phi node, there's likely a loop

        let has_phi = find_pattern_at(line, "= phi ", 0) >= 0;

        if has_phi { true }

        else if pipe + 1 >= end { false }

        else { inline_has_back_edge(ir, pipe + 1, end) }

    };

// v0.96.13: Rebuild IR adding alwaysinline/inlinehint to qualifying functions

fn inline_rebuild(ir: String, pos: i64, sb: i64, count: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= ir.len() { count }

    else {

        let fn_end = find_double_pipe(ir, pos);

        let pipe = find_pipe_in_range(ir, pos, fn_end);

        let header = ir.slice(pos, pipe);

        let has_define = find_pattern_noa_range(header, "define ", 0, header.len()) >= 0;

        let has_inline = find_pattern_noa_range(header, "alwaysinline", 0, header.len()) >= 0;

        let has_hint = find_pattern_noa_range(header, "inlinehint", 0, header.len()) >= 0;

        let has_norecurse = find_pattern_noa_range(header, "norecurse", 0, header.len()) >= 0;

        let is_main = find_pattern_noa_range(header, "@bmb_user_main", 0, header.len()) >= 0;

        let section = if has_define and not has_inline and not has_hint and not is_main and has_norecurse {

            let body_start = pipe + 1;

            let line_count = inline_count_lines(ir, body_start, fn_end, 0);

            let has_loops = inline_has_back_edge(ir, body_start, fn_end);

            // Small functions (≤15 lines, no loops) -> alwaysinline

            // Medium functions (≤150 lines) -> inlinehint

            if line_count <= 15 and not has_loops {

                let mp_pos = find_pattern_noa_range(header, "mustprogress", 0, header.len());

                if mp_pos >= 0 {

                    let before = header.slice(0, mp_pos);

                    let after = header.slice(mp_pos, header.len());

                    let new_header = before + "alwaysinline " + after;

                    let rest = if pipe >= fn_end { "" } else { ir.slice(pipe, fn_end) };

                    new_header + rest

                } else { ir.slice(pos, fn_end) }

            } else if line_count <= 150 {

                let mp_pos = find_pattern_noa_range(header, "mustprogress", 0, header.len());

                if mp_pos >= 0 {

                    let before = header.slice(0, mp_pos);

                    let after = header.slice(mp_pos, header.len());

                    let new_header = before + "inlinehint " + after;

                    let rest = if pipe >= fn_end { "" } else { ir.slice(pipe, fn_end) };

                    new_header + rest

                } else { ir.slice(pos, fn_end) }

            } else { ir.slice(pos, fn_end) }

        } else { ir.slice(pos, fn_end) };

        let was_annotated = section.len() != (fn_end - pos);

        let new_count = if was_annotated { count + 1 } else { count };

        let len = sb_len(sb);

        let _w1 = if len > 0 { sb_push(sb, DSEP()) } else { 0 };

        let _w2 = sb_push(sb, section);

        if fn_end + 2 >= ir.len() { new_count }

        else { inline_rebuild(ir, fn_end + 2, sb, new_count) }

    };

// v0.96.13: Add inlining attributes to qualifying functions

fn annotate_inlining(module_ir: String) -> String

  post it.len() >= module_ir.len()

= {

    let sb = sb_new();

    let count = inline_rebuild(module_ir, 0, sb, 0);

    if count == 0 { module_ir }

    else { sb_build(sb) }

};

// v0.96.13: Rebuild IR adding nofree to memory(none)/memory(read) functions

fn nofree_rebuild(ir: String, pos: i64, sb: i64, count: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= ir.len() { count }

    else {

        let fn_end = find_double_pipe(ir, pos);

        let pipe = find_pipe_in_range(ir, pos, fn_end);

        let header = ir.slice(pos, pipe);

        let has_define = find_pattern_noa_range(header, "define ", 0, header.len()) >= 0;

        let has_nofree = find_pattern_noa_range(header, "nofree", 0, header.len()) >= 0;

        let has_mem = find_pattern_noa_range(header, "memory(", 0, header.len()) >= 0;

        let section = if has_define and has_mem and not has_nofree {

            let mem_pos = find_pattern_noa_range(header, "memory(", 0, header.len());

            let before = header.slice(0, mem_pos);

            let after = header.slice(mem_pos, header.len());

            let new_header = before + "nofree " + after;

            let rest = if pipe >= fn_end { "" } else { ir.slice(pipe, fn_end) };

            new_header + rest

        } else { ir.slice(pos, fn_end) };

        let was_annotated = section.len() != (fn_end - pos);

        let new_count = if was_annotated { count + 1 } else { count };

        let len = sb_len(sb);

        let _w1 = if len > 0 { sb_push(sb, DSEP()) } else { 0 };

        let _w2 = sb_push(sb, section);

        if fn_end + 2 >= ir.len() { new_count }

        else { nofree_rebuild(ir, fn_end + 2, sb, new_count) }

    };

// v0.96.13: Add nofree to all functions with memory annotations

fn annotate_nofree(module_ir: String) -> String

  post it.len() >= module_ir.len()

= {

    let sb = sb_new();

    let count = nofree_rebuild(module_ir, 0, sb, 0);

    if count == 0 { module_ir }

    else { sb_build(sb) }

};

// v0.96.14: Extract function name (e.g. "@skip_ws") from LLVM IR define header

fn extract_ir_fn_name(header: String) -> String

  post it.len() <= header.len()

= let at_pos = find_char_in_range(header, 0, header.len(), 64); // '@'

    if at_pos < 0 { "" }

    else {

        let paren_pos = find_char_in_range(header, at_pos + 1, header.len(), 40); // '('

        if paren_pos < at_pos + 1 { "" } else { header.slice(at_pos, paren_pos) }

    };

// v0.96.14: Add "tail " before self-recursive calls in a function body

// For each line, if it contains "call i64 @fn_name(" or "call void @fn_name(",

// replace "call " with "tail call " (LLVM will verify tail position)

fn tailcall_annotate_body(ir: String, body_start: i64, fn_end: i64, fn_name: String, sb: i64, count: i64) -> i64

  pre count >= 0

  post it >= 0

= if body_start >= fn_end { count }

    else {

        let pipe = find_pipe_in_range(ir, body_start, fn_end);

        let line = ir.slice(body_start, pipe);

        // Check for self-recursive call pattern: "call i64 @fn_name(" or "call void @fn_name("

        let call_pat = "call i64 " + fn_name + "(";

        let call_void_pat = "call void " + fn_name + "(";

        let call_pos = find_pattern_noa_range(line, call_pat, 0, line.len());

        let call_void_pos = if call_pos < 0 { find_pattern_noa_range(line, call_void_pat, 0, line.len()) } else { 0 - 1 };

        let found_pos = if call_pos >= 0 { call_pos } else { call_void_pos };

        let has_tail = find_pattern_noa_range(line, "tail call", 0, line.len()) >= 0;

        let new_line = if found_pos >= 0 and not has_tail {

            // Insert "tail " before "call"

            let before = line.slice(0, found_pos);

            let after = line.slice(found_pos, line.len());

            before + "tail " + after

        } else { line };

        let _w = sb_push(sb, new_line);

        let _w2 = if pipe < fn_end { sb_push(sb, SEP()) } else { 0 };

        let new_count = if found_pos >= 0 and not has_tail { count + 1 } else { count };

        if pipe + 1 > fn_end { new_count }

        else { tailcall_annotate_body(ir, pipe + 1, fn_end, fn_name, sb, new_count) }

    };

// v0.96.14: Rebuild IR adding tail call annotations for self-recursive calls

fn tailcall_rebuild(ir: String, pos: i64, sb: i64, count: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= ir.len() { count }

    else {

        let fn_end = find_double_pipe(ir, pos);

        let pipe = find_pipe_in_range(ir, pos, fn_end);

        let header = ir.slice(pos, pipe);

        let has_define = find_pattern_noa_range(header, "define ", 0, header.len()) >= 0;

        let has_norecurse = find_pattern_noa_range(header, "norecurse", 0, header.len()) >= 0;

        // Only annotate recursive functions (those without norecurse)

        let section_result = if has_define and not has_norecurse {

            let fn_name = extract_ir_fn_name(header);

            if fn_name == "" { ir.slice(pos, fn_end) }

            else {

                // Build function with tail call annotations

                let fn_sb = sb_new();

                let _w_hdr = sb_push(fn_sb, header);

                let _w_sep = if pipe < fn_end { sb_push(fn_sb, SEP()) } else { 0 };

                let body_start = pipe + 1;

                let annotated = tailcall_annotate_body(ir, body_start, fn_end, fn_name, fn_sb, 0);

                if annotated > 0 { sb_build(fn_sb) }

                else { ir.slice(pos, fn_end) }

            }

        } else { ir.slice(pos, fn_end) };

        let was_annotated = section_result.len() != (fn_end - pos);

        let new_count = if was_annotated { count + 1 } else { count };

        let len = sb_len(sb);

        let _w1 = if len > 0 { sb_push(sb, DSEP()) } else { 0 };

        let _w2 = sb_push(sb, section_result);

        if fn_end + 2 >= ir.len() { new_count }

        else { tailcall_rebuild(ir, fn_end + 2, sb, new_count) }

    };

fn annotate_tailcalls(module_ir: String) -> String

  post it.len() >= module_ir.len()

= {

    let sb = sb_new();

    let count = tailcall_rebuild(module_ir, 0, sb, 0);

    if count == 0 { module_ir }

    else { sb_build(sb) }

};

// v0.96.24: Cont-pattern loop exit optimization

// When a while loop uses a flag variable pattern (e.g., while cont == 1 { ... cont = 0 ... }),

// redirect "store 0, ptr %flag; br label %loop_N" to "store 0, ptr %flag; br label %exit_N".

// This creates cleaner loop CFG that LLVM can better optimize (enables loop unrolling, etc.)

// The optimization detects: loop_N: load %var + icmp eq %var, 1 => %var is control variable

// Then replaces: store 0, ptr %var + br loop_N => store 0, ptr %var + br exit_N

fn optimize_cont_loop_exits(module_ir: String) -> String

  post it.len() <= module_ir.len()

= {

    let sb = sb_new();

    let count = cont_exit_rebuild(module_ir, 0, sb, 0);

    if count == 0 { module_ir }

    else { sb_build(sb) }

};

// Rebuild IR function-by-function, optimizing cont-pattern exits

fn cont_exit_rebuild(ir: String, pos: i64, sb: i64, count: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= ir.len() { count }

    else {

        let fn_end = find_double_pipe(ir, pos);

        let fn_ir = ir.slice(pos, fn_end);

        // Phase 1: Find loop control variable mappings for this function

        // Returns tab-separated pairs: "loop_0\tcont_4\tloop_3\tflag_7\t..."

        let ctrl_map = cont_exit_find_ctrl_vars(fn_ir, 0);

        // Phase 2: Apply replacements (ctrl_map != "" means there are cont-pattern loops)

        let new_count = if ctrl_map != "" { count + 1 } else { count };

        let result = if ctrl_map == "" { fn_ir }

                     else { cont_exit_apply(fn_ir, ctrl_map) };

        let len = sb_len(sb);

        let _w1 = if len > 0 { sb_push(sb, DSEP()) } else { 0 };

        let _w2 = sb_push(sb, result);

        if fn_end + 2 >= ir.len() { new_count }

        else { cont_exit_rebuild(ir, fn_end + 2, sb, new_count) }

    };

// Phase 1: Find all loop_N: headers that use flag-variable pattern

// Iterates line by line to avoid matching "loop_" inside instructions

// Pattern: "loop_N:" line, next line "load i64, ptr %VAR", next line "icmp eq ... 1"

// Returns: "loop_N\tVAR\t..." (tab-separated pairs)

fn cont_exit_find_ctrl_vars(fn_ir: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= {

    let sb = sb_new();

    let _w = cont_exit_scan_headers(fn_ir, pos, sb);

    sb_build(sb)

};

fn cont_exit_scan_headers(ir: String, pos: i64, sb: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= ir.len() { 0 }

    else {

        let sep = find_char_in_range(ir, pos, ir.len(), 31);

        let line = trim(ir.slice(pos, sep));

        // Check if this line is a loop label: starts with "loop_" and ends with ":"

        let is_loop_label = line.len() > 6 and

            line.byte_at(0) == 108 and line.byte_at(1) == 111 and line.byte_at(2) == 111 and

            line.byte_at(3) == 112 and line.byte_at(4) == 95 and

            line.byte_at(line.len() - 1) == 58;

        if is_loop_label and sep < ir.len() {

            let label = line.slice(0, line.len() - 1);

            // Check next line for "load i64, ptr %CTRL"

            let line1_start = sep + 1;

            let sep2 = find_char_in_range(ir, line1_start, ir.len(), 31);

            let line1 = ir.slice(line1_start, sep2);

            let load_pos = find_pattern_noa_range(line1, "load i64, ptr %", 0, line1.len());

            if load_pos >= 0 and sep2 < ir.len() {

                let var_start = load_pos + 15;

                let ctrl_var = trim(line1.slice(var_start, line1.len()));

                // Verify next-next line has "icmp eq" and ", 1"

                let line2_start = sep2 + 1;

                let sep3 = find_char_in_range(ir, line2_start, ir.len(), 31);

                let line2 = ir.slice(line2_start, sep3);

                let has_icmp_eq = find_pattern_noa_range(line2, "icmp eq", 0, line2.len()) >= 0;

                let has_one = find_pattern_noa_range(line2, ", 1", 0, line2.len()) >= 0;

                let _r = if has_icmp_eq and has_one {

                    let _w1 = sb_push(sb, label);

                    let _w2 = sb_push_char(sb, 9);

                    let _w3 = sb_push(sb, ctrl_var);

                    let _w4 = sb_push_char(sb, 9);

                    0

                } else { 0 };

                cont_exit_scan_headers(ir, sep + 1, sb)

            } else { cont_exit_scan_headers(ir, sep + 1, sb) }

        } else {

            if sep >= ir.len() { 0 }

            else { cont_exit_scan_headers(ir, sep + 1, sb) }

        }

    };

// Look up control variable for a given loop label in the map

// map format: "loop_0\tcont_4\tloop_3\tflag_7\t..."

fn cont_exit_lookup(map: String, loop_label: String) -> String

  post it.len() <= map.len()

= let search = loop_label + chr(9);

    let pos = find_pattern_noa_range(map, search, 0, map.len());

    if pos < 0 { "" }

    else {

        let var_start = pos + search.len();

        let tab_pos = find_char_in_range(map, var_start, map.len(), 9);

        map.slice(var_start, tab_pos)

    };

// Phase 2: Apply cont-exit replacements to a function's IR

// Scans line by line; when "store i64 0, ptr %CTRL" is followed by "br label %loop_N",

// and CTRL matches loop_N's control variable, replace with "br label %exit_N"

fn cont_exit_apply(fn_ir: String, ctrl_map: String) -> String

  post it.len() <= fn_ir.len()

= {

    let sb = sb_new();

    let _w = cont_exit_apply_lines(fn_ir, 0, ctrl_map, sb, "");

    sb_build(sb)

};

// Process lines, tracking previous line for pattern matching

fn cont_exit_apply_lines(ir: String, pos: i64, ctrl_map: String, sb: i64, prev_line: String) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= ir.len() { 0 }

    else {

        let sep = find_char_in_range(ir, pos, ir.len(), 31);

        let line = ir.slice(pos, sep);

        let trimmed = trim(line);

        // Check pattern: current line is "br label %loop_N" and prev has "store i64 0, ptr %VAR"

        let is_br_loop = find_pattern_noa_range(trimmed, "br label %loop_", 0, trimmed.len()) == 0;

        let prev_has_store0 = find_pattern_noa_range(prev_line, "store i64 0, ptr %", 0, prev_line.len()) >= 0;

        let new_line = if is_br_loop and prev_has_store0 {

            // Extract loop label: "br label %loop_N" -> "loop_N"

            let label_start = 10; // after "br label %"

            let loop_label = trimmed.slice(label_start, trimmed.len());

            // Extract variable from prev_line: "store i64 0, ptr %VAR" -> "VAR"

            let store_pos = find_pattern_noa_range(prev_line, "store i64 0, ptr %", 0, prev_line.len());

            let var_name = trim(prev_line.slice(store_pos + 18, prev_line.len()));

            // Look up expected control variable for this loop

            let expected_var = cont_exit_lookup(ctrl_map, loop_label);

            if expected_var == var_name and expected_var != "" {

                // Replace: br label %loop_N -> br label %exit_N

                let exit_label = "exit_" + loop_label.slice(5, loop_label.len());

                "  br label %" + exit_label

            } else { line }

        } else { line };

        let len = sb_len(sb);

        let _w1 = if len > 0 { sb_push(sb, SEP()) } else { 0 };

        let _w2 = sb_push(sb, new_line);

        if sep >= ir.len() { 0 }

        else { cont_exit_apply_lines(ir, sep + 1, ctrl_map, sb, trimmed) }

    };

fn build_dead_ptrtoint_set(ir: String, pos: i64, dead: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= ir.len() { dead }

    else {

        let pipe_pos = find_pipe_skip_quotes(ir, pos);

        let ws_start = low_skip_ws(ir, pos);

        let new_dead = if ws_start < pipe_pos and ir.byte_at(ws_start) == 37 {

            let line = ir.slice(pos, pipe_pos);

            try_mark_dead_ptrtoint(ir, line, dead)

        } else { dead };

        if pipe_pos >= ir.len() { new_dead }

        else { build_dead_ptrtoint_set(ir, pipe_pos + 1, new_dead) }

    };

fn try_mark_dead_ptrtoint(ir: String, line: String, dead: String) -> String

  post it.len() >= dead.len()

= {

    let p = low_skip_ws(line, 0);

    if p >= line.len() { dead }

    else if line.byte_at(p) != 37 { dead }

    else {

        let eq_pos = find_eq(line, p);

        if eq_pos >= line.len() { dead }

        else {

            let rhs = trim(line.slice(eq_pos + 1, line.len()));

            if starts_with(rhs, "ptrtoint ptr ", 0) {

                let dest = trim(line.slice(p, eq_pos));

                if is_var_unused_in_ir(ir, dest) {

                    dead + SEP() + dest + SEP()

                } else { dead }

            } else { dead }

        }

    }

};

fn is_dead_ptrtoint_range(ir: String, start: i64, end: i64, dead: String) -> bool

  pre start >= 0

  post it or not it

= {

    let p = low_skip_ws(ir, start);

    if p >= end { false }

    else if ir.byte_at(p) != 37 { false }

    else {

        let eq_pos = find_char_in_range(ir, p, end, 61);

        if eq_pos >= end { false }

        else {

            let rhs_start = low_skip_ws(ir, eq_pos + 1);

            if rhs_start + 13 <= end and match_bytes(ir, "ptrtoint ptr ", rhs_start, 0) {

                let dest_end = trim_end_pos(ir, p, eq_pos);

                let dest = ir.slice(p, dest_end);

                let key = SEP() + dest + SEP();

                find_pattern_noa(dead, key, 0) >= 0

            } else { false }

        }

    }

};

// v0.95.7: Uses sb_push_range + range-based check

fn rebuild_ir_no_dead_ptrtoints(ir: String, pos: i64, sb: i64, dead: String) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= ir.len() { 0 }

    else {

        let pipe_pos = find_pipe_skip_quotes(ir, pos);

        let _w = if is_dead_ptrtoint_range(ir, pos, pipe_pos, dead) {

            0

        } else {

            let len = sb_len(sb);

            let _w1 = if len > 0 { sb_push(sb, SEP()) } else { 0 };

            sb_push_range(sb, ir, pos, pipe_pos)

        };

        if pipe_pos >= ir.len() { 0 }

        else { rebuild_ir_no_dead_ptrtoints(ir, pipe_pos + 1, sb, dead) }

    };

// ============================================================================

// IR Store-Load Forwarding Pass

// When "store i64 %val, ptr %x" is followed by "%t = load i64, ptr %x"

// in the same basic block with no intervening store to %x or call,

// replace the load with "%t = add nsw i64 0, %val" (identity copy).

// ============================================================================

// Check if IR line is a store: "  store i64 %val, ptr %x"

fn slf_is_store(line: String) -> bool

  post it == (line.contains("store i64 ") or line.contains("store double "))

= let s = low_skip_ws(line, 0);

    find_pattern_at(line, "store i64 ", s) == s or find_pattern_at(line, "store double ", s) == s;

// Extract ptr name from "  store i64 %val, ptr %x" -> "%x"

fn slf_store_ptr(line: String) -> String

  post it.len() <= line.len()

= let ptr_pos = find_pattern_at(line, ", ptr ", 0);

    if ptr_pos < 0 { "" }

    else { trim_end(line.slice(ptr_pos + 6, line.len())) };

// Extract stored value from "  store i64 %val, ptr %x" -> "%val"

fn slf_store_val(line: String) -> String

  post it.len() <= line.len()

= let s = low_skip_ws(line, 0);

    let after_type = if find_pattern_at(line, "store i64 ", s) == s { s + 10 }

        else if find_pattern_at(line, "store double ", s) == s { s + 13 }

        else { 0 - 1 };

    if after_type < 0 { "" }

    else {

        let comma = find_pattern_at(line, ", ptr ", after_type);

        if comma < 0 { "" }

        else { trim_end(line.slice(after_type, comma)) }

    };

// Check if IR line is a load: "  %t = load i64, ptr %x"

fn slf_is_i64_load(line: String) -> bool

  post it == (line.contains(" = load i64, ptr "))

= find_pattern_at(line, " = load i64, ptr ", 0) >= 0;

// Extract ptr from "  %t = load i64, ptr %x" -> "%x"

fn slf_load_ptr(line: String) -> String

  post it.len() <= line.len()

= let load_pos = find_pattern_at(line, " = load i64, ptr ", 0);

    if load_pos < 0 { "" }

    else { trim_end(line.slice(load_pos + 17, line.len())) };

// Extract dest from "  %t = load i64, ptr %x" -> "%t"

fn slf_load_dest(line: String) -> String

  post it.len() <= line.len()

= let eq_pos = find_pattern_at(line, " = load i64, ptr ", 0);

    if eq_pos < 0 { "" }

    else { trim(line.slice(0, eq_pos)) };

// Check if line is a basic block boundary (label or terminator)

fn slf_is_bb_boundary(line: String) -> bool

  post not it or line.contains(":") or line.contains("br ") or line.contains("ret ")

= let s = low_skip_ws(line, 0);

    if s >= line.len() { false }

    else {

        let trimmed = trim(line);

        // Labels end with ':'

        (trimmed.len() > 0 and trimmed.byte_at(trimmed.len() - 1) == 58) or

        // Branches

        find_pattern_at(line, "br ", s) == s or

        find_pattern_at(line, "ret ", s) == s or

        find_pattern_at(line, "unreachable", s) == s

    };

// Check if line is a call (may clobber memory)

fn slf_is_call(line: String) -> bool

  post it == (line.contains("call "))

= find_pattern_at(line, "call ", 0) >= 0;

// Get the LAST value for key in the table (most recent store wins)

fn slf_table_get_last(table: String, key: String, pos: i64, found: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= table.len() { found } else {

        let semi = find_char(table, pos, 59);

        let entry = table.slice(pos, semi);

        let eq = find_char(entry, 0, 61);

        if eq >= entry.len() { slf_table_get_last(table, key, semi + 1, found) } else {

            let entry_key = entry.slice(0, eq);

            let new_found = if entry_key == key { entry.slice(eq + 1, entry.len()) } else { found };

            slf_table_get_last(table, key, semi + 1, new_found)

        }

    };

fn slf_table_get(table: String, key: String) -> String

  post it.len() <= table.len()

= slf_table_get_last(table, key, 0, "");

// Process IR lines: forward stores to loads within the same basic block

fn slf_process(ir: String, pos: i64, sb: i64, table: String) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= ir.len() { 0 } else {

        let pipe_pos = find_pipe_skip_quotes(ir, pos);

        let line = ir.slice(pos, pipe_pos);

        // Clear table on BB boundary or call

        let cur_table = if slf_is_bb_boundary(line) or slf_is_call(line) { "" } else { table };

        // Track stores

        let new_table = if slf_is_store(line) {

            let ptr = slf_store_ptr(line);

            let val = slf_store_val(line);

            if ptr != "" and val != "" { cp_table_set(cur_table, ptr, val) }

            else { cur_table }

        } else { cur_table };

        // Forward loads

        let new_line = if slf_is_i64_load(line) {

            let ptr = slf_load_ptr(line);

            let fwd = slf_table_get(new_table, ptr);

            if fwd != "" {

                let dest = slf_load_dest(line);

                "  " + dest + " = add nsw i64 0, " + fwd

            } else { line }

        } else { line };

        let len = sb_len(sb);

        let _w1 = if len > 0 { sb_push(sb, SEP()) } else { 0 };

        let _w2 = sb_push(sb, new_line);

        if pipe_pos >= ir.len() { 0 }

        else { slf_process(ir, pipe_pos + 1, sb, new_table) }

    };

fn eliminate_store_load_ir(ir: String) -> String

  post it.len() <= ir.len()

= {

    let sb = sb_new();

    let _w = slf_process(ir, 0, sb, "");

    let result = sb_build(sb);

    let _f = sb_free(sb);

    result

};

// ============================================================================

// IR Dead Store/Alloca Elimination Pass

// After store-load forwarding, many alloca+store pairs become dead (value

// never loaded). This pass removes them to reduce IR size.

// Two-pass: (1) identify dead allocas, (2) rebuild without dead lines.

// ============================================================================

// Pass 1: Scan IR lines to find alloca vars that are never loaded

// Returns comma-delimited dead set: ",name1,name2,"

fn dsa_find_dead(ir: String, pos: i64, allocas: String, loaded: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= ir.len() {

        // Return allocas that are not in loaded set

        dsa_filter_dead(allocas, loaded, 0, "")

    } else {

        let pipe_pos = find_pipe_skip_quotes(ir, pos);

        let line = ir.slice(pos, pipe_pos);

        let trimmed = trim(line);

        // Track allocas: "%name = alloca i64"

        let new_allocas = if find_pattern_at(trimmed, "= alloca i64", 0) > 0 {

            let eq_pos = find_pattern_at(trimmed, " = ", 0);

            if eq_pos > 0 {

                let name = trimmed.slice(0, eq_pos);

                allocas + "," + name

            } else { allocas }

        } else { allocas };

        // Track loads: "= load i64, ptr %name" or "= load double, ptr %name"

        let new_loaded = if find_pattern_at(trimmed, "= load ", 0) > 0 {

            let ptr_pos = find_pattern_at(trimmed, ", ptr ", 0);

            if ptr_pos >= 0 {

                let name = trim_end(trimmed.slice(ptr_pos + 6, trimmed.len()));

                // Strip trailing metadata like ", !invariant.load !0"

                let comma = find_char(name, 0, 44);

                let clean_name = if comma < name.len() { name.slice(0, comma) } else { name };

                loaded + "," + clean_name

            } else { loaded }

        } else { new_loaded_from_other(trimmed, loaded) };

        if pipe_pos >= ir.len() { dsa_filter_dead(new_allocas, new_loaded, 0, "") }

        else { dsa_find_dead(ir, pipe_pos + 1, new_allocas, new_loaded) }

    };

// Also track uses via "store ... ptr %name" where %name appears as a call argument, GEP base, etc.

fn new_loaded_from_other(_line: String, loaded: String) -> String

  post it == loaded

= // Check if line uses a ptr var for anything other than store dest

    // For now, just check if a ptr is used in GEP, call, or inttoptr context

    loaded;

// Filter: keep only alloca names not in loaded set

fn dsa_filter_dead(allocas: String, loaded: String, pos: i64, dead: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= allocas.len() { dead }

    else {

        let next_comma = find_char(allocas, pos + 1, 44);

        let name = if next_comma > allocas.len() { allocas.slice(pos + 1, allocas.len()) }

            else { allocas.slice(pos + 1, next_comma) };

        if name.len() == 0 { dsa_filter_dead(allocas, loaded, next_comma, dead) }

        else {

            let is_loaded = find_pattern_at(loaded, "," + name, 0) >= 0;

            let new_dead = if is_loaded { dead } else { dead + "," + name + "," };

            if next_comma > allocas.len() { new_dead }

            else { dsa_filter_dead(allocas, loaded, next_comma, new_dead) }

        }

    };

// Check if a line should be removed (dead alloca or store to dead alloca)

fn dsa_is_dead_line(line: String, dead: String) -> bool

  post not it or dead.len() > 0

= if dead.len() == 0 { false }

    else {

        let trimmed = trim(line);

        // Dead alloca: "%name = alloca i64" where name is in dead set

        if find_pattern_at(trimmed, "= alloca i64", 0) > 0 {

            let eq_pos = find_pattern_at(trimmed, " = ", 0);

            if eq_pos > 0 {

                let name = trimmed.slice(0, eq_pos);

                find_pattern_at(dead, "," + name + ",", 0) >= 0

            } else { false }

        }

        // Dead store: "store i64 %val, ptr %name" where name is in dead set

        else if find_pattern_at(trimmed, "store i64 ", 0) == 0 or find_pattern_at(trimmed, "store double ", 0) == 0 {

            let ptr_pos = find_pattern_at(trimmed, ", ptr ", 0);

            if ptr_pos >= 0 {

                let name = trim_end(trimmed.slice(ptr_pos + 6, trimmed.len()));

                find_pattern_at(dead, "," + name + ",", 0) >= 0

            } else { false }

        }

        else { false }

    };

// Pass 2: Rebuild IR without dead lines

fn dsa_rebuild(ir: String, pos: i64, sb: i64, dead: String) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= ir.len() { 0 }

    else {

        let pipe_pos = find_pipe_skip_quotes(ir, pos);

        let line = ir.slice(pos, pipe_pos);

        let _w = if dsa_is_dead_line(line, dead) { 0 }

            else {

                let len = sb_len(sb);

                let _w1 = if len > 0 { sb_push(sb, SEP()) } else { 0 };

                sb_push(sb, line)

            };

        if pipe_pos >= ir.len() { 0 }

        else { dsa_rebuild(ir, pipe_pos + 1, sb, dead) }

    };

fn eliminate_dead_stores_ir(ir: String) -> String

  post it.len() <= ir.len()

= {

    let dead = dsa_find_dead(ir, 0, "", "");

    if dead.len() == 0 { ir }

    else {

        let sb = sb_new();

        let _w = dsa_rebuild(ir, 0, sb, dead);

        let result = sb_build(sb);

        let _f = sb_free(sb);

        result

    }

};

// Module-level pass: scan for @name references, remove define blocks

// for functions never referenced. Uses line-by-line scanning with string builders

// for O(n) memory usage on large IR.

// Zero-allocation substring search (arena-safe replacement for find_pattern_at_slow)

fn find_pattern_noa(s: String, pat: String, pos: i64) -> i64

  pre pos >= 0

  post it >= -1

= if pos + pat.len() > s.len() { 0 - 1 }

    else if match_bytes(s, pat, pos, 0) { pos }

    else { find_pattern_noa(s, pat, pos + 1) };

fn match_bytes(s: String, pat: String, s_pos: i64, p_pos: i64) -> bool

  pre s_pos >= 0 and p_pos >= 0

  post it or not it

= if p_pos >= pat.len() { true }

    else if s.byte_at(s_pos + p_pos) != pat.byte_at(p_pos) { false }

    else { match_bytes(s, pat, s_pos, p_pos + 1) };

// Dead function elimination: remove unreferenced function definitions from module IR

fn eliminate_dead_functions_ir(ir: String) -> String

  post it.len() <= ir.len()

= {

    // Phase 1: collect @name refs from non-define lines (line-by-line for TCO safety)

    let set_sb = sb_new();

    let _w1 = sb_push(set_sb, ",main,bmb_user_main,");

    let _w2 = collect_refs_by_lines(ir, 0, set_sb, 0);

    let called = sb_build(set_sb);

    // Phase 2: rebuild IR keeping only referenced function sections

    let out_sb = sb_new();

    let _w3 = rebuild_ir_no_dead_fns(ir, 0, out_sb, called);

    sb_build(out_sb)

};

// Scan IR line-by-line for @name references, skip define header lines

// is_def_line: 1 if current line is a define header (first line after ||)

fn collect_refs_by_lines(ir: String, pos: i64, set_sb: i64, is_def_line: i64) -> i64

    post it >= 0

= 

    if pos >= ir.len() { 0 }

    else {

        let pipe_pos = find_pipe_skip_quotes(ir, pos);

        // Check if this is || (function separator — next line is define header)

        let is_dbl = pipe_pos + 1 < ir.len() and ir.byte_at(pipe_pos + 1) == 31;

        // Skip @names in define header lines

        let _w = if is_def_line == 1 { 0 }

                else { collect_refs_in_range(ir, pos, pipe_pos, set_sb) };

        if pipe_pos >= ir.len() { 0 }

        else if is_dbl { collect_refs_by_lines(ir, pipe_pos + 2, set_sb, 1) }

        else { collect_refs_by_lines(ir, pipe_pos + 1, set_sb, 0) }

    };

// Find @name references in IR range [start, end) and add to set_sb

fn collect_refs_in_range(ir: String, start: i64, end: i64, set_sb: i64) -> i64

    pre start >= 0

    post it >= 0

= 

    if start >= end { 0 }

    else {

        let at_pos = find_byte_in_range(ir, 64, start, end);

        if at_pos < 0 { 0 }

        else {

            let name_end = find_at_name_end_in(ir, at_pos + 1, end);

            let _w = if name_end > at_pos + 1 {

                let name = ir.slice(at_pos + 1, name_end);

                let _w1 = sb_push(set_sb, name);

                sb_push(set_sb, ",")

            } else { 0 };

            collect_refs_in_range(ir, name_end, end, set_sb)

        }

    };

fn find_at_name_end_in(s: String, pos: i64, end: i64) -> i64

    post it >= -1

= 

    if pos >= end { pos }

    else {

        let ch = s.byte_at(pos);

        if is_alnum_or_underscore(ch) or ch == 46 { find_at_name_end_in(s, pos + 1, end) }

        else { pos }

    };

// Rebuild IR skipping dead function blocks (separated by ||)

fn rebuild_ir_no_dead_fns(ir: String, pos: i64, sb: i64, called: String) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= ir.len() { 0 }

    else {

        let fn_end = find_double_pipe(ir, pos);

        let fn_name = extract_define_name_fast(ir, pos, fn_end);

        let keep = if fn_name.len() == 0 { true }

                   else {

                       let key = "," + fn_name + ",";

                       find_pattern_noa(called, key, 0) >= 0

                   };

        let _w = if keep {

            let len = sb_len(sb);

            let _w1 = if len > 0 { sb_push(sb, DSEP()) } else { 0 };

            sb_push_range(sb, ir, pos, fn_end)

        } else { 0 };

        if fn_end + 2 >= ir.len() { 0 }

        else { rebuild_ir_no_dead_fns(ir, fn_end + 2, sb, called) }

    };

// Extract function name from define header by searching directly in IR range

fn extract_define_name_fast(ir: String, start: i64, end: i64) -> String

  pre start >= 0

  post it.len() >= 0

= {

    let def_pos = find_pattern_noa_range(ir, "define ", start, end);

    if def_pos < 0 { "" }

    else {

        let at_pos = find_byte_in_range(ir, 64, def_pos + 7, end);

        if at_pos < 0 { "" }

        else {

            let name_end = find_at_name_end_in(ir, at_pos + 1, end);

            if name_end > at_pos + 1 { ir.slice(at_pos + 1, name_end) } else { "" }

        }

    }

};

// Zero-allocation pattern search within range [pos, end)

fn find_pattern_noa_range(s: String, pat: String, pos: i64, end: i64) -> i64

  pre pos >= 0 and end >= 0

  post it >= -1

= if pos + pat.len() > end { 0 - 1 }

    else if match_bytes(s, pat, pos, 0) { pos }

    else { find_pattern_noa_range(s, pat, pos + 1, end) };

fn find_byte_in_range(s: String, byte: i64, pos: i64, end: i64) -> i64

    post it >= -1

= 

    if pos >= end { -1 }

    else if s.byte_at(pos) == byte { pos }

    else { find_byte_in_range(s, byte, pos + 1, end) };

// v0.96.24: Prune unused runtime declarations from module IR

// The bootstrap emits all ~200 runtime declarations for every program.

// This pass removes declarations whose @name is not referenced in any function body.

// LLVM opt would remove them anyway, but this produces cleaner pre-opt IR.

fn prune_unused_decls(module_ir: String) -> String

  post it.len() <= module_ir.len()

= {

    // Phase 1: Find the header section (before first DSEP = function definitions)

    let first_dsep = find_double_pipe(module_ir, 0);

    if first_dsep >= module_ir.len() { module_ir }

    else {

        // Phase 2: Collect all @name references from function bodies

        let ref_sb = sb_new();

        let _w0 = sb_push(ref_sb, ",");

        let code_section = module_ir.slice(first_dsep, module_ir.len());

        let _w1 = collect_refs_in_code(code_section, 0, ref_sb);

        let refs = sb_build(ref_sb);

        // Phase 3: Rebuild header, keeping only used declarations

        let out_sb = sb_new();

        let _w2 = prune_decls_lines(module_ir, 0, first_dsep, refs, out_sb);

        let header = sb_build(out_sb);

        // Reconstruct: new_header + code_section

        header + code_section

    }

};

// Collect all @name references from code section

fn collect_refs_in_code(code: String, pos: i64, sb: i64) -> i64

    post it >= 0

= 

    if pos >= code.len() { 0 }

    else {

        let at_pos = find_byte_in_range(code, 64, pos, code.len());

        if at_pos < 0 { 0 }

        else {

            let name_end = find_at_name_end_in(code, at_pos + 1, code.len());

            let _w = if name_end > at_pos + 1 {

                let name = code.slice(at_pos + 1, name_end);

                let _w1 = sb_push(sb, name);

                sb_push(sb, ",")

            } else { 0 };

            collect_refs_in_code(code, name_end + 1, sb)

        }

    };

// Iterate header lines, keep non-declare lines and used declare lines

fn prune_decls_lines(ir: String, pos: i64, header_end: i64, refs: String, sb: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= header_end { 0 }

    else {

        let pipe = find_pipe_in_range(ir, pos, header_end);

        let end = if pipe < header_end { pipe } else { header_end };

        let line = ir.slice(pos, end);

        // Check if this is a declare line

        let is_decl = line.len() > 8 and line.byte_at(0) == 100 and line.byte_at(1) == 101 and

                      line.byte_at(2) == 99 and line.byte_at(3) == 108 and line.byte_at(4) == 97 and

                      line.byte_at(5) == 114 and line.byte_at(6) == 101 and line.byte_at(7) == 32;

        let keep = if is_decl {

            // Extract @name from declare line

            let at_pos = find_byte_in_range(line, 64, 0, line.len());

            if at_pos < 0 { true }

            else {

                let paren = find_byte_in_range(line, 40, at_pos + 1, line.len());

                let name_end = if paren >= 0 { paren } else { line.len() };

                let name = line.slice(at_pos + 1, name_end);

                // Check if name is in the reference set

                let key = "," + name + ",";

                find_pattern_noa(refs, key, 0) >= 0

            }

        } else { true };

        let _w = if keep {

            let len = sb_len(sb);

            let _w1 = if len > 0 { sb_push(sb, SEP()) } else { 0 };

            sb_push(sb, line)

        } else { 0 };

        if end + 1 >= header_end { 0 }

        else { prune_decls_lines(ir, end + 1, header_end, refs, sb) }

    };

fn build_all_registries(mir: String, fn_rsb: i64, ptr_rsb: i64) -> i64

  post it >= 0

= build_all_registries_acc(mir, 0, fn_rsb, ptr_rsb);

fn build_all_registries_acc(mir: String, pos: i64, fn_rsb: i64, ptr_rsb: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= mir.len() { 0 } else {

        let fn_end = find_double_pipe(mir, pos);

        let fn_mir = mir.slice(pos, fn_end);

        let _w1 = register_fn_type(fn_mir, fn_rsb);

        let _w2 = register_ptr_return(fn_mir, ptr_rsb);

        if fn_end + 2 >= mir.len() { 0 } else { build_all_registries_acc(mir, fn_end + 2, fn_rsb, ptr_rsb) }

    };

fn register_fn_type(fn_mir: String, rsb: i64) -> i64

  post it >= 0

= let first_pipe = find_char(fn_mir, 0, 31);

    let header = fn_mir.slice(0, first_pipe);

    if header.len() < 4 { 0 }

    else if low_starts_with_at(header, 0, "fn ") {

        let name_start = 3;

        let paren_pos = find_char(header, name_start, 40);

        let fn_name = header.slice(name_start, paren_pos);

        let close_pos = find_char(header, paren_pos, 41);

        let arrow_pos = find_arrow(header, close_pos);

        let brace_pos = find_char(header, arrow_pos, 123);

        let raw_ret = trim(header.slice(arrow_pos + 2, brace_pos));

        let ann = find_mir_annotation(raw_ret);

        let ret_type = if ann == "" { raw_ret } else { strip_annotation(raw_ret) };

        // v0.95: i32 return type support

        let llvm_ret = match ret_type { "f64" => "double", "ptr" => "ptr", "i32" => "i32", _ => "i64" };

        let params = header.slice(paren_pos + 1, close_pos);

        let param_sig = build_param_sig(params, 0, "");

        let _w1 = sb_push(rsb, "@" + fn_name + ":" + llvm_ret + ":" + param_sig + ",");

        0

    } else { 0 };

// ============================================================================

// Scans MIR for functions with @const annotation, 0 params, returning a constant.

// Replaces all call @name() with const <value> in the MIR.

// ============================================================================

// Main entry point: optimize MIR by inlining const functions

fn optimize_const_inlining(mir: String) -> String

  post it.len() >= 0

= let const_map = build_const_map(mir);

    if const_map == "" { mir }

    else { apply_const_map_to_mir(mir, const_map, 0) };

// Cycle 3250: Fixed-point loop for multi-level compound consts.
// Each iteration: (1) CF/DCE to fold arithmetic in const bodies,
// (2) re-register newly-simple consts, (3) propagate into callers.
// Terminates when IR stops changing (bounded by const declaration depth).
// Example: const A=3; const B=A+1; const C=B*2 — needs 3 iterations.

fn optimize_const_inlining_loop(mir: String, prev: String) -> String

  post it.len() >= 0

= if mir == prev { mir }

    else {

        let m1 = optimize_cf_dce_loop(mir, 0);

        let m2 = optimize_const_inlining(m1);

        optimize_const_inlining_loop(m2, mir)

    };

// Build map of const function name -> value from MIR

// Format: "@name=value,@name2=value2,"

fn build_const_map(mir: String) -> String

  post it.len() <= mir.len()

= let sb = sb_new();

    let _w1 = build_const_map_acc(mir, 0, sb);

    let result = sb_build(sb);

    let _f = sb_free(sb);

    result;

fn build_const_map_acc(mir: String, pos: i64, sb: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= mir.len() { 0 } else {

        let fn_end = find_double_pipe(mir, pos);

        let fn_mir = mir.slice(pos, fn_end);

        let _w1 = try_register_const_fn(fn_mir, sb);

        if fn_end + 2 >= mir.len() { 0 } else { build_const_map_acc(mir, fn_end + 2, sb) }

    };

// Push "@fn_name=value," to sb if value is a numeric (int, neg-int, or F: float) constant
fn const_map_push_if_num(fn_name: String, value: String, sb: i64) -> i64

  post it >= 0

= let first_ch = value.byte_at(0);
    let is_num = if first_ch >= 48 and first_ch <= 57 { true }
        else if first_ch == 45 and value.len() > 1 and value.byte_at(1) >= 48 and value.byte_at(1) <= 57 { true }
        else { first_ch == 70 and value.len() > 2 and value.byte_at(1) == 58 };
    if is_num {
        let _w1 = sb_push(sb, "@");
        let _w2 = sb_push(sb, fn_name);
        let _w3 = sb_push(sb, "=");
        let _w4 = sb_push(sb, value);
        let _w5 = sb_push(sb, ",");
        0
    } else { 0 };

// Check if a function MIR is a 0-arg @const returning a constant

// Must have ONLY: entry: | %_tN = const <value> | return %_tN | }

// Reject functions with calls, arithmetic, etc.

fn try_register_const_fn(fn_mir: String, sb: i64) -> i64

  post it >= 0

= let first_pipe = find_char(fn_mir, 0, 31);

    let header = if first_pipe >= fn_mir.len() { fn_mir } else { fn_mir.slice(0, first_pipe) };

    let has_const = find_pattern_at(header, "@const", 0);

    if has_const < 0 { 0 }

    else {

        let paren_pos = find_char(header, 3, 40);

        let fn_name = header.slice(3, paren_pos);

        let close_pos = find_char(header, paren_pos, 41);

        let params = trim(header.slice(paren_pos + 1, close_pos));

        if params.len() > 0 { 0 }

        else {

            // Verify body has no calls, copies, or arithmetic (Cycle 3250: multi-level const support)
            // A compound const like "const B = A + 1" has "= copy %A" and "= add" in its body
            // before CF/DCE folds them. We reject here so the loop can propagate iteratively.

            let has_call = find_pattern_at(fn_mir, "= call ", first_pipe);

            let has_copy = find_pattern_at(fn_mir, "= copy ", first_pipe);

            let has_add  = find_pattern_at(fn_mir, "= add ", first_pipe);

            let has_sub  = find_pattern_at(fn_mir, "= sub ", first_pipe);

            let has_mul  = find_pattern_at(fn_mir, "= mul ", first_pipe);

            let has_div  = find_pattern_at(fn_mir, "= div ", first_pipe);

            if has_call >= 0 or has_copy >= 0 or has_add >= 0 or has_sub >= 0 or has_mul >= 0 or has_div >= 0 { 0 }

            else {

                let const_pos = find_pattern_at(fn_mir, "= const ", first_pipe);

                if const_pos < 0 { 0 }

                else {

                    let value_start = const_pos + 8;

                    let line_end = find_char(fn_mir, value_start, 31);

                    let value = trim(fn_mir.slice(value_start, line_end));

                    if value.len() == 0 { 0 }
                    else { const_map_push_if_num(fn_name, value, sb) }

                }

            }

        }

    };

// Apply all const map entries to MIR

fn apply_const_map_to_mir(mir: String, const_map: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= const_map.len() { mir }

    else {

        let at_pos = find_char(const_map, pos, 64);

        if at_pos >= const_map.len() { mir }

        else {

            let eq_pos = find_char(const_map, at_pos, 61);

            let comma_pos = find_char(const_map, eq_pos, 44);

            let fn_name = const_map.slice(at_pos + 1, eq_pos);

            let value = const_map.slice(eq_pos + 1, comma_pos);

            let pattern = "call @" + fn_name + "()";

            let replacement = "const " + value;

            let new_mir = replace_all_in_mir(mir, pattern, replacement);

            // Cycle 3247: Also replace "copy %fn_name" in MIR (for array size and other var uses).
            // Use SEP-terminated pattern to avoid matching names that are prefixes of longer names.
            // e.g., const SIZE=5 replaces "copy %SIZE<31>" but not "copy %SIZE_BIG<31>".
            let copy_pat_mid = "copy %" + fn_name + SEP();
            let copy_rep_mid = "const " + value + SEP();
            let new_mir2 = replace_all_in_mir(new_mir, copy_pat_mid, copy_rep_mid);
            // Handle last instruction (no trailing SEP): ends_with "copy %fn_name"
            let copy_pat_end = "copy %" + fn_name;
            let new_mir3 = if new_mir2.ends_with(copy_pat_end) {
                new_mir2.slice(0, new_mir2.len() - copy_pat_end.len()) + "const " + value
            } else { new_mir2 };

            apply_const_map_to_mir(new_mir3, const_map, comma_pos + 1)

        }

    };

// Replace all occurrences of pattern in string with replacement

fn replace_all_in_mir(s: String, pattern: String, replacement: String) -> String

  post it.len() >= 0

= let first = find_pattern_at(s, pattern, 0);

    if first < 0 { s }

    else {

        let sb = sb_new();

        let _w1 = replace_all_in_mir_acc(s, 0, pattern, replacement, sb);

        let result = sb_build(sb);

        let _f = sb_free(sb);

        result

    };

fn replace_all_in_mir_acc(s: String, pos: i64, pattern: String, replacement: String, sb: i64) -> i64

  pre pos >= 0

  post it >= 0

= let found = find_pattern_at(s, pattern, pos);

    if found < 0 {

        sb_push(sb, s.slice(pos, s.len()))

    } else {

        let _w1 = sb_push(sb, s.slice(pos, found));

        let _w2 = sb_push(sb, replacement);

        replace_all_in_mir_acc(s, found + pattern.len(), pattern, replacement, sb)

    };

// ============================================================================

// MIR Constant Folding Pass

// Folds binary arithmetic (+,-,*,/,%) on known integer constants.

// Propagates constants through copy instructions.

// ============================================================================

// Constant table: "key1:val1;key2:val2" — ';' (59) entry sep, ':' (58) key-val sep

fn cf_table_set(table: String, key: String, val: i64) -> String

  post it.len() >= table.len()

= if table == "" { key + ":" + i2s(val) } else { table + ";" + key + ":" + i2s(val) };

fn cf_table_get_at(table: String, key: String, pos: i64) -> i64

  pre pos >= 0

  post it >= 0 or it < 0

= if pos >= table.len() { cf_not_found() } else {

        let semi = find_char(table, pos, 59);

        let entry = table.slice(pos, semi);

        let colon = find_char(entry, 0, 58);

        if colon >= entry.len() { cf_table_get_at(table, key, semi + 1) } else {

            let entry_key = entry.slice(0, colon);

            if entry_key == key { parse_int_from(entry, colon + 1, 0) }

            else { cf_table_get_at(table, key, semi + 1) }

        }

    };

fn cf_table_get(table: String, key: String) -> i64

  post it == it

= cf_table_get_at(table, key, 0);

fn cf_table_has(table: String, key: String) -> bool

  post it == (cf_table_get(table, key) != 0 - 99999999)

= cf_table_get(table, key) != cf_not_found();

// Check if line is integer constant: %dest = const <digits|minus>

// Must match the ASSIGNMENT's `= const`, not ` = const ` inside string content.

fn cf_is_int_const(line: String) -> bool

  post not it or line.contains(" = const ")

= let eq_pos = find_pattern_at(line, " = ", 0);

    if eq_pos < 0 { false } else {

        let after_eq = eq_pos + 3;

        if after_eq + 6 > line.len() { false }

        else if starts_with(line.slice(after_eq, line.len()), "const ", 0) {

            let vs = after_eq + 6;

            if vs >= line.len() { false } else {

                let ch = line.byte_at(vs);

                (ch >= 48 and ch <= 57) or ch == 45

            }

        } else { false }

    };

// Extract integer value from: %dest = const 42

// Must use the ASSIGNMENT's `= const`, not one inside string content.

fn cf_extract_int_val(line: String) -> i64

  post it == it

= let eq_pos = find_pattern_at(line, " = ", 0);

    if eq_pos < 0 { 0 } else {

        let after_eq = eq_pos + 3;

        if starts_with(line.slice(after_eq, line.len()), "const ", 0) {

            parse_int_from(line, after_eq + 6, 0)

        } else { 0 }

    };

// Extract dest from: %dest = ...

fn cf_extract_dest(line: String) -> String

  post it.len() <= line.len()

= let start = low_skip_ws(line, 0);

    if start >= line.len() { "" }

    else if line.byte_at(start) != 37 { "" }

    else {

        let eq_pos = find_pattern_at(line, " = ", start);

        if eq_pos < 0 { "" } else { line.slice(start, eq_pos) }

    };

// Check/extract copy: %dest = copy %src

// Must use first ` = ` to avoid matching inside string content.

fn cf_is_copy(line: String) -> bool

  post it == (line.contains(" = copy %"))

= let eq_pos = find_pattern_at(line, " = ", 0);

    if eq_pos < 0 { false } else {

        starts_with(line.slice(eq_pos + 3, line.len()), "copy %", 0)

    };

fn cf_copy_src(line: String) -> String

  post it.len() <= line.len()

= let eq_pos = find_pattern_at(line, " = ", 0);

    if eq_pos < 0 { "" } else {

        if starts_with(line.slice(eq_pos + 3, line.len()), "copy %", 0) {

            line.slice(eq_pos + 8, line.len())

        } else { "" }

    };

// Check if line is binary arithmetic: %dest = OP %a, %b

fn cf_is_arith(line: String) -> bool

  post it == (line.contains(" = + ") or line.contains(" = - ") or line.contains(" = * ") or line.contains(" = / ") or line.contains(" = % "))

= let eq_pos = find_pattern_at(line, " = ", 0);

    if eq_pos < 0 { false } else {

        let rest = line.slice(eq_pos + 3, line.len());

        starts_with(rest, "+ ", 0) or starts_with(rest, "- ", 0) or

        starts_with(rest, "* ", 0) or starts_with(rest, "/ ", 0) or

        starts_with(rest, "% ", 0)

    };

// Check if line is non-trapping arithmetic (excludes div/mod which trap on zero)

// Used by IfElseToSelect to ensure select operands cannot cause UB

fn cf_is_non_trapping_arith(line: String) -> bool

  post it == (line.contains(" = + ") or line.contains(" = - ") or line.contains(" = * "))

= let eq_pos = find_pattern_at(line, " = ", 0);

    if eq_pos < 0 { false } else {

        let rest = line.slice(eq_pos + 3, line.len());

        starts_with(rest, "+ ", 0) or starts_with(rest, "- ", 0) or

        starts_with(rest, "* ", 0)

    };

// Extract operator from binary arithmetic

fn cf_arith_op(line: String) -> String

  post it.len() <= line.len()

= let eq_pos = find_pattern_at(line, " = ", 0);

    if eq_pos < 0 { "" } else {

        let rest = line.slice(eq_pos + 3, line.len());

        if starts_with(rest, "+ ", 0) { "+" }

        else if starts_with(rest, "- ", 0) { "-" }

        else if starts_with(rest, "* ", 0) { "*" }

        else if starts_with(rest, "/ ", 0) { "/" }

        else if starts_with(rest, "% ", 0) { "%" }

        else { "" }

    };

// Extract left operand: %dest = OP %left, %right -> %left

fn cf_arith_left(line: String) -> String

  post it.len() <= line.len()

= let eq_pos = find_pattern_at(line, " = ", 0);

    if eq_pos < 0 { "" } else {

        let rest = line.slice(eq_pos + 3, line.len());

        let pct = find_char(rest, 0, 37);

        if pct >= rest.len() { "" } else {

            let comma = find_char(rest, pct, 44);

            if comma >= rest.len() { "" } else { rest.slice(pct, comma) }

        }

    };

// Extract right operand: ..., %right -> %right

fn cf_arith_right(line: String) -> String

  post it.len() <= line.len()

= let comma = find_char(line, 0, 44);

    if comma >= line.len() { "" } else {

        let rest = line.slice(comma + 1, line.len());

        let after_ws = low_skip_ws(rest, 0);

        if after_ws >= rest.len() { "" }

        else if rest.byte_at(after_ws) == 37 { rest.slice(after_ws, rest.len()) }

        else { "" }

    };

// Binary arithmetic on constants (5 branches — bootstrap limit)

fn cf_compute(op: String, a: i64, b: i64) -> i64

  post it == it

= if op == "+" { a + b } else { match op { "-" => a - b, "*" => a * b, "/" => if b == 0 { 0 } else { a / b }, "%" => if b == 0 { 0 } else { a - (a / b) * b }, _ => 0 } };

// Check if line is comparison: %dest = OP %a, %b where OP is ==,!=,<,>,<=,>=

fn cf_is_cmp(line: String) -> bool

  post it == (line.contains(" = == ") or line.contains(" = != ") or line.contains(" = <= ") or line.contains(" = >= ") or line.contains(" = < ") or line.contains(" = > "))

= let eq_pos = find_pattern_at(line, " = ", 0);

    if eq_pos < 0 { false } else {

        let rest = line.slice(eq_pos + 3, line.len());

        starts_with(rest, "== ", 0) or starts_with(rest, "!= ", 0) or

        starts_with(rest, "<= ", 0) or starts_with(rest, ">= ", 0) or

        starts_with(rest, "< ", 0) or starts_with(rest, "> ", 0)

    };

// Extract comparison operator

fn cf_cmp_op(line: String) -> String

  post it.len() <= line.len()

= let eq_pos = find_pattern_at(line, " = ", 0);

    if eq_pos < 0 { "" } else {

        let rest = line.slice(eq_pos + 3, line.len());

        if starts_with(rest, "== ", 0) { "==" }

        else if starts_with(rest, "!= ", 0) { "!=" }

        else if starts_with(rest, "<= ", 0) { "<=" }

        else if starts_with(rest, ">= ", 0) { ">=" }

        else if starts_with(rest, "< ", 0) { "<" }

        else if starts_with(rest, "> ", 0) { ">" }

        else { "" }

    };

// Evaluate comparison (separate from cf_compute to avoid 5-branch limit)

fn cf_eval_cmp(op: String, a: i64, b: i64) -> i64

  post it >= 0

= match op { "==" => if a == b { 1 } else { 0 }, "!=" => if a != b { 1 } else { 0 }, "<" => if a < b { 1 } else { 0 }, ">" => if a > b { 1 } else { 0 }, "<=" => if a <= b { 1 } else { 0 }, _ => if a >= b { 1 } else { 0 } };

// Check if line is shift: %dest = << %a, %b or >> %a, %b or >>> %a, %b

fn cf_is_shift(line: String) -> bool

  post it == (line.contains(" = << ") or line.contains(" = >>> ") or line.contains(" = >> "))

= let eq_pos = find_pattern_at(line, " = ", 0);

    if eq_pos < 0 { false } else {

        let rest = line.slice(eq_pos + 3, line.len());

        starts_with(rest, "<< ", 0) or starts_with(rest, ">>> ", 0) or starts_with(rest, ">> ", 0)

    };

// Extract shift operator

fn cf_shift_op(line: String) -> String

  post it.len() <= line.len()

= let eq_pos = find_pattern_at(line, " = ", 0);

    if eq_pos < 0 { "" } else {

        let rest = line.slice(eq_pos + 3, line.len());

        if starts_with(rest, "<< ", 0) { "<<" }

        else if starts_with(rest, ">>> ", 0) { ">>>" }

        else if starts_with(rest, ">> ", 0) { ">>" }

        else { "" }

    };

// Evaluate shift (>>> uses same approximation as >> for negative values; LLVM lshr is correct)

fn cf_eval_shift(op: String, a: i64, b: i64) -> i64

  post it == it

= if op == "<<" { a * cf_pow2(b) } else { a / cf_pow2(b) };

// 2^n helper for shift evaluation

fn cf_pow2(n: i64) -> i64

  pre n >= 0

  post it >= 1

= if n <= 0 { 1 } else { 2 * cf_pow2(n - 1) };

// Check if line is bitwise: %dest = band/bor/bxor %a, %b

fn cf_is_bitwise(line: String) -> bool

  post it == (line.contains(" = band ") or line.contains(" = bor ") or line.contains(" = bxor "))

= let eq_pos = find_pattern_at(line, " = ", 0);

    if eq_pos < 0 { false } else {

        let rest = line.slice(eq_pos + 3, line.len());

        starts_with(rest, "band ", 0) or starts_with(rest, "bor ", 0) or

        starts_with(rest, "bxor ", 0)

    };

// Extract bitwise operator

fn cf_bitwise_op(line: String) -> String

  post it.len() <= line.len()

= let eq_pos = find_pattern_at(line, " = ", 0);

    if eq_pos < 0 { "" } else {

        let rest = line.slice(eq_pos + 3, line.len());

        if starts_with(rest, "band ", 0) { "band" }

        else if starts_with(rest, "bor ", 0) { "bor" }

        else if starts_with(rest, "bxor ", 0) { "bxor" }

        else { "" }

    };

// Evaluate bitwise (separate function)

fn cf_eval_bitwise(op: String, a: i64, b: i64) -> i64

  post it == it

= if op == "band" { a band b } else if op == "bor" { a bor b } else { a bxor b };

// Check if line is unary neg: %dest = neg %src

// Must use first ` = ` to avoid matching inside string content.

fn cf_is_neg(line: String) -> bool

  post it == (line.contains(" = neg %"))

= let eq_pos = find_pattern_at(line, " = ", 0);

    if eq_pos < 0 { false } else {

        starts_with(line.slice(eq_pos + 3, line.len()), "neg %", 0)

    };

// Check if line is unary not: %dest = not %src

fn cf_is_not(line: String) -> bool

  post it == (line.contains(" = not %"))

= let eq_pos = find_pattern_at(line, " = ", 0);

    if eq_pos < 0 { false } else {

        starts_with(line.slice(eq_pos + 3, line.len()), "not %", 0)

    };

// Extract source from unary: %dest = neg %src -> %src

fn cf_unary_src(line: String) -> String

  post it.len() <= line.len()

= let eq_pos = find_pattern_at(line, " = ", 0);

    if eq_pos < 0 { "" } else {

        let rest = line.slice(eq_pos + 3, line.len());

        if starts_with(rest, "neg %", 0) { line.slice(eq_pos + 7, line.len()) }

        else if starts_with(rest, "not %", 0) { line.slice(eq_pos + 7, line.len()) }

        else { "" }

    };

// Power-of-2 check: n > 1 and (n & (n-1)) == 0

fn cf_is_pow2(n: i64) -> bool

  pre n >= 0

  post not it or n > 1

= n > 1 and (n band (n - 1)) == 0;

// Log2 for power-of-2 values

fn cf_log2(n: i64) -> i64

  pre n >= 0

  post it >= 0

= if n <= 1 { 0 } else { 1 + cf_log2(n / 2) };

// Check if algebraic simplification applies (one operand known: x+0, x*1, x*0, x-x, etc.)

fn cf_can_simplify(line: String, table: String) -> bool

  post not it or cf_is_arith(line) or cf_is_shift(line) or cf_is_bitwise(line)

= if cf_is_arith(line) {

        let op = cf_arith_op(line);

        let left = cf_arith_left(line);

        let right = cf_arith_right(line);

        let lk = cf_table_has(table, left);

        let rk = cf_table_has(table, right);

        // x - x -> 0

        if op == "-" and left == right { true }

        // x + 0, x - 0 -> x

        else if (op == "+" or op == "-") and rk and cf_table_get(table, right) == 0 { true }

        // 0 + x -> x

        else if op == "+" and lk and cf_table_get(table, left) == 0 { true }

        // x * 0, 0 * x -> 0

        else if op == "*" and rk and cf_table_get(table, right) == 0 { true }

        else if op == "*" and lk and cf_table_get(table, left) == 0 { true }

        // x * 1, 1 * x -> x

        else if op == "*" and rk and cf_table_get(table, right) == 1 { true }

        else if op == "*" and lk and cf_table_get(table, left) == 1 { true }

        // x / 1 -> x

        else if op == "/" and rk and cf_table_get(table, right) == 1 { true }

        // x % 1 -> 0

        else if op == "%" and rk and cf_table_get(table, right) == 1 { true }

        // x * 2^n -> x << n (strength reduction)

        else if op == "*" and rk and cf_is_pow2(cf_table_get(table, right)) { true }

        else { op == "*" and lk and cf_is_pow2(cf_table_get(table, left)) }

    } else if cf_is_shift(line) {

        let _left = cf_arith_left(line);

        let right = cf_arith_right(line);

        let rk = cf_table_has(table, right);

        // x << 0, x >> 0 -> x

        rk and cf_table_get(table, right) == 0

    } else if cf_is_bitwise(line) {

        let op = cf_bitwise_op(line);

        let left = cf_arith_left(line);

        let right = cf_arith_right(line);

        let lk = cf_table_has(table, left);

        let rk = cf_table_has(table, right);

        // x ^ x, x - x pattern -> 0 (already handled for arith)

        if (op == "bxor") and left == right { true }

        // x & x -> x, x | x -> x

        else if (op == "band" or op == "bor") and left == right { true }

        // x & 0, 0 & x -> 0

        else if op == "band" and rk and cf_table_get(table, right) == 0 { true }

        else if op == "band" and lk and cf_table_get(table, left) == 0 { true }

        // x | 0, 0 | x -> x

        else if op == "bor" and rk and cf_table_get(table, right) == 0 { true }

        else if op == "bor" and lk and cf_table_get(table, left) == 0 { true }

        // x ^ 0, 0 ^ x -> x

        else if op == "bxor" and rk and cf_table_get(table, right) == 0 { true }

        else { op == "bxor" and lk and cf_table_get(table, left) == 0 }

    } else { false };

// Generate algebraically simplified line

fn cf_simplified(line: String, table: String) -> String

  post it.len() >= 0

= let dest = cf_extract_dest(line);

    if cf_is_arith(line) { cf_simplified_arith(dest, line, table) }

    else if cf_is_shift(line) { cf_simplified_shift(dest, line, table) }

    else if cf_is_bitwise(line) { cf_simplified_bitwise(dest, line, table) }

    else { line };

fn cf_simplified_arith(dest: String, line: String, table: String) -> String

  post it.len() >= 0

= let op = cf_arith_op(line);

    let left = cf_arith_left(line);

    let right = cf_arith_right(line);

    let lk = cf_table_has(table, left);

    let rk = cf_table_has(table, right);

    // x - x -> 0

    if op == "-" and left == right { "  " + dest + " = const 0" }

    // x * 0, 0 * x -> 0

    else if op == "*" and rk and cf_table_get(table, right) == 0 { "  " + dest + " = const 0" }

    else if op == "*" and lk and cf_table_get(table, left) == 0 { "  " + dest + " = const 0" }

    // x + 0, x - 0 -> copy x

    else if (op == "+" or op == "-") and rk and cf_table_get(table, right) == 0 { "  " + dest + " = copy " + left }

    // 0 + x -> copy x

    else if op == "+" and lk and cf_table_get(table, left) == 0 { "  " + dest + " = copy " + right }

    // x * 1 -> copy x

    else if op == "*" and rk and cf_table_get(table, right) == 1 { "  " + dest + " = copy " + left }

    // 1 * x -> copy x

    else if op == "*" and lk and cf_table_get(table, left) == 1 { "  " + dest + " = copy " + right }

    // x / 1 -> copy x

    else if op == "/" and rk and cf_table_get(table, right) == 1 { "  " + dest + " = copy " + left }

    // x % 1 -> 0

    else if op == "%" and rk and cf_table_get(table, right) == 1 { "  " + dest + " = const 0" }

    // x * 2^n -> x << n (strength reduction, emits 2-line replacement)

    else if op == "*" and rk and cf_is_pow2(cf_table_get(table, right)) {

        let shift_amt = cf_log2(cf_table_get(table, right));

        "  " + dest + "_sr = const " + i2s(shift_amt) + SEP() + "  " + dest + " = << " + left + ", " + dest + "_sr"

    }

    // 2^n * x -> x << n (commutative)

    else if op == "*" and lk and cf_is_pow2(cf_table_get(table, left)) {

        let shift_amt = cf_log2(cf_table_get(table, left));

        "  " + dest + "_sr = const " + i2s(shift_amt) + SEP() + "  " + dest + " = << " + right + ", " + dest + "_sr"

    }

    else { line };

fn cf_simplified_shift(dest: String, line: String, table: String) -> String

  post it.len() <= line.len()

= let left = cf_arith_left(line);

    let right = cf_arith_right(line);

    let rk = cf_table_has(table, right);

    // x << 0, x >> 0 -> copy x

    if rk and cf_table_get(table, right) == 0 { "  " + dest + " = copy " + left }

    else { line };

fn cf_simplified_bitwise(dest: String, line: String, table: String) -> String

  post it.len() <= line.len()

= let op = cf_bitwise_op(line);

    let left = cf_arith_left(line);

    let right = cf_arith_right(line);

    let lk = cf_table_has(table, left);

    let rk = cf_table_has(table, right);

    // x ^ x -> 0

    if op == "bxor" and left == right { "  " + dest + " = const 0" }

    // x & x -> copy x, x | x -> copy x

    else if (op == "band" or op == "bor") and left == right { "  " + dest + " = copy " + left }

    // x & 0, 0 & x -> 0

    else if op == "band" and rk and cf_table_get(table, right) == 0 { "  " + dest + " = const 0" }

    else if op == "band" and lk and cf_table_get(table, left) == 0 { "  " + dest + " = const 0" }

    // x | 0, 0 | x -> copy x

    else if op == "bor" and rk and cf_table_get(table, right) == 0 { "  " + dest + " = copy " + left }

    else if op == "bor" and lk and cf_table_get(table, left) == 0 { "  " + dest + " = copy " + right }

    // x ^ 0 -> copy x

    else if op == "bxor" and rk and cf_table_get(table, right) == 0 { "  " + dest + " = copy " + left }

    // 0 ^ x -> copy x

    else if op == "bxor" and lk and cf_table_get(table, left) == 0 { "  " + dest + " = copy " + right }

    else { line };

// Check if line can be constant-folded (arithmetic, comparison, or unary)

fn cf_can_fold(line: String, table: String) -> bool

  post not it or cf_is_arith(line) or cf_is_cmp(line) or cf_is_neg(line) or cf_is_not(line) or cf_is_shift(line) or cf_is_bitwise(line)

= if cf_is_arith(line) or cf_is_cmp(line) or cf_is_shift(line) or cf_is_bitwise(line) {

        let left = cf_arith_left(line);

        let right = cf_arith_right(line);

        cf_table_has(table, left) and cf_table_has(table, right)

    } else if cf_is_neg(line) or cf_is_not(line) {

        let src = cf_unary_src(line);

        cf_table_has(table, src)

    } else { false };

// Generate folded replacement line

fn cf_folded(line: String, table: String) -> String

  post it.len() >= 0

= let dest = cf_extract_dest(line);

    if cf_is_neg(line) {

        let src = cf_unary_src(line);

        let val = cf_table_get(table, src);

        "  " + dest + " = const " + i2s(0 - val)

    } else if cf_is_not(line) {

        let src = cf_unary_src(line);

        let val = cf_table_get(table, src);

        let result = if val == 0 { 1 } else { 0 };

        "  " + dest + " = const " + i2s(result)

    } else {

        let left = cf_arith_left(line);

        let right = cf_arith_right(line);

        let lv = cf_table_get(table, left);

        let rv = cf_table_get(table, right);

        if cf_is_arith(line) {

            let op = cf_arith_op(line);

            "  " + dest + " = const " + i2s(cf_compute(op, lv, rv))

        } else if cf_is_cmp(line) {

            let op = cf_cmp_op(line);

            "  " + dest + " = const " + i2s(cf_eval_cmp(op, lv, rv))

        } else if cf_is_shift(line) {

            let op = cf_shift_op(line);

            "  " + dest + " = const " + i2s(cf_eval_shift(op, lv, rv))

        } else {

            let op = cf_bitwise_op(line);

            "  " + dest + " = const " + i2s(cf_eval_bitwise(op, lv, rv))

        }

    };

// Update const table after processing a line

fn cf_update_table(line: String, table: String) -> String

  post it.len() >= table.len()

= if cf_is_int_const(line) {

        let dest = cf_extract_dest(line);

        let val = cf_extract_int_val(line);

        cf_table_set(table, dest, val)

    } else if ube_is_phi(line) {

        // Phi constant propagation: if both incoming values are the same constant,

        // the phi result is that constant

        let dest = cf_extract_dest(line);

        let eq_pos = find_pattern_at(line, " = ", 0);

        let rhs = line.slice(eq_pos + 3, line.len());

        let phi_args = rhs.slice(4, rhs.len());

        let b1_start = find_char(phi_args, 0, 91);

        let b1_end = find_char(phi_args, b1_start, 93);

        let bracket1 = phi_args.slice(b1_start, b1_end + 1);

        let val1_var = ube_phi_val(bracket1);

        let b2_start = find_char(phi_args, b1_end + 1, 91);

        let b2_end = find_char(phi_args, b2_start, 93);

        let bracket2 = phi_args.slice(b2_start, b2_end + 1);

        let val2_var = ube_phi_val(bracket2);

        if cf_table_has(table, val1_var) and cf_table_has(table, val2_var) {

            let v1 = cf_table_get(table, val1_var);

            let v2 = cf_table_get(table, val2_var);

            if v1 == v2 { cf_table_set(table, dest, v1) } else { table }

        } else { table }

    } else if cf_is_copy(line) {

        let dest = cf_extract_dest(line);

        let src = cf_copy_src(line);

        if cf_table_has(table, src) {

            let val = cf_table_get(table, src);

            cf_table_set(table, dest, val)

        } else { table }

    } else { table };

// Process one function's MIR lines for constant folding

// Branch simplification: detect "branch %cond, then, else" with known cond

fn cf_is_branch(line: String) -> bool

  post it == (line.contains("branch "))

= let s = low_skip_ws(line, 0);

    find_pattern_at(line, "branch ", s) == s;

fn cf_branch_cond(line: String) -> String

  post it.len() <= line.len()

= let s = low_skip_ws(line, 0);

    let after = s + 7;

    let comma = find_char(line, after, 44);

    trim_end(line.slice(after, comma));

fn cf_branch_then(line: String) -> String

  post it.len() <= line.len()

= let s = low_skip_ws(line, 0);

    let after = s + 7;

    let comma1 = find_char(line, after, 44);

    let start = low_skip_ws(line, comma1 + 1);

    let comma2 = find_char(line, start, 44);

    trim_end(line.slice(start, comma2));

fn cf_branch_else(line: String) -> String

  post it.len() <= line.len()

= let s = low_skip_ws(line, 0);

    let after = s + 7;

    let comma1 = find_char(line, after, 44);

    let start1 = low_skip_ws(line, comma1 + 1);

    let comma2 = find_char(line, start1, 44);

    let start2 = low_skip_ws(line, comma2 + 1);

    trim_end(line.slice(start2, line.len()));

fn cf_can_simplify_branch(line: String, table: String) -> bool

  post not it or cf_is_branch(line)

= if cf_is_branch(line) {

        let cond = cf_branch_cond(line);

        // Known condition value

        if cf_table_has(table, cond) { true }

        // Both targets are the same (branch %c, L, L -> goto L)

        else { cf_branch_then(line) == cf_branch_else(line) }

    } else { false };

fn cf_simplified_branch(line: String, table: String) -> String

  post it.len() <= line.len()

= let then_label = cf_branch_then(line);

    let else_label = cf_branch_else(line);

    // Both targets the same — unconditional goto

    if then_label == else_label { "  goto " + then_label }

    else {

        let cond = cf_branch_cond(line);

        let val = cf_table_get(table, cond);

        if val != 0 { "  goto " + then_label }

        else { "  goto " + else_label }

    };

// Check if phi can be folded (both incoming values are the same known constant)

fn cf_can_fold_phi(line: String, table: String) -> bool

  post not it or ube_is_phi(line)

= if ube_is_phi(line) {

        let eq_pos = find_pattern_at(line, " = ", 0);

        let rhs = line.slice(eq_pos + 3, line.len());

        let phi_args = rhs.slice(4, rhs.len());

        let b1_start = find_char(phi_args, 0, 91);

        let b1_end = find_char(phi_args, b1_start, 93);

        let bracket1 = phi_args.slice(b1_start, b1_end + 1);

        let val1_var = ube_phi_val(bracket1);

        let b2_start = find_char(phi_args, b1_end + 1, 91);

        let b2_end = find_char(phi_args, b2_start, 93);

        let bracket2 = phi_args.slice(b2_start, b2_end + 1);

        let val2_var = ube_phi_val(bracket2);

        if cf_table_has(table, val1_var) and cf_table_has(table, val2_var) {

            cf_table_get(table, val1_var) == cf_table_get(table, val2_var)

        } else { false }

    } else { false };

// Fold phi to constant when both incoming values are the same known constant

fn cf_folded_phi(line: String, table: String) -> String

  post it.len() <= line.len()

= let dest = cf_extract_dest(line);

    let eq_pos = find_pattern_at(line, " = ", 0);

    let rhs = line.slice(eq_pos + 3, line.len());

    let phi_args = rhs.slice(4, rhs.len());

    let b1_start = find_char(phi_args, 0, 91);

    let b1_end = find_char(phi_args, b1_start, 93);

    let bracket1 = phi_args.slice(b1_start, b1_end + 1);

    let val1_var = ube_phi_val(bracket1);

    let val = cf_table_get(table, val1_var);

    "  " + dest + " = const " + i2s(val);

// Check if line is a select instruction

fn cf_is_select(line: String) -> bool

  post it == (line.contains(" = select "))

= let eq_pos = find_pattern_at(line, " = ", 0);

    if eq_pos < 0 { false }

    else { starts_with(line.slice(eq_pos + 3, line.len()), "select ", 0) };

// Parse select parts: returns "cond,val1,val2"

fn cf_select_parts(line: String) -> String

  post it.len() <= line.len()

= let eq_pos = find_pattern_at(line, " = ", 0);

    let rhs = line.slice(eq_pos + 3, line.len());

    let after_sel = rhs.slice(7, rhs.len());

    let c1 = find_char(after_sel, 0, 44);

    let cond = trim_end(after_sel.slice(0, c1));

    let p2 = low_skip_ws(after_sel, c1 + 1);

    let c2 = find_char(after_sel, p2, 44);

    let val1 = trim_end(after_sel.slice(p2, c2));

    let p3 = low_skip_ws(after_sel, c2 + 1);

    let val2 = trim_end(after_sel.slice(p3, after_sel.len()));

    cond + "," + val1 + "," + val2;

// Check if select can be simplified (same values or known condition)

fn cf_can_simplify_select(line: String, table: String) -> bool

  post not it or cf_is_select(line)

= if cf_is_select(line) {

        let parts = cf_select_parts(line);

        let c1 = find_char(parts, 0, 44);

        let cond = parts.slice(0, c1);

        let c2 = find_char(parts, c1 + 1, 44);

        let val1 = parts.slice(c1 + 1, c2);

        let val2 = parts.slice(c2 + 1, parts.len());

        if val1 == val2 { true }

        else { cf_table_has(table, cond) }

    } else { false };

// Simplify select to copy

fn cf_simplified_select(line: String, table: String) -> String

  post it.len() <= line.len()

= let dest = cf_extract_dest(line);

    let parts = cf_select_parts(line);

    let c1 = find_char(parts, 0, 44);

    let cond = parts.slice(0, c1);

    let c2 = find_char(parts, c1 + 1, 44);

    let val1 = parts.slice(c1 + 1, c2);

    let val2 = parts.slice(c2 + 1, parts.len());

    if val1 == val2 { "  " + dest + " = copy " + val1 }

    else if cf_table_get(table, cond) != 0 { "  " + dest + " = copy " + val1 }

    else { "  " + dest + " = copy " + val2 };

// Dispatch: try fold, simplify, branch, phi, select

fn cf_try_simplify(line: String, table: String) -> String

  post it.len() >= 0

= if cf_can_fold(line, table) { cf_folded(line, table) }

    else if cf_can_simplify(line, table) { cf_simplified(line, table) }

    else if cf_can_simplify_branch(line, table) { cf_simplified_branch(line, table) }

    else if cf_can_fold_phi(line, table) { cf_folded_phi(line, table) }

    else { cf_try_simplify_select(line, table) };

fn cf_try_simplify_select(line: String, table: String) -> String

  post it.len() <= line.len()

= if cf_can_simplify_select(line, table) { cf_simplified_select(line, table) }

    else { line };

fn cf_fold_fn_lines(mir: String, pos: i64, sb: i64, table: String) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= mir.len() { 0 } else {

        let pipe_pos = find_pipe_skip_quotes(mir, pos);

        let line = mir.slice(pos, pipe_pos);

        let out_line = cf_try_simplify(line, table);

        let new_table = cf_update_table(out_line, table);

        let len = sb_len(sb);

        let _w1 = if len > 0 { sb_push(sb, SEP()) } else { 0 };

        let _w2 = sb_push(sb, out_line);

        if pipe_pos >= mir.len() { 0 }

        else { cf_fold_fn_lines(mir, pipe_pos + 1, sb, new_table) }

    };

// Process one function's MIR

fn cf_fold_function(fn_mir: String) -> String

  post it.len() <= fn_mir.len()

= let sb = sb_new();

    let _w = cf_fold_fn_lines(fn_mir, 0, sb, "");

    let result = sb_build(sb);

    let _f = sb_free(sb);

    result;

// Process entire program MIR function by function

fn cf_fold_program(mir: String, pos: i64, sb: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= mir.len() { 0 } else {

        let fn_end = find_double_pipe(mir, pos);

        let fn_mir = mir.slice(pos, fn_end);

        let folded = cf_fold_function(fn_mir);

        let len = sb_len(sb);

        let _w1 = if len > 0 { sb_push(sb, DSEP()) } else { 0 };

        let _w2 = sb_push(sb, folded);

        if fn_end + 2 >= mir.len() { 0 }

        else { cf_fold_program(mir, fn_end + 2, sb) }

    };

// Main entry: constant folding optimization

fn optimize_const_folding(mir: String) -> String

  post it.len() <= mir.len()

= let sb = sb_new();

    let _w = cf_fold_program(mir, 0, sb);

    let result = sb_build(sb);

    let _f = sb_free(sb);

    result;

// ============================================================================

// MIR Dead Code Elimination Pass

// Removes instructions whose results are never used downstream.

// ============================================================================

// Check if line has side effects (calls, stores — must keep even if result unused)

fn dce_has_side_effects(line: String) -> bool

  post it == (line.contains("call ") or line.contains("store ") or line.contains("store_ptr "))

= find_pattern_at(line, "call ", 0) >= 0 or

    find_pattern_at(line, "store ", 0) >= 0 or

    find_pattern_at(line, "store_ptr ", 0) >= 0;

// Check if target variable appears in line's RHS (after " = ")

fn dce_var_in_rhs(line: String, target: String) -> bool

  post not it or line.contains(target)

= let eq_pos = find_pattern_at(line, " = ", 0);

    if eq_pos < 0 {

        find_pattern_at(line, target, 0) >= 0

    } else {

        let rhs = line.slice(eq_pos + 3, line.len());

        find_pattern_at(rhs, target, 0) >= 0

    };

// Check if target variable is used in any line after pos in fn_mir

fn dce_var_used_after(fn_mir: String, target: String, pos: i64) -> bool

  pre pos >= 0

  post not it or pos < fn_mir.len()

= if pos >= fn_mir.len() { false } else {

        let pipe = find_char(fn_mir, pos, 31);

        let line = fn_mir.slice(pos, pipe);

        if dce_var_in_rhs(line, target) { true }

        else if pipe >= fn_mir.len() { false }

        else { dce_var_used_after(fn_mir, target, pipe + 1) }

    };

// Combined DCE + UBE: remove unreachable blocks and dead instructions in one pass

// reachable: 1 if in reachable block, 0 if in unreachable block

fn dce_ube_fn_lines(fn_mir: String, pos: i64, sb: i64, targets: String, reachable: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= fn_mir.len() { 0 } else {

        let pipe = find_pipe_skip_quotes(fn_mir, pos);

        let line = fn_mir.slice(pos, pipe);

        // Update reachability when we see a label

        let new_reachable = if ube_is_label(line) {

            let label = ube_label_name(line);

            if ube_is_entry(label) or ube_has_target(targets, label) { 1 } else { 0 }

        } else { reachable };

        // If unreachable, skip the line entirely

        let _keep = if new_reachable == 0 { false }

        else {

            // Simplify phi nodes with dead incoming edges

            let processed = if ube_is_phi(line) { ube_simplify_phi(line, targets) } else { line };

            // Standard DCE check

            let dest = cf_extract_dest(processed);

            let dce_keep = if dest == "" { true }

                else if dce_has_side_effects(processed) { true }

                else if pipe >= fn_mir.len() { true }

                else { dce_var_used_after(fn_mir, dest, pipe + 1) };

            let len = sb_len(sb);

            let _w1 = if dce_keep {

                let _w2 = if len > 0 { sb_push(sb, SEP()) } else { 0 };

                sb_push(sb, processed)

            } else { 0 };

            dce_keep

        };

        if pipe >= fn_mir.len() { 0 }

        else { dce_ube_fn_lines(fn_mir, pipe + 1, sb, targets, new_reachable) }

    };

// DCE a single function (with integrated UBE to remove unreachable blocks)

fn dce_function(fn_mir: String) -> String

  post it.len() <= fn_mir.len()

= let targets = ube_collect_targets(fn_mir, 0, "");

    let sb = sb_new();

    let _w = dce_ube_fn_lines(fn_mir, 0, sb, targets, 1);

    let result = sb_build(sb);

    let _f = sb_free(sb);

    result;

// DCE across all functions in the program

fn dce_program(mir: String, pos: i64, sb: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= mir.len() { 0 } else {

        let fn_end = find_double_pipe(mir, pos);

        let fn_mir = mir.slice(pos, fn_end);

        let cleaned = dce_function(fn_mir);

        let len = sb_len(sb);

        let _w1 = if len > 0 { sb_push(sb, DSEP()) } else { 0 };

        let _w2 = sb_push(sb, cleaned);

        if fn_end + 2 >= mir.len() { 0 }

        else { dce_program(mir, fn_end + 2, sb) }

    };

// Main entry: dead code elimination

fn optimize_dce(mir: String) -> String

  post it.len() <= mir.len()

= let sb = sb_new();

    let _w = dce_program(mir, 0, sb);

    let result = sb_build(sb);

    let _f = sb_free(sb);

    result;

// ============================================================================

// MIR Unreachable Block Elimination (UBE) Pass

// After branch simplification converts branch->goto, some labels become

// unreachable. This pass removes those blocks and simplifies phi nodes.

// ============================================================================

// Check if a MIR line is a label (trimmed line ends with ':')

fn ube_is_label(line: String) -> bool

  post it == (find_pattern_at(line, " = ", 0) < 0 and trim_end(line.slice(low_skip_ws(line, 0), line.len())).ends_with(":"))

= let s = low_skip_ws(line, 0);

    if s >= line.len() { false } else {

        let trimmed = trim_end(line.slice(s, line.len()));

        if trimmed.len() == 0 { false }

        else {

            let last = trimmed.byte_at(trimmed.len() - 1);

            // Must end with ':' (58) and not contain '=' (not an instruction)

            last == 58 and find_pattern_at(line, " = ", 0) < 0

        }

    };

// Extract label name from a label line (everything before ':')

fn ube_label_name(line: String) -> String

  post it.len() <= line.len()

= let s = low_skip_ws(line, 0);

    let trimmed = trim_end(line.slice(s, line.len()));

    trimmed.slice(0, trimmed.len() - 1);

// Check if a label is an entry-like label (always reachable)

fn ube_is_entry(label: String) -> bool

  post it == (label == "entry" or label.starts_with("i32_entry"))

= label == "entry" or starts_with(label, "i32_entry", 0);

// Extract goto target from "  goto label"

fn ube_goto_target(line: String) -> String

  post it.len() <= line.len()

= let s = low_skip_ws(line, 0);

    if find_pattern_at(line, "goto ", s) == s {

        trim_end(line.slice(s + 5, line.len()))

    } else { "" };

// Collect all jump targets from function MIR (comma-separated label list)

fn ube_collect_targets(fn_mir: String, pos: i64, targets: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= fn_mir.len() { targets } else {

        let pipe = find_pipe_skip_quotes(fn_mir, pos);

        let line = fn_mir.slice(pos, pipe);

        let new_targets = if find_pattern_at(line, "goto ", low_skip_ws(line, 0)) == low_skip_ws(line, 0) {

            let target = ube_goto_target(line);

            if target == "" { targets }

            else if targets == "" { target }

            else { targets + "," + target }

        } else if cf_is_branch(line) {

            let t1 = cf_branch_then(line);

            let t2 = cf_branch_else(line);

            let acc = if targets == "" { t1 } else { targets + "," + t1 };

            acc + "," + t2

        } else { targets };

        if pipe >= fn_mir.len() { new_targets }

        else { ube_collect_targets(fn_mir, pipe + 1, new_targets) }

    };

// Check if label is in comma-separated target list

fn ube_has_target(targets: String, label: String) -> bool

  post it == (targets != "" and ube_has_target_at(targets, label, 0))

= if targets == "" { false }

    else { ube_has_target_at(targets, label, 0) };

fn ube_has_target_at(targets: String, label: String, pos: i64) -> bool

  pre pos >= 0

  post not it or pos < targets.len()

= if pos >= targets.len() { false } else {

        let comma = find_char(targets, pos, 44);

        let entry = targets.slice(pos, comma);

        if entry == label { true }

        else if comma >= targets.len() { false }

        else { ube_has_target_at(targets, label, comma + 1) }

    };

// Check if a MIR line is a phi node: %dest = phi [...]

fn ube_is_phi(line: String) -> bool

  post it == (line.contains(" = phi "))

= let eq_pos = find_pattern_at(line, " = ", 0);

    if eq_pos < 0 { false } else {

        starts_with(line.slice(eq_pos + 3, line.len()), "phi ", 0)

    };

// Extract phi value from "[%val, label]" bracket expression

// Returns the %val part

fn ube_phi_val(bracket: String) -> String

  post it.len() <= bracket.len()

= // bracket = "[%val, label]"

    let start = 1;

    let comma = find_char(bracket, start, 44);

    trim_end(bracket.slice(start, comma));

// Extract phi label from "[%val, label]" bracket expression

fn ube_phi_label(bracket: String) -> String

  post it.len() <= bracket.len()

= let comma = find_char(bracket, 0, 44);

    let start = low_skip_ws(bracket, comma + 1);

    let end_bracket = find_char(bracket, start, 93);

    trim_end(bracket.slice(start, end_bracket));

// Simplify phi: if an incoming label was eliminated, remove that edge.

// If only one edge remains, convert to "copy %val".

// Input: phi line like "  %dest = phi [%v1, l1], [%v2, l2]"

// targets: comma-separated reachable labels

fn ube_simplify_phi(line: String, targets: String) -> String

  post it.len() <= line.len()

= let eq_pos = find_pattern_at(line, " = ", 0);

    let dest = line.slice(low_skip_ws(line, 0), eq_pos);

    let rhs = line.slice(eq_pos + 3, line.len());

    // rhs starts with "phi "

    let phi_args = rhs.slice(4, rhs.len());

    // Parse bracket pairs: find [ and ] delimiters

    let b1_start = find_char(phi_args, 0, 91);

    let b1_end = find_char(phi_args, b1_start, 93);

    let bracket1 = phi_args.slice(b1_start, b1_end + 1);

    let label1 = ube_phi_label(bracket1);

    let val1 = ube_phi_val(bracket1);

    let b2_start = find_char(phi_args, b1_end + 1, 91);

    let b2_end = find_char(phi_args, b2_start, 93);

    let bracket2 = phi_args.slice(b2_start, b2_end + 1);

    let label2 = ube_phi_label(bracket2);

    let val2 = ube_phi_val(bracket2);

    let l1_live = ube_is_entry(label1) or ube_has_target(targets, label1);

    let l2_live = ube_is_entry(label2) or ube_has_target(targets, label2);

    // Both values are the same -> redundant phi, convert to copy

    if val1 == val2 { "  " + dest + " = copy " + val1 }

    else if l1_live and l2_live { line }

    else if l1_live { "  " + dest + " = copy " + val1 }

    else if l2_live { "  " + dest + " = copy " + val2 }

    else { line };

// ============================================================================

// MIR Copy Propagation Pass

// Replaces uses of %b with %a when %b = copy %a.

// ============================================================================

// Check if character is alphanumeric or underscore (valid in variable names)

fn cp_is_var_char(c: i64) -> bool

  pre c >= 0

  post not it or (c >= 48 and c <= 122)

= (c >= 48 and c <= 57) or (c >= 65 and c <= 90) or (c >= 97 and c <= 122) or c == 95;

// Find end of variable name starting after '%'

fn cp_var_end(s: String, pos: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= s.len() { pos }

    else if cp_is_var_char(s.byte_at(pos)) { cp_var_end(s, pos + 1) }

    else { pos };

// Copy table: "key1=val1;key2=val2" using ';' (59) and '=' (61)

fn cp_table_set(table: String, key: String, val: String) -> String

  post it.len() >= table.len()

= if table == "" { key + "=" + val } else { table + ";" + key + "=" + val };

fn cp_table_get_at(table: String, key: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= table.len() { "" } else {

        let semi = find_char(table, pos, 59);

        let entry = table.slice(pos, semi);

        let eq = find_char(entry, 0, 61);

        if eq >= entry.len() { cp_table_get_at(table, key, semi + 1) } else {

            let entry_key = entry.slice(0, eq);

            if entry_key == key { entry.slice(eq + 1, entry.len()) }

            else { cp_table_get_at(table, key, semi + 1) }

        }

    };

fn cp_table_get(table: String, key: String) -> String

  post it.len() <= table.len()

= cp_table_get_at(table, key, 0);

// Replace %var patterns in text using copy table, starting from pos

fn cp_replace_vars(text: String, table: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= text.len() { text }

    else if text.byte_at(pos) == 37 {

        let var_end = cp_var_end(text, pos + 1);

        let var_name = text.slice(pos, var_end);

        let replacement = cp_table_get(table, var_name);

        if replacement == "" { cp_replace_vars(text, table, var_end) }

        else {

            let new_text = text.slice(0, pos) + replacement + text.slice(var_end, text.len());

            cp_replace_vars(new_text, table, pos + replacement.len())

        }

    } else { cp_replace_vars(text, table, pos + 1) };

// Replace variables in line's RHS only (preserve LHS destination)

// Special handling for store: only replace value operand, not destination

fn cp_replace_in_line(line: String, table: String) -> String

  post it.len() >= 0

= if table == "" { line } else {

        let trimmed_start = low_skip_ws(line, 0);

        let eq_pos = find_pattern_at(line, " = ", 0);

        if eq_pos >= 0 {

            let lhs = line.slice(0, eq_pos + 3);

            let rhs = line.slice(eq_pos + 3, line.len());

            lhs + cp_replace_vars(rhs, table, 0)

        } else if find_pattern_at(line, "store ", trimmed_start) == trimmed_start {

            let comma_pos = find_char(line, 0, 44);

            if comma_pos >= line.len() { line } else {

                let before = line.slice(0, comma_pos + 2);

                let after = line.slice(comma_pos + 2, line.len());

                before + cp_replace_vars(after, table, 0)

            }

        } else {

            cp_replace_vars(line, table, 0)

        }

    };

// Process each line: track copies and replace in subsequent lines

fn cp_fn_lines(fn_mir: String, pos: i64, sb: i64, table: String) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= fn_mir.len() { 0 } else {

        let pipe = find_char(fn_mir, pos, 31);

        let line = fn_mir.slice(pos, pipe);

        let new_line = cp_replace_in_line(line, table);

        let new_table = if cf_is_copy(new_line) {

            let dest = cf_extract_dest(new_line);

            let src = cf_copy_src(new_line);

            // Only propagate SSA-to-SSA copies (source is %_t temp, not user var alloca)

            if find_pattern_at(src, "%_t", 0) == 0 {

                let resolved = cp_table_get(table, src);

                let actual = if resolved == "" { src } else { resolved };

                cp_table_set(table, dest, actual)

            } else { table }

        } else { table };

        let len = sb_len(sb);

        let _w1 = if len > 0 { sb_push(sb, SEP()) } else { 0 };

        let _w2 = sb_push(sb, new_line);

        if pipe >= fn_mir.len() { 0 }

        else { cp_fn_lines(fn_mir, pipe + 1, sb, new_table) }

    };

fn cp_function(fn_mir: String) -> String

  post it.len() <= fn_mir.len()

= let sb = sb_new();

    let _w = cp_fn_lines(fn_mir, 0, sb, "");

    let result = sb_build(sb);

    let _f = sb_free(sb);

    result;

fn cp_program(mir: String, pos: i64, sb: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= mir.len() { 0 } else {

        let fn_end = find_double_pipe(mir, pos);

        let fn_mir = mir.slice(pos, fn_end);

        let propagated = cp_function(fn_mir);

        let len = sb_len(sb);

        let _w1 = if len > 0 { sb_push(sb, DSEP()) } else { 0 };

        let _w2 = sb_push(sb, propagated);

        if fn_end + 2 >= mir.len() { 0 }

        else { cp_program(mir, fn_end + 2, sb) }

    };

fn optimize_copy_prop(mir: String) -> String

  post it.len() <= mir.len()

= let sb = sb_new();

    let _w = cp_program(mir, 0, sb);

    let result = sb_build(sb);

    let _f = sb_free(sb);

    result;

// ============================================================================

// Pure Function CSE (v0.96.26)

// Eliminates redundant calls to @pure/@const functions within the same block.

// If the same pure function is called with the same arguments twice in a block,

// the second call is replaced with a copy from the first call's result.

// Arguments are resolved through a constant/copy value table to normalize keys.

// ============================================================================

// Build set of pure/const function names from module MIR.

// Scans function headers for "@pure" or "@const" annotations.

// Returns ";"-separated list: "name1;name2;"

fn pfcse_build_pure_set(mir: String, pos: i64, acc: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= mir.len() { acc } else {

        let fn_end = find_double_pipe(mir, pos);

        let fn_mir = mir.slice(pos, fn_end);

        let first_pipe = find_char(fn_mir, 0, 31);

        let header = if first_pipe < 0 or first_pipe >= fn_mir.len() { fn_mir } else { fn_mir.slice(0, first_pipe) };

        let has_pure = find_pattern_at(header, "@pure", 0) >= 0;

        let has_const = find_pattern_at(header, "@const", 0) >= 0;

        let new_acc = if has_pure or has_const {

            let name_start = 3;

            let paren_pos = find_char(header, name_start, 40);

            let fn_name = if paren_pos > name_start { header.slice(name_start, paren_pos) } else { "" };

            if fn_name == "" { acc } else { acc + fn_name + ";" }

        } else { acc };

        if fn_end + 2 >= mir.len() { new_acc }

        else { pfcse_build_pure_set(mir, fn_end + 2, new_acc) }

    };

// Check if function name is in the pure set

fn pfcse_is_pure(pure_set: String, name: String) -> bool

  post it == (pure_set != "" and name != "" and pure_set.contains(name + ";"))

= if pure_set == "" or name == "" { false }

    else { find_pattern_at(pure_set, name + ";", 0) >= 0 };

// Value table: maps variable names to their resolved values.

// Format: "%var=value;%var2=value2;" where value is either "I:42" (constant) or "%other" (copy source)

fn pfcse_val_lookup_at(vtable: String, name: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= vtable.len() { "" } else {

        let semi = find_char(vtable, pos, 59);

        if semi < 0 or semi >= vtable.len() { "" }

        else {

            let eq = find_char(vtable, pos, 61);

            if eq < 0 or eq >= semi { pfcse_val_lookup_at(vtable, name, semi + 1) }

            else {

                let key = vtable.slice(pos, eq);

                if key == name { vtable.slice(eq + 1, semi) }

                else { pfcse_val_lookup_at(vtable, name, semi + 1) }

            }

        }

    };

fn pfcse_val_lookup(vtable: String, name: String) -> String

  post it.len() <= vtable.len()

= pfcse_val_lookup_at(vtable, name, 0);

fn pfcse_val_add(vtable: String, name: String, value: String) -> String

  post it.len() == vtable.len() + name.len() + value.len() + 2

= vtable + name + "=" + value + ";";

// Resolve a variable to its canonical value through copy chains.

// Returns the resolved value: a constant string like "I:42" or the root variable name.

fn pfcse_resolve(vtable: String, name: String) -> String

  post it.len() >= 0

= let val = pfcse_val_lookup(vtable, name);

    if val == "" { name }

    else if val.len() > 0 and val.byte_at(0) == 37 { pfcse_resolve(vtable, val) }

    else { val };

// Extract call function name from MIR: "  %_tN = call @fn_name(...)" -> "fn_name"

fn pfcse_call_fn(line: String) -> String

  post it.len() <= line.len()

= let call_at = find_pattern_at(line, "call @", 0);

    if call_at < 0 { "" }

    else {

        let name_start = call_at + 6;

        let paren_pos = find_char(line, name_start, 40);

        if paren_pos <= name_start { "" }

        else { line.slice(name_start, paren_pos) }

    };

// Extract args string from call: "  %_t = call @fn(%a, %b)" -> "%a, %b"

fn pfcse_call_args(line: String) -> String

  post it.len() <= line.len()

= let open = find_pattern_at(line, "call @", 0);

    if open < 0 { "" }

    else {

        let paren = find_char(line, open + 6, 40);

        if paren < 0 { "" }

        else {

            let close = find_char(line, paren + 1, 41);

            if close <= paren { "" }

            else { line.slice(paren + 1, close) }

        }

    };

// Resolve a single argument through the value table

fn pfcse_resolve_arg(vtable: String, arg: String) -> String

  post it.len() >= 0

= let trimmed = trim(arg);

    if trimmed == "" { "" }

    else if trimmed.byte_at(0) == 37 { pfcse_resolve(vtable, trimmed) }

    else { trimmed };

// Build canonical call key: "fn_name(resolved_arg1,resolved_arg2)"

// Resolves each argument through the value table to normalize different

// temporaries holding the same constant value.

fn pfcse_build_key_args(vtable: String, args: String, pos: i64, acc: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= args.len() { acc }

    else {

        let comma = find_char(args, pos, 44);

        let end_pos = if comma >= args.len() { args.len() } else { comma };

        let arg = args.slice(pos, end_pos);

        let resolved = pfcse_resolve_arg(vtable, arg);

        let new_acc = if acc == "" { resolved } else { acc + "," + resolved };

        if end_pos >= args.len() { new_acc }

        else { pfcse_build_key_args(vtable, args, end_pos + 1, new_acc) }

    };

fn pfcse_build_key(vtable: String, line: String) -> String

  post it.len() >= 0

= let fn_name = pfcse_call_fn(line);

    let args = pfcse_call_args(line);

    let resolved_args = pfcse_build_key_args(vtable, args, 0, "");

    fn_name + "(" + resolved_args + ")";

// Call map: stores canonical_key -> dest mappings, format "key=dest;key2=dest2;"

fn pfcse_map_lookup_at(cmap: String, sig: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= cmap.len() { "" } else {

        let semi = find_char(cmap, pos, 59);

        if semi < 0 or semi >= cmap.len() { "" }

        else {

            let eq = find_char(cmap, pos, 61);

            if eq < 0 or eq >= semi { pfcse_map_lookup_at(cmap, sig, semi + 1) }

            else {

                let key = cmap.slice(pos, eq);

                if key == sig { cmap.slice(eq + 1, semi) }

                else { pfcse_map_lookup_at(cmap, sig, semi + 1) }

            }

        }

    };

fn pfcse_map_lookup(cmap: String, sig: String) -> String

  post it.len() <= cmap.len()

= pfcse_map_lookup_at(cmap, sig, 0);

fn pfcse_map_add(cmap: String, sig: String, dest: String) -> String

  post it.len() == cmap.len() + sig.len() + dest.len() + 2

= cmap + sig + "=" + dest + ";";

// Update value table from instruction: track constants and copies

fn pfcse_update_vtable(vtable: String, line: String) -> String

  post it.len() >= vtable.len()

= let dest = cf_extract_dest(line);

    if dest == "" { vtable }

    else {

        let eq_pos = find_pattern_at(line, " = ", 0);

        if eq_pos < 0 { vtable }

        else {

            let rhs = line.slice(eq_pos + 3, line.len());

            if starts_with(rhs, "const ", 0) {

                // Track constant: %_t0 = const I:42 -> vtable[%_t0] = "I:42"

                let val = rhs.slice(6, rhs.len());

                pfcse_val_add(vtable, dest, val)

            } else if starts_with(rhs, "copy %", 0) {

                // Track copy: %_t1 = copy %_t0 -> vtable[%_t1] = "%_t0"

                let src = rhs.slice(5, rhs.len());

                pfcse_val_add(vtable, dest, src)

            } else { vtable }

        }

    };

// Process one function's MIR for pure function CSE.

// cmap (call map) and vtable (value table) are reset at each label (block boundary).

fn pfcse_fn_lines(fn_mir: String, pos: i64, sb: i64, pure_set: String, cmap: String, vtable: String, count: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= fn_mir.len() { count } else {

        let pipe = find_pipe_skip_quotes(fn_mir, pos);

        let line = fn_mir.slice(pos, pipe);

        let len = sb_len(sb);

        if ube_is_label(line) {

            let _w = if len > 0 { sb_push(sb, SEP()) } else { 0 };

            let _w2 = sb_push(sb, line);

            if pipe >= fn_mir.len() { count }

            else { pfcse_fn_lines(fn_mir, pipe + 1, sb, pure_set, "", "", count) }

        } else {

            let new_vtable = pfcse_update_vtable(vtable, line);

            let call_pos = find_pattern_at(line, " = call @", 0);

            if call_pos < 0 {

                let _w = if len > 0 { sb_push(sb, SEP()) } else { 0 };

                let _w2 = sb_push(sb, line);

                if pipe >= fn_mir.len() { count }

                else { pfcse_fn_lines(fn_mir, pipe + 1, sb, pure_set, cmap, new_vtable, count) }

            } else {

                let fn_name = pfcse_call_fn(line);

                if pfcse_is_pure(pure_set, fn_name) {

                    let canon_key = pfcse_build_key(new_vtable, line);

                    let existing = pfcse_map_lookup(cmap, canon_key);

                    if existing == "" {

                        let dest = cf_extract_dest(line);

                        let new_cmap = pfcse_map_add(cmap, canon_key, dest);

                        let _w = if len > 0 { sb_push(sb, SEP()) } else { 0 };

                        let _w2 = sb_push(sb, line);

                        if pipe >= fn_mir.len() { count }

                        else { pfcse_fn_lines(fn_mir, pipe + 1, sb, pure_set, new_cmap, new_vtable, count) }

                    } else {

                        let dest = cf_extract_dest(line);

                        let copy_line = "  " + dest + " = copy " + existing;

                        let _w = if len > 0 { sb_push(sb, SEP()) } else { 0 };

                        let _w2 = sb_push(sb, copy_line);

                        if pipe >= fn_mir.len() { count + 1 }

                        else { pfcse_fn_lines(fn_mir, pipe + 1, sb, pure_set, cmap, new_vtable, count + 1) }

                    }

                } else {

                    let _w = if len > 0 { sb_push(sb, SEP()) } else { 0 };

                    let _w2 = sb_push(sb, line);

                    if pipe >= fn_mir.len() { count }

                    else { pfcse_fn_lines(fn_mir, pipe + 1, sb, pure_set, cmap, new_vtable, count) }

                }

            }

        }

    };

fn pfcse_function(fn_mir: String, pure_set: String) -> String

  post it.len() <= fn_mir.len()

= let sb = sb_new();

    let _count = pfcse_fn_lines(fn_mir, 0, sb, pure_set, "", "", 0);

    let result = sb_build(sb);

    let _f = sb_free(sb);

    result;

fn pfcse_program(mir: String, pos: i64, sb: i64, pure_set: String) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= mir.len() { 0 } else {

        let fn_end = find_double_pipe(mir, pos);

        let fn_mir = mir.slice(pos, fn_end);

        let optimized = pfcse_function(fn_mir, pure_set);

        let len = sb_len(sb);

        let _w1 = if len > 0 { sb_push(sb, DSEP()) } else { 0 };

        let _w2 = sb_push(sb, optimized);

        if fn_end + 2 >= mir.len() { 0 }

        else { pfcse_program(mir, fn_end + 2, sb, pure_set) }

    };

fn optimize_pure_fn_cse(mir: String) -> String

  post it.len() <= mir.len()

= let pure_set = pfcse_build_pure_set(mir, 0, "");

    if pure_set == "" { mir }

    else {

        let sb = sb_new();

        let _w = pfcse_program(mir, 0, sb, pure_set);

        let result = sb_build(sb);

        let _f = sb_free(sb);

        result

    };

// ============================================================================

// Memory Load CSE (MemoryLoadCSE)

// v0.96.26: Eliminates redundant load_ptr instructions and duplicate GEP

// computations within the same basic block.

// - GEP CSE: same (base, offset) -> reuse first result

// - Load CSE: same pointer -> reuse first loaded value

// - Cache invalidated by store_ptr and memory-writing function calls.

// Reuses pfcse_* helpers for value table, resolution, and map operations.

// ============================================================================

// Extend value table to also track GEP canonical values.

// For gep: %_tN = gep %base, %offset -> vtable[%_tN] = "G:resolved_base,resolved_offset"

fn mlcse_update_vtable(vtable: String, line: String) -> String

  post it.len() >= vtable.len()

= let vt = pfcse_update_vtable(vtable, line);

    let dest = cf_extract_dest(line);

    if dest == "" { vt }

    else {

        let eq_pos = find_pattern_at(line, " = gep ", 0);

        if eq_pos < 0 { vt }

        else {

            let args_start = eq_pos + 7;

            let args_str = line.slice(args_start, line.len());

            let comma = find_char(args_str, 0, 44);

            if comma < 0 or comma >= args_str.len() { vt }

            else {

                let base = trim(args_str.slice(0, comma));

                let offset = trim(args_str.slice(comma + 1, args_str.len()));

                let rb = pfcse_resolve(vt, base);

                let ro = pfcse_resolve(vt, offset);

                pfcse_val_add(vt, dest, "G:" + rb + "," + ro)

            }

        }

    };

// Known-safe builtins that do NOT write to pointer memory.

// Uses ";name;" delimited format for exact matching.

fn mlcse_safe_builtins() -> String

  post it.len() > 0

= ";abs;min;max;sqrt;floor;ceil;round;sin;cos;tan;atan;atan2;exp;log;log2;log10;pow_f64;fmod;fabs;f64_min;f64_max;popcount;clz;ctz;bit_reverse;bswap;rotate_left;rotate_right;clamp;i64_to_f64;f64_to_i64;chr;ord;len;byte_at;char_at;str_eq;str_cmp;str_len;str_data;load_i64;load_f64;load_u8;load_i32;hash_i64;hash_str;println;print;println_str;print_str;println_f64;print_f64;bmb_println_i64;bmb_print_i64;bmb_println_str;bmb_print_str;bmb_println_f64;bmb_print_f64;vec_len;";

// Check if a function call is safe (does not write to pointer memory)

fn mlcse_is_safe_call(fn_name: String, pure_set: String, safe_set: String) -> bool

  post it or fn_name.len() > 0

= if fn_name == "" { true }

    else if pfcse_is_pure(pure_set, fn_name) { true }

    else { find_pattern_at(safe_set, ";" + fn_name + ";", 0) >= 0 };

// Check if a function call is a memory-reading call that can be CSE'd.

// These read from mutable memory but don't write — cacheable with invalidation on stores.

fn mlcse_is_read_call(fn_name: String) -> bool

  post it == (fn_name == "vec_get" or fn_name == "load_i64" or fn_name == "load_f64" or fn_name == "load_u8" or fn_name == "load_i32")

= fn_name == "vec_get" or fn_name == "load_i64" or fn_name == "load_f64" or

    fn_name == "load_u8" or fn_name == "load_i32";

// mlcse_ctx packs pure_set~safe_set (immutable context for mlcse_fn_lines)

fn mlcse_ctx_pack(pure_set: String, safe_set: String) -> String

  post it.len() >= 0

= pure_set + "~" + safe_set;

// Process one function's MIR for memory load + GEP CSE.

// load_cache, gep_cache, and vtable are reset at each label (block boundary).

fn mlcse_fn_lines(fn_mir: String, pos: i64, sb: i64, mlcse_ctx: String, load_cache: String, gep_cache: String, vtable: String, count: i64) -> i64

  pre pos >= 0

  post it >= 0

= let pure_set = mlcse_ctx.slice(0, find_char(mlcse_ctx, 0, 126));
    let mlcse_safe_pos = find_char(mlcse_ctx, 0, 126);
    let safe_set = mlcse_ctx.slice(mlcse_safe_pos + 1, mlcse_ctx.len());
    if pos >= fn_mir.len() { count } else {

        let pipe = find_pipe_skip_quotes(fn_mir, pos);

        let line = fn_mir.slice(pos, pipe);

        let len = sb_len(sb);

        if ube_is_label(line) {

            // Block boundary: reset all caches

            let _w = if len > 0 { sb_push(sb, SEP()) } else { 0 };

            let _w2 = sb_push(sb, line);

            if pipe >= fn_mir.len() { count }

            else { mlcse_fn_lines(fn_mir, pipe + 1, sb, mlcse_ctx, "", "", "", count) }

        } else {

            let new_vt = mlcse_update_vtable(vtable, line);

            // Detect instruction type

            let is_gep = find_pattern_at(line, " = gep ", 0) >= 0;

            let is_load = if is_gep { false } else { find_pattern_at(line, " = load_ptr ", 0) >= 0 };

            let is_store = if not is_gep and not is_load {

                find_pattern_at(line, "store_ptr ", 0) >= 0

            } else { false };

            let is_call = if not is_gep and not is_load and not is_store {

                find_pattern_at(line, "call @", 0) >= 0

            } else { false };

            if is_gep {

                // GEP instruction: try to CSE

                let dest = cf_extract_dest(line);

                let gep_val = pfcse_val_lookup(new_vt, dest);

                let existing = if gep_val != "" { pfcse_map_lookup(gep_cache, gep_val) } else { "" };

                if existing != "" {

                    // GEP CSE: replace with copy

                    let copy_line = "  " + dest + " = copy " + existing;

                    let _w = if len > 0 { sb_push(sb, SEP()) } else { 0 };

                    let _w2 = sb_push(sb, copy_line);

                    let vt2 = pfcse_val_add(new_vt, dest, existing);

                    if pipe >= fn_mir.len() { count + 1 }

                    else { mlcse_fn_lines(fn_mir, pipe + 1, sb, mlcse_ctx, load_cache, gep_cache, vt2, count + 1) }

                } else {

                    // Cache this GEP

                    let new_gc = if gep_val != "" { pfcse_map_add(gep_cache, gep_val, dest) } else { gep_cache };

                    let _w = if len > 0 { sb_push(sb, SEP()) } else { 0 };

                    let _w2 = sb_push(sb, line);

                    if pipe >= fn_mir.len() { count }

                    else { mlcse_fn_lines(fn_mir, pipe + 1, sb, mlcse_ctx, load_cache, new_gc, new_vt, count) }

                }

            } else if is_load {

                // load_ptr instruction: try to CSE

                let lp = find_pattern_at(line, " = load_ptr ", 0);

                let ptr = trim(line.slice(lp + 12, line.len()));

                let resolved = pfcse_resolve(new_vt, ptr);

                let existing = pfcse_map_lookup(load_cache, resolved);

                if existing != "" {

                    // Load CSE: replace with copy

                    let dest = cf_extract_dest(line);

                    let copy_line = "  " + dest + " = copy " + existing;

                    let _w = if len > 0 { sb_push(sb, SEP()) } else { 0 };

                    let _w2 = sb_push(sb, copy_line);

                    let vt2 = pfcse_val_add(new_vt, dest, existing);

                    if pipe >= fn_mir.len() { count + 1 }

                    else { mlcse_fn_lines(fn_mir, pipe + 1, sb, mlcse_ctx, load_cache, gep_cache, vt2, count + 1) }

                } else {

                    // Cache this load

                    let dest = cf_extract_dest(line);

                    let new_lc = pfcse_map_add(load_cache, resolved, dest);

                    let _w = if len > 0 { sb_push(sb, SEP()) } else { 0 };

                    let _w2 = sb_push(sb, line);

                    if pipe >= fn_mir.len() { count }

                    else { mlcse_fn_lines(fn_mir, pipe + 1, sb, mlcse_ctx, new_lc, gep_cache, new_vt, count) }

                }

            } else if is_store {

                // store_ptr: invalidate ALL load caches (but keep GEP cache — stores don't change addresses)

                let _w = if len > 0 { sb_push(sb, SEP()) } else { 0 };

                let _w2 = sb_push(sb, line);

                if pipe >= fn_mir.len() { count }

                else { mlcse_fn_lines(fn_mir, pipe + 1, sb, mlcse_ctx, "", gep_cache, new_vt, count) }

            } else if is_call {

                let fn_name = pfcse_call_fn(line);

                let has_dest = find_pattern_at(line, " = call @", 0) >= 0;

                let is_read = if has_dest { mlcse_is_read_call(fn_name) } else { false };

                if is_read {

                    // Memory-reading call (vec_get, load_i64, etc.): try to CSE

                    let call_key = pfcse_build_key(new_vt, line);

                    let existing = pfcse_map_lookup(load_cache, call_key);

                    if existing != "" {

                        // CSE: replace with copy

                        let dest = cf_extract_dest(line);

                        let copy_line = "  " + dest + " = copy " + existing;

                        let _w = if len > 0 { sb_push(sb, SEP()) } else { 0 };

                        let _w2 = sb_push(sb, copy_line);

                        let vt2 = pfcse_val_add(new_vt, dest, existing);

                        if pipe >= fn_mir.len() { count + 1 }

                        else { mlcse_fn_lines(fn_mir, pipe + 1, sb, mlcse_ctx, load_cache, gep_cache, vt2, count + 1) }

                    } else {

                        // Cache this read call

                        let dest = cf_extract_dest(line);

                        let new_lc = pfcse_map_add(load_cache, call_key, dest);

                        let _w = if len > 0 { sb_push(sb, SEP()) } else { 0 };

                        let _w2 = sb_push(sb, line);

                        if pipe >= fn_mir.len() { count }

                        else { mlcse_fn_lines(fn_mir, pipe + 1, sb, mlcse_ctx, new_lc, gep_cache, new_vt, count) }

                    }

                } else {

                    // Other function call: check if it might write to memory

                    let safe = mlcse_is_safe_call(fn_name, pure_set, safe_set);

                    let new_lc = if safe { load_cache } else { "" };

                    let _w = if len > 0 { sb_push(sb, SEP()) } else { 0 };

                    let _w2 = sb_push(sb, line);

                    if pipe >= fn_mir.len() { count }

                    else { mlcse_fn_lines(fn_mir, pipe + 1, sb, mlcse_ctx, new_lc, gep_cache, new_vt, count) }

                }

            } else {

                // Other instruction: maintain caches

                let _w = if len > 0 { sb_push(sb, SEP()) } else { 0 };

                let _w2 = sb_push(sb, line);

                if pipe >= fn_mir.len() { count }

                else { mlcse_fn_lines(fn_mir, pipe + 1, sb, mlcse_ctx, load_cache, gep_cache, new_vt, count) }

            }

        }

    };

fn mlcse_function(fn_mir: String, pure_set: String, safe_set: String) -> String

  post it.len() <= fn_mir.len()

= let mlcse_ctx = mlcse_ctx_pack(pure_set, safe_set);
    let sb = sb_new();

    let _count = mlcse_fn_lines(fn_mir, 0, sb, mlcse_ctx, "", "", "", 0);

    let result = sb_build(sb);

    let _f = sb_free(sb);

    result;

fn mlcse_program(mir: String, pos: i64, sb: i64, pure_set: String, safe_set: String) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= mir.len() { 0 } else {

        let fn_end = find_double_pipe(mir, pos);

        let fn_mir = mir.slice(pos, fn_end);

        let optimized = mlcse_function(fn_mir, pure_set, safe_set);

        let len = sb_len(sb);

        let _w1 = if len > 0 { sb_push(sb, DSEP()) } else { 0 };

        let _w2 = sb_push(sb, optimized);

        if fn_end + 2 >= mir.len() { 0 }

        else { mlcse_program(mir, fn_end + 2, sb, pure_set, safe_set) }

    };

fn optimize_mem_load_cse(mir: String) -> String

  post it.len() <= mir.len()

= let pure_set = pfcse_build_pure_set(mir, 0, "");

    let safe_set = mlcse_safe_builtins();

    let sb = sb_new();

    let _w = mlcse_program(mir, 0, sb, pure_set, safe_set);

    let result = sb_build(sb);

    let _f = sb_free(sb);

    result;

// ============================================================================

// Constant Function Evaluation (ConstFnEval)

// v0.96.26: Evaluates 0-arg functions that return a simple constant value.

// Replaces calls to such functions with the constant directly.

// Phase 1: Scan module for 0-arg functions, check body for constant return.

// Phase 2: Replace 0-arg calls with the constant value.

// ============================================================================

// Check if function body has side-effectful instructions (calls, store_ptr, or labels)

fn cfeval_has_side_effects(body: String, pos: i64) -> bool

  pre pos >= 0

  post not it or pos < body.len()

= if pos >= body.len() { false } else {

        let pipe = find_pipe_skip_quotes(body, pos);

        let line = body.slice(pos, pipe);

        let has_call = find_pattern_at(line, "call @", 0) >= 0;

        let has_store_ptr = find_pattern_at(line, "store_ptr ", 0) >= 0;

        let is_label = ube_is_label(line);

        if has_call or has_store_ptr or is_label { true }

        else if pipe >= body.len() { false }

        else { cfeval_has_side_effects(body, pipe + 1) }

    };

// Find the constant value returned by a function body.

// Tracks const assignments and matches return variable to a constant.

fn cfeval_find_return_const(body: String, pos: i64, consts: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= body.len() { "" } else {

        let pipe = find_pipe_skip_quotes(body, pos);

        let line = body.slice(pos, pipe);

        // Track constant assignments: %_tN = const VALUE

        let dest = cf_extract_dest(line);

        let new_consts = if dest != "" {

            let eq_pos = find_pattern_at(line, " = ", 0);

            if eq_pos < 0 { consts }

            else {

                let rhs = line.slice(eq_pos + 3, line.len());

                if starts_with(rhs, "const ", 0) {

                    let cval = rhs.slice(6, rhs.len());

                    consts + dest + "=" + cval + ";"

                } else { consts }

            }

        } else { consts };

        // Check for return instruction

        let ret_pos = find_pattern_at(line, "return ", 0);

        if ret_pos >= 0 {

            let ret_var = trim(line.slice(ret_pos + 7, line.len()));

            pfcse_map_lookup(new_consts, ret_var)

        } else if pipe >= body.len() { "" }

        else { cfeval_find_return_const(body, pipe + 1, new_consts) }

    };

// Build map of 0-arg const function name -> constant value.

// Format: "fn_name=const_value;fn_name2=const_value2;"

fn cfeval_build_const_map(mir: String, pos: i64, acc: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= mir.len() { acc } else {

        let fn_end = find_double_pipe(mir, pos);

        let fn_mir = mir.slice(pos, fn_end);

        let first_pipe = find_char(fn_mir, 0, 31);

        let header = if first_pipe < 0 or first_pipe >= fn_mir.len() { fn_mir } else { fn_mir.slice(0, first_pipe) };

        // Check for 0-arg function: "fn name() -> ..."

        let paren_open = find_char(header, 0, 40);

        let is_zero_arg = if paren_open >= 0 and paren_open + 1 < header.len() {

            header.byte_at(paren_open + 1) == 41

        } else { false };

        let new_acc = if is_zero_arg {

            let body = if first_pipe >= 0 and first_pipe < fn_mir.len() { fn_mir.slice(first_pipe + 1, fn_mir.len()) } else { "" };

            // Check: no side effects

            let has_effects = cfeval_has_side_effects(body, 0);

            if has_effects { acc }

            else {

                let cval = cfeval_find_return_const(body, 0, "");

                if cval == "" { acc }

                else {

                    let name_start = 3;

                    let fn_name = header.slice(name_start, paren_open);

                    acc + fn_name + "=" + cval + ";"

                }

            }

        } else { acc };

        if fn_end + 2 >= mir.len() { new_acc }

        else { cfeval_build_const_map(mir, fn_end + 2, new_acc) }

    };

// Replace 0-arg const function calls with constant values

fn cfeval_fn_lines(fn_mir: String, pos: i64, sb: i64, const_map: String, count: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= fn_mir.len() { count } else {

        let pipe = find_pipe_skip_quotes(fn_mir, pos);

        let line = fn_mir.slice(pos, pipe);

        let len = sb_len(sb);

        // Check for call with destination: %_tN = call @fn_name(...)

        let call_pos = find_pattern_at(line, " = call @", 0);

        if call_pos >= 0 {

            let fn_name = pfcse_call_fn(line);

            let args = pfcse_call_args(line);

            let is_zero_arg = args == "" or trim(args) == "";

            let cval = if is_zero_arg { pfcse_map_lookup(const_map, fn_name) } else { "" };

            if cval != "" {

                // Replace call with constant

                let dest = cf_extract_dest(line);

                let const_line = "  " + dest + " = const " + cval;

                let _w = if len > 0 { sb_push(sb, SEP()) } else { 0 };

                let _w2 = sb_push(sb, const_line);

                if pipe >= fn_mir.len() { count + 1 }

                else { cfeval_fn_lines(fn_mir, pipe + 1, sb, const_map, count + 1) }

            } else {

                let _w = if len > 0 { sb_push(sb, SEP()) } else { 0 };

                let _w2 = sb_push(sb, line);

                if pipe >= fn_mir.len() { count }

                else { cfeval_fn_lines(fn_mir, pipe + 1, sb, const_map, count) }

            }

        } else {

            let _w = if len > 0 { sb_push(sb, SEP()) } else { 0 };

            let _w2 = sb_push(sb, line);

            if pipe >= fn_mir.len() { count }

            else { cfeval_fn_lines(fn_mir, pipe + 1, sb, const_map, count) }

        }

    };

fn cfeval_function(fn_mir: String, const_map: String) -> String

  post it.len() <= fn_mir.len()

= let sb = sb_new();

    let _count = cfeval_fn_lines(fn_mir, 0, sb, const_map, 0);

    let result = sb_build(sb);

    let _f = sb_free(sb);

    result;

fn cfeval_program(mir: String, pos: i64, sb: i64, const_map: String) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= mir.len() { 0 } else {

        let fn_end = find_double_pipe(mir, pos);

        let fn_mir = mir.slice(pos, fn_end);

        let optimized = cfeval_function(fn_mir, const_map);

        let len = sb_len(sb);

        let _w1 = if len > 0 { sb_push(sb, DSEP()) } else { 0 };

        let _w2 = sb_push(sb, optimized);

        if fn_end + 2 >= mir.len() { 0 }

        else { cfeval_program(mir, fn_end + 2, sb, const_map) }

    };

fn optimize_const_fn_eval(mir: String) -> String

  post it.len() <= mir.len()

= let const_map = cfeval_build_const_map(mir, 0, "");

    if const_map == "" { mir }

    else {

        let sb = sb_new();

        let _w = cfeval_program(mir, 0, sb, const_map);

        let result = sb_build(sb);

        let _f = sb_free(sb);

        result

    };

// ============================================================================

// Tail Recursive to Loop (TRL)

// Converts tail-recursive functions to loops using phi nodes.

// Pattern: fn f(params) { ... call @f(new_args) ... return result }

// becomes: fn f(params) { entry: goto loop_header; loop_header: phis + body }

// ============================================================================

// Extract function name from MIR header: "fn name(...) -> ..."

fn trl_fn_name(header: String) -> String

  post it.len() <= header.len()

= let start = find_pattern_at(header, "fn ", 0);

    if start < 0 { "" }

    else {

        let ns = start + 3;

        let paren = find_char(header, ns, 40);

        if paren <= ns { "" } else { header.slice(ns, paren) }

    };

// Extract parameter names from header: "fn name(p1: t1, p2: t2) -> ..."

// Returns ";p1;p2;" format

fn trl_param_names(header: String) -> String

  post it.len() <= header.len()

= let open = find_char(header, 0, 40);

    let close = find_char(header, open + 1, 41);

    if open < 0 or close <= open + 1 { "" }

    else { trl_parse_params(header.slice(open + 1, close), 0, "") };

fn trl_parse_params(params: String, pos: i64, acc: String) -> String

    pre pos >= 0

    post it.len() >= 0

=

    let p = low_skip_ws(params, pos);

    if p >= params.len() { acc }

    else {

        let colon = find_char(params, p, 58);

        if colon <= p { acc }

        else {

            let name = "%" + trim(params.slice(p, colon));

            let comma = find_char(params, colon, 44);

            let next = if comma < 0 or comma >= params.len() { params.len() } else { comma + 1 };

            trl_parse_params(params, next, acc + name + ";")

        }

    };

// Get Nth parameter name from ";%p1;%p2;" format (0-indexed)

fn trl_param_at(params: String, idx: i64) -> String

  pre idx >= 0

  post it.len() >= 0

= trl_param_at_scan(params, 0, idx);

fn trl_param_at_scan(params: String, pos: i64, idx: i64) -> String

    pre pos >= 0

    post it.len() >= 0

=

    if pos >= params.len() { "" }

    else {

        let semi = find_char(params, pos, 59);

        if semi < 0 or semi >= params.len() { "" }

        else if idx == 0 { params.slice(pos, semi) }

        else { trl_param_at_scan(params, semi + 1, idx - 1) }

    };

// Count parameters in ";%p1;%p2;" format

fn trl_param_count(params: String) -> i64

  post it >= 0

= trl_count_chars(params, 0, 59, 0);

fn trl_count_chars(s: String, pos: i64, ch: i64, count: i64) -> i64

    pre pos >= 0 and pos <= s.len() and count >= 0 and count <= pos

    post it >= 0

=

    if pos >= s.len() { count }

    else if s.byte_at(pos) == ch { trl_count_chars(s, pos + 1, ch, count + 1) }

    else { trl_count_chars(s, pos + 1, ch, count) };

// Find a self-recursive tail call in a function's MIR body.

// Returns the block label containing the tail call, or "" if none.

// A tail call is: %_tN = call @self_name(...) immediately followed by goto merge_M

// where merge_M has: phi [..., %_tN, this_block] then return %phi_result

// v0.96.41: Also verify that goto target block leads to return (not loop continuation)

fn trl_find_tail_call(fn_mir: String, pos: i64, fn_name: String) -> String

    pre pos >= 0

    post it.len() >= 0

=

    if pos >= fn_mir.len() { "" }

    else {

        let pipe = find_pipe_skip_quotes(fn_mir, pos);

        let line = fn_mir.slice(pos, pipe);

        let call_pat = " = call @" + fn_name + "(";

        let is_self_call = find_pattern_at(line, call_pat, 0) >= 0;

        if is_self_call {

            // Check next line is "goto ..." (not part of larger computation)

            let next_pipe = if pipe < fn_mir.len() { find_pipe_skip_quotes(fn_mir, pipe + 1) } else { fn_mir.len() };

            let next_line = if pipe < fn_mir.len() { fn_mir.slice(pipe + 1, next_pipe) } else { "" };

            let trimmed_next = trim(next_line);

            let is_goto = find_pattern_at(trimmed_next, "goto ", 0) == 0;

            // v0.96.41: Verify goto target block contains return (true tail position)

            let is_tail_pos = if is_goto {

                let goto_target = trim(trimmed_next.slice(5, trimmed_next.len()));

                trl_block_has_return(fn_mir, goto_target)

            } else { false };

            if is_tail_pos { line } else { trl_find_tail_call(fn_mir, pipe + 1, fn_name) }

        } else {

            if pipe >= fn_mir.len() { "" } else { trl_find_tail_call(fn_mir, pipe + 1, fn_name) }

        }

    };

// v0.96.41: Check if a block (identified by label) contains a return statement.

// Scans from the label until the next label or end of function.

// A block is a tail position if it contains "return ..." (possibly preceded by phi).

fn trl_block_has_return(fn_mir: String, label: String) -> bool

  post not it or fn_mir.contains(label)

= let label_pat = label + ":";

    let label_pos = find_pattern_at(fn_mir, label_pat, 0);

    if label_pos < 0 { false }

    else {

        // Skip past the label line itself

        let pipe_after = find_pipe_skip_quotes(fn_mir, label_pos);

        if pipe_after >= fn_mir.len() { false }

        else { trl_scan_block_for_return(fn_mir, pipe_after + 1) }

    };

// Scan lines within a block for "return". Stop at the next label or end.

fn trl_scan_block_for_return(fn_mir: String, pos: i64) -> bool

  pre pos >= 0

  post not it or pos < fn_mir.len()

= if pos >= fn_mir.len() { false }

    else {

        let pipe = find_pipe_skip_quotes(fn_mir, pos);

        let line = fn_mir.slice(pos, pipe);

        let trimmed = trim(line);

        // Stop if we hit another block label

        let is_label = if trimmed.len() > 0 { ube_is_label(trimmed) } else { false };

        if is_label { false }

        else {

            let is_return = find_pattern_at(trimmed, "return ", 0) == 0;

            if is_return { true }

            else if pipe >= fn_mir.len() { false }

            else { trl_scan_block_for_return(fn_mir, pipe + 1) }

        }

    };

// Extract call arguments from "  %_tN = call @fn(arg1, arg2)"

// Returns ";arg1;arg2;" format

fn trl_call_args(line: String) -> String

  post it.len() <= line.len()

= let open = find_char(line, 0, 40);

    let close = find_last_char(line, 41);

    if open < 0 or close <= open { "" }

    else { trl_split_args(line.slice(open + 1, close), 0, "") };

fn trl_split_args(args: String, pos: i64, acc: String) -> String

    pre pos >= 0

    post it.len() >= 0

=

    let p = low_skip_ws(args, pos);

    if p >= args.len() { acc }

    else {

        let comma = find_char(args, p, 44);

        let end = if comma < 0 or comma >= args.len() { args.len() } else { comma };

        let arg = trim(args.slice(p, end));

        let next = if comma < 0 or comma >= args.len() { args.len() } else { comma + 1 };

        trl_split_args(args, next, acc + arg + ";")

    };

// Find last occurrence of a character

fn find_last_char(s: String, ch: i64) -> i64

    post it >= -1

= find_last_char_scan(s, s.len() - 1, ch);

fn find_last_char_scan(s: String, pos: i64, ch: i64) -> i64

    pre pos >= -1

    post it >= -1

= 

    if pos < 0 { 0 - 1 }

    else if s.byte_at(pos) == ch { pos }

    else { find_last_char_scan(s, pos - 1, ch) };

// Substitute parameter references in a MIR line

// Replaces %param_name with %param_name_loop for each varying param

fn trl_subst_line(line: String, subst_from: String, subst_to: String) -> String

  post it.len() >= line.len()

= if subst_from == "" { line }

    else {

        let semi = find_char(subst_from, 0, 59);

        let from = subst_from.slice(0, semi);

        let to_semi = find_char(subst_to, 0, 59);

        let to_val = subst_to.slice(0, to_semi);

        let new_line = trl_replace_var(line, from, to_val);

        let rest_from = if semi + 1 >= subst_from.len() { "" } else { subst_from.slice(semi + 1, subst_from.len()) };

        let rest_to = if to_semi + 1 >= subst_to.len() { "" } else { subst_to.slice(to_semi + 1, subst_to.len()) };

        trl_subst_line(new_line, rest_from, rest_to)

    };

// Replace occurrences of variable %name with %replacement in a line

// Only replaces when %name is followed by non-alphanumeric (word boundary)

fn trl_replace_var(line: String, var_name: String, replacement: String) -> String

  post it.len() >= 0

= let pos = find_pattern_at(line, var_name, 0);

    if pos < 0 { line }

    else {

        let after = pos + var_name.len();

        let is_boundary = if after >= line.len() { true }

            else {

                let ch = line.byte_at(after);

                not (ch >= 48 and ch <= 57) and not (ch >= 65 and ch <= 90) and not (ch >= 97 and ch <= 122) and ch != 95

            };

        if is_boundary {

            let before = line.slice(0, pos);

            let rest = line.slice(after, line.len());

            let new_rest = trl_replace_var(rest, var_name, replacement);

            before + replacement + new_rest

        } else {

            let before = line.slice(0, after);

            let rest = line.slice(after, line.len());

            before + trl_replace_var(rest, var_name, replacement)

        }

    };

// Build phi nodes for loop header

// For each param, create: %param_loop = phi [%param, entry], [new_arg, tail_block_label]

fn trl_build_phis(params: String, call_args: String, idx: i64, count: i64, tail_block_label: String, subst_to: String) -> String

  pre idx >= 0

  post it.len() >= 0

= if idx >= count { "" }

    else {

        let param = trl_param_at(params, idx);

        let arg_semi = find_char(call_args, 0, 59);

        let arg = if arg_semi < 0 { call_args } else { call_args.slice(0, arg_semi) };

        let rest_args = if arg_semi < 0 or arg_semi + 1 >= call_args.len() { "" } else { call_args.slice(arg_semi + 1, call_args.len()) };

        let loop_var = param + "_loop";

        // Substitute the arg with loop vars (e.g., %acc in factorial(n-1, acc*n) -> %acc_loop)

        let subst_arg = trl_subst_line(arg, params, subst_to);

        let phi = "  " + loop_var + " = phi [" + param + ", entry], [" + subst_arg + ", " + tail_block_label + "]";

        let rest = trl_build_phis(params, rest_args, idx + 1, count, tail_block_label, subst_to);

        if rest == "" { phi } else { phi + SEP() + rest }

    };

// Build substitution target list: ";%p1_loop;%p2_loop;" from ";%p1;%p2;"

fn trl_build_subst_to(params: String) -> String

  post it.len() >= params.len()

= if params == "" { "" }

    else {

        let semi = find_char(params, 0, 59);

        let param = params.slice(0, semi);

        let rest = if semi + 1 >= params.len() { "" } else { params.slice(semi + 1, params.len()) };

        param + "_loop;" + trl_build_subst_to(rest)

    };

fn trl_find_label_scan(fn_mir: String, pos: i64, cur_label: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= fn_mir.len() { cur_label }

    else {

        let pipe = find_pipe_skip_quotes(fn_mir, pos);

        let line = fn_mir.slice(pos, pipe);

        let trimmed = trim(line);

        let new_label = if ube_is_label(trimmed) {

            let colon = find_char(trimmed, 0, 58);

            if colon > 0 { trimmed.slice(0, colon) } else { cur_label }

        } else { cur_label };

        if pipe >= fn_mir.len() { new_label }

        else { trl_find_label_scan(fn_mir, pipe + 1, new_label) }

    };

// Find the block label at a specific position by scanning backwards for the nearest label

fn trl_block_label_at(fn_mir: String, target_pos: i64) -> String

  pre target_pos >= 0

  post it.len() >= 0

= trl_block_label_scan(fn_mir, 0, "entry", target_pos);

fn trl_block_label_scan(fn_mir: String, pos: i64, cur_label: String, target: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= target { cur_label }

    else {

        let pipe = find_pipe_skip_quotes(fn_mir, pos);

        let line = fn_mir.slice(pos, pipe);

        let trimmed = trim(line);

        let new_label = if ube_is_label(trimmed) {

            let colon = find_char(trimmed, 0, 58);

            if colon > 0 { trimmed.slice(0, colon) } else { cur_label }

        } else { cur_label };

        if pipe >= fn_mir.len() or pipe >= target { new_label }

        else { trl_block_label_scan(fn_mir, pipe + 1, new_label, target) }

    };

// Count self-recursive calls in a function body

fn trl_count_self_calls(body: String, pos: i64, fn_name: String, count: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= body.len() { count }

    else {

        let pipe = find_pipe_skip_quotes(body, pos);

        let line = body.slice(pos, pipe);

        let call_pat = "call @" + fn_name + "(";

        let has_call = find_pattern_at(line, call_pat, 0) >= 0;

        let new_count = if has_call { count + 1 } else { count };

        if pipe >= body.len() { new_count }

        else { trl_count_self_calls(body, pipe + 1, fn_name, new_count) }

    };

// Transform a single function: detect tail recursion and convert to loop

// Only handles functions with exactly ONE self-recursive call (single tail call site)

fn trl_transform_fn(fn_mir: String) -> String

  post it.len() >= 0

= let first_pipe = find_pipe_skip_quotes(fn_mir, 0);

    let header = fn_mir.slice(0, first_pipe);

    let fn_name = trl_fn_name(header);

    if fn_name == "" or fn_name == "main" { fn_mir }

    else {

        let params = trl_param_names(header);

        let param_count = trl_param_count(params);

        if param_count == 0 { fn_mir }

        else {

            let body = if first_pipe < fn_mir.len() { fn_mir.slice(first_pipe + 1, fn_mir.len()) } else { "" };

            // Only handle single tail call site (skip multi-site for now)

            let call_count = trl_count_self_calls(body, 0, fn_name, 0);

            if call_count != 1 { fn_mir }

            else {

                let tail_call_line = trl_find_tail_call(body, 0, fn_name);

                if tail_call_line == "" { fn_mir }

                else {

                    let call_args = trl_call_args(tail_call_line);

                    let arg_count = trl_param_count(call_args);

                    if arg_count != param_count { fn_mir }

                    else {

                        // Find the block label containing the tail call

                        let call_pos = find_pattern_at(body, tail_call_line, 0);

                        let tail_block = trl_block_label_at(body, call_pos);

                        // Build substitution maps

                        let subst_to = trl_build_subst_to(params);

                        // Build phi nodes

                        let phis = trl_build_phis(params, call_args, 0, param_count, tail_block, subst_to);

                        // Build the transformed function

                        trl_build_transformed(header, body, params, subst_to, phis, tail_call_line, fn_name)

                    }

                }

            }

        }

    };

// Extract destination variable from tail call line: "  %_tN = call @fn(...)" -> "%_tN"

fn trl_call_dest(line: String) -> String

  post it.len() <= line.len()

= let eq_pos = find_pattern_at(line, " = ", 0);

    if eq_pos < 0 { "" } else { trim(line.slice(0, eq_pos)) };

// Simplify a phi that references the tail call result

// If the phi has [base_val, base_label], [call_result, tail_label],

// and call_result is the removed tail call dest, convert to copy of base_val

fn trl_simplify_phi(line: String, call_dest: String, params: String, subst_to: String) -> String

  post it.len() >= 0

= let eq_pos = find_pattern_at(line, " = ", 0);

    let dest = trim(line.slice(0, eq_pos));

    // Check if this phi references the tail call result

    let has_call_dest = find_pattern_at(line, call_dest, eq_pos) >= 0;

    if has_call_dest {

        // Extract the first bracket (base case value)

        let first_bracket = find_char(line, eq_pos, 91);

        let first_end = find_char(line, first_bracket, 93);

        let first_content = line.slice(first_bracket + 1, first_end);

        let first_val = trim(extract_phi_val(first_content));

        // Check second bracket

        let second_bracket = find_char(line, first_end, 91);

        let second_end = find_char(line, second_bracket, 93);

        let second_content = line.slice(second_bracket + 1, second_end);

        let second_val = trim(extract_phi_val(second_content));

        // Determine which bracket has the call dest, use the other

        let base_val = if find_pattern_at(first_content, call_dest, 0) >= 0 { second_val } else { first_val };

        // Substitute and create copy

        let subst_val = trl_subst_line(base_val, params, subst_to);

        let subst_dest = trl_subst_line(dest, params, subst_to);

        "  " + subst_dest + " = copy " + subst_val

    } else { trl_subst_line(line, params, subst_to) };

// Build the transformed function MIR

fn trl_build_transformed(header: String, body: String, params: String, subst_to: String, phis: String, tail_call_line: String, fn_name: String) -> String

  post it.len() >= 0

= let call_dest = trl_call_dest(tail_call_line);

    let sb = sb_new();

    // Header

    let _w1 = sb_push(sb, header);

    // Entry block: just goto loop_header

    let _w2 = sb_push(sb, SEP());

    let _w3 = sb_push(sb, "entry:");

    let _w4 = sb_push(sb, SEP());

    let _w5 = sb_push(sb, "  goto loop_header");

    // Loop header with phis

    let _w6 = sb_push(sb, SEP());

    let _w7 = sb_push(sb, "loop_header:");

    let _w8 = sb_push(sb, SEP());

    let _w9 = sb_push(sb, phis);

    // Emit body lines with substitutions, skipping entry: label and tail call+goto

    let _w10 = trl_emit_body(body, 0, sb, params, subst_to, tail_call_line, false, call_dest);

    let result = sb_build(sb);

    let _f = sb_free(sb);

    result;

// Emit transformed body lines

// Skip: "entry:" label (we already emitted it), tail call line, goto after tail call

// Also simplify phis that reference the removed tail call result

fn trl_emit_body(body: String, pos: i64, sb: i64, params: String, subst_to: String, tail_call_line: String, skip_next_goto: bool, call_dest: String) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= body.len() { 0 }

    else {

        let pipe = find_pipe_skip_quotes(body, pos);

        let line = body.slice(pos, pipe);

        let trimmed = trim(line);

        // Skip "entry:" label (already emitted before loop_header)

        let is_entry_label = trimmed == "entry:";

        // Skip only the exact tail call line (not other self-recursive calls)

        let is_tail_call = trim(line) == trim(tail_call_line);

        // Check for phi referencing the removed tail call result

        let is_phi_with_call = if ube_is_phi(line) and call_dest != "" { find_pattern_at(line, call_dest, 0) >= 0 } else { false };

        // Skip goto after tail call, replace with goto loop_header

        let is_goto = find_pattern_at(trimmed, "goto ", 0) == 0;

        let do_skip = is_entry_label or is_tail_call;

        let emit = if do_skip { false }

            else if is_phi_with_call {

                // Simplify phi: remove the dead edge, convert to copy

                let simplified = trl_simplify_phi(line, call_dest, params, subst_to);

                let _w = sb_push(sb, SEP());

                let _w2 = sb_push(sb, simplified);

                false

            }

            else if skip_next_goto and is_goto {

                // Replace this goto with goto loop_header

                let _w = sb_push(sb, SEP());

                let _w2 = sb_push(sb, "  goto loop_header");

                false

            }

            else { true };

        let _w = if emit {

            let subst_line = trl_subst_line(line, params, subst_to);

            // Replace "entry" label refs in phis with "loop_header"

            // (old entry content now lives in loop_header block)

            let fixed_line = if ube_is_phi(subst_line) { trl_replace_var(subst_line, "entry", "loop_header") } else { subst_line };

            let _w = sb_push(sb, SEP());

            sb_push(sb, fixed_line)

        } else { 0 };

        let new_skip = is_tail_call;

        if pipe >= body.len() { 0 }

        else { trl_emit_body(body, pipe + 1, sb, params, subst_to, tail_call_line, new_skip, call_dest) }

    };

// Process entire module: transform each function

fn trl_program(mir: String, pos: i64, sb: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= mir.len() { 0 } else {

        let fn_end = find_double_pipe(mir, pos);

        let fn_mir = mir.slice(pos, fn_end);

        let transformed = trl_transform_fn(fn_mir);

        let len = sb_len(sb);

        let _w1 = if len > 0 { sb_push(sb, DSEP()) } else { 0 };

        let _w2 = sb_push(sb, transformed);

        if fn_end + 2 >= mir.len() { 0 }

        else { trl_program(mir, fn_end + 2, sb) }

    };

// Main entry point

fn optimize_tail_recursive_to_loop(mir: String) -> String

  post it.len() >= 0

= let sb = sb_new();

    let _w = trl_program(mir, 0, sb);

    let result = sb_build(sb);

    let _f = sb_free(sb);

    result;

// ============================================================================

// Loop Invariant Code Motion (LICM)

// Hoists pure function calls out of TRL-created loops when all arguments

// are loop-invariant. E.g., s.len() called every iteration becomes called once.

// ============================================================================

// Check if a phi variable is invariant: back-edge value equals the dest.

// E.g., %s_loop = phi [%s, entry], [%s_loop, else_1] -> invariant (always %s)

// Returns the entry value if invariant, "" otherwise.

fn licm_phi_invariant(line: String, copy_map: String) -> String

  post it.len() <= line.len()

= let eq_pos = find_pattern_at(line, " = phi ", 0);

    if eq_pos < 0 { "" }

    else {

        let dest = trim(line.slice(0, eq_pos));

        let phi_part = line.slice(eq_pos + 7, line.len());

        // Parse first value: [val1, label1]

        let b1 = find_char(phi_part, 0, 91);

        let c1 = find_char(phi_part, b1 + 1, 44);

        let e1 = find_char(phi_part, c1, 93);

        if b1 >= phi_part.len() or c1 >= phi_part.len() or e1 >= phi_part.len() { "" }

        else {

            let val1 = trim(phi_part.slice(b1 + 1, c1));

            // Parse second value: [val2, label2]

            let b2 = find_char(phi_part, e1 + 1, 91);

            let c2 = find_char(phi_part, b2 + 1, 44);

            let e2 = find_char(phi_part, c2, 93);

            if b2 >= phi_part.len() or c2 >= phi_part.len() or e2 >= phi_part.len() { "" }

            else {

                let val2 = trim(phi_part.slice(b2 + 1, c2));

                // Invariant if back-edge value == dest (value doesn't change)

                // Also check via copy map: val2 might be a copy of dest (e.g. %_t12 = copy %s_loop)

                let val2_resolved = licm_resolve_copy(val2, copy_map);

                if val2 == dest or val2_resolved == dest { val1 }

                else {

                    let val1_resolved = licm_resolve_copy(val1, copy_map);

                    if val1 == dest or val1_resolved == dest { val2 }

                    else { "" }

                }

            }

        }

    };

// Resolve a variable through the copy map. Returns the copy source or "".

fn licm_resolve_copy(vname: String, copy_map: String) -> String

  post it.len() <= copy_map.len()

= let pat = vname + "=";

    let pos = find_pattern_at(copy_map, pat, 0);

    if pos < 0 { "" }

    else {

        let start = pos + vname.len() + 1;

        let semi = find_char(copy_map, start, 59);

        if semi >= copy_map.len() { "" } else { copy_map.slice(start, semi) }

    };

// Build copy map from function MIR: scans for "%_tN = copy %var" patterns

// Format: "%_t12=%s_loop;%_t15=%ch_loop;"

fn licm_build_copy_map(fn_mir: String, pos: i64, acc: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= fn_mir.len() { acc }

    else {

        let pipe = find_pipe_skip_quotes(fn_mir, pos);

        let line = fn_mir.slice(pos, pipe);

        let trimmed = trim(line);

        let new_acc = if cf_is_copy(trimmed) {

            let dest = cf_extract_dest(trimmed);

            let src = cf_copy_src(trimmed);

            acc + dest + "=" + src + ";"

        } else { acc };

        if pipe >= fn_mir.len() { new_acc }

        else { licm_build_copy_map(fn_mir, pipe + 1, new_acc) }

    };

// Build invariant map from loop_header phis.

// Format: "%s_loop=%s;%ch_loop=%ch;" — maps loop var to entry value

fn licm_build_invariant_map(fn_mir: String, lh_pos: i64, copy_map: String) -> String

  pre lh_pos >= 0

  post it.len() >= 0

= licm_scan_phis(fn_mir, lh_pos, "", copy_map);

fn licm_scan_phis(fn_mir: String, pos: i64, acc: String, copy_map: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= fn_mir.len() { acc }

    else {

        let pipe = find_pipe_skip_quotes(fn_mir, pos);

        let line = fn_mir.slice(pos, pipe);

        let trimmed = trim(line);

        // Stop at first non-phi line (phis come first in block)

        let is_phi = find_pattern_at(trimmed, "= phi ", 0) >= 0;

        if is_phi {

            let eq = find_pattern_at(line, " = phi ", 0);

            let dest = trim(line.slice(0, eq));

            let entry_val = licm_phi_invariant(line, copy_map);

            let new_acc = if entry_val != "" { acc + dest + "=" + entry_val + ";" } else { acc };

            if pipe >= fn_mir.len() { new_acc } else { licm_scan_phis(fn_mir, pipe + 1, new_acc, copy_map) }

        } else { acc }

    };

// Check if a variable is in the invariant map. Returns entry value or "".

fn licm_is_invariant(vname: String, inv_map: String) -> String

  post it.len() <= inv_map.len()

= let pat = vname + "=";

    let pos = find_pattern_at(inv_map, pat, 0);

    if pos < 0 { "" }

    else {

        let start = pos + vname.len() + 1;

        let semi = find_char(inv_map, start, 59);

        if semi >= inv_map.len() { "" } else { inv_map.slice(start, semi) }

    };

// Check if a function is pure (safe to hoist out of loop)

fn licm_is_pure_fn(fn_name: String) -> bool

  post it == (fn_name == "@bmb_string_len" or fn_name == "@bmb_array_len" or fn_name == "@bmb_string_char_at" or fn_name == "@bmb_string_eq" or fn_name == "@bmb_string_is_empty")

= fn_name == "@bmb_string_len" or fn_name == "@bmb_array_len" or

    fn_name == "@bmb_string_char_at" or fn_name == "@bmb_string_eq" or

    fn_name == "@bmb_string_is_empty";

// Check if all arguments of a call are loop-invariant or constants.

// call_line: "  %_t5 = call @fn(%arg1, %arg2)"

// Returns true if all args are invariant (directly or via copy chain).

fn licm_all_args_invariant(call_line: String, inv_map: String, copy_map: String) -> bool

  post it or not it

= let open = find_char(call_line, 0, 40);

    let close = find_last_char(call_line, 41);

    if open >= call_line.len() or close <= open + 1 { true }

    else {

        let args_str = call_line.slice(open + 1, close);

        licm_check_args(args_str, 0, inv_map, copy_map)

    };

fn licm_check_args(args: String, pos: i64, inv_map: String, copy_map: String) -> bool

  pre pos >= 0

  post it or not it

= if pos >= args.len() { true }

    else {

        // Find next comma or end

        let comma = find_char(args, pos, 44);

        let end = if comma >= args.len() { args.len() } else { comma };

        let arg = trim(args.slice(pos, end));

        // Check: is it a constant (number)?

        let is_const = if arg.len() > 0 {

            let ch = arg.byte_at(0);

            ch >= 48 and ch <= 57 or ch == 45

        } else { true };

        // Check: is it in invariant map (directly or via copy chain)?

        let is_inv = if is_const { true }

            else if licm_is_invariant(arg, inv_map) != "" { true }

            else {

                // Try copy chain: arg might be %_tN = copy %var_loop where %var_loop is invariant

                let copy_src = licm_resolve_copy(arg, copy_map);

                if copy_src != "" { licm_is_invariant(copy_src, inv_map) != "" } else { false }

            };

        if is_inv {

            if comma >= args.len() { true } else { licm_check_args(args, comma + 1, inv_map, copy_map) }

        } else { false }

    };

// Replace loop variables with entry values in a call line

fn licm_subst_invariant(call_line: String, inv_map: String, copy_map: String) -> String

  post it.len() >= 0

= let open = find_char(call_line, 0, 40);

    let close = find_last_char(call_line, 41);

    if open >= call_line.len() or close <= open + 1 { call_line }

    else {

        let prefix = call_line.slice(0, open + 1);

        let args_str = call_line.slice(open + 1, close);

        let new_args = licm_subst_args(args_str, 0, "", inv_map, copy_map);

        prefix + new_args + ")"

    };

fn licm_subst_args(args: String, pos: i64, acc: String, inv_map: String, copy_map: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= args.len() { acc }

    else {

        let comma = find_char(args, pos, 44);

        let end = if comma >= args.len() { args.len() } else { comma };

        let arg = trim(args.slice(pos, end));

        // Try direct invariant lookup, then copy chain

        let entry_val = licm_is_invariant(arg, inv_map);

        let new_arg = if entry_val != "" { entry_val }

            else {

                let copy_src = licm_resolve_copy(arg, copy_map);

                let via_copy = if copy_src != "" { licm_is_invariant(copy_src, inv_map) } else { "" };

                if via_copy != "" { via_copy } else { arg }

            };

        let sep = if acc == "" { "" } else { ", " };

        let new_acc = acc + sep + new_arg;

        if comma >= args.len() { new_acc } else { licm_subst_args(args, comma + 1, new_acc, inv_map, copy_map) }

    };

// Extract function name from call: "  %_t5 = call @fn_name(args)" -> "@fn_name"

fn licm_call_fn_name(line: String) -> String

  post it.len() <= line.len()

= let call_pos = find_pattern_at(line, "call @", 0);

    if call_pos < 0 { "" }

    else {

        let start = call_pos + 5;

        let paren = find_char(line, start, 40);

        if paren >= line.len() { "" } else { line.slice(start, paren) }

    };

// Main LICM transformation for a single function

fn licm_function(fn_mir: String) -> String

  post it.len() >= 0

= // Find loop_header: label

    let lh_pat = SEP() + "loop_header:";

    let lh_pos = find_pattern_at(fn_mir, lh_pat, 0);

    if lh_pos < 0 { fn_mir }

    else {

        // Find the position after "loop_header:" label

        let after_lh = lh_pos + lh_pat.len();

        let phi_start = if after_lh < fn_mir.len() { after_lh + 1 } else { fn_mir.len() };

        // Build copy map from entire function (for resolving %_tN = copy %var patterns)

        let copy_map = licm_build_copy_map(fn_mir, 0, "");

        // Build invariant map from phis (using copy map to resolve back-edge values)

        let inv_map = licm_build_invariant_map(fn_mir, phi_start, copy_map);

        if inv_map == "" { fn_mir }

        else {

            // Find hoistable calls in loop_header block (after phis)

            let hoistable = licm_find_hoistable(fn_mir, phi_start, inv_map, "", copy_map);

            if hoistable == "" { fn_mir }

            else {

                // Restructure: insert hoisted calls before "goto loop_header", remove from loop body

                licm_restructure(fn_mir, hoistable, inv_map, copy_map)

            }

        }

    };

// Find hoistable call lines in loop_header block.

// Returns ";line1;line2;" format of hoistable call lines.

fn licm_find_hoistable(fn_mir: String, pos: i64, inv_map: String, acc: String, copy_map: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= fn_mir.len() { acc }

    else {

        let pipe = find_pipe_skip_quotes(fn_mir, pos);

        let line = fn_mir.slice(pos, pipe);

        let trimmed = trim(line);

        // Stop at next label (end of loop_header block)

        let is_label = if trimmed.len() > 0 { trimmed.byte_at(trimmed.len() - 1) == 58 } else { false };

        if is_label { acc }

        else {

            let is_call = find_pattern_at(line, " = call @", 0) >= 0;

            let new_acc = if is_call {

                let fn_name = licm_call_fn_name(line);

                let is_pure = licm_is_pure_fn(fn_name);

                let all_inv = if is_pure { licm_all_args_invariant(line, inv_map, copy_map) } else { false };

                if all_inv { acc + trim(line) + ";" } else { acc }

            } else { acc };

            if pipe >= fn_mir.len() { new_acc } else { licm_find_hoistable(fn_mir, pipe + 1, inv_map, new_acc, copy_map) }

        }

    };

// Restructure: insert hoisted calls before "goto loop_header" and remove from loop body

fn licm_restructure(fn_mir: String, hoistable: String, inv_map: String, copy_map: String) -> String

  post it.len() >= 0

= let sb = sb_new();

    let _w = licm_emit(fn_mir, 0, sb, hoistable, inv_map, copy_map, false);

    let result = sb_build(sb);

    let _f = sb_free(sb);

    result;

fn licm_emit(fn_mir: String, pos: i64, sb: i64, hoistable: String, inv_map: String, copy_map: String, inserted: bool) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= fn_mir.len() { 0 }

    else {

        let pipe = find_pipe_skip_quotes(fn_mir, pos);

        let line = fn_mir.slice(pos, pipe);

        let trimmed = trim(line);

        // Check if this line should be hoisted (remove from original position)

        let should_remove = find_pattern_at(hoistable, trimmed + ";", 0) >= 0;

        // Check if this is the "goto loop_header" in entry block — insert hoisted calls before it

        let is_goto_lh = trimmed == "goto loop_header" and not inserted;

        let _w = if is_goto_lh {

            // Insert hoisted calls with substituted args

            let _h = licm_emit_hoisted(hoistable, 0, sb, inv_map, copy_map);

            // Then emit the goto

            let _w1 = sb_push(sb, SEP());

            let _w2 = sb_push(sb, line);

            0

        } else if should_remove {

            0

        } else {

            let _w1 = if pos > 0 { sb_push(sb, SEP()) } else { 0 };

            sb_push(sb, line)

        };

        let new_inserted = inserted or is_goto_lh;

        if pipe >= fn_mir.len() { 0 }

        else { licm_emit(fn_mir, pipe + 1, sb, hoistable, inv_map, copy_map, new_inserted) }

    };

// Emit hoisted call lines with invariant substitution

fn licm_emit_hoisted(hoistable: String, pos: i64, sb: i64, inv_map: String, copy_map: String) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= hoistable.len() { 0 }

    else {

        let semi = find_char(hoistable, pos, 59);

        if semi >= hoistable.len() { 0 }

        else {

            let call_line = hoistable.slice(pos, semi);

            if call_line.len() > 0 {

                let subst_line = licm_subst_invariant(call_line, inv_map, copy_map);

                let _w1 = sb_push(sb, SEP());

                sb_push(sb, "  " + subst_line)

            } else { 0 };

            licm_emit_hoisted(hoistable, semi + 1, sb, inv_map, copy_map)

        }

    };

// Process entire module

fn licm_program(mir: String, pos: i64, sb: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= mir.len() { 0 } else {

        let fn_end = find_double_pipe(mir, pos);

        let fn_mir = mir.slice(pos, fn_end);

        let transformed = licm_function(fn_mir);

        let len = sb_len(sb);

        let _w1 = if len > 0 { sb_push(sb, DSEP()) } else { 0 };

        let _w2 = sb_push(sb, transformed);

        if fn_end + 2 >= mir.len() { 0 }

        else { licm_program(mir, fn_end + 2, sb) }

    };

// Main entry point

fn optimize_licm(mir: String) -> String

  post it.len() >= 0

= let sb = sb_new();

    let _w = licm_program(mir, 0, sb);

    let result = sb_build(sb);

    let _f = sb_free(sb);

    result;

// ============================================================================

// Redundant Phi Elimination (RPE)

// Replaces phi nodes where all incoming values resolve to the same constant.

// E.g., %_t77 = phi [%_t75, L1], [%_t76, L2] where %_t75 = const 0, %_t76 = const 0

//   -> %_t77 = const 0

// ============================================================================

// Look up a variable's const definition in fn_mir.

// Returns the constant value string if `var = const VAL`, else "".

fn rpe_lookup_const(fn_mir: String, vname: String) -> String

  post it.len() <= fn_mir.len()

= rpe_lookup_const_depth(fn_mir, vname, 0);

// Look up a variable's const value, chasing through copy chains (up to depth 4)

fn rpe_lookup_const_depth(fn_mir: String, vname: String, depth: i64) -> String

  pre depth >= 0

  post it.len() >= 0

= if depth >= 4 { "" }

    else {

        let pattern = vname + " = const ";

        let pos = find_pattern_at(fn_mir, pattern, 0);

        if pos >= 0 {

            let val_start = pos + pattern.len();

            let pipe = find_char(fn_mir, val_start, 31);

            trim_end(fn_mir.slice(val_start, pipe))

        } else {

            // Check if it's a copy of another variable

            let cp_pattern = vname + " = copy ";

            let cp_pos = find_pattern_at(fn_mir, cp_pattern, 0);

            if cp_pos < 0 { "" }

            else {

                let src_start = cp_pos + cp_pattern.len();

                let pipe = find_char(fn_mir, src_start, 31);

                let src = trim_end(fn_mir.slice(src_start, pipe));

                // Chase the copy chain

                if find_pattern_at(src, "%_t", 0) == 0 {

                    rpe_lookup_const_depth(fn_mir, src, depth + 1)

                } else { "" }

            }

        }

    };

// Simplify a phi line if all incoming values are the same constant.

// Returns simplified line or original.

fn rpe_simplify_phi(fn_mir: String, line: String) -> String

  post it.len() >= 0

= let eq_pos = find_pattern_at(line, " = ", 0);

    if eq_pos < 0 { line }

    else {

        let dest = line.slice(low_skip_ws(line, 0), eq_pos);

        let rhs = line.slice(eq_pos + 3, line.len());

        let phi_args = rhs.slice(4, rhs.len());

        let b1_start = find_char(phi_args, 0, 91);

        let b1_end = find_char(phi_args, b1_start, 93);

        let bracket1 = phi_args.slice(b1_start, b1_end + 1);

        let val1 = ube_phi_val(bracket1);

        let b2_start = find_char(phi_args, b1_end + 1, 91);

        let b2_end = find_char(phi_args, b2_start, 93);

        let bracket2 = phi_args.slice(b2_start, b2_end + 1);

        let val2 = ube_phi_val(bracket2);

        // If values are already the same, simplify directly

        if val1 == val2 { "  " + dest + " = copy " + val1 }

        else {

            // Look up const definitions for both values

            let c1 = rpe_lookup_const(fn_mir, val1);

            let c2 = rpe_lookup_const(fn_mir, val2);

            if c1 != "" and c1 == c2 { "  " + dest + " = const " + c1 }

            else { line }

        }

    };

// Walk lines in a function, simplifying redundant phis

fn rpe_fn_lines(fn_mir: String, pos: i64, sb: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= fn_mir.len() { 0 } else {

        let pipe = find_pipe_skip_quotes(fn_mir, pos);

        let line = fn_mir.slice(pos, pipe);

        let new_line = if ube_is_phi(line) { rpe_simplify_phi(fn_mir, line) } else { line };

        let len = sb_len(sb);

        let _w1 = if len > 0 { sb_push(sb, SEP()) } else { 0 };

        let _w2 = sb_push(sb, new_line);

        if pipe >= fn_mir.len() { 0 }

        else { rpe_fn_lines(fn_mir, pipe + 1, sb) }

    };

// Process a single function

fn rpe_function(fn_mir: String) -> String

  post it.len() <= fn_mir.len()

= let sb = sb_new();

    let _w = rpe_fn_lines(fn_mir, 0, sb);

    let result = sb_build(sb);

    let _f = sb_free(sb);

    result;

// Process all functions

fn rpe_program(mir: String, pos: i64, sb: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= mir.len() { 0 } else {

        let fn_end = find_double_pipe(mir, pos);

        let fn_mir = mir.slice(pos, fn_end);

        let simplified = rpe_function(fn_mir);

        let len = sb_len(sb);

        let _w1 = if len > 0 { sb_push(sb, DSEP()) } else { 0 };

        let _w2 = sb_push(sb, simplified);

        if fn_end + 2 >= mir.len() { 0 }

        else { rpe_program(mir, fn_end + 2, sb) }

    };

fn optimize_redundant_phi(mir: String) -> String

  post it.len() <= mir.len()

= let sb = sb_new();

    let _w = rpe_program(mir, 0, sb);

    let result = sb_build(sb);

    let _f = sb_free(sb);

    result;

// === If-to-Select Conversion ===

// Pattern: branch %c, L1, L2 | L1: | goto L3 | L2: | goto L3 | L3: | %d = phi [v1, L1], [v2, L2]

// Becomes: %d = select %c, v1, v2

// Only handles empty branches (both just goto same merge).

// Get the Nth pipe-separated line from fn_mir starting at pos

// Returns (line_start, line_end, next_pos) packed as: line_start * 1000000000 + line_end

fn ifs_line_at(fn_mir: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= fn_mir.len() { "" } else {

        let pipe = find_pipe_skip_quotes(fn_mir, pos);

        fn_mir.slice(pos, pipe)

    };

fn ifs_next_pos(fn_mir: String, pos: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= fn_mir.len() { fn_mir.len() } else {

        let pipe = find_pipe_skip_quotes(fn_mir, pos);

        if pipe >= fn_mir.len() { fn_mir.len() } else { pipe + 1 }

    };

// Match phi labels against then/else branches; returns "cond,val1,val2,dest" or ""
fn ifs_check_phi_match(phi_val1: String, phi_label1: String, phi_val2: String, phi_label2: String, l_then: String, l_else: String, cond: String, dest: String) -> String

  post it.len() >= 0

= if phi_label1 == l_then and phi_label2 == l_else {

        cond + "," + phi_val1 + "," + phi_val2 + "," + dest

    } else if phi_label1 == l_else and phi_label2 == l_then {

        cond + "," + phi_val2 + "," + phi_val1 + "," + dest

    } else { "" };

// Extract phi node after merge label and match its edges to then/else branches
fn ifs_check_phi_branch(fn_mir: String, p_merge: i64, cond: String, l_then: String, l_else: String) -> String

  pre p_merge >= 0
  post it.len() >= 0

= let p6 = ifs_next_pos(fn_mir, p_merge);
    let line6 = ifs_line_at(fn_mir, p6);
    if ube_is_phi(line6) {
        let dest = cf_extract_dest(line6);
        let eq_pos = find_pattern_at(line6, " = ", 0);
        let rhs = line6.slice(eq_pos + 3, line6.len());
        let b1s = find_char(rhs, 0, 91);
        let b1e = find_char(rhs, b1s, 93);
        let bracket1 = rhs.slice(b1s, b1e + 1);
        let b2s = find_char(rhs, b1e + 1, 91);
        let b2e = find_char(rhs, b2s, 93);
        let bracket2 = rhs.slice(b2s, b2e + 1);
        let phi_val1 = ube_phi_val(bracket1);
        let phi_label1 = ube_phi_label(bracket1);
        let phi_val2 = ube_phi_val(bracket2);
        let phi_label2 = ube_phi_label(bracket2);
        ifs_check_phi_match(phi_val1, phi_label1, phi_val2, phi_label2, l_then, l_else, cond, dest)
    } else { "" };

// Check if the 7-line pattern matches at the given branch position

// Returns "" if no match, or "cond,val1,val2,dest" if match

fn ifs_check_pattern(fn_mir: String, branch_line: String, branch_pos: i64) -> String

  pre branch_pos >= 0

  post it.len() >= 0

= let cond = cf_branch_cond(branch_line);

    let l_then = cf_branch_then(branch_line);

    let l_else = cf_branch_else(branch_line);

    // Line 2: L_then:

    let p1 = ifs_next_pos(fn_mir, branch_pos);

    let line1 = ifs_line_at(fn_mir, p1);

    if ube_is_label(line1) and ube_label_name(line1) == l_then {

        // Line 3: goto L_merge

        let p2 = ifs_next_pos(fn_mir, p1);

        let line2 = ifs_line_at(fn_mir, p2);

        let goto1 = ube_goto_target(line2);

        if goto1 != "" {

            // Line 4: L_else:

            let p3 = ifs_next_pos(fn_mir, p2);

            let line3 = ifs_line_at(fn_mir, p3);

            if ube_is_label(line3) and ube_label_name(line3) == l_else {

                // Line 5: goto L_merge (same target)

                let p4 = ifs_next_pos(fn_mir, p3);

                let line4 = ifs_line_at(fn_mir, p4);

                let goto2 = ube_goto_target(line4);

                if goto2 == goto1 {

                    // Line 6: L_merge:

                    let p5 = ifs_next_pos(fn_mir, p4);

                    let line5 = ifs_line_at(fn_mir, p5);

                    if ube_is_label(line5) and ube_label_name(line5) == goto1 {
                        ifs_check_phi_branch(fn_mir, p5, cond, l_then, l_else)
                    } else { "" }

                } else { "" }

            } else { "" }

        } else { "" }

    } else { "" };

// Check if a line is a pure (side-effect-free, non-trapping) instruction

// Pure: non-trapping arithmetic (+,-,*), comparison, shift, bitwise, neg, not, copy, const

// NOT pure: div, mod (trap on zero), call, store, load, alloca, branch, goto, return, label

fn ifs_is_pure(line: String) -> bool

  post not it or line.contains(" = ")

= let s = low_skip_ws(line, 0);

    if s >= line.len() { false }

    else if line.byte_at(s) != 37 { false }

    else {

        let eq_pos = find_pattern_at(line, " = ", s);

        if eq_pos < 0 { false } else {

            let rhs = line.slice(eq_pos + 3, line.len());

            // const, copy, neg, not, select

            if starts_with(rhs, "const ", 0) { true }

            else if starts_with(rhs, "copy ", 0) { true }

            else if starts_with(rhs, "neg ", 0) { true }

            else if starts_with(rhs, "not ", 0) { true }

            else if starts_with(rhs, "select ", 0) { true }

            // Non-trapping arithmetic/cmp/shift/bitwise (div/mod excluded — they trap on zero)

            else { cf_is_non_trapping_arith(line) or cf_is_cmp(line) or cf_is_shift(line) or cf_is_bitwise(line) }

        }

    };

// Extended pattern: then has 1 pure instruction, else is empty (8 lines)

// branch %c, L1, L2 | L1: | <instr> | goto L3 | L2: | goto L3 | L3: | phi

// Returns: "extra~cond~val1~val2~dest" or ""

fn ifs_check_then_one(fn_mir: String, branch_line: String, branch_pos: i64) -> String

  pre branch_pos >= 0

  post it.len() >= 0

= let cond = cf_branch_cond(branch_line);

    let l_then = cf_branch_then(branch_line);

    let l_else = cf_branch_else(branch_line);

    let p1 = ifs_next_pos(fn_mir, branch_pos);

    let line1 = ifs_line_at(fn_mir, p1);

    if ube_is_label(line1) and ube_label_name(line1) == l_then {

        let p2 = ifs_next_pos(fn_mir, p1);

        let instr = ifs_line_at(fn_mir, p2);

        if ifs_is_pure(instr) {

            let p3 = ifs_next_pos(fn_mir, p2);

            let goto1_line = ifs_line_at(fn_mir, p3);

            let goto1 = ube_goto_target(goto1_line);

            if goto1 != "" {

                ifs_check_then_one_rest(fn_mir, p3, instr, cond, l_then, l_else, goto1)

            } else { "" }

        } else { "" }

    } else { "" };

// Continue checking: L2: | goto L3 | L3: | phi

fn ifs_check_then_one_rest(fn_mir: String, p3: i64, instr: String, cond: String, l_then: String, l_else: String, goto1: String) -> String

  pre p3 >= 0

  post it.len() >= 0

= let p4 = ifs_next_pos(fn_mir, p3);

    let line4 = ifs_line_at(fn_mir, p4);

    if ube_is_label(line4) and ube_label_name(line4) == l_else {

        let p5 = ifs_next_pos(fn_mir, p4);

        let goto2_line = ifs_line_at(fn_mir, p5);

        let goto2 = ube_goto_target(goto2_line);

        if goto2 == goto1 {

            let p6 = ifs_next_pos(fn_mir, p5);

            let line6 = ifs_line_at(fn_mir, p6);

            if ube_is_label(line6) and ube_label_name(line6) == goto1 {

                let p7 = ifs_next_pos(fn_mir, p6);

                let phi_line = ifs_line_at(fn_mir, p7);

                if ube_is_phi(phi_line) {

                    ifs_match_phi_select(phi_line, instr, cond, l_then, l_else)

                } else { "" }

            } else { "" }

        } else { "" }

    } else { "" };

// Extended pattern: then is empty, else has 1 pure instruction (8 lines)

// branch %c, L1, L2 | L1: | goto L3 | L2: | <instr> | goto L3 | L3: | phi

fn ifs_check_else_one(fn_mir: String, branch_line: String, branch_pos: i64) -> String

  pre branch_pos >= 0

  post it.len() >= 0

= let cond = cf_branch_cond(branch_line);

    let l_then = cf_branch_then(branch_line);

    let l_else = cf_branch_else(branch_line);

    let p1 = ifs_next_pos(fn_mir, branch_pos);

    let line1 = ifs_line_at(fn_mir, p1);

    if ube_is_label(line1) and ube_label_name(line1) == l_then {

        let p2 = ifs_next_pos(fn_mir, p1);

        let goto1_line = ifs_line_at(fn_mir, p2);

        let goto1 = ube_goto_target(goto1_line);

        if goto1 != "" {

            let p3 = ifs_next_pos(fn_mir, p2);

            let line3 = ifs_line_at(fn_mir, p3);

            if ube_is_label(line3) and ube_label_name(line3) == l_else {

                ifs_check_else_one_rest(fn_mir, p3, cond, l_then, l_else, goto1)

            } else { "" }

        } else { "" }

    } else { "" };

// Continue: <instr> | goto L3 | L3: | phi

fn ifs_check_else_one_rest(fn_mir: String, p3: i64, cond: String, l_then: String, l_else: String, goto1: String) -> String

  pre p3 >= 0

  post it.len() >= 0

= let p4 = ifs_next_pos(fn_mir, p3);

    let instr = ifs_line_at(fn_mir, p4);

    if ifs_is_pure(instr) {

        let p5 = ifs_next_pos(fn_mir, p4);

        let goto2_line = ifs_line_at(fn_mir, p5);

        let goto2 = ube_goto_target(goto2_line);

        if goto2 == goto1 {

            let p6 = ifs_next_pos(fn_mir, p5);

            let line6 = ifs_line_at(fn_mir, p6);

            if ube_is_label(line6) and ube_label_name(line6) == goto1 {

                let p7 = ifs_next_pos(fn_mir, p6);

                let phi_line = ifs_line_at(fn_mir, p7);

                if ube_is_phi(phi_line) {

                    ifs_match_phi_select(phi_line, instr, cond, l_then, l_else)

                } else { "" }

            } else { "" }

        } else { "" }

    } else { "" };

// Common: match phi edges to then/else, return "extra~cond~val1~val2~dest"

fn ifs_match_phi_select(phi_line: String, instr: String, cond: String, l_then: String, l_else: String) -> String

  post it.len() >= 0

= let dest = cf_extract_dest(phi_line);

    let eq_pos = find_pattern_at(phi_line, " = ", 0);

    let rhs = phi_line.slice(eq_pos + 3, phi_line.len());

    let b1s = find_char(rhs, 0, 91);

    let b1e = find_char(rhs, b1s, 93);

    let bracket1 = rhs.slice(b1s, b1e + 1);

    let b2s = find_char(rhs, b1e + 1, 91);

    let b2e = find_char(rhs, b2s, 93);

    let bracket2 = rhs.slice(b2s, b2e + 1);

    let pv1 = ube_phi_val(bracket1);

    let pl1 = ube_phi_label(bracket1);

    let pv2 = ube_phi_val(bracket2);

    let pl2 = ube_phi_label(bracket2);

    if pl1 == l_then and pl2 == l_else { instr + "~" + cond + "~" + pv1 + "~" + pv2 + "~" + dest }

    else if pl1 == l_else and pl2 == l_then { instr + "~" + cond + "~" + pv2 + "~" + pv1 + "~" + dest }

    else { "" };

// Process function MIR: replace branch+empty_blocks+phi with select

fn ifs_fn_lines(fn_mir: String, pos: i64, sb: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= fn_mir.len() { 0 } else {

        let pipe = find_pipe_skip_quotes(fn_mir, pos);

        let line = fn_mir.slice(pos, pipe);

        if cf_is_branch(line) {

            let match_result = ifs_check_pattern(fn_mir, line, pos);

            if match_result != "" {

                // Parse match: cond,val1,val2,dest

                let c1 = find_char(match_result, 0, 44);

                let cond = match_result.slice(0, c1);

                let c2 = find_char(match_result, c1 + 1, 44);

                let val1 = match_result.slice(c1 + 1, c2);

                let c3 = find_char(match_result, c2 + 1, 44);

                let val2 = match_result.slice(c2 + 1, c3);

                let dest = match_result.slice(c3 + 1, match_result.len());

                // Emit select instruction

                let select_line = "  " + dest + " = select " + cond + ", " + val1 + ", " + val2;

                let len = sb_len(sb);

                let _w1 = if len > 0 { sb_push(sb, SEP()) } else { 0 };

                let _w2 = sb_push(sb, select_line);

                // Skip 6 lines (branch already consumed, skip then_label, goto, else_label, goto, merge_label, phi)

                let p1 = ifs_next_pos(fn_mir, pos);

                let p2 = ifs_next_pos(fn_mir, p1);

                let p3 = ifs_next_pos(fn_mir, p2);

                let p4 = ifs_next_pos(fn_mir, p3);

                let p5 = ifs_next_pos(fn_mir, p4);

                let p6 = ifs_next_pos(fn_mir, p5);

                // Keep merge label alive only if referenced in downstream phis

                let ml = ifs_line_at(fn_mir, p5);

                let mn = ube_label_name(ml);

                let _w3 = if gcs_label_in_phi(fn_mir, mn) {

                    let _wa = sb_push(sb, SEP());

                    let _wb = sb_push(sb, "  goto " + mn);

                    let _wc = sb_push(sb, SEP());

                    sb_push(sb, mn + ":")

                } else { 0 };

                // Continue after the phi line

                let p7 = ifs_next_pos(fn_mir, p6);

                if p7 >= fn_mir.len() { 0 }

                else { ifs_fn_lines(fn_mir, p7, sb) }

            } else {

                // Try extended patterns (one side has 1 pure instruction)

                ifs_try_extended(fn_mir, line, pos, pipe, sb)

            }

        } else {

            let len = sb_len(sb);

            let _w1 = if len > 0 { sb_push(sb, SEP()) } else { 0 };

            let _w2 = sb_push(sb, line);

            if pipe >= fn_mir.len() { 0 }

            else { ifs_fn_lines(fn_mir, pipe + 1, sb) }

        }

    };

// Try extended patterns: then-one-instr, else-one-instr, or both-sides

fn ifs_try_extended(fn_mir: String, line: String, pos: i64, pipe: i64, sb: i64) -> i64

  pre pos >= 0

  post it >= 0

= let ext_a = ifs_check_then_one(fn_mir, line, pos);

    if ext_a != "" {

        ifs_emit_extended(fn_mir, pos, ext_a, sb)

    } else {

        let ext_b = ifs_check_else_one(fn_mir, line, pos);

        if ext_b != "" {

            ifs_emit_extended(fn_mir, pos, ext_b, sb)

        } else {

            ifs_try_both_or_fallback(fn_mir, line, pos, pipe, sb)

        }

    };

// Continue: try both-sides pattern or fall back to emitting branch

fn ifs_try_both_or_fallback(fn_mir: String, line: String, pos: i64, pipe: i64, sb: i64) -> i64

  pre pos >= 0

  post it >= 0

= let ext_c = ifs_check_both(fn_mir, line, pos);

    if ext_c != "" {

        ifs_emit_both(fn_mir, pos, ext_c, sb)

    } else {

        ifs_try_two_or_fallback(fn_mir, line, pos, pipe, sb)

    };

// Try 2-instruction patterns (then-two, else-two, flex-copy-else) or fall back

fn ifs_try_two_or_fallback(fn_mir: String, line: String, pos: i64, pipe: i64, sb: i64) -> i64

  pre pos >= 0

  post it >= 0

= let ext_d = ifs_check_then_two(fn_mir, line, pos);

    if ext_d != "" {

        ifs_emit_both(fn_mir, pos, ext_d, sb)

    } else {

        let ext_e = ifs_check_else_two(fn_mir, line, pos);

        if ext_e != "" {

            ifs_emit_both(fn_mir, pos, ext_e, sb)

        } else {

            // Try generalized flex pattern: both sides copies+pure (up to 3 pure each)

            let flex = ifs_check_flex_both_sides(fn_mir, line, pos, sb);

            if flex >= 0 { flex }

            else { ifs_emit_branch_fallback(fn_mir, line, pipe, sb) }

        }

    };

// Fallback: emit branch as-is and continue

fn ifs_emit_branch_fallback(fn_mir: String, line: String, pipe: i64, sb: i64) -> i64

  post it >= 0

= let len = sb_len(sb);

    let _w1 = if len > 0 { sb_push(sb, SEP()) } else { 0 };

    let _w2 = sb_push(sb, line);

    if pipe >= fn_mir.len() { 0 }

    else { ifs_fn_lines(fn_mir, pipe + 1, sb) };

// Both-sides pattern: 9 lines

// branch %c, L1, L2 | L1: | <instr1> | goto L3 | L2: | <instr2> | goto L3 | L3: | phi

// Returns: "instr1~instr2~cond~val1~val2~dest" or ""

fn ifs_check_both(fn_mir: String, branch_line: String, branch_pos: i64) -> String

  pre branch_pos >= 0

  post it.len() >= 0

= let cond = cf_branch_cond(branch_line);

    let l_then = cf_branch_then(branch_line);

    let l_else = cf_branch_else(branch_line);

    let p1 = ifs_next_pos(fn_mir, branch_pos);

    let line1 = ifs_line_at(fn_mir, p1);

    if ube_is_label(line1) and ube_label_name(line1) == l_then {

        let p2 = ifs_next_pos(fn_mir, p1);

        let instr1 = ifs_line_at(fn_mir, p2);

        if ifs_is_pure(instr1) {

            let p3 = ifs_next_pos(fn_mir, p2);

            let goto1_line = ifs_line_at(fn_mir, p3);

            let goto1 = ube_goto_target(goto1_line);

            if goto1 != "" {

                ifs_check_both_rest(fn_mir, p3, instr1, cond, l_then, l_else, goto1)

            } else { "" }

        } else { "" }

    } else { "" };

// Continue: L2: | <instr2> | goto L3 | L3: | phi

fn ifs_check_both_rest(fn_mir: String, p3: i64, instr1: String, cond: String, l_then: String, l_else: String, goto1: String) -> String

  pre p3 >= 0

  post it.len() >= 0

= let p4 = ifs_next_pos(fn_mir, p3);

    let line4 = ifs_line_at(fn_mir, p4);

    if ube_is_label(line4) and ube_label_name(line4) == l_else {

        let p5 = ifs_next_pos(fn_mir, p4);

        let instr2 = ifs_line_at(fn_mir, p5);

        if ifs_is_pure(instr2) {

            let p6 = ifs_next_pos(fn_mir, p5);

            let goto2_line = ifs_line_at(fn_mir, p6);

            let goto2 = ube_goto_target(goto2_line);

            if goto2 == goto1 {

                ifs_check_both_rest2(fn_mir, p6, instr1, instr2, cond, l_then, l_else, goto1)

            } else { "" }

        } else { "" }

    } else { "" };

// Continue: L3: | phi

fn ifs_check_both_rest2(fn_mir: String, p6: i64, instr1: String, instr2: String, cond: String, l_then: String, l_else: String, goto1: String) -> String

  pre p6 >= 0

  post it.len() >= 0

= let p7 = ifs_next_pos(fn_mir, p6);

    let line7 = ifs_line_at(fn_mir, p7);

    if ube_is_label(line7) and ube_label_name(line7) == goto1 {

        let p8 = ifs_next_pos(fn_mir, p7);

        let phi_line = ifs_line_at(fn_mir, p8);

        if ube_is_phi(phi_line) {

            ifs_match_phi_both(phi_line, instr1, instr2, cond, l_then, l_else)

        } else { "" }

    } else { "" };

// Match phi for both-sides pattern, returns "instr1~instr2~cond~val1~val2~dest"

fn ifs_match_phi_both(phi_line: String, instr1: String, instr2: String, cond: String, l_then: String, l_else: String) -> String

  post it.len() >= 0

= let dest = cf_extract_dest(phi_line);

    let eq_pos = find_pattern_at(phi_line, " = ", 0);

    let rhs = phi_line.slice(eq_pos + 3, phi_line.len());

    let b1s = find_char(rhs, 0, 91);

    let b1e = find_char(rhs, b1s, 93);

    let bracket1 = rhs.slice(b1s, b1e + 1);

    let b2s = find_char(rhs, b1e + 1, 91);

    let b2e = find_char(rhs, b2s, 93);

    let bracket2 = rhs.slice(b2s, b2e + 1);

    let pv1 = ube_phi_val(bracket1);

    let pl1 = ube_phi_label(bracket1);

    let pv2 = ube_phi_val(bracket2);

    let pl2 = ube_phi_label(bracket2);

    if pl1 == l_then and pl2 == l_else { instr1 + "~" + instr2 + "~" + cond + "~" + pv1 + "~" + pv2 + "~" + dest }

    else if pl1 == l_else and pl2 == l_then { instr1 + "~" + instr2 + "~" + cond + "~" + pv2 + "~" + pv1 + "~" + dest }

    else { "" };

// 2-instruction then pattern (9 lines):

// branch %c, L1, L2 | L1: | <i1> | <i2> | goto L3 | L2: | goto L3 | L3: | phi

fn ifs_check_then_two(fn_mir: String, branch_line: String, branch_pos: i64) -> String

  pre branch_pos >= 0

  post it.len() >= 0

= let cond = cf_branch_cond(branch_line);

    let l_then = cf_branch_then(branch_line);

    let l_else = cf_branch_else(branch_line);

    let p1 = ifs_next_pos(fn_mir, branch_pos);

    let line1 = ifs_line_at(fn_mir, p1);

    if ube_is_label(line1) and ube_label_name(line1) == l_then {

        let p2 = ifs_next_pos(fn_mir, p1);

        let instr1 = ifs_line_at(fn_mir, p2);

        if ifs_is_pure(instr1) {

            let p3 = ifs_next_pos(fn_mir, p2);

            let instr2 = ifs_line_at(fn_mir, p3);

            if ifs_is_pure(instr2) {

                ifs_check_then_two_rest(fn_mir, p3, instr1, instr2, cond, l_then, l_else)

            } else { "" }

        } else { "" }

    } else { "" };

// Continue: goto L3 | L2: | goto L3 | L3: | phi

fn ifs_check_then_two_rest(fn_mir: String, p3: i64, instr1: String, instr2: String, cond: String, l_then: String, l_else: String) -> String

  pre p3 >= 0

  post it.len() >= 0

= let p4 = ifs_next_pos(fn_mir, p3);

    let goto1_line = ifs_line_at(fn_mir, p4);

    let goto1 = ube_goto_target(goto1_line);

    if goto1 != "" {

        let p5 = ifs_next_pos(fn_mir, p4);

        let line5 = ifs_line_at(fn_mir, p5);

        if ube_is_label(line5) and ube_label_name(line5) == l_else {

            let p6 = ifs_next_pos(fn_mir, p5);

            let goto2_line = ifs_line_at(fn_mir, p6);

            let goto2 = ube_goto_target(goto2_line);

            if goto2 == goto1 {

                ifs_check_both_rest2(fn_mir, p6, instr1, instr2, cond, l_then, l_else, goto1)

            } else { "" }

        } else { "" }

    } else { "" };

// 2-instruction else pattern (9 lines):

// branch %c, L1, L2 | L1: | goto L3 | L2: | <i1> | <i2> | goto L3 | L3: | phi

fn ifs_check_else_two(fn_mir: String, branch_line: String, branch_pos: i64) -> String

  pre branch_pos >= 0

  post it.len() >= 0

= let cond = cf_branch_cond(branch_line);

    let l_then = cf_branch_then(branch_line);

    let l_else = cf_branch_else(branch_line);

    let p1 = ifs_next_pos(fn_mir, branch_pos);

    let line1 = ifs_line_at(fn_mir, p1);

    if ube_is_label(line1) and ube_label_name(line1) == l_then {

        let p2 = ifs_next_pos(fn_mir, p1);

        let goto1_line = ifs_line_at(fn_mir, p2);

        let goto1 = ube_goto_target(goto1_line);

        if goto1 != "" {

            let p3 = ifs_next_pos(fn_mir, p2);

            let line3 = ifs_line_at(fn_mir, p3);

            if ube_is_label(line3) and ube_label_name(line3) == l_else {

                ifs_check_else_two_rest(fn_mir, p3, cond, l_then, l_else, goto1)

            } else { "" }

        } else { "" }

    } else { "" };

// Continue: <i1> | <i2> | goto L3 | L3: | phi

fn ifs_check_else_two_rest(fn_mir: String, p3: i64, cond: String, l_then: String, l_else: String, goto1: String) -> String

  pre p3 >= 0

  post it.len() >= 0

= let p4 = ifs_next_pos(fn_mir, p3);

    let instr1 = ifs_line_at(fn_mir, p4);

    if ifs_is_pure(instr1) {

        let p5 = ifs_next_pos(fn_mir, p4);

        let instr2 = ifs_line_at(fn_mir, p5);

        if ifs_is_pure(instr2) {

            let p6 = ifs_next_pos(fn_mir, p5);

            let goto2_line = ifs_line_at(fn_mir, p6);

            let goto2 = ube_goto_target(goto2_line);

            if goto2 == goto1 {

                ifs_check_both_rest2(fn_mir, p6, instr1, instr2, cond, l_then, l_else, goto1)

            } else { "" }

        } else { "" }

    } else { "" };

// Check merge label + phi after else block; emit select if valid, else free SBs and return -1
// l_ctx = ifs_ctx_pack(l_then, l_else)
fn ifs_flex_check_phi_merge(fn_mir: String, else_goto_pos: i64, goto_target: String, cond: String, l_ctx: String, then_sb: i64, else_sb: i64, sb: i64) -> i64

  pre else_goto_pos >= 0
  post it >= -1

= let p_merge = ifs_next_pos(fn_mir, else_goto_pos);
    let merge_line = ifs_line_at(fn_mir, p_merge);
    if ube_is_label(merge_line) and ube_label_name(merge_line) == goto_target {
        let p_phi = ifs_next_pos(fn_mir, p_merge);
        let phi_line = ifs_line_at(fn_mir, p_phi);
        if ube_is_phi(phi_line) {
            let phi_cond = ifs_ctx_pack(phi_line, cond);
            ifs_flex_emit_select(phi_cond, l_ctx, then_sb, else_sb, fn_mir, p_phi, sb, goto_target)
        } else { let _tf = sb_free(then_sb); let _ef = sb_free(else_sb); 0 - 1 }
    } else { let _tf = sb_free(then_sb); let _ef = sb_free(else_sb); 0 - 1 };

// Generalized flex pattern: both sides have copies + pure instructions (variable lines)

// branch %c, L1, L2 | L1: | <then: copies+pure> | goto L3 | L2: | <else: copies+pure> | goto L3 | L3: | phi

// Handles parameter copies in both blocks by scanning flexibly and emitting select

fn ifs_check_flex_both_sides(fn_mir: String, branch_line: String, branch_pos: i64, sb: i64) -> i64

  pre branch_pos >= 0

  post it >= -1

= let cond = cf_branch_cond(branch_line);

    let l_then = cf_branch_then(branch_line);

    let l_else = cf_branch_else(branch_line);

    // Check then label

    let p1 = ifs_next_pos(fn_mir, branch_pos);

    let line1 = ifs_line_at(fn_mir, p1);

    if ube_is_label(line1) and ube_label_name(line1) == l_then {

        // Scan then block (any goto target accepted)

        let then_sb = sb_new();

        let then_goto_pos = ifs_flex_scan_block(fn_mir, p1, then_sb, 0, 3, "");

        if then_goto_pos > 0 {

            let then_goto_line = ifs_line_at(fn_mir, then_goto_pos);

            let goto_target = ube_goto_target(then_goto_line);

            // Check else label

            let p_else = ifs_next_pos(fn_mir, then_goto_pos);

            let line_else = ifs_line_at(fn_mir, p_else);

            if ube_is_label(line_else) and ube_label_name(line_else) == l_else {

                // Scan else block (must match goto_target)

                let else_sb = sb_new();

                let else_goto_pos = ifs_flex_scan_block(fn_mir, p_else, else_sb, 0, 3, goto_target);

                if else_goto_pos > 0 {
                    ifs_flex_check_phi_merge(fn_mir, else_goto_pos, goto_target, cond, ifs_ctx_pack(l_then, l_else), then_sb, else_sb, sb)
                } else { let _tf = sb_free(then_sb); let _ef = sb_free(else_sb); 0 - 1 }

            } else { let _tf = sb_free(then_sb); 0 - 1 }

        } else { let _tf = sb_free(then_sb); 0 - 1 }

    } else { 0 - 1 };

// ifs_flex context packing: phi_cond = phi_line~cond, l_ctx = l_then~l_else

fn ifs_ctx_pack(a: String, b: String) -> String

  post it.len() >= 0

= a + "~" + b;

fn ifs_ctx_first(s: String) -> String

  post it.len() >= 0

= s.slice(0, find_char(s, 0, 126));

fn ifs_ctx_second(s: String) -> String

  post it.len() >= 0

= let p = find_char(s, 0, 126); s.slice(p + 1, s.len());

// Helper: parse phi and emit select for generalized flex patterns

fn ifs_flex_emit_select(phi_cond: String, l_ctx: String, then_sb: i64, else_sb: i64, fn_mir: String, p_phi: i64, sb: i64, merge_name: String) -> i64

  post it >= 0

= let phi_line = ifs_ctx_first(phi_cond);
    let cond = ifs_ctx_second(phi_cond);
    let l_then = ifs_ctx_first(l_ctx);
    let l_else = ifs_ctx_second(l_ctx);
    let dest = cf_extract_dest(phi_line);

    let eq_pos = find_pattern_at(phi_line, " = ", 0);

    let rhs = phi_line.slice(eq_pos + 3, phi_line.len());

    let b1s = find_char(rhs, 0, 91);

    let b1e = find_char(rhs, b1s, 93);

    let bracket1 = rhs.slice(b1s, b1e + 1);

    let b2s = find_char(rhs, b1e + 1, 91);

    let b2e = find_char(rhs, b2s, 93);

    let bracket2 = rhs.slice(b2s, b2e + 1);

    let pv1 = ube_phi_val(bracket1);

    let pl1 = ube_phi_label(bracket1);

    let pv2 = ube_phi_val(bracket2);

    let pl2 = ube_phi_label(bracket2);

    let val_then = if pl1 == l_then { pv1 } else if pl2 == l_then { pv2 } else { "" };

    let val_else = if pl1 == l_else { pv1 } else if pl2 == l_else { pv2 } else { "" };

    if val_then != "" and val_else != "" {

        // Emit: then_content | else_content | select

        let then_content = sb_build(then_sb);

        let _tf = sb_free(then_sb);

        let else_content = sb_build(else_sb);

        let _ef = sb_free(else_sb);

        let _w1 = if then_content.len() > 0 {

            let l1 = sb_len(sb);

            let _ww1 = if l1 > 0 { sb_push(sb, SEP()) } else { 0 };

            sb_push(sb, then_content)

        } else { 0 };

        let _w2 = if else_content.len() > 0 {

            let l2 = sb_len(sb);

            let _ww2 = if l2 > 0 { sb_push(sb, SEP()) } else { 0 };

            sb_push(sb, else_content)

        } else { 0 };

        let select_line = "  " + dest + " = select " + cond + ", " + val_then + ", " + val_else;

        let l3 = sb_len(sb);

        let _w3 = if l3 > 0 { sb_push(sb, SEP()) } else { 0 };

        let _w4 = sb_push(sb, select_line);

        // Keep merge label alive only if referenced in downstream phis

        let _wf1 = if gcs_label_in_phi(fn_mir, merge_name) {

            let _wfa = sb_push(sb, SEP());

            let _wfb = sb_push(sb, "  goto " + merge_name);

            let _wfc = sb_push(sb, SEP());

            sb_push(sb, merge_name + ":")

        } else { 0 };

        // Continue after phi

        let p_after = ifs_next_pos(fn_mir, p_phi);

        if p_after >= fn_mir.len() { 0 }

        else { ifs_fn_lines(fn_mir, p_after, sb) }

    } else { let _tf = sb_free(then_sb); let _ef = sb_free(else_sb); 0 - 1 };

// Scan block lines: collect copies + up to max_pure non-copy pure instructions, stop at goto

// Helper: check goto target match and pure count limit

fn ifs_flex_check_goto(n_pure: i64, max_pure: i64, goto_target: String, goto_tgt: String, next_p: i64) -> i64

  pre n_pure >= 0 and max_pure >= 0 and next_p >= 0

  post it >= 0

= if n_pure > max_pure { 0 }

    else if goto_target == "" { next_p }

    else if goto_tgt == goto_target { next_p }

    else { 0 };

// If goto_target is "", any goto is accepted; otherwise must match

// Returns position of goto line on success, 0 on failure

fn ifs_flex_scan_block(fn_mir: String, pos_after_label: i64, block_sb: i64, n_pure: i64, max_pure: i64, goto_target: String) -> i64

  pre n_pure >= 0 and max_pure >= 0

  post it >= 0

= let next_p = ifs_next_pos(fn_mir, pos_after_label);

    if next_p >= fn_mir.len() { 0 } else {

        let line = ifs_line_at(fn_mir, next_p);

        let goto_tgt = ube_goto_target(line);

        if goto_tgt != "" {

            ifs_flex_check_goto(n_pure, max_pure, goto_target, goto_tgt, next_p)

        } else if cf_is_copy(line) {

            // Copy: add to block_sb, don't count as effective instruction

            let blen = sb_len(block_sb);

            let _w1 = if blen > 0 { sb_push(block_sb, SEP()) } else { 0 };

            let _w2 = sb_push(block_sb, line);

            ifs_flex_scan_block(fn_mir, next_p, block_sb, n_pure, max_pure, goto_target)

        } else if ifs_is_pure(line) and n_pure < max_pure {

            // Non-copy pure instruction: add and count

            let blen = sb_len(block_sb);

            let _w1 = if blen > 0 { sb_push(block_sb, SEP()) } else { 0 };

            let _w2 = sb_push(block_sb, line);

            ifs_flex_scan_block(fn_mir, next_p, block_sb, n_pure + 1, max_pure, goto_target)

        } else { 0 }

    };

// Emit both-sides select pattern (instr1 + instr2 + select) and skip 9 lines

fn ifs_emit_both(fn_mir: String, pos: i64, result: String, sb: i64) -> i64

  pre pos >= 0

  post it >= 0

= // Parse: instr1~instr2~cond~val1~val2~dest

    let t1 = find_char(result, 0, 126);

    let instr1 = result.slice(0, t1);

    let t2 = find_char(result, t1 + 1, 126);

    let instr2 = result.slice(t1 + 1, t2);

    let t3 = find_char(result, t2 + 1, 126);

    let cond = result.slice(t2 + 1, t3);

    let t4 = find_char(result, t3 + 1, 126);

    let val1 = result.slice(t3 + 1, t4);

    let t5 = find_char(result, t4 + 1, 126);

    let val2 = result.slice(t4 + 1, t5);

    let dest = result.slice(t5 + 1, result.len());

    // Emit instr1 + instr2 + select

    let len = sb_len(sb);

    let _w1 = if len > 0 { sb_push(sb, SEP()) } else { 0 };

    let _w2 = sb_push(sb, instr1);

    let _w3 = sb_push(sb, SEP());

    let _w4 = sb_push(sb, instr2);

    let select_line = "  " + dest + " = select " + cond + ", " + val1 + ", " + val2;

    let _w5 = sb_push(sb, SEP());

    let _w6 = sb_push(sb, select_line);

    // Skip 9 lines and continue

    ifs_skip_both_continue(fn_mir, pos, sb);

// Skip 8 lines after branch (9 total) and continue processing

fn ifs_skip_both_continue(fn_mir: String, pos: i64, sb: i64) -> i64

  pre pos >= 0

  post it >= 0

= let p1 = ifs_next_pos(fn_mir, pos);

    let p2 = ifs_next_pos(fn_mir, p1);

    let p3 = ifs_next_pos(fn_mir, p2);

    let p4 = ifs_next_pos(fn_mir, p3);

    let p5 = ifs_next_pos(fn_mir, p4);

    let p6 = ifs_next_pos(fn_mir, p5);

    let p7 = ifs_next_pos(fn_mir, p6);

    let p8 = ifs_next_pos(fn_mir, p7);

    // Keep merge label (p7) alive only if referenced in downstream phis

    let ml_b = ifs_line_at(fn_mir, p7);

    let mn_b = ube_label_name(ml_b);

    let _wb1 = if gcs_label_in_phi(fn_mir, mn_b) {

        let _wba = sb_push(sb, SEP());

        let _wbb = sb_push(sb, "  goto " + mn_b);

        let _wbc = sb_push(sb, SEP());

        sb_push(sb, mn_b + ":")

    } else { 0 };

    let p9 = ifs_next_pos(fn_mir, p8);

    if p9 >= fn_mir.len() { 0 }

    else { ifs_fn_lines(fn_mir, p9, sb) };

// Emit extended select pattern (extra_instr + select) and skip 8 lines

fn ifs_emit_extended(fn_mir: String, pos: i64, result: String, sb: i64) -> i64

  pre pos >= 0

  post it >= 0

= // Parse result: extra~cond~val1~val2~dest

    let t1 = find_char(result, 0, 126);

    let extra = result.slice(0, t1);

    let t2 = find_char(result, t1 + 1, 126);

    let cond = result.slice(t1 + 1, t2);

    let t3 = find_char(result, t2 + 1, 126);

    let val1 = result.slice(t2 + 1, t3);

    let t4 = find_char(result, t3 + 1, 126);

    let val2 = result.slice(t3 + 1, t4);

    let dest = result.slice(t4 + 1, result.len());

    // Emit extra instruction

    let len = sb_len(sb);

    let _w1 = if len > 0 { sb_push(sb, SEP()) } else { 0 };

    let _w2 = sb_push(sb, extra);

    // Emit select

    let select_line = "  " + dest + " = select " + cond + ", " + val1 + ", " + val2;

    let _w3 = sb_push(sb, SEP());

    let _w4 = sb_push(sb, select_line);

    // Skip 7 more lines after branch (8 total: branch + label + instr_or_goto + goto + label + goto + label + phi)

    let p1 = ifs_next_pos(fn_mir, pos);

    let p2 = ifs_next_pos(fn_mir, p1);

    let p3 = ifs_next_pos(fn_mir, p2);

    let p4 = ifs_next_pos(fn_mir, p3);

    let p5 = ifs_next_pos(fn_mir, p4);

    let p6 = ifs_next_pos(fn_mir, p5);

    let p7 = ifs_next_pos(fn_mir, p6);

    // Keep merge label (p6) alive only if referenced in downstream phis

    let ml_e = ifs_line_at(fn_mir, p6);

    let mn_e = ube_label_name(ml_e);

    let _w5 = if gcs_label_in_phi(fn_mir, mn_e) {

        let _wea = sb_push(sb, SEP());

        let _web = sb_push(sb, "  goto " + mn_e);

        let _wec = sb_push(sb, SEP());

        sb_push(sb, mn_e + ":")

    } else { 0 };

    let p8 = ifs_next_pos(fn_mir, p7);

    if p8 >= fn_mir.len() { 0 }

    else { ifs_fn_lines(fn_mir, p8, sb) };

fn ifs_function(fn_mir: String) -> String

  post it.len() <= fn_mir.len()

= let sb = sb_new();

    let _w = ifs_fn_lines(fn_mir, 0, sb);

    let result = sb_build(sb);

    let _f = sb_free(sb);

    result;

fn ifs_program(mir: String, pos: i64, sb: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= mir.len() { 0 } else {

        let fn_end = find_double_pipe(mir, pos);

        let fn_mir = mir.slice(pos, fn_end);

        let converted = ifs_function(fn_mir);

        let len = sb_len(sb);

        let _w1 = if len > 0 { sb_push(sb, DSEP()) } else { 0 };

        let _w2 = sb_push(sb, converted);

        if fn_end + 2 >= mir.len() { 0 }

        else { ifs_program(mir, fn_end + 2, sb) }

    };

fn optimize_if_select(mir: String) -> String

  post it.len() <= mir.len()

= let sb = sb_new();

    let _w = ifs_program(mir, 0, sb);

    let result = sb_build(sb);

    let _f = sb_free(sb);

    result;

// === Goto Chain Simplification (GCS) ===

// Redirect goto/branch targets through empty intermediate blocks

// E.g., goto L1 where L1: goto L2 -> goto L2

// Check if a label is referenced as a phi predecessor anywhere in the function

fn gcs_label_in_phi(fn_mir: String, label: String) -> bool

  post it == (fn_mir.contains(", " + label + "]"))

= let pattern = ", " + label + "]";

    find_pattern_at(fn_mir, pattern, 0) >= 0;

// Check if line at pos is a forwarding label (label: followed by goto)

// Returns "label=target" or ""

// Skip labels that appear as phi predecessors (forwarding would break phi edges)

fn gcs_is_forward(fn_mir: String, pos: i64, pipe: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= let line = fn_mir.slice(pos, pipe);

    if ube_is_label(line) and pipe < fn_mir.len() {

        let label = ube_label_name(line);

        if ube_is_entry(label) { "" }

        else if gcs_label_in_phi(fn_mir, label) { "" }

        else {

            let p2 = pipe + 1;

            let pipe2 = find_pipe_skip_quotes(fn_mir, p2);

            let next_line = fn_mir.slice(p2, pipe2);

            let target = ube_goto_target(next_line);

            if target != "" { label + "=" + target }

            else { "" }

        }

    } else { "" };

// Build forwarding map: "label1=target1,label2=target2,..."

fn gcs_find_forwards(fn_mir: String, pos: i64, map: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= fn_mir.len() { map } else {

        let pipe = find_pipe_skip_quotes(fn_mir, pos);

        let entry = gcs_is_forward(fn_mir, pos, pipe);

        let new_map = if entry != "" {

            if map == "" { entry } else { map + "," + entry }

        } else { map };

        if pipe >= fn_mir.len() { new_map }

        else { gcs_find_forwards(fn_mir, pipe + 1, new_map) }

    };

// Find "search" in map ensuring it's at position 0 or preceded by ','

fn gcs_find_in_map(map: String, search: String, from: i64) -> i64

  pre from >= 0

  post it >= -1

= let pos = find_pattern_at(map, search, from);

    if pos < 0 { 0 - 1 }

    else if pos == 0 { pos }

    else if map.byte_at(pos - 1) == 44 { pos }

    else { gcs_find_in_map(map, search, pos + 1) };

// Look up label in forwarding map

fn gcs_map_get(map: String, label: String) -> String

  post it.len() <= map.len()

= let search = label + "=";

    let pos = gcs_find_in_map(map, search, 0);

    if pos < 0 { "" }

    else {

        let val_start = pos + search.len();

        let comma = find_char(map, val_start, 44);

        if comma >= map.len() { map.slice(val_start, map.len()) }

        else { map.slice(val_start, comma) }

    };

// Follow forwarding chain to final destination (max 5 hops)

fn gcs_resolve(map: String, label: String, depth: i64) -> String

  pre depth >= 0

  post it.len() >= 0

= if depth >= 5 { label }

    else {

        let target = gcs_map_get(map, label);

        if target == "" { label }

        else { gcs_resolve(map, target, depth + 1) }

    };

// Rewrite a goto line using forwarding map

fn gcs_rewrite_goto(line: String, map: String) -> String

  post it.len() >= 0

= let target = ube_goto_target(line);

    if target == "" { line }

    else {

        let resolved = gcs_resolve(map, target, 0);

        if resolved == target { line }

        else { "  goto " + resolved }

    };

// Rewrite a branch line using forwarding map

fn gcs_rewrite_branch(line: String, map: String) -> String

  post it.len() >= 0

= let cond = cf_branch_cond(line);

    let t1 = cf_branch_then(line);

    let t2 = cf_branch_else(line);

    let r1 = gcs_resolve(map, t1, 0);

    let r2 = gcs_resolve(map, t2, 0);

    if r1 == t1 and r2 == t2 { line }

    else { "  branch " + cond + ", " + r1 + ", " + r2 };

// Rewrite a single line: replace goto/branch targets if forwarded

fn gcs_rewrite_line(line: String, map: String) -> String

  post it.len() >= 0

= if ube_goto_target(line) != "" { gcs_rewrite_goto(line, map) }

    else if cf_is_branch(line) { gcs_rewrite_branch(line, map) }

    else { line };

// Rewrite function MIR with forwarding map

fn gcs_rewrite_fn(fn_mir: String, pos: i64, map: String, sb: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= fn_mir.len() { 0 } else {

        let pipe = find_pipe_skip_quotes(fn_mir, pos);

        let line = fn_mir.slice(pos, pipe);

        let new_line = gcs_rewrite_line(line, map);

        let len = sb_len(sb);

        let _w1 = if len > 0 { sb_push(sb, SEP()) } else { 0 };

        let _w2 = sb_push(sb, new_line);

        if pipe >= fn_mir.len() { 0 }

        else { gcs_rewrite_fn(fn_mir, pipe + 1, map, sb) }

    };

// Simplify goto chains in a single function

fn gcs_function(fn_mir: String) -> String

  post it.len() >= 0

= let map = gcs_find_forwards(fn_mir, 0, "");

    if map == "" { fn_mir }

    else {

        let sb = sb_new();

        let _w = gcs_rewrite_fn(fn_mir, 0, map, sb);

        let result = sb_build(sb);

        let _f = sb_free(sb);

        result

    };

// Process all functions in the program

fn gcs_program(mir: String, pos: i64, sb: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= mir.len() { 0 } else {

        let fn_end = find_double_pipe(mir, pos);

        let fn_mir = mir.slice(pos, fn_end);

        let simplified = gcs_function(fn_mir);

        let len = sb_len(sb);

        let _w1 = if len > 0 { sb_push(sb, DSEP()) } else { 0 };

        let _w2 = sb_push(sb, simplified);

        if fn_end + 2 >= mir.len() { 0 }

        else { gcs_program(mir, fn_end + 2, sb) }

    };

fn optimize_goto_chain(mir: String) -> String

  post it.len() >= 0

= let sb = sb_new();

    let _w = gcs_program(mir, 0, sb);

    let result = sb_build(sb);

    let _f = sb_free(sb);

    result;

// ============================================================================

// Phi-Aware Empty Block Threading (PHT)

// Eliminates forwarding blocks (label: | goto target) that appear in phi nodes.

// The goto chain pass skips these because forwarding would break phi edges.

// PHT handles them by also updating phi predecessors.

// ============================================================================

// Check if a forwarding block is in a phi (opposite of gcs_is_forward)

fn pht_is_phi_fwd(fn_mir: String, pos: i64, pipe: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= let line = fn_mir.slice(pos, pipe);

    if ube_is_label(line) and pipe < fn_mir.len() {

        let label = ube_label_name(line);

        if ube_is_entry(label) { "" }

        else if gcs_label_in_phi(fn_mir, label) {

            let p2 = pipe + 1;

            let pipe2 = find_pipe_skip_quotes(fn_mir, p2);

            let next_line = fn_mir.slice(p2, pipe2);

            // Case 1: label: | goto target (empty forwarding block)

            let target = ube_goto_target(next_line);

            if target != "" { label + "=" + target }

            // Case 2: label: | copy %param | goto target (single-copy with safe source)

            else if cf_is_copy(next_line) and pipe2 < fn_mir.len() {

                let p3 = pipe2 + 1;

                let pipe3 = find_pipe_skip_quotes(fn_mir, p3);

                let goto_line = fn_mir.slice(p3, pipe3);

                let target2 = ube_goto_target(goto_line);

                if target2 != "" {

                    // Only forward if copy source is safe (not an alloca variable)

                    let src = cf_copy_src(next_line);

                    if pht_has_alloca(fn_mir, src) { "" }

                    else { label + "=" + target2 }

                } else { "" }

            } else { "" }

        } else { "" }

    } else { "" };

// Check if a variable name has an alloca in the function MIR

fn pht_has_alloca(fn_mir: String, name: String) -> bool

  post it == (fn_mir.contains("alloca " + name))

= let pattern = "alloca " + name;

    find_pattern_at(fn_mir, pattern, 0) >= 0;

// Build copy-value map for copy-only forwarding blocks

// For blocks like "label: | %dest = copy %src | goto target", record "label:%dest=%src"

// Only include copies where src is a parameter (no alloca), not a mutable variable

fn pht_get_copy_info(fn_mir: String, pos: i64, pipe: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= let line = fn_mir.slice(pos, pipe);

    if ube_is_label(line) and pipe < fn_mir.len() {

        let label = ube_label_name(line);

        let p2 = pipe + 1;

        let pipe2 = find_pipe_skip_quotes(fn_mir, p2);

        let next_line = fn_mir.slice(p2, pipe2);

        if cf_is_copy(next_line) and pipe2 < fn_mir.len() {

            let p3 = pipe2 + 1;

            let pipe3 = find_pipe_skip_quotes(fn_mir, p3);

            let goto_line = fn_mir.slice(p3, pipe3);

            if ube_goto_target(goto_line) != "" {

                let dest = cf_extract_dest(next_line);

                let src = cf_copy_src(next_line);

                // Only fold if source is a parameter (not an alloca variable)

                // Alloca vars are mutable and may have different types (ptr vs i64)

                if pht_has_alloca(fn_mir, src) { "" }

                else { label + ":" + dest + "=" + src }

            } else { "" }

        } else { "" }

    } else { "" };

fn pht_find_copy_map(fn_mir: String, pos: i64, map: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= fn_mir.len() { map } else {

        let pipe = find_pipe_skip_quotes(fn_mir, pos);

        let entry = pht_get_copy_info(fn_mir, pos, pipe);

        let new_map = if entry != "" {

            if map == "" { entry } else { map + "," + entry }

        } else { map };

        if pipe >= fn_mir.len() { new_map }

        else { pht_find_copy_map(fn_mir, pipe + 1, new_map) }

    };

// Look up a label's copy value replacement in the copy_map

// copy_map format: "label1:%dest1=%src1,label2:%dest2=%src2"

// Returns "%src" if val matches %dest for the given label, else ""

fn pht_copy_lookup(copy_map: String, label: String, val: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= copy_map.len() { "" } else {

        let comma = find_char(copy_map, pos, 44);

        let entry = copy_map.slice(pos, comma);

        let colon = find_char(entry, 0, 58);

        let entry_label = entry.slice(0, colon);

        if entry_label == label {

            let eq = find_char(entry, colon + 1, 61);

            let dest = entry.slice(colon + 1, eq);

            let src = entry.slice(eq + 1, entry.len());

            if dest == val { src } else { "" }

        } else if comma >= copy_map.len() { "" }

        else { pht_copy_lookup(copy_map, label, val, comma + 1) }

    };

// Build phi-forwarding map (label=target for forwarding blocks in phis)

fn pht_find_phi_fwds(fn_mir: String, pos: i64, map: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= fn_mir.len() { map } else {

        let pipe = find_pipe_skip_quotes(fn_mir, pos);

        let entry = pht_is_phi_fwd(fn_mir, pos, pipe);

        let new_map = if entry != "" {

            if map == "" { entry } else { map + "," + entry }

        } else { map };

        if pipe >= fn_mir.len() { new_map }

        else { pht_find_phi_fwds(fn_mir, pipe + 1, new_map) }

    };

// Find predecessor block of a label (scan function for goto/branch targeting label)

// Returns predecessor block label, or "" if not found or has multiple predecessors

fn pht_find_pred(fn_mir: String, label: String, pos: i64, cur_label: String, found: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= fn_mir.len() { found } else {

        let pipe = find_pipe_skip_quotes(fn_mir, pos);

        let line = fn_mir.slice(pos, pipe);

        let new_cur = if ube_is_label(line) { ube_label_name(line) } else { cur_label };

        let targets_label = ube_goto_target(line) == label or (cf_is_branch(line) and (cf_branch_then(line) == label or cf_branch_else(line) == label));

        let new_found = if targets_label {

            if found == "" { new_cur }

            else { "MULTI" }

        } else { found };

        if new_found == "MULTI" { "" }

        else if pipe >= fn_mir.len() { new_found }

        else { pht_find_pred(fn_mir, label, pipe + 1, new_cur, new_found) }

    };

// Build phi predecessor map from forwarding map

// For each L=T in fwd_map, find predecessor P and add L=P to phi_map

fn pht_build_phi_map(fn_mir: String, fwd_map: String, pos: i64, phi_map: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= fwd_map.len() { phi_map } else {

        let eq_pos = find_char(fwd_map, pos, 61);

        let comma = find_char(fwd_map, eq_pos, 44);

        let label = fwd_map.slice(pos, eq_pos);

        let pred = pht_find_pred(fn_mir, label, 0, "entry", "");

        let new_phi_map = if pred == "" { phi_map }

            else if phi_map == "" { label + "=" + pred }

            else { phi_map + "," + label + "=" + pred };

        if comma >= fwd_map.len() { new_phi_map }

        else { pht_build_phi_map(fn_mir, fwd_map, comma + 1, new_phi_map) }

    };

// Replace label in a phi line: ", old_label]" -> ", new_label]"

fn pht_replace_phi_label(line: String, old_label: String, new_label: String) -> String

  post it.len() >= 0

= let pattern = ", " + old_label + "]";

    let pos = find_pattern_at(line, pattern, 0);

    if pos < 0 { line }

    else {

        let before = line.slice(0, pos);

        let after = line.slice(pos + pattern.len(), line.len());

        before + ", " + new_label + "]" + after

    };

// Look up a label in the copy_map. Returns "dest=src" or ""

fn pht_copy_get(copy_map: String, label: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= if copy_map == "" or pos >= copy_map.len() { "" } else {

        let comma = find_char(copy_map, pos, 44);

        let entry = copy_map.slice(pos, comma);

        let colon = find_char(entry, 0, 58);

        let entry_label = entry.slice(0, colon);

        if entry_label == label { entry.slice(colon + 1, entry.len()) }

        else if comma >= copy_map.len() { "" }

        else { pht_copy_get(copy_map, label, comma + 1) }

    };

// Replace both value and label in a phi operand: [old_val, old_label] -> [new_val, new_label]

fn pht_replace_phi_operand(line: String, old_label: String, new_label: String, old_val: String, new_val: String) -> String

  post it.len() >= 0

= let pattern = old_val + ", " + old_label + "]";

    let pos = find_pattern_at(line, pattern, 0);

    if pos < 0 { pht_replace_phi_label(line, old_label, new_label) }

    else {

        let before = line.slice(0, pos);

        let after = line.slice(pos + pattern.len(), line.len());

        before + new_val + ", " + new_label + "]" + after

    };

// Apply phi map and copy map to a phi line (replace predecessors and values)

fn pht_update_phi_line(line: String, phi_map: String, copy_map: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= phi_map.len() { line } else {

        let eq_pos = find_char(phi_map, pos, 61);

        let comma = find_char(phi_map, eq_pos, 44);

        let old_label = phi_map.slice(pos, eq_pos);

        let new_label = phi_map.slice(eq_pos + 1, comma);

        // Check if this forwarding block has a copy to fold into the phi

        let copy_info = pht_copy_get(copy_map, old_label, 0);

        let updated = if copy_info == "" {

            pht_replace_phi_label(line, old_label, new_label)

        } else {

            let ceq = find_char(copy_info, 0, 61);

            let old_val = copy_info.slice(0, ceq);

            let new_val = copy_info.slice(ceq + 1, copy_info.len());

            pht_replace_phi_operand(line, old_label, new_label, old_val, new_val)

        };

        if comma >= phi_map.len() { updated }

        else { pht_update_phi_line(updated, phi_map, copy_map, comma + 1) }

    };

// Rewrite a single line: forward gotos/branches and update phi predecessors + values

fn pht_rewrite_line(line: String, fwd_map: String, phi_map: String, copy_map: String) -> String

  post it.len() >= 0

= if ube_goto_target(line) != "" { gcs_rewrite_goto(line, fwd_map) }

    else if cf_is_branch(line) { gcs_rewrite_branch(line, fwd_map) }

    else if ube_is_phi(line) { pht_update_phi_line(line, phi_map, copy_map, 0) }

    else { line };

// Rewrite function MIR with phi-aware forwarding

fn pht_rewrite_fn(fn_mir: String, pos: i64, fwd_map: String, phi_map: String, copy_map: String, sb: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= fn_mir.len() { 0 } else {

        let pipe = find_pipe_skip_quotes(fn_mir, pos);

        let line = fn_mir.slice(pos, pipe);

        let new_line = pht_rewrite_line(line, fwd_map, phi_map, copy_map);

        let len = sb_len(sb);

        let _w1 = if len > 0 { sb_push(sb, SEP()) } else { 0 };

        let _w2 = sb_push(sb, new_line);

        if pipe >= fn_mir.len() { 0 }

        else { pht_rewrite_fn(fn_mir, pipe + 1, fwd_map, phi_map, copy_map, sb) }

    };

// Apply phi-threading to a single function

fn pht_function(fn_mir: String) -> String

  post it.len() >= 0

= let fwd_map = pht_find_phi_fwds(fn_mir, 0, "");

    if fwd_map == "" { fn_mir }

    else {

        let phi_map = pht_build_phi_map(fn_mir, fwd_map, 0, "");

        if phi_map == "" { fn_mir }

        else {

            let copy_map = pht_find_copy_map(fn_mir, 0, "");

            let sb = sb_new();

            let _w = pht_rewrite_fn(fn_mir, 0, fwd_map, phi_map, copy_map, sb);

            let result = sb_build(sb);

            let _f = sb_free(sb);

            result

        }

    };

// Apply phi-threading to all functions

fn pht_program(mir: String, pos: i64, sb: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= mir.len() { 0 } else {

        let fn_end = find_double_pipe(mir, pos);

        let fn_mir = mir.slice(pos, fn_end);

        let threaded = pht_function(fn_mir);

        let len = sb_len(sb);

        let _w1 = if len > 0 { sb_push(sb, DSEP()) } else { 0 };

        let _w2 = sb_push(sb, threaded);

        if fn_end + 2 >= mir.len() { 0 }

        else { pht_program(mir, fn_end + 2, sb) }

    };

fn optimize_phi_thread(mir: String) -> String

  post it.len() >= 0

= let sb = sb_new();

    let _w = pht_program(mir, 0, sb);

    let result = sb_build(sb);

    let _f = sb_free(sb);

    result;

// Run if-to-select twice to handle nested if-else (inner then outer in same iteration)

fn optimize_if_select_twice(mir: String) -> String

  post it.len() <= mir.len()

= let first = optimize_if_select(mir);

    optimize_if_select(first);

// Iterative optimization: CF + CP + DCE + if-select(x2) + goto-chain + phi-thread + DCE until stable (max 4 iterations)

fn optimize_cf_dce_loop(mir: String, iter: i64) -> String

  pre iter >= 0

  post it.len() >= 0

= if iter >= 4 { mir } else {

        let folded = optimize_const_folding(mir);

        let propagated = optimize_copy_prop(folded);

        // v0.96.26: Pure function CSE — eliminate redundant pure/const calls in same block

        let pure_csed = optimize_pure_fn_cse(propagated);

        // v0.96.26: Memory load CSE — eliminate redundant GEP + load_ptr in same block

        let mem_csed = optimize_mem_load_cse(pure_csed);

        // v0.96.26: Constant function evaluation — replace 0-arg const calls with constants

        let cfevaled = optimize_const_fn_eval(mem_csed);

        // Redundant phi elimination: simplify phis where all values are the same constant

        let phi_simplified = optimize_redundant_phi(cfevaled);

        let cleaned = optimize_dce(phi_simplified);

        let selected = optimize_if_select_twice(cleaned);

        let chained = optimize_goto_chain(selected);

        // Phi-aware threading: forward through empty blocks that appear in phi nodes

        let threaded = optimize_phi_thread(chained);

        // Post-chain DCE: remove dead forwarding blocks

        let final_clean = optimize_dce(threaded);

        if final_clean == mir { mir }

        else { optimize_cf_dce_loop(final_clean, iter + 1) }

    };

fn build_param_sig(params: String, pos: i64, acc: String) -> String

  pre pos >= 0

  post it.len() >= 0

= let p = low_skip_ws(params, pos);

    if p >= params.len() { acc } else {

        let comma = find_comma_or_end(params, p);

        let param = trim_end(params.slice(p, comma));

        let colon_pos = find_char(param, 0, 58);

        let param_type = trim(param.slice(colon_pos + 1, param.len()));

        // v0.95: i32 params map to "s" (passed as i32, sext to i64 in prologue)

        let sig = match param_type { "f64" => "d", "ptr" => "p", "i32" => "s", _ => "i" };

        let new_acc = acc + sig;

        if comma >= params.len() { new_acc } else { build_param_sig(params, comma + 1, new_acc) }

    };

fn lookup_fn_ret(registry: String, fn_name: String) -> String

  post it.len() <= registry.len()

= let clean_fn = if fn_name.len() > 0 and fn_name.byte_at(0) == 64 { fn_name.slice(1, fn_name.len()) } else { fn_name };

    lookup_fn_ret_at(registry, 0, clean_fn);

fn lookup_fn_ret_at(registry: String, pos: i64, fn_name: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= registry.len() { "" } else {

        let comma_pos = find_char(registry, pos, 44);

        let colon1 = find_char(registry, pos, 58);

        let name_start = if pos < colon1 and registry.byte_at(pos) == 64 { pos + 1 } else { pos };

        if colon1 - name_start == fn_name.len() and match_bytes(registry, fn_name, name_start, 0) {

            let colon2 = find_char(registry, colon1 + 1, 58);

            registry.slice(colon1 + 1, colon2)

        } else {

            if comma_pos >= registry.len() { "" } else { lookup_fn_ret_at(registry, comma_pos + 1, fn_name) }

        }

    };

fn lookup_fn_both(registry: String, fn_name: String) -> String

  post it.len() <= registry.len()

= let clean_fn = if fn_name.len() > 0 and fn_name.byte_at(0) == 64 { fn_name.slice(1, fn_name.len()) } else { fn_name };

    lookup_fn_both_at(registry, 0, clean_fn);

fn lookup_fn_both_at(registry: String, pos: i64, fn_name: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= registry.len() { "" } else {

        let comma_pos = find_char(registry, pos, 44);

        let colon1 = find_char(registry, pos, 58);

        let name_start = if pos < colon1 and registry.byte_at(pos) == 64 { pos + 1 } else { pos };

        if colon1 - name_start == fn_name.len() and match_bytes(registry, fn_name, name_start, 0) {

            // Return "ret_type:param_sig" — everything after first colon

            registry.slice(colon1 + 1, comma_pos)

        } else {

            if comma_pos >= registry.len() { "" } else { lookup_fn_both_at(registry, comma_pos + 1, fn_name) }

        }

    };

fn find_mir_annotation(s: String) -> String

  post it.len() <= s.len()

= find_mir_annotation_at(s, 0);

fn find_mir_annotation_at(s: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= s.len() { "" }

    else if s.byte_at(pos) == 64 {

        let name_end = low_find_ident_end(s, pos + 1);

        s.slice(pos + 1, name_end)

    } else { find_mir_annotation_at(s, pos + 1) };

fn strip_annotation(s: String) -> String

  post it.len() <= s.len()

= strip_annotation_at(s, 0);

fn strip_annotation_at(s: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= s.len() { s }

    else if s.byte_at(pos) == 64 { trim(s.slice(0, pos)) }

    else { strip_annotation_at(s, pos + 1) };

fn llvm_gen_fn_header(line: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 1

= let name_start = pos + 3;

    let paren_pos = find_char(line, name_start, 40);

    let fn_name = line.slice(name_start, paren_pos);

    let close_pos = find_char(line, paren_pos, 41);

    let params = line.slice(paren_pos + 1, close_pos);

    let formatted_params = format_fn_params(params, 0, "");

    let arrow_pos = find_arrow(line, close_pos);

    let brace_pos = find_char(line, arrow_pos, 123);

    // v0.46: Use trim to handle leading/trailing whitespace in return type

    let raw_ret_type = trim(line.slice(arrow_pos + 2, brace_pos));

    let ann = find_mir_annotation(raw_ret_type);

    let ret_type = if ann == "" { raw_ret_type } else { strip_annotation(raw_ret_type) };

    // v0.95: i32 return type support

    let llvm_ret = if ret_type == "f64" { "double" } else if ret_type == "i32" { "i32" } else { "i64" };

    let emitted_name = if fn_name == "main" { "bmb_user_main" } else { fn_name };

    // v0.96.46: main (bmb_user_main) gets alwaysinline so opt inlines it into the @main wrapper

    let base_attrs = if fn_name == "main" { " alwaysinline norecurse nosync nounwind mustprogress \"no-trapping-math\"=\"true\" uwtable" } else { " mustprogress nounwind willreturn nosync \"no-trapping-math\"=\"true\" uwtable" };

    let pure_attrs = if ann == "pure" or ann == "const" { " memory(none) nofree" } else { "" };

    let inline_attrs = if ann == "inline" { " alwaysinline" } else { "" };

    // M12 Phase 2b: @effect:IO Net -> "bmb-effect"="IO Net" LLVM string attribute
    let eff_attrs = if ann == "effect" {
        let colon_pos = str_find(raw_ret_type, "@effect:");
        if colon_pos >= 0 {
            let eff_val = str_trim(raw_ret_type.slice(colon_pos + 8, raw_ret_type.len()));
            " \"bmb-effect\"=\"" + eff_val + "\""
        } else { "" }
    } else { "" };

    let attrs = base_attrs + pure_attrs + inline_attrs + eff_attrs;

    // v0.97: @export annotation -> dllexport linkage (Windows) or global visibility (Unix/Linux)

    // Without @export: private linkage (better LLVM optimization)

    let linkage = if fn_name == "main" { "define " } else if ann == "export" { "define dllexport " } else { "define private " };

    // v0.96.44: Add noundef on return values — all BMB functions return initialized values

    let ret_attrs = if fn_name == "main" { "" } else { "noundef " };

    let header = linkage + ret_attrs + llvm_ret + " @" + emitted_name + "(" + formatted_params + ")" + attrs + " {";

    // v0.95: Generate sext prologue for i32 parameters

    let i32_prologue = gen_i32_param_sexts(params, 0, "");

    if i32_prologue == "" { header } else { header + SEP() + "i32_entry:" + SEP() + i32_prologue + SEP() + "  br label %entry" };

// v0.95: Generate sext instructions for i32 parameters

// Scans parameter list, for each i32 param emits: %name = sext i32 %name_i32 to i64

fn gen_i32_param_sexts(params: String, pos: i64, acc: String) -> String

  pre pos >= 0

  post it.len() >= 0

= let p = low_skip_ws(params, pos);

    if p >= params.len() { acc } else {

        let comma = find_comma_or_end(params, p);

        let param = trim_end(params.slice(p, comma));

        let colon_pos = find_char(param, 0, 58);

        let name = param.slice(0, colon_pos);

        let param_type = trim(param.slice(colon_pos + 1, param.len()));

        let new_acc = if param_type == "i32" {

            let sext_line = "  %" + name + " = sext i32 %" + name + "_i32 to i64";

            if acc == "" { sext_line } else { acc + SEP() + sext_line }

        } else { acc };

        if comma >= params.len() { new_acc } else { gen_i32_param_sexts(params, comma + 1, new_acc) }

    };

// v0.46: Added String parameter type support

fn format_fn_params(params: String, pos: i64, acc: String) -> String

  pre pos >= 0

  post it.len() >= 0

= let p = low_skip_ws(params, pos);

    if p >= params.len() { acc } else {

        let comma = find_comma_or_end(params, p);

        let param = trim_end(params.slice(p, comma));

        let colon_pos = find_char(param, 0, 58);

        let name = param.slice(0, colon_pos);

        let param_type = trim(param.slice(colon_pos + 1, param.len()));

        // v0.95: i32 params declared as i32 with _i32 suffix (sext in prologue)

        // Note: String params remain i64 (pointer-as-integer model) — nonnull on params

        // requires full ptr-mode migration of the bootstrap codegen pipeline

        let llvm_type = match param_type { "f64" => "double", "i32" => "i32", "fn_i64" => "i64", _ => "i64" };

        let param_name = if param_type == "i32" { "%" + name + "_i32" } else { "%" + name };

        let typed_param = llvm_type + " noundef " + param_name;

        let new_acc = if acc == "" { typed_param } else { acc + ", " + typed_param };

        if comma >= params.len() { new_acc } else { format_fn_params(params, comma + 1, new_acc) }

    };

fn find_arrow(s: String, pos: i64) -> i64

    post it >= -1

= 

    if pos + 1 >= s.len() { pos } else if s.byte_at(pos) == 45 and s.byte_at(pos + 1) == 62 { pos } else { find_arrow(s, pos + 1) };

fn ends_with_colon(s: String) -> bool

  post it == trim_end(s).ends_with(":")

= if s.len() == 0 { false } else {

        let last = trim_end(s);

        if last.len() == 0 { false } else { last.byte_at(last.len() - 1) == 58 }

    };

fn find_double_pipe(s: String, pos: i64) -> i64

    post it >= -1

= 

    if pos + 1 >= s.len() { s.len() }

    else if s.byte_at(pos) == 31 and s.byte_at(pos + 1) == 31 { pos }

    else if s.byte_at(pos) == 34 { find_double_pipe(s, skip_quoted_string(s, pos + 1)) }

    else { find_double_pipe(s, pos + 1) };

fn gen_module_header() -> String

  post it.len() == 26

= "; ModuleID = bmb_bootstrap";

// Runtime declarations — all LLVM extern function declarations

fn gen_runtime_decls() -> String

  post it.len() >= 0

= // I/O + Math + Array

    "declare void @println(i64) nofree nounwind willreturn" + SEP() +

    "declare void @print_str(ptr nocapture readonly) nofree nounwind willreturn" + SEP() +

    "declare void @println_str(ptr nocapture readonly) nofree nounwind willreturn" + SEP() +

    "declare void @eprint(i64) nofree nounwind willreturn" + SEP() +

    "declare void @eprintln(i64) nofree nounwind willreturn" + SEP() +

    "declare void @eprint_str(ptr nocapture readonly) nofree nounwind willreturn" + SEP() +

    "declare void @eprintln_str(ptr nocapture readonly) nofree nounwind willreturn" + SEP() +

    "declare void @eprint_f64(double) nofree nounwind willreturn" + SEP() +


// ============================================================================

// SECTION 12b: String Literal Handling (v0.60.109)

// ============================================================================

// Collect all string literals from MIR, returns tab-separated list

// Now passes current list as parameter instead of rebuilding every iteration

fn collect_strings_from_mir(mir: String) -> String

  post it.len() <= mir.len()

= collect_strings_acc_v2(mir, 0, "");

// Uses String accumulator directly, trading some allocation for avoiding

// the O(N) sb_build call that was happening on every string found

// "empty list" from "list containing empty string" in tab-separated format

fn collect_strings_acc_v2(mir: String, pos: i64, acc: String) -> String

    pre pos >= 0

    post it.len() >= 0

=

    if pos >= mir.len() { acc } else {

        let next = find_string_in_mir(mir, pos);

        if next < 0 { acc } else {

            let str_start = next + 8;

            let str_end = find_quote_in_mir(mir, str_start);

            let str_content_raw = mir.slice(str_start, str_end);

            let str_content = if str_content_raw == "" { chr(2) } else { str_content_raw };

            let is_dup = string_in_list(acc, str_content);

            let new_acc = if is_dup == 0 {

                if acc == "" { str_content } else { acc + chr(9) + str_content }

            } else { acc };

            collect_strings_acc_v2(mir, str_end + 1, new_acc)

        }

    };

// Find "string " pattern in MIR (returns position or -1)

fn find_string_in_mir(mir: String, pos: i64) -> i64

    post it >= -1

= 

    if pos + 8 > mir.len() { 0 - 1 }

    else if matches_string_pattern(mir, pos) { pos }

    else { find_string_in_mir(mir, pos + 1) };

fn matches_string_pattern(s: String, pos: i64) -> bool

  pre pos >= 0

  post not it or pos + 5 < s.len()

= s.byte_at(pos) == 115 and s.byte_at(pos + 1) == 116 and

    s.byte_at(pos + 2) == 114 and s.byte_at(pos + 3) == 105 and

    s.byte_at(pos + 4) == 110 and s.byte_at(pos + 5) == 103 and

    s.byte_at(pos + 6) == 32 and s.byte_at(pos + 7) == 34;

fn find_quote_in_mir(s: String, pos: i64) -> i64

    post it >= -1

= 

    if pos >= s.len() { s.len() }

    else if s.byte_at(pos) == 92 and pos + 1 < s.len() { find_quote_in_mir(s, pos + 2) }

    else if s.byte_at(pos) == 34 { pos }

    else { find_quote_in_mir(s, pos + 1) };

fn string_in_list(list: String, target: String) -> i64

  post it >= 0

= if list == "" { 0 } else { string_in_list_scan(list, target, 0) };

fn string_in_list_scan(list: String, target: String, pos: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= list.len() { 0 } else {

        let pipe = find_tab_in_list(list, pos);

        let end = if pipe >= list.len() { list.len() } else { pipe };

        let item = list.slice(pos, end);

        if item == target { 1 }

        else if pipe >= list.len() { 0 }

        else { string_in_list_scan(list, target, pipe + 1) }

    };

fn find_tab_in_list(s: String, pos: i64) -> i64

    post it >= -1

= 

    if pos >= s.len() { s.len() }

    else if s.byte_at(pos) == 9 { pos }

    else { find_tab_in_list(s, pos + 1) };

// Find index of string in list

fn find_string_index(list: String, target: String) -> i64

    post it >= -1

= find_string_index_scan(list, target, 0, 0);

fn find_string_index_scan(list: String, target: String, pos: i64, idx: i64) -> i64

    post it >= -1

= 

    if pos >= list.len() { 0 } else {

        let pipe = find_tab_in_list(list, pos);

        let end = if pipe >= list.len() { list.len() } else { pipe };

        let item = list.slice(pos, end);

        let search = if target == "" { chr(2) } else { target };

        if item == search { idx }

        else if pipe >= list.len() { 0 }

        else { find_string_index_scan(list, search, pipe + 1, idx + 1) }

    };

// Returns comma-separated list of function names

fn collect_string_fns_from_mir(mir: String) -> String

  post it.len() <= mir.len()

= collect_string_fns_acc(mir, 0, "");

fn collect_string_fns_acc(mir: String, pos: i64, acc: String) -> String

    pre pos >= 0

    post it.len() >= 0

=

    if pos >= mir.len() { acc }

    else {

        // Find next function definition

        let fn_start = find_fn_start(mir, pos);

        if fn_start < 0 { acc }

        else {

            let fn_name = extract_fn_name_from_mir(mir, fn_start);

            let ret_type = extract_fn_ret_type_from_mir(mir, fn_start);

            // M5-5c: tag Array<String> returns with "A:" prefix in same registry

            // to avoid plumbing a separate list through ~20 codegen signatures

            // Cycle 2682: Array<f64> returns get "F:" prefix (same registry)

            let entry = match ret_type { "String" => fn_name, "Array<String>" => "A:" + fn_name, "Array<f64>" => "F:" + fn_name, _ => "" };

            let new_acc = if entry == "" { acc }

                else if acc == "" { entry }

                else { acc + "," + entry };

            // Find end of this function and continue

            let fn_end = find_fn_end(mir, fn_start);

            if fn_end < 0 { new_acc } else { collect_string_fns_acc(mir, fn_end, new_acc) }

        }

    };

// Find "fn " at or after pos

fn find_fn_start(mir: String, pos: i64) -> i64

    post it >= -1

= 

    if pos + 3 > mir.len() { 0 - 1 }

    else if mir.byte_at(pos) == 102 and mir.byte_at(pos + 1) == 110 and mir.byte_at(pos + 2) == 32 { pos }

    else { find_fn_start(mir, pos + 1) };

// Extract function name after "fn "

fn extract_fn_name_from_mir(mir: String, fn_start: i64) -> String

  pre fn_start >= 0

  post it.len() >= 0

= let name_start = fn_start + 3;

    let paren = find_char(mir, name_start, 40);

    if paren < name_start { "" } else { mir.slice(name_start, paren) };

// Extract return type after "-> "

fn extract_fn_ret_type_from_mir(mir: String, fn_start: i64) -> String

  pre fn_start >= 0

  post it.len() >= 0

= let arrow = find_arrow_in_mir(mir, fn_start);

    if arrow < 0 { "i64" }

    else {

        let type_start = arrow + 3;

        let brace = find_char(mir, type_start, 123);

        if brace < type_start { "i64" } else { trim(mir.slice(type_start, brace)) }

    };

// Find "-> " after fn_start

fn find_arrow_in_mir(mir: String, pos: i64) -> i64

    post it >= -1

= 

    if pos + 3 > mir.len() { 0 - 1 }

    else if mir.byte_at(pos) == 45 and mir.byte_at(pos + 1) == 62 and mir.byte_at(pos + 2) == 32 { pos }

    else if mir.byte_at(pos) == 123 { 0 - 1 }  // Hit '{' before finding arrow

    else { find_arrow_in_mir(mir, pos + 1) };

// Find end of function (double unit separator)

fn find_fn_end(mir: String, pos: i64) -> i64

    post it >= -1

= 

    if pos + 1 >= mir.len() { 0 - 1 }

    else if mir.byte_at(pos) == 31 and mir.byte_at(pos + 1) == 31 { pos + 2 }

    else { find_fn_end(mir, pos + 1) };

// Check if function name is in dynamic string functions list

fn is_dynamic_string_fn(fn_name: String, string_fns: String) -> bool

  post it == (string_fns != "" and check_fn_in_list(fn_name, string_fns, 0))

= if string_fns == "" { false }

    else { check_fn_in_list(fn_name, string_fns, 0) };

fn check_fn_in_list(fn_name: String, list: String, pos: i64) -> bool

  pre pos >= 0

  post not it or pos < list.len()

= if pos >= list.len() { false }

    else {

        let comma = find_comma_or_end(list, pos);

        let item = list.slice(pos, comma);

        if item == fn_name { true }

        else if comma >= list.len() { false }

        else { check_fn_in_list(fn_name, list, comma + 1) }

    };

// M5-5c: Check if function returns Array<String> (tagged as "A:fn_name")

fn is_dynamic_string_array_fn(fn_name: String, string_fns: String) -> bool

  post it == (string_fns != "" and check_array_fn_in_list(fn_name, string_fns, 0))

= if string_fns == "" { false }

    else { check_array_fn_in_list(fn_name, string_fns, 0) };

fn check_array_fn_in_list(fn_name: String, list: String, pos: i64) -> bool

  pre pos >= 0

  post it or not it

= if pos >= list.len() { false }

    else {

        let comma = find_comma_or_end(list, pos);

        let item = list.slice(pos, comma);

        // Match "A:" + fn_name exactly

        let matches = if item.len() >= 2 and item.byte_at(0) == 65 and item.byte_at(1) == 58 {

            item.slice(2, item.len()) == fn_name

        } else { false };

        if matches { true }

        else if comma >= list.len() { false }

        else { check_array_fn_in_list(fn_name, list, comma + 1) }

    };

// Cycle 2682: Check if function returns Array<f64> (tagged as "F:fn_name")

fn is_dynamic_f64_array_fn(fn_name: String, string_fns: String) -> bool

  post it == (string_fns != "" and check_f64_array_fn_in_list(fn_name, string_fns, 0))

= if string_fns == "" { false }

    else { check_f64_array_fn_in_list(fn_name, string_fns, 0) };

fn check_f64_array_fn_in_list(fn_name: String, list: String, pos: i64) -> bool

  pre pos >= 0

  post it or not it

= if pos >= list.len() { false }

    else {

        let comma = find_comma_or_end(list, pos);

        let item = list.slice(pos, comma);

        // Match "F:" + fn_name exactly (70 = 'F', 58 = ':')

        let matches = if item.len() >= 2 and item.byte_at(0) == 70 and item.byte_at(1) == 58 {

            item.slice(2, item.len()) == fn_name

        } else { false };

        if matches { true }

        else if comma >= list.len() { false }

        else { check_f64_array_fn_in_list(fn_name, list, comma + 1) }

    };

// Generate global string constants

fn gen_string_globals(strings: String) -> String

  post it.len() >= 0

= if strings == "" { "" } else {

        let sb = sb_new();

        let _w1 = gen_string_globals_acc(strings, 0, 0, sb);

        sb_build(sb)

    };

// confusion with the output line separator. Use \7C for | (byte 124).

fn escape_llvm_string(s: String) -> String

  post it.len() >= s.len()

= escape_llvm_string_acc(s, 0, "");

fn escape_llvm_string_acc(s: String, pos: i64, acc: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= s.len() { acc }

    else {

        let ch = s.byte_at(pos);

        if ch == 92 and pos + 1 < s.len() {

            let next = s.byte_at(pos + 1);

            match next { 110 => escape_llvm_string_acc(s, pos + 2, acc + chr(92) + "0A"), 116 => escape_llvm_string_acc(s, pos + 2, acc + chr(92) + "09"), 114 => escape_llvm_string_acc(s, pos + 2, acc + chr(92) + "0D"), 48 => escape_llvm_string_acc(s, pos + 2, acc + chr(92) + "00"), 92 => escape_llvm_string_acc(s, pos + 2, acc + chr(92) + "5C"), 34 => escape_llvm_string_acc(s, pos + 2, acc + chr(92) + "22"), _ => escape_llvm_string_acc(s, pos + 1, acc + chr(92) + "5C") }

        } else if ch == 124 { escape_llvm_string_acc(s, pos + 1, acc + chr(92) + "7C") }

        else if ch == 34 { escape_llvm_string_acc(s, pos + 1, acc + chr(92) + "22") }

        else { escape_llvm_string_acc(s, pos + 1, acc + chr(ch)) }

    };

fn count_string_bytes(s: String) -> i64

    post it >= 0

= count_string_bytes_acc(s, 0, 0);

fn count_string_bytes_acc(s: String, pos: i64, count: i64) -> i64

    pre pos >= 0 and pos <= s.len() and count >= 0 and count <= pos

    post it >= 0

=

    if pos >= s.len() { count }

    else {

        let ch = s.byte_at(pos);

        if ch == 92 and pos + 1 < s.len() {

            let next = s.byte_at(pos + 1);

            if next == 110 or next == 116 or next == 114 or next == 48 or next == 92 or next == 34 {

                count_string_bytes_acc(s, pos + 2, count + 1)

            } else { count_string_bytes_acc(s, pos + 1, count + 1) }

        } else { count_string_bytes_acc(s, pos + 1, count + 1) }

    };

fn gen_string_globals_acc(strings: String, pos: i64, idx: i64, sb: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= strings.len() { 0 } else {

        let pipe = find_tab_in_list(strings, pos);

        let end = if pipe >= strings.len() { strings.len() } else { pipe };

        let str_content_raw = strings.slice(pos, end);

        let str_content = if str_content_raw == chr(2) { "" } else { str_content_raw };

        let escaped_content = escape_llvm_string(str_content);

        let byte_count = count_string_bytes(str_content);

        let str_len = byte_count + 1;

        let idx_str = int_to_string(idx);

        let data_name = "@str_data_" + idx_str;

        let global = data_name + " = private unnamed_addr constant [" +

            int_to_string(str_len) + " x i8] c" + chr(34) + escaped_content + chr(92) + "00" + chr(34);

        // Pre-allocated BmbString: { ptr data, i64 len, i64 cap }

        let bmb_global = "@str_bmb_" + idx_str + " = private unnamed_addr constant { ptr, i64, i64 } { ptr " +

            data_name + ", i64 " + int_to_string(byte_count) + ", i64 " + int_to_string(byte_count) + " }";

        let len = sb_len(sb);

        let _w1 = if len > 0 { sb_push(sb, SEP()) } else { 0 };

        let _w2 = sb_push(sb, global);

        let _w3 = sb_push(sb, SEP());

        let _w4 = sb_push(sb, bmb_global);

        if pipe >= strings.len() { 0 } else { gen_string_globals_acc(strings, pipe + 1, idx + 1, sb) }

    };

// LlvmSCtx: pack/unpack strings+string_fns+registry+struct_reg into single context string

fn llvm_sctx_pack(strings: String, string_fns: String, registry: String, struct_reg: String) -> String

  post it.len() >= 4

= int_to_string(strings.len()) + ":" + strings + int_to_string(string_fns.len()) + ":" + string_fns + int_to_string(registry.len()) + ":" + registry + int_to_string(struct_reg.len()) + ":" + struct_reg;

fn llvm_sctx_colon_pos(ctx: String, pos: i64) -> i64

  pre pos >= 0

  post it >= pos

= if pos >= ctx.len() { pos } else if ctx.byte_at(pos) == 58 { pos } else { llvm_sctx_colon_pos(ctx, pos + 1) };

fn llvm_sctx_parse_len(ctx: String, pos: i64, acc: i64) -> i64

  pre pos >= 0 and acc >= 0

  post it >= 0

= if pos >= ctx.len() { acc } else {
        let c = ctx.byte_at(pos);
        if c == 58 { acc } else { llvm_sctx_parse_len(ctx, pos + 1, acc * 10 + (c - 48)) }
    };

fn llvm_sctx_skip1(ctx: String, pos: i64) -> i64

  pre pos >= 0

  post it >= pos

= let colon = llvm_sctx_colon_pos(ctx, pos);
    let len = llvm_sctx_parse_len(ctx, pos, 0);
    colon + 1 + len;

fn llvm_sctx_extract1(ctx: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= let colon = llvm_sctx_colon_pos(ctx, pos);
    let len = llvm_sctx_parse_len(ctx, pos, 0);
    ctx.slice(colon + 1, colon + 1 + len);

fn llvm_sctx_strings(ctx: String) -> String

  post it.len() >= 0

= llvm_sctx_extract1(ctx, 0);

fn llvm_sctx_string_fns(ctx: String) -> String

  post it.len() >= 0

= llvm_sctx_extract1(ctx, llvm_sctx_skip1(ctx, 0));

fn llvm_sctx_registry(ctx: String) -> String

  post it.len() >= 0

= llvm_sctx_extract1(ctx, llvm_sctx_skip1(ctx, llvm_sctx_skip1(ctx, 0)));

fn llvm_sctx_struct_reg(ctx: String) -> String

  post it.len() >= 0

= llvm_sctx_extract1(ctx, llvm_sctx_skip1(ctx, llvm_sctx_skip1(ctx, llvm_sctx_skip1(ctx, 0))));

// Generate program with string table

fn gen_program_sb_with_strings_fns_structs(mir: String, strings: String, string_fns: String, struct_reg: String) -> String

  post it.len() >= 0

= let fn_rsb = sb_new();

    let ptr_rsb = sb_new();

    let _w0 = build_all_registries(mir, fn_rsb, ptr_rsb);

    let registry = sb_build(fn_rsb);

    let ptr_ret_reg = sb_build(ptr_rsb);

    let _f1 = sb_free(fn_rsb);

    let _f2 = sb_free(ptr_rsb);

    let sb = sb_new();

    let fn_sb = sb_new();

    let str_sb = sb_new();

    let ptr_sb = sb_new();

    let llvm_sctx = llvm_sctx_pack(strings, string_fns, registry, struct_reg);

    let _w1 = gen_program_acc_sb_structs_reuse(mir, 0, llvm_sctx, sb, ptr_ret_reg, fn_sb, str_sb, ptr_sb);

    let _ff1 = sb_free(fn_sb);

    let _ff2 = sb_free(str_sb);

    let _ff3 = sb_free(ptr_sb);

    sb_build(sb);

fn gen_program_acc_sb_structs_reuse(mir: String, pos: i64, llvm_sctx: String, sb: i64, ptr_ret_reg: String, fn_sb: i64, str_sb: i64, ptr_sb: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= mir.len() { 0 } else {

        let fn_end = find_double_pipe(mir, pos);

        let _save = bmb_arena_save();

        let fn_mir = mir.slice(pos, fn_end);

        let fn_llvm = gen_function_sb_structs_reuse(fn_mir, llvm_sctx, ptr_ret_reg, fn_sb, str_sb, ptr_sb);

        let len = sb_len(sb);

        let _w1 = if len > 0 { sb_push(sb, DSEP()) } else { 0 };

        let _w2 = sb_push(sb, fn_llvm);

        let _restore = bmb_arena_restore();

        if fn_end + 2 >= mir.len() { 0 } else { gen_program_acc_sb_structs_reuse(mir, fn_end + 2, llvm_sctx, sb, ptr_ret_reg, fn_sb, str_sb, ptr_sb) }

    };

// v0.93.4: Check if MIR contains a self-call (direct recursion)

fn mir_has_self_call(mir: String, fn_name: String) -> bool

  post it == (mir.contains("call @" + fn_name + "("))

= let pattern = "call @" + fn_name + "(";

    find_pattern_noa(mir, pattern, 0) >= 0;

// v0.93.4: Add norecurse attribute to non-recursive functions

fn add_norecurse_attr(ir: String) -> String

  post it.len() >= ir.len()

= // Find "mustprogress" in the first line (define header) and add norecurse before it

    let pipe_pos = find_pipe_skip_quotes(ir, 0);

    let header = ir.slice(0, pipe_pos);

    let rest = if pipe_pos >= ir.len() { "" } else { ir.slice(pipe_pos, ir.len()) };

    let mp_pos = find_pattern_noa(header, "mustprogress", 0);

    if mp_pos < 0 { ir }

    else {

        let before = header.slice(0, mp_pos);

        let after = header.slice(mp_pos, header.len());

        before + "norecurse " + after + rest

    };

// v0.96.44: Add nofree attribute to functions that don't call free/realloc

fn add_nofree_attr(ir: String) -> String

  post it.len() >= ir.len()

= let pipe_pos = find_pipe_skip_quotes(ir, 0);

    let header = ir.slice(0, pipe_pos);

    // Skip if already has nofree (pure/const functions)

    if find_pattern_noa(header, "nofree", 0) >= 0 { ir }

    // Check body for free/realloc calls

    else if find_pattern_noa(ir, "@free(", pipe_pos) >= 0 { ir }

    else if find_pattern_noa(ir, "@realloc(", pipe_pos) >= 0 { ir }

    else if find_pattern_noa(ir, "@bmb_realloc(", pipe_pos) >= 0 { ir }

    else {

        let rest = if pipe_pos >= ir.len() { "" } else { ir.slice(pipe_pos, ir.len()) };

        let mp_pos = find_pattern_noa(header, "mustprogress", 0);

        if mp_pos < 0 { ir }

        else {

            let before = header.slice(0, mp_pos);

            let after = header.slice(mp_pos, header.len());

            before + "nofree " + after + rest

        }

    };

// v0.96.44: Add speculatable to memory(none) leaf functions (no user-defined calls)

// Only safe for leaf functions — LLVM may speculate calls past base case in recursive functions

fn add_speculatable_attr(ir: String) -> String

  post it.len() >= ir.len()

= let pipe_pos = find_pipe_skip_quotes(ir, 0);

    let header = ir.slice(0, pipe_pos);

    // Only apply to memory(none) functions

    if find_pattern_noa(header, "memory(none)", 0) < 0 { ir }

    // Skip if already has speculatable

    else if find_pattern_noa(header, "speculatable", 0) >= 0 { ir }

    // Check if function has any user-defined calls (non-intrinsic, non-runtime)

    // Leaf = only calls llvm.* intrinsics — no @user_func() calls

    else if has_user_call_in_body(ir, pipe_pos) { ir }

    else {

        let rest = if pipe_pos >= ir.len() { "" } else { ir.slice(pipe_pos, ir.len()) };

        let mn_pos = find_pattern_noa(header, "memory(none)", 0);

        let before = header.slice(0, mn_pos + 12);

        let after = header.slice(mn_pos + 12, header.len());

        before + " speculatable" + after + rest

    };

// Check if IR body has user-defined function calls (not llvm.* intrinsics)

fn has_user_call_in_body(ir: String, pos: i64) -> bool

  pre pos >= 0

  post it or not it

= if pos >= ir.len() { false }

    else {

        let call_pos = find_pattern_noa(ir, " call ", pos);

        if call_pos < 0 { false }

        else {

            // Find @name after "call <type> @"

            let at_pos = find_byte_in_range(ir, 64, call_pos + 6, ir.len());

            if at_pos < 0 { false }

            else {

                // Check if it's an llvm.* intrinsic

                let after_at = at_pos + 1;

                if after_at + 4 < ir.len() and ir.byte_at(after_at) == 108 and ir.byte_at(after_at + 1) == 108 and ir.byte_at(after_at + 2) == 118 and ir.byte_at(after_at + 3) == 109 {

                    // starts with "llvm" — skip this call and check next

                    has_user_call_in_body(ir, call_pos + 6)

                } else { true }

            }

        }

    };

fn run_ir_passes(raw_ir: String, is_recursive: bool, fn_name: String) -> String

  post it.len() >= 0

= let p0 = eliminate_store_load_ir(raw_ir);

    let p0b = eliminate_dead_stores_ir(p0);

    let p1 = eliminate_identity_copies_ir(p0b);

    let p2 = eliminate_zext_trunc_ir(p1);

    let p3 = eliminate_dead_zexts_ir(p2);

    let p4 = eliminate_inttoptr_roundtrips_ir(p3);

    let p5 = eliminate_dead_ptrtoints_ir(p4);

    let p6 = annotate_memory_none_ir(p5);

    let p7 = annotate_memory_read_ir(p6);

    let p8 = if is_recursive or fn_name == "main" { p7 } else { add_norecurse_attr(p7) };

    let p9 = add_nofree_attr(p8);

    let p10 = add_speculatable_attr(p9);

    fix_typed_ret_placeholders_ir(p10);

fn gen_function_sb_structs_reuse(mir: String, llvm_sctx: String, ptr_ret_reg: String, fn_sb: i64, str_sb: i64, ptr_sb: i64) -> String

  post it.len() >= 0

= let _c1 = sb_clear(fn_sb);

    let _c2 = sb_clear(str_sb);

    let _c3 = sb_clear(ptr_sb);

    let ret_type = extract_mir_return_type(mir);

    // v0.93.4: Detect direct recursion for norecurse attribute

    let fn_start = find_pattern_at(mir, "fn ", 0);

    let fn_name = if fn_start >= 0 { extract_fn_name_from_mir(mir, fn_start) } else { "" };

    let is_recursive = if fn_name == "" { true } else { mir_has_self_call(mir, fn_name) };

    let _w0 = init_string_params_sb(mir, str_sb);

    let _w0p = init_ptr_params_sb(mir, ptr_sb);

    let _w0r = init_fn_ptr_returns(ptr_ret_reg, ptr_sb);

    let _w0i = init_i64_params_sb(mir, str_sb);

    let _w1 = gen_fn_lines_structs(mir, 0, fn_sb, ret_type, llvm_sctx, "", str_sb, ptr_sb);

    let raw_ir = sb_build(fn_sb);

    run_ir_passes(raw_ir, is_recursive, fn_name);

fn init_string_params_sb(mir: String, str_sb: i64) -> i64

  post it >= 0

= let fn_start = find_pattern_at(mir, "fn ", 0);

    if fn_start < 0 { 0 } else {

        let paren_start = find_char(mir, fn_start, 40);

        let paren_end = find_char(mir, paren_start, 41);

        if paren_start < 0 or paren_end < 0 { 0 }

        else {

            let params = mir.slice(paren_start + 1, paren_end);

            collect_string_params_sb(params, 0, str_sb)

        }

    };

// Collect string parameters and push "S:%name," markers to SB

fn collect_string_params_sb(params: String, pos: i64, str_sb: i64) -> i64

    post it >= 0

= 

    let p = low_skip_ws(params, pos);

    if p >= params.len() { 0 }

    else {

        let comma_pos = find_comma_or_end(params, p);

        let param = params.slice(p, comma_pos);

        let colon_pos = find_char(param, 0, 58);

        if colon_pos < param.len() {

            let param_name = trim(param.slice(0, colon_pos));

            let param_type = trim(param.slice(colon_pos + 1, param.len()));

            let _w = if param_type == "String" {

                let _w1 = sb_push(str_sb, "S:%");

                let _w2 = sb_push(str_sb, param_name);

                sb_push(str_sb, ",")

            } else if param_type == "f64" {

                let _w1 = sb_push(str_sb, "D:%");

                let _w2 = sb_push(str_sb, param_name);

                sb_push(str_sb, ",")

            } else { match param_type { "*f64" => let _w1 = sb_push(str_sb, "F:%");

                let _w2 = sb_push(str_sb, param_name);

                sb_push(str_sb, ","), "i32" => // v0.95: Track i32 parameters for type-correct codegen

                let _w1 = sb_push(str_sb, "W:%");

                let _w2 = sb_push(str_sb, param_name);

                sb_push(str_sb, ","), _ => 0 } };

            if comma_pos >= params.len() { 0 }

            else { collect_string_params_sb(params, comma_pos + 1, str_sb) }

        } else {

            if comma_pos >= params.len() { 0 }

            else { collect_string_params_sb(params, comma_pos + 1, str_sb) }

        }

    };

// v0.95: Track i64 parameter names in str_sb with "P:%name," prefix

// Used for indirect call detection when call target is a function parameter

fn init_i64_params_sb(mir: String, str_sb: i64) -> i64

  post it >= 0

= let fn_start = find_pattern_at(mir, "fn ", 0);

    if fn_start < 0 { 0 } else {

        let paren_start = find_char(mir, fn_start, 40);

        let paren_end = find_char(mir, paren_start, 41);

        if paren_start < 0 or paren_end < 0 { 0 }

        else {

            let params = mir.slice(paren_start + 1, paren_end);

            collect_i64_params_sb(params, 0, str_sb)

        }

    };

fn collect_i64_params_sb(params: String, pos: i64, str_sb: i64) -> i64

    post it >= 0

= 

    let p = low_skip_ws(params, pos);

    if p >= params.len() { 0 }

    else {

        let comma_pos = find_comma_or_end(params, p);

        let param = params.slice(p, comma_pos);

        let colon_pos = find_char(param, 0, 58);

        let _w = if colon_pos < param.len() {

            let param_name = trim(param.slice(0, colon_pos));

            let param_type = trim(param.slice(colon_pos + 1, param.len()));

            if param_type == "i64" {

                let _w1 = sb_push(str_sb, "P:%");

                let _w2 = sb_push(str_sb, param_name);

                sb_push(str_sb, ",")

            } else if param_type == "fn_i64" {

                let _w1 = sb_push(str_sb, "H:%");

                let _w2 = sb_push(str_sb, param_name);

                sb_push(str_sb, ",")

            } else { 0 }

        } else { 0 };

        if comma_pos >= params.len() { 0 }

        else { collect_i64_params_sb(params, comma_pos + 1, str_sb) }

    };

// Format: "fn_name:StructName,fn_name2:StructName2,"

fn register_ptr_return(fn_mir: String, rsb: i64) -> i64

  post it >= 0

= let first_pipe = find_char(fn_mir, 0, 31);

    let header = fn_mir.slice(0, first_pipe);

    if header.len() < 4 { 0 }

    else if low_starts_with_at(header, 0, "fn ") {

        let name_start = 3;

        let paren_pos = find_char(header, name_start, 40);

        let fn_name = header.slice(name_start, paren_pos);

        let close_pos = find_char(header, paren_pos, 41);

        let arrow_pos = find_arrow(header, close_pos);

        let brace_pos = find_char(header, arrow_pos, 123);

        let raw_ret = trim(header.slice(arrow_pos + 2, brace_pos));

        let ann = find_mir_annotation(raw_ret);

        let ret_type = if ann == "" { raw_ret } else { strip_annotation(raw_ret) };

        if is_struct_ptr_type(ret_type) {

            let struct_name = extract_struct_name_from_ptr_type(ret_type);

            let _w1 = sb_push(rsb, fn_name);

            let _w2 = sb_push(rsb, ":");

            let _w3 = sb_push(rsb, struct_name);

            sb_push(rsb, ",")

        } else { 0 }

    } else { 0 };

fn init_fn_ptr_returns(ptr_ret_reg: String, ptr_sb: i64) -> i64

  post it >= 0

= init_fn_ptr_returns_at(ptr_ret_reg, 0, ptr_sb);

fn init_fn_ptr_returns_at(reg: String, pos: i64, ptr_sb: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= reg.len() { 0 } else {

        let comma_pos = find_comma_or_end(reg, pos);

        let entry = reg.slice(pos, comma_pos);

        let colon_pos = find_char(entry, 0, 58);

        if colon_pos < entry.len() {

            let fn_name = entry.slice(0, colon_pos);

            let struct_name = entry.slice(colon_pos + 1, entry.len());

            let _w1 = sb_push(ptr_sb, "F:@");

            let _w2 = sb_push(ptr_sb, fn_name);

            let _w3 = sb_push(ptr_sb, ":");

            let _w4 = sb_push(ptr_sb, struct_name);

            let _w5 = sb_push(ptr_sb, ",");

            if comma_pos >= reg.len() { 0 }

            else { init_fn_ptr_returns_at(reg, comma_pos + 1, ptr_sb) }

        } else {

            if comma_pos >= reg.len() { 0 }

            else { init_fn_ptr_returns_at(reg, comma_pos + 1, ptr_sb) }

        }

    };

fn is_struct_ptr_type(t: String) -> bool

  post it == (t.starts_with("*"))

= t.len() >= 2 and t.byte_at(0) == 42;

fn extract_struct_name_from_ptr_type(t: String) -> String

  post it.len() <= t.len()

= if t.len() >= 2 and t.byte_at(0) == 42 { t.slice(1, t.len()) }

    else { "" };

// Format: "P:%name:StructName," for each *StructName parameter

fn init_ptr_params_sb(mir: String, ptr_sb: i64) -> i64

  post it >= 0

= let fn_start = find_pattern_at(mir, "fn ", 0);

    if fn_start < 0 { 0 } else {

        let paren_start = find_char(mir, fn_start, 40);

        let paren_end = find_char(mir, paren_start, 41);

        if paren_start < 0 or paren_end < 0 { 0 }

        else {

            let params = mir.slice(paren_start + 1, paren_end);

            collect_ptr_params_sb(params, 0, ptr_sb)

        }

    };

fn collect_ptr_params_sb(params: String, pos: i64, ptr_sb: i64) -> i64

    post it >= 0

= 

    let p = low_skip_ws(params, pos);

    if p >= params.len() { 0 }

    else {

        let comma_pos = find_comma_or_end(params, p);

        let param = params.slice(p, comma_pos);

        let colon_pos = find_char(param, 0, 58);

        if colon_pos < param.len() {

            let param_name = trim(param.slice(0, colon_pos));

            let param_type = trim(param.slice(colon_pos + 1, param.len()));

            let _w = if is_struct_ptr_type(param_type) {

                let struct_name = extract_struct_name_from_ptr_type(param_type);

                let _w1 = sb_push(ptr_sb, "P:%");

                let _w2 = sb_push(ptr_sb, param_name);

                let _w3 = sb_push(ptr_sb, ":");

                let _w4 = sb_push(ptr_sb, struct_name);

                sb_push(ptr_sb, ",")

            } else { 0 };

            if comma_pos >= params.len() { 0 }

            else { collect_ptr_params_sb(params, comma_pos + 1, ptr_sb) }

        } else {

            if comma_pos >= params.len() { 0 }

            else { collect_ptr_params_sb(params, comma_pos + 1, ptr_sb) }

        }

    };

fn push_ptr_marker(ptr_sb: i64, varname: String, struct_name: String) -> i64

  post it >= 0

= let _w1 = sb_push(ptr_sb, "P:");

    let _w2 = sb_push(ptr_sb, varname);

    let _w3 = sb_push(ptr_sb, ":");

    let _w4 = sb_push(ptr_sb, struct_name);

    sb_push(ptr_sb, ",");

fn get_struct_ptr_type(varname: String, ptr_sb: i64) -> String

  post it.len() >= 0

= let content = sb_build(ptr_sb);

    get_struct_ptr_type_from(varname, content, 0);

fn get_struct_ptr_type_from(varname: String, content: String, pos: i64) -> String

    pre pos >= 0

    post it.len() >= 0

=

    if pos >= content.len() { "" } else {

        let comma_pos = find_comma_or_end(content, pos);

        let entry = content.slice(pos, comma_pos);

        // Entry format: "P:%varname:StructName"

        if entry.len() >= 4 and entry.byte_at(0) == 80 and entry.byte_at(1) == 58 {

            let after_p = 2;

            let second_colon = find_char_from(entry, after_p, 58);

            if second_colon < entry.len() {

                let entry_var = entry.slice(after_p, second_colon);

                let entry_struct = entry.slice(second_colon + 1, entry.len());

                if entry_var == varname { entry_struct }

                else if comma_pos >= content.len() { "" }

                else { get_struct_ptr_type_from(varname, content, comma_pos + 1) }

            }

            else if comma_pos >= content.len() { "" }

            else { get_struct_ptr_type_from(varname, content, comma_pos + 1) }

        }

        else if comma_pos >= content.len() { "" }

        else { get_struct_ptr_type_from(varname, content, comma_pos + 1) }

    };

fn find_char_from(s: String, pos: i64, ch: i64) -> i64

    post it >= -1

= 

    if pos >= s.len() { s.len() }

    else if s.byte_at(pos) == ch { pos }

    else { find_char_from(s, pos + 1, ch) };

fn count_struct_fields(registry: String, struct_name: String) -> i64

    post it >= 0

= count_struct_fields_at(registry, 0, struct_name);

fn count_struct_fields_at(registry: String, pos: i64, struct_name: String) -> i64

    post it >= 0

= 

    if pos >= registry.len() { 0 } else {

        let semi_pos = find_char(registry, pos, 59);

        let entry = registry.slice(pos, semi_pos);

        let colon_pos = find_char(entry, 0, 58);

        let name = entry.slice(0, colon_pos);

        if name == struct_name {

            let fields = entry.slice(colon_pos + 1, entry.len());

            count_commas(fields, 0) + 1

        }

        else if semi_pos + 1 >= registry.len() { 0 }

        else { count_struct_fields_at(registry, semi_pos + 1, struct_name) }

    };

fn count_commas(s: String, pos: i64) -> i64

    pre pos >= 0 and pos <= s.len()

    post it >= 0 and it <= s.len() - pos

= 

    if pos >= s.len() { 0 }

    else if s.byte_at(pos) == 44 { 1 + count_commas(s, pos + 1) }

    else { count_commas(s, pos + 1) };

fn build_struct_gep_type(struct_reg: String, struct_name: String) -> String

  post it.len() >= 0

= let field_count = count_struct_fields(struct_reg, struct_name);

    "{ " + build_field_types_str(struct_reg, struct_name, field_count) + " }";

fn build_field_types_str(struct_reg: String, struct_name: String, count: i64) -> String

  pre count >= 0

  post it.len() >= 0

= build_field_types_acc(struct_reg, struct_name, 0, count, "");

fn build_field_types_acc(struct_reg: String, struct_name: String, idx: i64, count: i64, acc: String) -> String

  pre idx >= 0

  post it.len() >= 0

= if idx >= count { acc } else {

        let is_f64 = is_field_f64_by_index(struct_reg, struct_name, idx);

        let field_type = if is_f64 { "double" } else { "i64" };

        let new_acc = if acc == "" { field_type } else { acc + ", " + field_type };

        build_field_types_acc(struct_reg, struct_name, idx + 1, count, new_acc)

    };

fn is_field_f64_by_index(struct_reg: String, struct_name: String, idx: i64) -> bool

  pre idx >= 0

  post not it or struct_reg.len() > 0

= is_field_f64_by_index_at(struct_reg, 0, struct_name, idx);

fn is_field_f64_by_index_at(registry: String, pos: i64, struct_name: String, idx: i64) -> bool

  pre pos >= 0

  post not it or pos < registry.len()

= if pos >= registry.len() { false } else {

        let semi_pos = find_char(registry, pos, 59);

        let entry = registry.slice(pos, semi_pos);

        let colon_pos = find_char(entry, 0, 58);

        let name = entry.slice(0, colon_pos);

        if name == struct_name {

            let fields = entry.slice(colon_pos + 1, entry.len());

            check_field_f64_at_index(fields, 0, 0, idx)

        }

        else if semi_pos + 1 >= registry.len() { false }

        else { is_field_f64_by_index_at(registry, semi_pos + 1, struct_name, idx) }

    };

fn check_field_f64_at_index(fields: String, pos: i64, cur_idx: i64, target_idx: i64) -> bool

  pre pos >= 0

  post not it or pos < fields.len()

= if pos >= fields.len() { false } else {

        let comma_pos = find_comma_or_end(fields, pos);

        let raw_name = fields.slice(pos, comma_pos);

        if cur_idx == target_idx {

            let tilde_pos = find_char(raw_name, 0, 126);

            tilde_pos < raw_name.len()

        }

        else if comma_pos >= fields.len() { false }

        else { check_field_f64_at_index(fields, comma_pos + 1, cur_idx + 1, target_idx) }

    };

fn find_pattern_at(s: String, pat: String, pos: i64) -> i64

    post it >= -1

= 

    // Check from start - MIR functions always start with "fn "

    if pos == 0 and pat.len() <= s.len() and match_bytes(s, pat, 0, 0) { 0 }

    // If not at start, do linear search

    else { find_pattern_noa(s, pat, pos) };

// Legacy alias — redirects to zero-allocation implementation

fn find_pattern_at_slow(s: String, pat: String, pos: i64) -> i64

    post it >= -1

= 

    find_pattern_noa(s, pat, pos);

fn gen_fn_lines_structs(mir: String, pos: i64, sb: i64, ret_type: String, llvm_sctx: String, mapping: String, str_sb: i64, ptr_sb: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= mir.len() { 0 } else {

        let pipe_pos = find_pipe_skip_quotes(mir, pos);

        let line = mir.slice(pos, pipe_pos);

        let result = llvm_gen_fn_line_structs(line, ret_type, llvm_sctx, mapping, str_sb, ptr_sb);

        let is_changed = result.len() > 0 and result.byte_at(0) == 33;

        let new_mapping = if is_changed { extract_new_mapping(result) } else { mapping };

        let llvm_line = if is_changed { extract_new_llvm_line(result) } else { result };

        let len = sb_len(sb);

        let _w1 = if len > 0 and llvm_line != "" { sb_push(sb, SEP()) } else { 0 };

        let _w2 = if llvm_line != "" { sb_push(sb, llvm_line) } else { 0 };

        if pipe_pos >= mir.len() { 0 } else { gen_fn_lines_structs(mir, pipe_pos + 1, sb, ret_type, llvm_sctx, new_mapping, str_sb, ptr_sb) }

    };

fn llvm_gen_fn_line_structs(line: String, ret_type: String, llvm_sctx: String, mapping: String, str_sb: i64, ptr_sb: i64) -> String

  post it.len() >= 0

= let p = low_skip_ws(line, 0);

    if p >= line.len() { same_mapping_empty() }

    else if low_starts_with_at(line, p, "fn ") { same_mapping(llvm_gen_fn_header(line, p)) }

    else if ends_with_colon(line) { same_mapping(line) }

    else if line == "}" { same_mapping("}") }

    else { llvm_gen_line_structs(line, ret_type, llvm_sctx, mapping, str_sb, ptr_sb) };

fn llvm_gen_line_structs(line: String, ret_type: String, llvm_sctx: String, mapping: String, str_sb: i64, ptr_sb: i64) -> String

  post it.len() >= 0

= let struct_reg = llvm_sctx_struct_reg(llvm_sctx);
    let p = low_skip_ws(line, 0);

    if p >= line.len() { same_mapping_empty() }

    else if line.byte_at(p) == 37 { llvm_gen_assign_structs(line, p, llvm_sctx, mapping, str_sb, ptr_sb) }

    else if low_starts_with_at(line, p, "return") { same_mapping(llvm_gen_return_typed(line, p, ret_type)) }

    else if low_starts_with_at(line, p, "branch") { same_mapping(llvm_gen_branch(line, p)) }

    else if low_starts_with_at(line, p, "goto") { same_mapping(llvm_gen_goto(line, p)) }

    else if low_starts_with_at(line, p, "alloca") { llvm_gen_alloca(line, p, mapping) }

    else if low_starts_with_at(line, p, "store_ptr_u8") { llvm_gen_store_ptr_u8_sb(line, p + 12, str_sb) }

    else if low_starts_with_at(line, p, "store_ptr_i32") { llvm_gen_store_ptr_i32_sb(line, p + 13, str_sb) }

    else if low_starts_with_at(line, p, "store_ptr_bool") { llvm_gen_store_ptr_bool_sb(line, p + 14, str_sb) }

    else if low_starts_with_at(line, p, "store_ptr_f64") { llvm_gen_store_ptr_f64_sb(line, p + 13, str_sb) }

    else if low_starts_with_at(line, p, "store_ptr") { llvm_gen_store_ptr_sb(line, p + 9, str_sb) }

    else if low_starts_with_at(line, p, "store") { llvm_gen_store_sb(line, p, mapping, str_sb) }

    else if low_starts_with_at(line, p, "field-store") { llvm_gen_field_store(line, p + 11, struct_reg, str_sb) }

    else if low_starts_with_at(line, p, "mark_") { llvm_gen_line_mark(line, p, str_sb) }

    else if low_starts_with_at(line, p, "mutex-") { same_mapping(llvm_gen_conc_stmt(line, p)) }

    else if low_starts_with_at(line, p, "arc-") { same_mapping(llvm_gen_conc_stmt(line, p)) }

    else if low_starts_with_at(line, p, "atomic-") { same_mapping(llvm_gen_conc_stmt(line, p)) }

    else if low_starts_with_at(line, p, "channel-") { same_mapping(llvm_gen_conc_stmt(line, p)) }

    else if low_starts_with_at(line, p, "rwlock-") { same_mapping(llvm_gen_conc_stmt(line, p)) }

    else if low_starts_with_at(line, p, "condvar-") { same_mapping(llvm_gen_conc_stmt(line, p)) }

    else if low_starts_with_at(line, p, "async-") { same_mapping(llvm_gen_conc_stmt(line, p)) }

    else if low_starts_with_at(line, p, "thread-pool-") { same_mapping(llvm_gen_conc_stmt(line, p)) }

    else if low_starts_with_at(line, p, "thread-join") { same_mapping(llvm_gen_conc_stmt(line, p)) }

    else if low_starts_with_at(line, p, "scope-") { same_mapping(llvm_gen_conc_stmt(line, p)) }

    else if line.byte_at(p) == 40 { same_mapping(llvm_gen_channel_new(line, p)) }

    else { same_mapping(line) };

fn llvm_gen_line_mark(line: String, p: i64, str_sb: i64) -> String

  pre p >= 0

  post it.len() >= 0

= if low_starts_with_at(line, p, "mark_f64_ptr") { llvm_handle_mark_f64_ptr(line, p, str_sb) }

  else if low_starts_with_at(line, p, "mark_str_ptr_if") { llvm_handle_mark_str_ptr_if(line, p, str_sb) }

  else { llvm_handle_mark_str_ptr(line, p, str_sb) };

fn llvm_gen_assign_structs(line: String, pos: i64, llvm_sctx: String, mapping: String, str_sb: i64, ptr_sb: i64) -> String

  pre pos >= 0

  post it.len() >= 1

= let eq_pos = find_eq(line, pos);

    let dest = line.slice(pos, eq_pos - 1);

    let after_eq = low_skip_ws(line, eq_pos + 1);

    llvm_gen_rhs_structs(line, after_eq, dest, llvm_sctx, mapping, str_sb, ptr_sb);

fn llvm_gen_rhs_structs(line: String, pos: i64, dest: String, llvm_sctx: String, mapping: String, str_sb: i64, ptr_sb: i64) -> String

  pre pos >= 0

  post it.len() >= 1

= let strings = llvm_sctx_strings(llvm_sctx);
    let string_fns = llvm_sctx_string_fns(llvm_sctx);
    let registry = llvm_sctx_registry(llvm_sctx);
    let struct_reg = llvm_sctx_struct_reg(llvm_sctx);
    if low_starts_with_at(line, pos, "field-access") {

        llvm_gen_field_access(line, pos + 12, dest, struct_reg, str_sb, ptr_sb)

    }

    else if low_starts_with_at(line, pos, "+|") or low_starts_with_at(line, pos, "-|") or low_starts_with_at(line, pos, "*|") or low_starts_with_at(line, pos, "+%") or low_starts_with_at(line, pos, "-%") or low_starts_with_at(line, pos, "*%") {

        // Saturating +|/-|/*| and wrapping +%/-%/*%: delegate to main RHS handler

        llvm_gen_rhs_with_strings_map_and_fns_reg(line, pos, dest, strings, string_fns, mapping, str_sb, registry)

    }

    else if low_starts_with_at(line, pos, "+") {

        llvm_gen_add_struct_aware(line, pos + 1, dest, mapping, str_sb, struct_reg, ptr_sb)

    }

    else if low_starts_with_at(line, pos, "copy") {

        llvm_gen_copy_struct_aware(line, pos, dest, mapping, str_sb, ptr_sb, registry)

    }

    else if low_starts_with_at(line, pos, "call") {

        llvm_gen_call_struct_aware(line, pos, dest, llvm_sctx, mapping, str_sb, ptr_sb)

    }

    else {

        // Delegate to existing registry-aware RHS handler

        llvm_gen_rhs_with_strings_map_and_fns_reg(line, pos, dest, strings, string_fns, mapping, str_sb, registry)

    };

fn llvm_gen_rhs_copy_markers(src: String, dest: String, str_sb: i64) -> i64

  pre str_sb >= 0

  post it == 0 or it == 1

= let is_string = is_string_var_sb(src, str_sb);
    let is_double = is_double_var_sb(src, str_sb);
    let is_f64_ptr = is_f64_ptr_sb(src, str_sb);
    let is_str_ptr = is_str_ptr_sb(src, str_sb);
    let is_i32 = is_i32_var_sb(src, str_sb);
    let _w = if is_string { push_string_marker(str_sb, dest) } else if is_double { push_double_marker(str_sb, dest) } else if is_f64_ptr { push_f64_ptr_marker(str_sb, dest) } else if is_str_ptr { push_str_ptr_marker(str_sb, dest) } else if is_i32 { push_i32_marker(str_sb, dest) } else { 0 };
    if is_double { 1 } else { 0 };

fn llvm_gen_rhs_copy_alloca_markers(src: String, dest: String, str_sb: i64) -> i64

  pre str_sb >= 0

  post it == 0 or it == 1

= let alloca_is_double = is_double_var_sb(src, str_sb);
    let alloca_is_string = is_string_var_sb(src, str_sb);
    let alloca_is_f64_ptr = is_f64_ptr_sb(src, str_sb);
    let alloca_is_str_ptr = is_str_ptr_sb(src, str_sb);
    let alloca_is_i32 = is_i32_var_sb(src, str_sb);
    let _w = if alloca_is_string { push_string_marker(str_sb, dest) }
        else if alloca_is_f64_ptr { push_f64_ptr_marker(str_sb, dest) }
        else if alloca_is_str_ptr { push_str_ptr_marker(str_sb, dest) }
        else if alloca_is_i32 { push_i32_marker(str_sb, dest) }
        else { 0 };
    if alloca_is_double { 1 } else { 0 };

fn llvm_gen_rhs_copy_branch(line: String, pos: i64, dest: String, mapping: String, str_sb: i64, registry: String) -> String

  pre pos >= 0

  post it.len() >= 1

= let src_start = low_skip_ws(line, pos + 4);
    let src = trim_end(line.slice(src_start, line.len()));
    let is_fnref = src.len() > 1 and src.byte_at(0) == 37
        and not (is_hof_param_sb(src, str_sb) or is_i64_param_sb(src, str_sb))
        and find_pattern_at(registry, "@" + src.slice(1, src.len()) + ":", 0) >= 0;
    if is_fnref {
        let fn_name = src.slice(1, src.len());
        let both_sig = lookup_fn_both(registry, fn_name);
        let is_zero_arg = both_sig.len() > 0 and both_sig.byte_at(both_sig.len() - 1) == 58;
        if is_zero_arg {
            let ret_type = lookup_fn_ret(registry, fn_name);
            let llvm_ret = if ret_type == "double" { "double" } else { "i64" };
            let _mark = if ret_type == "double" { push_double_marker(str_sb, dest) } else { 0 };
            same_mapping("  " + dest + " = call " + llvm_ret + " @" + fn_name + "()")
        } else {
            same_mapping("  " + dest + " = ptrtoint ptr @" + fn_name + " to i64")
        }
    } else if is_user_variable(dest) {
        let resolved_src = resolve_variable(src, mapping);
        let _md = llvm_gen_rhs_copy_markers(src, dest, str_sb);
        let name_mapping = add_mapping(mapping, dest, resolved_src);
        changed_mapping_empty(name_mapping)
    } else {
        let resolved_src = resolve_variable(src, mapping);
        if resolved_src == "ALLOCA" {
            let alloca_is_double = llvm_gen_rhs_copy_alloca_markers(src, dest, str_sb);
            if alloca_is_double > 0 {
                let _w = push_double_marker(str_sb, dest);
                same_mapping("  " + dest + " = load double, ptr " + src)
            } else {
                same_mapping("  " + dest + " = load i64, ptr " + src)
            }
        } else {
            let src_is_double = llvm_gen_rhs_copy_markers(src, dest, str_sb);
            if src_is_double > 0 {
                same_mapping("  " + dest + " = fadd nsz double 0.0, " + resolved_src)
            } else {
                same_mapping("  " + dest + " = add nsw i64 0, " + resolved_src)
            }
        }
    };

fn llvm_gen_rhs_conv_float(line: String, pos: i64, dest: String, str_sb: i64) -> String

  pre pos >= 0

  post it.len() >= 1

= if low_starts_with_at(line, pos, "fptosi") {
        let src_start = low_skip_ws(line, pos + 6);
        let src = trim_end(line.slice(src_start, line.len()));
        if is_double_var_sb(src, str_sb) {
            same_mapping("  " + dest + " = fptosi double " + src + " to i64")
        } else {
            same_mapping("  " + dest + " = add nsw i64 " + src + ", 0")
        }
    } else if low_starts_with_at(line, pos, "sitofp") {
        let src_start = low_skip_ws(line, pos + 6);
        let src = trim_end(line.slice(src_start, line.len()));
        let _w = push_double_marker(str_sb, dest);
        same_mapping("  " + dest + " = sitofp i64 " + src + " to double")
    } else if low_starts_with_at(line, pos, "trunc_i32") {
        let src_start = low_skip_ws(line, pos + 9);
        let src = trim_end(line.slice(src_start, line.len()));
        let _w = push_i32_marker(str_sb, dest);
        same_mapping("  " + dest + "_w = trunc i64 " + src + " to i32" + SEP() + "  " + dest + " = sext i32 " + dest + "_w to i64")
    } else if low_starts_with_at(line, pos, "f+") { let _w = push_double_marker(str_sb, dest); same_mapping(llvm_gen_float_binop("fadd", line, pos + 2, dest)) }
    else if low_starts_with_at(line, pos, "f-") { let _w = push_double_marker(str_sb, dest); same_mapping(llvm_gen_float_binop("fsub", line, pos + 2, dest)) }
    else if low_starts_with_at(line, pos, "f*") { let _w = push_double_marker(str_sb, dest); same_mapping(llvm_gen_float_binop("fmul", line, pos + 2, dest)) }
    else if low_starts_with_at(line, pos, "f/") { let _w = push_double_marker(str_sb, dest); same_mapping(llvm_gen_float_binop("fdiv", line, pos + 2, dest)) }
    else if low_starts_with_at(line, pos, "f<=") { same_mapping(llvm_gen_float_cmp("ole", line, pos + 3, dest)) }
    else if low_starts_with_at(line, pos, "f>=") { same_mapping(llvm_gen_float_cmp("oge", line, pos + 3, dest)) }
    else if low_starts_with_at(line, pos, "f<") { same_mapping(llvm_gen_float_cmp("olt", line, pos + 2, dest)) }
    else if low_starts_with_at(line, pos, "f>") { same_mapping(llvm_gen_float_cmp("ogt", line, pos + 2, dest)) }
    else if low_starts_with_at(line, pos, "f==") { same_mapping(llvm_gen_float_cmp("oeq", line, pos + 3, dest)) }
    else if low_starts_with_at(line, pos, "f!=") { same_mapping(llvm_gen_float_cmp("one", line, pos + 3, dest)) }
    else { same_mapping("  ; unknown-float: " + line) };

fn llvm_gen_rhs_arith_logic(line: String, pos: i64, dest: String, mapping: String, str_sb: i64) -> String

  pre pos >= 0

  post it.len() >= 1

= if low_starts_with_at(line, pos, "+|") { same_mapping(llvm_gen_sat_binop("llvm.sadd.sat.i64", line, pos + 2, dest)) }
    else if low_starts_with_at(line, pos, "-|") { same_mapping(llvm_gen_sat_binop("llvm.ssub.sat.i64", line, pos + 2, dest)) }
    else if low_starts_with_at(line, pos, "*|") { same_mapping(llvm_gen_sat_mul(line, pos + 2, dest)) }
    else if low_starts_with_at(line, pos, "+%") { same_mapping(llvm_gen_wrap_binop("add", line, pos + 2, dest)) }
    else if low_starts_with_at(line, pos, "-%") { same_mapping(llvm_gen_wrap_binop("sub", line, pos + 2, dest)) }
    else if low_starts_with_at(line, pos, "*%") { same_mapping(llvm_gen_wrap_binop("mul", line, pos + 2, dest)) }
    else if low_starts_with_at(line, pos, "+") { llvm_gen_add_with_strings_sb(line, pos + 1, dest, mapping, str_sb) }
    else if low_starts_with_at(line, pos, "-") { llvm_gen_binop_sb("sub", "fsub", line, pos + 1, dest, str_sb) }
    else if low_starts_with_at(line, pos, "*") { llvm_gen_binop_sb("mul", "fmul", line, pos + 1, dest, str_sb) }
    else if low_starts_with_at(line, pos, "/") { llvm_gen_binop_sb("sdiv", "fdiv", line, pos + 1, dest, str_sb) }
    else if low_starts_with_at(line, pos, "%") { same_mapping(llvm_gen_binop("srem", line, pos + 1, dest)) }
    else if low_starts_with_at(line, pos, "bxor") { same_mapping(llvm_gen_binop("xor", line, pos + 4, dest)) }
    else if low_starts_with_at(line, pos, "band") { same_mapping(llvm_gen_binop("and", line, pos + 4, dest)) }
    else if low_starts_with_at(line, pos, "bor") { same_mapping(llvm_gen_binop("or", line, pos + 3, dest)) }
    else if low_starts_with_at(line, pos, "bnot") { same_mapping(llvm_gen_bnot(line, pos + 4, dest)) }
    else if low_starts_with_at(line, pos, "<<") { same_mapping(llvm_gen_binop("shl", line, pos + 2, dest)) }
    else if low_starts_with_at(line, pos, ">>>") { same_mapping(llvm_gen_binop("lshr", line, pos + 3, dest)) }
    else if low_starts_with_at(line, pos, ">>") { same_mapping(llvm_gen_binop("ashr", line, pos + 2, dest)) }
    else if low_starts_with_at(line, pos, "<=") { llvm_gen_cmp_sb("sle", "ole", line, pos + 2, dest, str_sb) }
    else if low_starts_with_at(line, pos, ">=") { llvm_gen_cmp_sb("sge", "oge", line, pos + 2, dest, str_sb) }
    else if low_starts_with_at(line, pos, "<") { llvm_gen_cmp_sb("slt", "olt", line, pos + 1, dest, str_sb) }
    else if low_starts_with_at(line, pos, ">") { llvm_gen_cmp_sb("sgt", "ogt", line, pos + 1, dest, str_sb) }
    else if low_starts_with_at(line, pos, "==") { llvm_gen_cmp_with_strings_sb("eq", line, pos + 2, dest, str_sb) }
    else if low_starts_with_at(line, pos, "!=") { llvm_gen_cmp_with_strings_sb("ne", line, pos + 2, dest, str_sb) }
    else if low_starts_with_at(line, pos, "and") { same_mapping(llvm_gen_binop("and", line, pos + 3, dest)) }
    else if low_starts_with_at(line, pos, "or") { same_mapping(llvm_gen_binop("or", line, pos + 2, dest)) }
    else if low_starts_with_at(line, pos, "not") { same_mapping(llvm_gen_not(line, pos + 3, dest)) }
    else if low_starts_with_at(line, pos, "neg") { llvm_gen_neg_sb(line, pos + 3, dest, str_sb) }
    else if low_starts_with_at(line, pos, "phi") { llvm_gen_phi_with_strings_sb(line, pos, dest, str_sb) }
    else { same_mapping("  ; unknown-arith: " + line) };

fn llvm_gen_rhs_ptr_ops(line: String, pos: i64, dest: String, str_sb: i64) -> String

  pre pos >= 0

  post it.len() >= 1

= if low_starts_with_at(line, pos, "gep_u8") { llvm_gen_gep_u8_sb(line, pos + 6, dest, str_sb) }
    else if low_starts_with_at(line, pos, "gep_i32") { llvm_gen_gep_i32_sb(line, pos + 7, dest, str_sb) }
    else if low_starts_with_at(line, pos, "gep_bool") { llvm_gen_gep_bool_sb(line, pos + 8, dest, str_sb) }
    else if low_starts_with_at(line, pos, "gep_f64") { llvm_gen_gep_f64_sb(line, pos + 7, dest, str_sb) }
    else if low_starts_with_at(line, pos, "gep") { llvm_gen_gep_sb(line, pos + 3, dest, str_sb) }
    else if low_starts_with_at(line, pos, "load_ptr_u8") { llvm_gen_load_ptr_u8_sb(line, pos + 11, dest, str_sb) }
    else if low_starts_with_at(line, pos, "load_ptr_i32") { llvm_gen_load_ptr_i32_sb(line, pos + 12, dest, str_sb) }
    else if low_starts_with_at(line, pos, "load_ptr_bool") { llvm_gen_load_ptr_bool_sb(line, pos + 13, dest, str_sb) }
    else if low_starts_with_at(line, pos, "load_ptr_f64") { llvm_gen_load_ptr_f64_sb(line, pos + 12, dest, str_sb) }
    else if low_starts_with_at(line, pos, "load_ptr") { llvm_gen_load_ptr_sb(line, pos + 8, dest, str_sb) }
    else if low_starts_with_at(line, pos, "store_ptr_u8") { llvm_gen_store_ptr_u8_sb(line, pos + 12, str_sb) }
    else if low_starts_with_at(line, pos, "store_ptr_i32") { llvm_gen_store_ptr_i32_sb(line, pos + 13, str_sb) }
    else if low_starts_with_at(line, pos, "store_ptr_bool") { llvm_gen_store_ptr_bool_sb(line, pos + 14, str_sb) }
    else if low_starts_with_at(line, pos, "store_ptr_f64") { llvm_gen_store_ptr_f64_sb(line, pos + 13, str_sb) }
    else if low_starts_with_at(line, pos, "store_ptr") { llvm_gen_store_ptr_sb(line, pos + 9, str_sb) }
    else { same_mapping("  ; unknown-ptr: " + line) };

fn llvm_gen_rhs_misc_ops(line: String, pos: i64, dest: String, mapping: String, strings: String, string_fns: String, str_sb: i64, registry: String) -> String

  pre pos >= 0

  post it.len() >= 1

= if low_starts_with_at(line, pos, "string") {
        let str_start = low_skip_ws(line, pos + 6);
        let str_content = line.slice(str_start + 1, line.len() - 1);
        let _w = push_string_marker(str_sb, dest);
        same_mapping(llvm_gen_string_ref(dest, str_content, strings))
    } else if low_starts_with_at(line, pos, "call") { llvm_gen_call_with_string_tracking_sb_reg(line, pos, dest, str_sb, string_fns, registry) }
    else if low_starts_with_at(line, pos, "mutex-") { same_mapping(llvm_gen_conc_rhs(line, pos, dest)) }
    else if low_starts_with_at(line, pos, "thread-pool-") { same_mapping(llvm_gen_conc_rhs(line, pos, dest)) }
    else if low_starts_with_at(line, pos, "thread-") { same_mapping(llvm_gen_conc_rhs(line, pos, dest)) }
    else if low_starts_with_at(line, pos, "arc-") { same_mapping(llvm_gen_conc_rhs(line, pos, dest)) }
    else if low_starts_with_at(line, pos, "atomic-") { same_mapping(llvm_gen_conc_rhs(line, pos, dest)) }
    else if low_starts_with_at(line, pos, "channel-") { same_mapping(llvm_gen_conc_rhs(line, pos, dest)) }
    else if low_starts_with_at(line, pos, "sender-") { same_mapping(llvm_gen_conc_rhs(line, pos, dest)) }
    else if low_starts_with_at(line, pos, "rwlock-") { same_mapping(llvm_gen_conc_rhs(line, pos, dest)) }
    else if low_starts_with_at(line, pos, "barrier-") { same_mapping(llvm_gen_conc_rhs(line, pos, dest)) }
    else if low_starts_with_at(line, pos, "condvar-") { same_mapping(llvm_gen_conc_rhs(line, pos, dest)) }
    else if low_starts_with_at(line, pos, "block-on") { same_mapping(llvm_gen_conc_rhs(line, pos, dest)) }
    else if low_starts_with_at(line, pos, "async-") { same_mapping(llvm_gen_conc_rhs(line, pos, dest)) }
    else if low_starts_with_at(line, pos, "scope-") { same_mapping(llvm_gen_conc_rhs(line, pos, dest)) }
    else if low_starts_with_at(line, pos, "nullable_select") { same_mapping(llvm_gen_nullable_select(line, pos + 15, dest)) }
    else if low_starts_with_at(line, pos, "select") { same_mapping(llvm_gen_select(line, pos + 6, dest)) }
    else if low_starts_with_at(line, pos, "closure_new") { llvm_gen_closure_new_sb(line, pos + 11, dest, mapping, str_sb) }
    else if low_starts_with_at(line, pos, "closure_load") { same_mapping(llvm_gen_closure_load(line, pos + 12, dest)) }
    else if low_starts_with_at(line, pos, "fn_ref") {
        let name_start = low_skip_ws(line, pos + 6);
        let fn_name = trim_end(line.slice(name_start, line.len()));
        same_mapping("  " + dest + " = ptrtoint ptr " + fn_name + " to i64")
    }
    else { same_mapping("  ; unknown: " + line) };

fn llvm_gen_rhs_with_strings_map_and_fns_reg(line: String, pos: i64, dest: String, strings: String, string_fns: String, mapping: String, str_sb: i64, registry: String) -> String

  pre pos >= 0

  post it.len() >= 1

= if low_starts_with_at(line, pos, "const") {

        let val_start = low_skip_ws(line, pos + 5);

        let val = line.slice(val_start, line.len());

        let trimmed_val = trim_end(val);

        if trimmed_val.len() >= 2 and trimmed_val.byte_at(0) == 70 and trimmed_val.byte_at(1) == 58 {

            let float_val = trimmed_val.slice(2, trimmed_val.len());

            let _w = push_double_marker(str_sb, dest);

            same_mapping("  " + dest + " = fadd nsz double 0.0, " + float_val)

        } else {

            same_mapping("  " + dest + " = add nsw i64 0, " + trimmed_val)

        }

    } else if low_starts_with_at(line, pos, "copy") {

        llvm_gen_rhs_copy_branch(line, pos, dest, mapping, str_sb, registry)

    } else if low_starts_with_at(line, pos, "fptosi") or low_starts_with_at(line, pos, "sitofp")
        or low_starts_with_at(line, pos, "trunc_i32") or low_starts_with_at(line, pos, "f+")
        or low_starts_with_at(line, pos, "f-") or low_starts_with_at(line, pos, "f*")
        or low_starts_with_at(line, pos, "f/") or low_starts_with_at(line, pos, "f<")
        or low_starts_with_at(line, pos, "f>") or low_starts_with_at(line, pos, "f=")
        or low_starts_with_at(line, pos, "f!") {

        llvm_gen_rhs_conv_float(line, pos, dest, str_sb)

    } else if low_starts_with_at(line, pos, "+") or low_starts_with_at(line, pos, "-")
        or low_starts_with_at(line, pos, "*") or low_starts_with_at(line, pos, "/")
        or low_starts_with_at(line, pos, "%") or low_starts_with_at(line, pos, "bxor")
        or low_starts_with_at(line, pos, "band") or low_starts_with_at(line, pos, "bor")
        or low_starts_with_at(line, pos, "bnot") or low_starts_with_at(line, pos, "<<")
        or low_starts_with_at(line, pos, ">>>") or low_starts_with_at(line, pos, ">>")
        or low_starts_with_at(line, pos, "<=") or low_starts_with_at(line, pos, ">=")
        or low_starts_with_at(line, pos, "<") or low_starts_with_at(line, pos, ">")
        or low_starts_with_at(line, pos, "==") or low_starts_with_at(line, pos, "!=")
        or low_starts_with_at(line, pos, "and") or low_starts_with_at(line, pos, "or")
        or low_starts_with_at(line, pos, "not") or low_starts_with_at(line, pos, "neg")
        or low_starts_with_at(line, pos, "phi") {

        llvm_gen_rhs_arith_logic(line, pos, dest, mapping, str_sb)

    } else if low_starts_with_at(line, pos, "gep") or low_starts_with_at(line, pos, "load_ptr")
        or low_starts_with_at(line, pos, "store_ptr") {

        llvm_gen_rhs_ptr_ops(line, pos, dest, str_sb)

    } else {

        llvm_gen_rhs_misc_ops(line, pos, dest, mapping, strings, string_fns, str_sb, registry)

    };

fn llvm_gen_nullable_select(line: String, pos: i64, dest: String) -> String

  pre pos >= 0

  post it.len() >= 1

= let p1 = low_skip_ws(line, pos);

    let comma = find_comma(line, p1);

    let recv = trim_end(line.slice(p1, comma));

    let p2 = low_skip_ws(line, comma + 1);

    let default_val = trim_end(line.slice(p2, line.len()));

    "  " + dest + "_ns = icmp ne i64 " + recv + ", 0" + SEP() + "  " + dest + " = select i1 " + dest + "_ns, i64 " + recv + ", i64 " + default_val;

fn llvm_gen_select(line: String, pos: i64, dest: String) -> String

  pre pos >= 0

  post it.len() >= 1

= let p1 = low_skip_ws(line, pos);

    let comma1 = find_comma(line, p1);

    let cond = trim_end(line.slice(p1, comma1));

    let p2 = low_skip_ws(line, comma1 + 1);

    let comma2 = find_comma(line, p2);

    let val_true = trim_end(line.slice(p2, comma2));

    let p3 = low_skip_ws(line, comma2 + 1);

    let val_false = trim_end(line.slice(p3, line.len()));

    // Same-value select: skip trunc+select, just assign

    if val_true == val_false { "  " + dest + " = add nsw i64 0, " + val_true }

    else { "  " + dest + "_s = trunc i64 " + cond + " to i1" + SEP() + "  " + dest + " = select i1 " + dest + "_s, i64 " + val_true + ", i64 " + val_false };

// Returns tagged result: llvm_line directly (mapping unchanged) or "!len:mapping+llvm_line" (mapping changed)

fn llvm_gen_add_struct_aware(line: String, pos: i64, dest: String, mapping: String, str_sb: i64, struct_reg: String, ptr_sb: i64) -> String

  pre pos >= 0

  post it.len() >= 1

= let p1 = low_skip_ws(line, pos);

    let comma = find_comma(line, p1);

    let left = trim_end(line.slice(p1, comma));

    let p2 = low_skip_ws(line, comma + 1);

    let right = trim_end(line.slice(p2, line.len()));

    // Check if left operand is a struct pointer

    let left_struct = get_struct_ptr_type(left, ptr_sb);

    if left_struct != "" {

        // Struct pointer arithmetic: emit GEP with struct type for proper scaling

        let struct_type = build_struct_gep_type(struct_reg, left_struct);

        let conv = "  " + left + "_p0 = inttoptr i64 " + left + " to ptr";

        let gep = "  " + dest + "_gep = getelementptr inbounds nuw " + struct_type + ", ptr " + left + "_p0, i64 " + right;

        let to_int = "  " + dest + " = ptrtoint ptr " + dest + "_gep to i64";

        // Propagate struct pointer type to dest

        let _w = push_ptr_marker(ptr_sb, dest, left_struct);

        same_mapping(conv + SEP() + gep + SEP() + to_int)

    } else {

        // Regular integer add - delegate to existing handler

        llvm_gen_add_with_strings_sb(line, pos, dest, mapping, str_sb)

    };

fn llvm_gen_copy_struct_aware(line: String, pos: i64, dest: String, mapping: String, str_sb: i64, ptr_sb: i64, registry: String) -> String

  pre pos >= 0

  post it.len() >= 1

= let src_start = low_skip_ws(line, pos + 4);

    let src = trim_end(line.slice(src_start, line.len()));

    // Propagate struct pointer type through copy

    let src_struct = get_struct_ptr_type(src, ptr_sb);

    let _w = if src_struct != "" { push_ptr_marker(ptr_sb, dest, src_struct) } else { 0 };

    // Delegate to existing copy handler in the struct-aware path

    // Re-dispatch through the main RHS handler for proper string/double tracking

    llvm_gen_rhs_with_strings_map_and_fns_reg(line, pos, dest, "", "", mapping, str_sb, registry);

fn llvm_gen_call_struct_aware(line: String, pos: i64, dest: String, llvm_sctx: String, mapping: String, str_sb: i64, ptr_sb: i64) -> String

  pre pos >= 0

  post it.len() >= 1

= // v0.95: Check for indirect call (function pointer in variable or parameter)

    let call_fn = extract_call_fn_name(line, pos);

    let var_name = "%" + call_fn;

    let resolved = resolve_variable(var_name, mapping);

    if resolved == "ALLOCA" {

        // v0.95: Uniform closure call — all ALLOCA indirect calls use closure protocol

        llvm_gen_indirect_call(line, pos, dest, var_name, str_sb)

    } else if is_hof_param_sb(var_name, str_sb) {

        // Cycle 2934: HOF call — fn(T)->R parameter, direct inttoptr + call (no closure protocol)

        llvm_gen_hof_call(line, pos, dest, var_name)

    } else if is_i64_param_sb(var_name, str_sb) {

        // v0.95: Uniform closure call — all param indirect calls use closure protocol

        llvm_gen_indirect_call_param(line, pos, dest, var_name, str_sb)

    } else {

    let strings = llvm_sctx_strings(llvm_sctx);
    let string_fns = llvm_sctx_string_fns(llvm_sctx);
    let registry = llvm_sctx_registry(llvm_sctx);

    // First delegate to existing call handler for proper codegen

    let result = llvm_gen_rhs_with_strings_map_and_fns_reg(line, pos, dest, strings, string_fns, mapping, str_sb, registry);

    // Check if the called function returns a struct pointer

    // Extract function name from MIR: "call @fn_name(...)"

    let call_start = low_skip_ws(line, pos + 4);

    let fn_name_end = find_fn_name_end(line, call_start);

    let fn_name = line.slice(call_start, fn_name_end);

    // Look up the function's return type in MIR (from the MIR function headers)

    // For now, use the ptr_sb to check if any param or call result has been marked

    // The function name should have been registered with its ptr return type

    let fn_ret_struct = get_fn_ptr_return_type(fn_name, ptr_sb);

    let _w = if fn_ret_struct != "" { push_ptr_marker(ptr_sb, dest, fn_ret_struct) } else { 0 };

    result

    };

// Cycle 2934: HOF call — plain function pointer parameter, direct inttoptr + call

// MIR: %_tN = call @f(args) where f: fn_i64 -> inttoptr %f to ptr; call i64 %fptr(args)

fn llvm_gen_hof_call(line: String, pos: i64, dest: String, var_name: String) -> String

  pre pos >= 0

  post it.len() >= 1

= let at_pos = find_char(line, pos, 64);

    let paren_pos = find_char(line, at_pos, 40);

    let close_pos = find_char(line, paren_pos, 41);

    let args = line.slice(paren_pos + 1, close_pos);

    let fptr_tmp = dest + "_hfptr";

    let cast_ir = "  " + fptr_tmp + " = inttoptr i64 " + var_name + " to ptr";

    let formatted_args = format_i64_call_args(args);

    let call_ir = "  " + dest + " = call i64 " + fptr_tmp + "(" + formatted_args + ")";

    same_mapping(cast_ir + SEP() + call_ir);

// v0.95: Generate indirect call through function pointer stored in alloca variable

// MIR: %_tN = call @var_name(args) -> loads from alloca, inttoptr, indirect call

fn llvm_gen_indirect_call(line: String, pos: i64, dest: String, var_name: String, str_sb: i64) -> String

  pre pos >= 0

  post it.len() >= 1

= // Parse args from MIR line: %_tN = call @name(arg1, arg2, ...)

    let at_pos = find_char(line, pos, 64);

    let paren_pos = find_char(line, at_pos, 40);

    let close_pos = find_char(line, paren_pos, 41);

    let args = line.slice(paren_pos + 1, close_pos);

    // v0.95: Uniform closure protocol — load struct, extract fn_ptr, pass closure as first arg

    let cl_tmp = dest + "_cl";

    let env_tmp = dest + "_envp";

    let fni_tmp = dest + "_fni";

    let ptr_tmp = dest + "_fptr";

    let load_ir = "  " + cl_tmp + " = load i64, ptr " + var_name;

    let env_ir = "  " + env_tmp + " = inttoptr i64 " + cl_tmp + " to ptr";

    let fni_ir = "  " + fni_tmp + " = load i64, ptr " + env_tmp;

    let cast_ir = "  " + ptr_tmp + " = inttoptr i64 " + fni_tmp + " to ptr";

    let formatted_args = format_indirect_call_args(args, 0, "", str_sb);

    let all_args = "i64 " + cl_tmp + (if formatted_args == "" { "" } else { ", " + formatted_args });

    let call_ir = "  " + dest + " = call i64 " + ptr_tmp + "(" + all_args + ")";

    same_mapping(load_ir + SEP() + env_ir + SEP() + fni_ir + SEP() + cast_ir + SEP() + call_ir);

// v0.95: Indirect call through function pointer parameter — uniform closure protocol

fn llvm_gen_indirect_call_param(line: String, pos: i64, dest: String, var_name: String, str_sb: i64) -> String

  pre pos >= 0

  post it.len() >= 1

= let at_pos = find_char(line, pos, 64);

    let paren_pos = find_char(line, at_pos, 40);

    let close_pos = find_char(line, paren_pos, 41);

    let args = line.slice(paren_pos + 1, close_pos);

    // v0.95: Uniform closure protocol — extract fn_ptr from struct, pass closure as first arg

    let env_tmp = dest + "_envp";

    let fni_tmp = dest + "_fni";

    let ptr_tmp = dest + "_fptr";

    let env_ir = "  " + env_tmp + " = inttoptr i64 " + var_name + " to ptr";

    let fni_ir = "  " + fni_tmp + " = load i64, ptr " + env_tmp;

    let cast_ir = "  " + ptr_tmp + " = inttoptr i64 " + fni_tmp + " to ptr";

    let formatted_args = format_indirect_call_args(args, 0, "", str_sb);

    let all_args = "i64 " + var_name + (if formatted_args == "" { "" } else { ", " + formatted_args });

    let call_ir = "  " + dest + " = call i64 " + ptr_tmp + "(" + all_args + ")";

    same_mapping(env_ir + SEP() + fni_ir + SEP() + cast_ir + SEP() + call_ir);

// Format arguments for indirect function call: %_t0 -> i64 %_t0

fn format_indirect_call_args(args: String, pos: i64, acc: String, str_sb: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= let p = low_skip_ws(args, pos);

    if p >= args.len() { acc }

    else {

        let comma = find_comma_or_end(args, p);

        let arg = trim_end(args.slice(p, comma));

        let arg_is_double = is_double_var_sb(arg, str_sb);

        let typed_arg = if arg_is_double { "double " + arg } else { "i64 " + arg };

        let new_acc = if acc == "" { typed_arg } else { acc + ", " + typed_arg };

        if comma >= args.len() { new_acc } else { format_indirect_call_args(args, comma + 1, new_acc, str_sb) }

    };

// v0.95: Generate closure allocation — malloc struct, store fn_ptr + captures

// MIR: closure_new @fn_name, count, %cap0, %cap1, ...

fn llvm_gen_closure_new_sb(line: String, pos: i64, dest: String, mapping: String, str_sb: i64) -> String

  pre pos >= 0

  post it.len() >= 1

= // pos points right after "closure_new"

    let p = low_skip_ws(line, pos);

    let at_pos = p + 1;

    let comma1 = find_comma(line, at_pos);

    let fn_name = "@" + trim(line.slice(at_pos, comma1));

    let count_start = low_skip_ws(line, comma1 + 1);

    let comma2 = find_comma_or_end(line, count_start);

    let count_str = trim(line.slice(count_start, comma2));

    let cap_count = parse_int_from(count_str, 0, 0);

    let struct_size = (2 + cap_count) * 8;

    let csb = sb_new();

    // 1. Get fn pointer as i64

    let _w1 = sb_push(csb, "  " + dest + "_fn = ptrtoint ptr " + fn_name + " to i64");

    // 2. Allocate struct

    let _w2 = sb_push(csb, SEP() + "  " + dest + "_env = call noalias ptr @malloc(i64 " + int_to_string(struct_size) + ")");

    // 3. Store fn pointer at offset 0

    let _w3 = sb_push(csb, SEP() + "  store i64 " + dest + "_fn, ptr " + dest + "_env");

    // 4. Store count at offset 1

    let _w4 = sb_push(csb, SEP() + "  " + dest + "_cnp = getelementptr inbounds nuw i64, ptr " + dest + "_env, i32 1");

    let _w5 = sb_push(csb, SEP() + "  store i64 " + int_to_string(cap_count) + ", ptr " + dest + "_cnp");

    // 5. Store each capture

    let caps_start = if comma2 >= line.len() { line.len() } else { comma2 + 1 };

    let _w6 = gen_closure_cap_stores(line, caps_start, dest, mapping, csb, 0, cap_count);

    // 6. Convert struct ptr to i64

    let _w7 = sb_push(csb, SEP() + "  " + dest + " = ptrtoint ptr " + dest + "_env to i64");

    // Mark as closure in str_sb

    let _w8 = push_closure_marker(str_sb, dest, cap_count);

    let ir = sb_build(csb);

    same_mapping(ir);

fn gen_closure_cap_stores(line: String, pos: i64, dest: String, mapping: String, csb: i64, idx: i64, count: i64) -> i64

  pre pos >= 0

  post it >= 0

= if idx >= count { 0 }

    else {

        let p = low_skip_ws(line, pos);

        let comma = find_comma_or_end(line, p);

        let cap_var = trim(line.slice(p, comma));

        let resolved = resolve_variable(cap_var, mapping);

        let cap_val = if resolved == "ALLOCA" {

            let val_tmp = dest + "_cv" + int_to_string(idx);

            let _w = sb_push(csb, SEP() + "  " + val_tmp + " = load i64, ptr " + cap_var);

            val_tmp

        } else { resolved };

        let offset = idx + 2;

        let _w1 = sb_push(csb, SEP() + "  " + dest + "_cp" + int_to_string(idx) + " = getelementptr inbounds nuw i64, ptr " + dest + "_env, i32 " + int_to_string(offset));

        let _w2 = sb_push(csb, SEP() + "  store i64 " + cap_val + ", ptr " + dest + "_cp" + int_to_string(idx));

        let next_pos = if comma >= line.len() { line.len() } else { comma + 1 };

        gen_closure_cap_stores(line, next_pos, dest, mapping, csb, idx + 1, count)

    };

// v0.95: Load a capture from __closure struct: closure_load %__closure, N

fn llvm_gen_closure_load(line: String, pos: i64, dest: String) -> String

  pre pos >= 0

  post it.len() >= 1

= let p = low_skip_ws(line, pos);

    let comma = find_comma(line, p);

    let closure_var = trim(line.slice(p, comma));

    let idx_start = low_skip_ws(line, comma + 1);

    let idx_str = trim_end(line.slice(idx_start, line.len()));

    let idx = parse_int_from(idx_str, 0, 0);

    let offset = idx + 2;

    let ptr_tmp = dest + "_p";

    let gep_tmp = dest + "_g";

    "  " + ptr_tmp + " = inttoptr i64 " + closure_var + " to ptr" + SEP() + "  " + gep_tmp + " = getelementptr inbounds nuw i64, ptr " + ptr_tmp + ", i32 " + int_to_string(offset) + SEP() + "  " + dest + " = load i64, ptr " + gep_tmp;

fn find_fn_name_end(line: String, pos: i64) -> i64

    post it >= -1

= 

    if pos >= line.len() { pos }

    else if line.byte_at(pos) == 40 { pos }  // '('

    else { find_fn_name_end(line, pos + 1) };

// This looks in ptr_sb for "F:@fn_name:StructName," entries

fn get_fn_ptr_return_type(fn_name: String, ptr_sb: i64) -> String

  post it.len() >= 0

= let content = sb_build(ptr_sb);

    get_fn_ptr_return_from(fn_name, content, 0);

fn get_fn_ptr_return_from(fn_name: String, content: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= content.len() { "" } else {

        let comma_pos = find_comma_or_end(content, pos);

        let entry = content.slice(pos, comma_pos);

        // Entry format: "F:@fn_name:StructName"

        if entry.len() >= 4 and entry.byte_at(0) == 70 and entry.byte_at(1) == 58 {

            let after_f = 2;

            let second_colon = find_char_from(entry, after_f, 58);

            if second_colon < entry.len() {

                let entry_fn = entry.slice(after_f, second_colon);

                let entry_struct = entry.slice(second_colon + 1, entry.len());

                if entry_fn == fn_name { entry_struct }

                else if comma_pos >= content.len() { "" }

                else { get_fn_ptr_return_from(fn_name, content, comma_pos + 1) }

            }

            else if comma_pos >= content.len() { "" }

            else { get_fn_ptr_return_from(fn_name, content, comma_pos + 1) }

        }

        else if comma_pos >= content.len() { "" }

        else { get_fn_ptr_return_from(fn_name, content, comma_pos + 1) }

    };

// MIR: %dest = field-access %base.fieldname

// LLVM: %dest_ptr = getelementptr i64, ptr %base, i32 field_index

//       %dest = load i64, ptr %dest_ptr

fn llvm_gen_field_access(line: String, pos: i64, dest: String, struct_reg: String, str_sb: i64, ptr_sb: i64) -> String

  pre pos >= 0

  post it.len() >= 1

= let p1 = low_skip_ws(line, pos);

    // Find dot separator in %base.field

    let dot_pos = find_char(line, p1, 46);

    let base = trim_end(line.slice(p1, dot_pos));

    let field = trim_end(line.slice(dot_pos + 1, line.len()));

    let field_idx = if field.len() > 0 and is_digit(field.byte_at(0)) { parse_int_simple(field, 0, 0) } else { lookup_field_by_name(struct_reg, field) };

    let field_is_dbl = is_field_f64(struct_reg, field);

    let field_is_str = is_field_string(struct_reg, field);

    // M5-5d: Array<String> field — mark dest as str-ptr array so subsequent

    // index/load propagates @println_str dispatch (mirrors M5-5c fn-return pattern)

    // Cycle 2682: Array<f64> field — mark dest as f64-ptr array for @println_f64 dispatch

    let field_is_str_arr = is_field_str_array(struct_reg, field);

    let field_is_f64_arr = is_field_f64_array(struct_reg, field);

    let load_type = if field_is_dbl == 1 { "double" } else { "i64" };

    let _dm = if field_is_dbl == 1 { push_double_marker(str_sb, dest) } else { 0 };

    let _sm = if field_is_str == 1 { push_string_marker(str_sb, dest) } else { 0 };

    let _am = if field_is_str_arr == 1 { push_str_ptr_marker(str_sb, dest) } else { 0 };

    let _af = if field_is_f64_arr == 1 { push_f64_ptr_marker(str_sb, dest) } else { 0 };

    let field_ptr = get_field_ptr_from_registry(struct_reg, field);

    let _pm = if field_ptr != "" { push_ptr_marker(ptr_sb, dest, field_ptr) } else { 0 };

    let ptr_name = dest + "_ptr";

    let conv = "  " + base + "_p = inttoptr i64 " + base + " to ptr";

    let gep_line = "  " + ptr_name + " = getelementptr inbounds nuw i64, ptr " + base + "_p, i32 " + i2s(field_idx);

    let load_line = "  " + dest + " = load " + load_type + ", ptr " + ptr_name;

    same_mapping(conv + SEP() + gep_line + SEP() + load_line);

fn lookup_field_by_name(registry: String, field_name: String) -> i64

  post it >= 0

= lookup_field_by_name_at(registry, 0, field_name);

fn lookup_field_by_name_at(registry: String, pos: i64, field_name: String) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= registry.len() { 0 } else {

        let semi_pos = find_char(registry, pos, 59);

        let entry = registry.slice(pos, semi_pos);

        let colon_pos = find_char(entry, 0, 58);

        let fields = entry.slice(colon_pos + 1, entry.len());

        let idx = find_field_index_or_neg(fields, 0, 0, field_name);

        if idx >= 0 { idx }

        else if semi_pos + 1 >= registry.len() { 0 }

        else { lookup_field_by_name_at(registry, semi_pos + 1, field_name) }

    };

fn find_field_index_or_neg(fields: String, pos: i64, idx: i64, target: String) -> i64

    post it >= -1

= 

    if pos >= fields.len() { 0 - 1 } else {

        let comma_pos = find_comma_or_end(fields, pos);

        let raw_name = fields.slice(pos, comma_pos);

        // Strip ~d suffix for comparison

        let name = strip_type_suffix(raw_name);

        if name == target { idx }

        else if comma_pos >= fields.len() { 0 - 1 }

        else { find_field_index_or_neg(fields, comma_pos + 1, idx + 1, target) }

    };

// Strip ~d type suffix from field name

fn strip_type_suffix(name: String) -> String

  post it.len() <= name.len()

= let tilde_pos = find_char(name, 0, 126);

    if tilde_pos < name.len() { name.slice(0, tilde_pos) } else { name };

// Check if a field is f64 by looking up in registry

fn is_field_f64(registry: String, field_name: String) -> i64

  post it >= 0

= is_field_f64_at(registry, 0, field_name);

fn is_field_f64_at(registry: String, pos: i64, field_name: String) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= registry.len() { 0 } else {

        let semi_pos = find_char(registry, pos, 59);

        let entry = registry.slice(pos, semi_pos);

        let colon_pos = find_char(entry, 0, 58);

        let fields = entry.slice(colon_pos + 1, entry.len());

        let result = check_field_is_f64(fields, 0, field_name);

        if result >= 0 { result }

        else if semi_pos + 1 >= registry.len() { 0 }

        else { is_field_f64_at(registry, semi_pos + 1, field_name) }

    };

// Search fields for name and check if it has ~d suffix. Returns 1 if f64, 0 if found not f64, -1 if not found

fn check_field_is_f64(fields: String, pos: i64, target: String) -> i64

  pre pos >= 0

  post it >= -1

= if pos >= fields.len() { 0 - 1 } else {

        let comma_pos = find_comma_or_end(fields, pos);

        let raw_name = fields.slice(pos, comma_pos);

        let name = strip_type_suffix(raw_name);

        if name == target {

            let suffix = if raw_name.len() > name.len() { raw_name.slice(name.len(), raw_name.len()) } else { "" };

            if suffix == "~d" { 1 } else { 0 }

        }

        else if comma_pos >= fields.len() { 0 - 1 }

        else { check_field_is_f64(fields, comma_pos + 1, target) }

    };

fn is_field_string(registry: String, field_name: String) -> i64

  post it >= 0

= is_field_string_at(registry, 0, field_name);

fn is_field_string_at(registry: String, pos: i64, field_name: String) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= registry.len() { 0 } else {

        let semi_pos = find_char(registry, pos, 59);

        let entry = registry.slice(pos, semi_pos);

        let colon_pos = find_char(entry, 0, 58);

        let fields = entry.slice(colon_pos + 1, entry.len());

        let result = check_field_is_string(fields, 0, field_name);

        if result >= 0 { result }

        else if semi_pos + 1 >= registry.len() { 0 }

        else { is_field_string_at(registry, semi_pos + 1, field_name) }

    };

fn check_field_is_string(fields: String, pos: i64, target: String) -> i64

  pre pos >= 0

  post it >= -1

= if pos >= fields.len() { 0 - 1 } else {

        let comma_pos = find_comma_or_end(fields, pos);

        let raw_name = fields.slice(pos, comma_pos);

        let name = strip_type_suffix(raw_name);

        if name == target {

            let suffix = if raw_name.len() > name.len() { raw_name.slice(name.len(), raw_name.len()) } else { "" };

            if suffix == "~s" { 1 } else { 0 }

        }

        else if comma_pos >= fields.len() { 0 - 1 }

        else { check_field_is_string(fields, comma_pos + 1, target) }

    };

// M5-5d: check if a field holds an Array<String> (carries str-ptr markers)

fn is_field_str_array(registry: String, field_name: String) -> i64

  post it >= 0

= is_field_str_array_at(registry, 0, field_name);

fn is_field_str_array_at(registry: String, pos: i64, field_name: String) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= registry.len() { 0 } else {

        let semi_pos = find_char(registry, pos, 59);

        let entry = registry.slice(pos, semi_pos);

        let colon_pos = find_char(entry, 0, 58);

        let fields = entry.slice(colon_pos + 1, entry.len());

        let result = check_field_is_str_array(fields, 0, field_name);

        if result >= 0 { result }

        else if semi_pos + 1 >= registry.len() { 0 }

        else { is_field_str_array_at(registry, semi_pos + 1, field_name) }

    };

fn check_field_is_str_array(fields: String, pos: i64, target: String) -> i64

  pre pos >= 0

  post it >= -1

= if pos >= fields.len() { 0 - 1 } else {

        let comma_pos = find_comma_or_end(fields, pos);

        let raw_name = fields.slice(pos, comma_pos);

        let name = strip_type_suffix(raw_name);

        if name == target {

            let suffix = if raw_name.len() > name.len() { raw_name.slice(name.len(), raw_name.len()) } else { "" };

            if suffix == "~a" { 1 } else { 0 }

        }

        else if comma_pos >= fields.len() { 0 - 1 }

        else { check_field_is_str_array(fields, comma_pos + 1, target) }

    };

// Cycle 2682: check if a field holds an Array<f64> (carries f64-ptr markers)

fn is_field_f64_array(registry: String, field_name: String) -> i64

  post it >= 0

= is_field_f64_array_at(registry, 0, field_name);

fn is_field_f64_array_at(registry: String, pos: i64, field_name: String) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= registry.len() { 0 } else {

        let semi_pos = find_char(registry, pos, 59);

        let entry = registry.slice(pos, semi_pos);

        let colon_pos = find_char(entry, 0, 58);

        let fields = entry.slice(colon_pos + 1, entry.len());

        let result = check_field_is_f64_array(fields, 0, field_name);

        if result >= 0 { result }

        else if semi_pos + 1 >= registry.len() { 0 }

        else { is_field_f64_array_at(registry, semi_pos + 1, field_name) }

    };

fn check_field_is_f64_array(fields: String, pos: i64, target: String) -> i64

  pre pos >= 0

  post it >= -1

= if pos >= fields.len() { 0 - 1 } else {

        let comma_pos = find_comma_or_end(fields, pos);

        let raw_name = fields.slice(pos, comma_pos);

        let name = strip_type_suffix(raw_name);

        if name == target {

            let suffix = if raw_name.len() > name.len() { raw_name.slice(name.len(), raw_name.len()) } else { "" };

            if suffix == "~af" { 1 } else { 0 }

        }

        else if comma_pos >= fields.len() { 0 - 1 }

        else { check_field_is_f64_array(fields, comma_pos + 1, target) }

    };

fn get_field_ptr_from_registry(registry: String, field_name: String) -> String

  post it.len() <= registry.len()

= get_field_ptr_from_registry_at(registry, 0, field_name);

fn get_field_ptr_from_registry_at(registry: String, pos: i64, field_name: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= registry.len() { "" } else {

        let semi_pos = find_char(registry, pos, 59);

        let entry = registry.slice(pos, semi_pos);

        let colon_pos = find_char(entry, 0, 58);

        let fields = entry.slice(colon_pos + 1, entry.len());

        let result = check_field_ptr_type(fields, 0, field_name);

        if result != "" { result }

        else if semi_pos + 1 >= registry.len() { "" }

        else { get_field_ptr_from_registry_at(registry, semi_pos + 1, field_name) }

    };

// Search fields for name and extract ~p-StructName. Returns struct name or ""

fn check_field_ptr_type(fields: String, pos: i64, target: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= fields.len() { "" } else {

        let comma_pos = find_comma_or_end(fields, pos);

        let raw_name = fields.slice(pos, comma_pos);

        let name = strip_type_suffix(raw_name);

        if name == target {

            let suffix = if raw_name.len() > name.len() { raw_name.slice(name.len(), raw_name.len()) } else { "" };

            // Check for ~p- prefix (at least 4 chars: ~p-X)

            if suffix.len() >= 4 and suffix.byte_at(0) == 126 and suffix.byte_at(1) == 112 and suffix.byte_at(2) == 45 {

                suffix.slice(3, suffix.len())

            } else { "" }

        }

        else if comma_pos >= fields.len() { "" }

        else { check_field_ptr_type(fields, comma_pos + 1, target) }

    };

// MIR: field-store %base.fieldname, %value

// LLVM: %_fst_N_p = inttoptr i64 %base to ptr

//       %_fst_N_ptr = getelementptr i64, ptr %_fst_N_p, i32 field_index

//       store i64 %value, ptr %_fst_N_ptr

fn llvm_gen_field_store(line: String, pos: i64, struct_reg: String, str_sb: i64) -> String

  pre pos >= 0

  post it.len() >= 1

= let p1 = low_skip_ws(line, pos);

    // Find dot separator in %base.field

    let dot_pos = find_char(line, p1, 46);

    let base = trim_end(line.slice(p1, dot_pos));

    // Find comma separator between base.field and value

    let comma_pos = find_comma(line, dot_pos);

    let field = trim_end(line.slice(dot_pos + 1, comma_pos));

    let p2 = low_skip_ws(line, comma_pos + 1);

    let value = trim_end(line.slice(p2, line.len()));

    // Look up field index (numeric field names like "0", "1" for enum payload)

    let field_idx = if field.len() > 0 and is_digit(field.byte_at(0)) { parse_int_simple(field, 0, 0) } else { lookup_field_by_name(struct_reg, field) };

    let prefix = base + "_fs" + i2s(field_idx);

    let conv = "  " + prefix + "_p = inttoptr i64 " + base + " to ptr";

    let gep_line = "  " + prefix + "_ptr = getelementptr inbounds nuw i64, ptr " + prefix + "_p, i32 " + i2s(field_idx);

    let is_dbl_val = is_double_var_sb(value, str_sb);

    let is_dbl_field = is_field_f64(struct_reg, field);

    let is_dbl = if is_dbl_val { 1 } else { is_dbl_field };

    let store_type = if is_dbl == 1 { "double" } else { "i64" };

    let store_line = "  store " + store_type + " " + value + ", ptr " + prefix + "_ptr";

    same_mapping(conv + SEP() + gep_line + SEP() + store_line);

// Add a string marker to the mapping: "S:varname" (prepend for O(1) recent lookup)

fn push_string_marker(str_sb: i64, varname: String) -> i64

  post it >= 0

= let _w1 = sb_push(str_sb, "S:");

    let _w2 = sb_push(str_sb, varname);

    sb_push(str_sb, ",");

fn is_string_var_sb(varname: String, str_sb: i64) -> bool

  post it == (bmb_sb_contains(str_sb, "S:" + varname) > 0)

= let marker = "S:" + varname;

    bmb_sb_contains(str_sb, marker) > 0;

fn push_double_marker(str_sb: i64, varname: String) -> i64

  post it >= 0

= let _w1 = sb_push(str_sb, "D:");

    let _w2 = sb_push(str_sb, varname);

    sb_push(str_sb, ",");

fn is_double_var_sb(varname: String, str_sb: i64) -> bool

  post it == (bmb_sb_contains(str_sb, "D:" + varname) > 0)

= let marker = "D:" + varname;

    bmb_sb_contains(str_sb, marker) > 0;

fn is_f64_ptr_sb(varname: String, str_sb: i64) -> bool

  post it == (bmb_sb_contains(str_sb, "F:" + varname) > 0)

= let marker = "F:" + varname;

    bmb_sb_contains(str_sb, marker) > 0;

fn push_f64_ptr_marker(str_sb: i64, varname: String) -> i64

  post it >= 0

= let _w1 = sb_push(str_sb, "F:");

    let _w2 = sb_push(str_sb, varname);

    sb_push(str_sb, ",");

// v0.95: Check if variable is an i64 function parameter (for indirect call detection)

fn is_i64_param_sb(varname: String, str_sb: i64) -> bool

  post it == (bmb_sb_contains(str_sb, "P:" + varname) > 0)

= let marker = "P:" + varname;

    bmb_sb_contains(str_sb, marker) > 0;

// Cycle 2934: Check if variable is a HOF (fn(T)->R) parameter

fn is_hof_param_sb(varname: String, str_sb: i64) -> bool

  post it == (bmb_sb_contains(str_sb, "H:" + varname) > 0)

= let marker = "H:" + varname;

    bmb_sb_contains(str_sb, marker) > 0;

// v0.95: Check if variable is marked as i32 in SB

fn is_i32_var_sb(varname: String, str_sb: i64) -> bool

  post it == (bmb_sb_contains(str_sb, "W:" + varname) > 0)

= let marker = "W:" + varname;

    bmb_sb_contains(str_sb, marker) > 0;

// v0.95: Mark variable as i32 in SB

fn push_i32_marker(str_sb: i64, varname: String) -> i64

  post it >= 0

= let _w1 = sb_push(str_sb, "W:");

    let _w2 = sb_push(str_sb, varname);

    sb_push(str_sb, ",");

fn is_str_ptr_sb(varname: String, str_sb: i64) -> bool

  post it == (bmb_sb_contains(str_sb, "R:" + varname) > 0)

= let marker = "R:" + varname;

    bmb_sb_contains(str_sb, marker) > 0;

fn push_str_ptr_marker(str_sb: i64, varname: String) -> i64

  post it >= 0

= let _w1 = sb_push(str_sb, "R:");

    let _w2 = sb_push(str_sb, varname);

    sb_push(str_sb, ",");

// v0.95: Closure variable markers — CN:%varname, where N is capture count

fn is_closure_var_sb(varname: String, str_sb: i64) -> bool

  post it == check_closure_marker(varname, str_sb, 9)

= check_closure_marker(varname, str_sb, 9);

fn check_closure_marker(varname: String, str_sb: i64, n: i64) -> bool

  pre n >= 0

  post not it or n > 0

= if n <= 0 { false }

    else {

        let marker = "C" + int_to_string(n) + ":" + varname + ",";

        if bmb_sb_contains(str_sb, marker) > 0 { true }

        else { check_closure_marker(varname, str_sb, n - 1) }

    };

fn get_closure_cap_count_sb(varname: String, str_sb: i64) -> i64

  post it >= 0

= find_closure_count(varname, str_sb, 9);

fn find_closure_count(varname: String, str_sb: i64, n: i64) -> i64

    pre n >= 0

    post it >= 0

= if n <= 0 { 0 }

    else {

        let marker = "C" + int_to_string(n) + ":" + varname + ",";

        if bmb_sb_contains(str_sb, marker) > 0 { n }

        else { find_closure_count(varname, str_sb, n - 1) }

    };

fn push_closure_marker(str_sb: i64, name: String, count: i64) -> i64

  pre count >= 0

  post it >= 0

= let _w1 = sb_push(str_sb, "C");

    let _w2 = sb_push(str_sb, int_to_string(count));

    let _w3 = sb_push(str_sb, ":");

    let _w4 = sb_push(str_sb, name);

    sb_push(str_sb, ",");

// "mark_f64_ptr" = 12 chars, then space, then %varname starts at p+13

fn llvm_handle_mark_f64_ptr(line: String, p: i64, str_sb: i64) -> String

  pre p >= 0

  post it.len() >= 0

= let varname = trim_end(line.slice(p + 13, line.len()));

    let _w = push_f64_ptr_marker(str_sb, varname);

    same_mapping("");

// "mark_str_ptr" = 12 chars, then space, then %varname starts at p+13

fn llvm_handle_mark_str_ptr(line: String, p: i64, str_sb: i64) -> String

  pre p >= 0

  post it.len() >= 0

= let varname = trim_end(line.slice(p + 13, line.len()));

    let _w = push_str_ptr_marker(str_sb, varname);

    same_mapping("");

// M5-5b: mark_str_ptr_if %dest, %src — conditional marking based on src var type

// "mark_str_ptr_if" = 15 chars, then space, args start at p+16

fn llvm_handle_mark_str_ptr_if(line: String, p: i64, str_sb: i64) -> String

  pre p >= 0

  post it.len() >= 0

= let rest = line.slice(p + 16, line.len());

    let comma = find_comma(rest, 0);

    let dest = trim_end(rest.slice(0, comma));

    let src_start = low_skip_ws(rest, comma + 1);

    let src_clean = trim_end(rest.slice(src_start, rest.len()));

    let src_is_str = is_string_var_sb(src_clean, str_sb);

    let _w = if src_is_str { push_str_ptr_marker(str_sb, dest) } else { 0 };

    same_mapping("");

fn llvm_gen_cmp_with_strings_sb(pred: String, line: String, pos: i64, dest: String, str_sb: i64) -> String

  pre pos >= 0

  post it.len() >= 1

= let p1 = low_skip_ws(line, pos);

    let comma = find_comma(line, p1);

    let left = line.slice(p1, comma);

    llvm_gen_cmp_with_strings_sb_2(pred, line, pos, dest, str_sb, left, comma);

fn llvm_gen_cmp_with_strings_sb_2(pred: String, line: String, pos: i64, dest: String, str_sb: i64, left: String, comma: i64) -> String

  pre pos >= 0

  post it.len() >= 1

= let p2 = low_skip_ws(line, comma + 1);

    let right = line.slice(p2, line.len());

    let left_trimmed = trim_end(left);

    let right_trimmed = trim_end(right);

    llvm_gen_cmp_with_strings_sb_3(pred, line, pos, dest, str_sb, left_trimmed, right_trimmed);

fn llvm_gen_cmp_with_strings_sb_3(pred: String, line: String, pos: i64, dest: String, str_sb: i64, left_trimmed: String, right_trimmed: String) -> String

  pre pos >= 0

  post it.len() >= 1

= let left_is_string = is_string_var_sb(left_trimmed, str_sb);

    let right_is_string = is_string_var_sb(right_trimmed, str_sb);

    if left_is_string or right_is_string {

        // Reuse existing string cmp (mapping param unused for string cmp result - it returns same_mapping)

        llvm_gen_string_cmp(pred, left_trimmed, right_trimmed, dest, "")

    } else {

        let left_is_double = is_double_var_sb(left_trimmed, str_sb);

        let right_is_double = is_double_var_sb(right_trimmed, str_sb);

        if left_is_double or right_is_double {

            let float_pred = if pred == "eq" { "oeq" } else { "one" };

            same_mapping("  " + dest + "_cmp = fcmp " + float_pred + " double " + left_trimmed + ", " + right_trimmed + SEP() + "  " + dest + " = zext i1 " + dest + "_cmp to i64")

        } else {

            same_mapping(llvm_gen_cmp(pred, line, pos, dest))

        }

    };

fn llvm_gen_add_with_strings_sb(line: String, pos: i64, dest: String, mapping: String, str_sb: i64) -> String

  pre pos >= 0

  post it.len() >= 1

= let p1 = low_skip_ws(line, pos);

    let comma = find_comma(line, p1);

    let left = line.slice(p1, comma);

    llvm_gen_add_with_strings_sb_2(line, pos, dest, mapping, str_sb, p1, comma, left);

fn llvm_gen_add_with_strings_sb_2(line: String, pos: i64, dest: String, mapping: String, str_sb: i64, _p1: i64, comma: i64, left: String) -> String

  pre pos >= 0

  post it.len() >= 1

= let p2 = low_skip_ws(line, comma + 1);

    let right = line.slice(p2, line.len());

    let left_trimmed = trim_end(left);

    let right_trimmed = trim_end(right);

    llvm_gen_add_with_strings_sb_3(dest, mapping, str_sb, left_trimmed, right_trimmed);

fn llvm_gen_add_with_strings_sb_3(dest: String, _mapping: String, str_sb: i64, left_trimmed: String, right_trimmed: String) -> String

  post it.len() >= 0

= let left_is_string = is_string_var_sb(left_trimmed, str_sb);

    let right_is_string = is_string_var_sb(right_trimmed, str_sb);

    if left_is_string or right_is_string {

        llvm_gen_add_string_concat_sb(dest, str_sb, left_trimmed, right_trimmed)

    } else {

        let left_is_double = is_double_var_sb(left_trimmed, str_sb);

        let right_is_double = is_double_var_sb(right_trimmed, str_sb);

        if left_is_double or right_is_double {

            let _w = push_double_marker(str_sb, dest);

            same_mapping("  " + dest + " = fadd double " + left_trimmed + ", " + right_trimmed)

        } else {

            same_mapping("  " + dest + " = add nsw i64 " + left_trimmed + ", " + right_trimmed)

        }

    };

fn llvm_gen_add_string_concat_sb(dest: String, str_sb: i64, left_trimmed: String, right_trimmed: String) -> String

  post it.len() >= 0

= let lptr = dest + "_l";

    let rptr = dest + "_r";

    let cptr = dest + "_c";

    llvm_gen_add_string_concat_sb_2(dest, str_sb, left_trimmed, right_trimmed, lptr, rptr, cptr);

fn llvm_gen_add_string_concat_sb_2(dest: String, str_sb: i64, left_trimmed: String, right_trimmed: String, lptr: String, rptr: String, cptr: String) -> String

  post it.len() >= 0

= let line1 = "  " + lptr + " = inttoptr i64 " + left_trimmed + " to ptr";

    let line2 = "  " + rptr + " = inttoptr i64 " + right_trimmed + " to ptr";

    let line3 = "  " + cptr + " = call ptr @bmb_string_concat(ptr " + lptr + ", ptr " + rptr + ")";

    let line4 = "  " + dest + " = ptrtoint ptr " + cptr + " to i64";

    let _w = push_string_marker(str_sb, dest);

    same_mapping(line1 + SEP() + line2 + SEP() + line3 + SEP() + line4);

// Checks if operands are double-marked; if so, emits float op instead

fn llvm_gen_binop_sb(int_op: String, float_op: String, line: String, pos: i64, dest: String, str_sb: i64) -> String

  pre pos >= 0

  post it.len() >= 1

= let p1 = low_skip_ws(line, pos);

    let comma = find_comma(line, p1);

    let left = trim_end(line.slice(p1, comma));

    let p2 = low_skip_ws(line, comma + 1);

    let right = trim_end(line.slice(p2, line.len()));

    let left_is_double = is_double_var_sb(left, str_sb);

    let right_is_double = is_double_var_sb(right, str_sb);

    if left_is_double or right_is_double {

        let _w = push_double_marker(str_sb, dest);

        same_mapping("  " + dest + " = " + float_op + " double " + left + ", " + right)

    } else {

        let op_with_nsw = match int_op { "add" => "add nsw", "sub" => "sub nsw", "mul" => "mul nsw", _ => int_op };

        same_mapping("  " + dest + " = " + op_with_nsw + " i64 " + left + ", " + right)

    };

// Checks if operands are double-marked; if so, emits fcmp instead of icmp

fn llvm_gen_cmp_sb(int_pred: String, float_pred: String, line: String, pos: i64, dest: String, str_sb: i64) -> String

  pre pos >= 0

  post it.len() >= 1

= let p1 = low_skip_ws(line, pos);

    let comma = find_comma(line, p1);

    let left = trim_end(line.slice(p1, comma));

    let p2 = low_skip_ws(line, comma + 1);

    let right = trim_end(line.slice(p2, line.len()));

    let left_is_double = is_double_var_sb(left, str_sb);

    let right_is_double = is_double_var_sb(right, str_sb);

    if left_is_double or right_is_double {

        same_mapping("  " + dest + "_cmp = fcmp " + float_pred + " double " + left + ", " + right + SEP() + "  " + dest + " = zext i1 " + dest + "_cmp to i64")

    } else {

        same_mapping("  " + dest + "_cmp = icmp " + int_pred + " i64 " + left + ", " + right + SEP() + "  " + dest + " = zext i1 " + dest + "_cmp to i64")

    };

fn llvm_gen_neg_sb(line: String, pos: i64, dest: String, str_sb: i64) -> String

  pre pos >= 0

  post it.len() >= 1

= let p = low_skip_ws(line, pos);

    let operand = trim_end(line.slice(p, line.len()));

    let is_double = is_double_var_sb(operand, str_sb);

    if is_double {

        let _w = push_double_marker(str_sb, dest);

        same_mapping("  " + dest + " = fneg double " + operand)

    } else {

        same_mapping("  " + dest + " = sub nsw i64 0, " + operand)

    };

fn llvm_gen_phi_with_strings_sb(line: String, pos: i64, dest: String, str_sb: i64) -> String

  pre pos >= 0

  post it.len() >= 1

= let bracket_start = find_char(line, pos, 91);

    let first_end = find_char(line, bracket_start, 93);

    let first_content = line.slice(bracket_start + 1, first_end);

    let first_val = extract_phi_val(first_content);

    let second_start = find_char(line, first_end, 91);

    let second_end = find_char(line, second_start, 93);

    let second_content = line.slice(second_start + 1, second_end);

    let second_val = extract_phi_val(second_content);

    let first_is_string = is_string_var_sb(first_val, str_sb);

    let second_is_string = is_string_var_sb(second_val, str_sb);

    let first_is_double = is_double_var_sb(first_val, str_sb);

    let second_is_double = is_double_var_sb(second_val, str_sb);

    let _w = if first_is_string or second_is_string { push_string_marker(str_sb, dest) }

            else if first_is_double or second_is_double { push_double_marker(str_sb, dest) }

            else { 0 };

    if first_is_double or second_is_double {

        same_mapping(llvm_gen_phi_typed(line, pos, dest, "f64"))

    } else {

        same_mapping(llvm_gen_phi(line, pos, dest))

    };

fn llvm_gen_call_with_string_tracking_sb_reg(line: String, pos: i64, dest: String, str_sb: i64, string_fns: String, registry: String) -> String

  pre pos >= 0

  post it.len() >= 1

= let fn_name = extract_call_fn_name(line, pos);

    let dispatch = llvm_try_println_str_dispatch(line, pos, dest, fn_name, str_sb);

    if dispatch != "" { same_mapping(dispatch) }

    else {

    let llvm_code = llvm_gen_call_reg(line, pos, dest, registry);

    let is_hardcoded_string_fn = is_string_returning_fn(fn_name);

    let is_dynamic_string_fn_result = is_dynamic_string_fn(fn_name, string_fns);

    let is_string_fn = is_hardcoded_string_fn or is_dynamic_string_fn_result;

    // M5-5c: function returns Array<String> -> dest carries str-ptr array

    // Cycle 2682: function returns Array<f64> -> dest carries f64-ptr array

    let is_str_array_fn = is_dynamic_string_array_fn(fn_name, string_fns);

    let is_f64_array_fn = is_dynamic_f64_array_fn(fn_name, string_fns);

    let ret_type = lookup_fn_ret(registry, fn_name);

    let is_double_fn = ret_type == "double" or is_builtin_double_fn(fn_name);

    let is_i32_fn = ret_type == "i32";

    let _w = if is_string_fn { push_string_marker(str_sb, dest) }

            else if is_str_array_fn { push_str_ptr_marker(str_sb, dest) }

            else if is_f64_array_fn { push_f64_ptr_marker(str_sb, dest) }

            else if is_double_fn { push_double_marker(str_sb, dest) }

            else if is_i32_fn { push_i32_marker(str_sb, dest) }

            else { 0 };

    same_mapping(llvm_code)

    };

fn llvm_try_println_str_dispatch(line: String, pos: i64, dest: String, fn_name: String, str_sb: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= if fn_name == "println" or fn_name == "print" or fn_name == "eprintln" or fn_name == "eprint" {

        let after_call = low_skip_ws(line, pos + 4);

        let at_pos = if line.byte_at(after_call) == 64 { after_call + 1 } else { after_call };

        let paren_pos = find_char(line, at_pos, 40);

        let close_pos = find_char(line, paren_pos, 41);

        let arg = trim(line.slice(paren_pos + 1, close_pos));

        if is_string_var_sb(arg, str_sb) {

            let str_fn = if fn_name == "println" { "@println_str" }

                         else { match fn_name { "print" => "@print_str", "eprintln" => "@eprintln_str", _ => "@eprint_str" } };

            let ptr_tmp = dest + "_sp";

            "  " + ptr_tmp + " = inttoptr i64 " + arg + " to ptr" + SEP() + "  call void " + str_fn + "(ptr " + ptr_tmp + ")" + SEP() + "  " + dest + " = add nsw i64 0, 0"

        } else if is_double_var_sb(arg, str_sb) {

            let f64_fn = match fn_name { "println" => "@println_f64", "print" => "@print_f64", "eprintln" => "@eprintln_f64", _ => "@eprint_f64" };

            "  call void " + f64_fn + "(double " + arg + ")" + SEP() + "  " + dest + " = add nsw i64 0, 0"

        } else { "" }

    } else { "" };

fn is_builtin_double_fn(name: String) -> bool

  post it == (name == "sqrt" or name == "i64_to_f64" or name == "sin" or name == "cos" or name == "tan" or name == "atan" or name == "atan2" or name == "log" or name == "log2" or name == "log10" or name == "exp" or name == "fmod" or name == "pow_f64" or name == "bmb_f64_floor" or name == "bmb_f64_ceil" or name == "bmb_f64_round" or name == "bmb_f64_sqrt" or name == "bmb_f64_abs" or name == "bmb_f64_min" or name == "bmb_f64_max" or name == "f64_min" or name == "f64_max" or name == "parse_f64" or name == "fabs" or name == "floor" or name == "ceil" or name == "round")

= name == "sqrt" or name == "i64_to_f64" or name == "sin" or name == "cos" or name == "tan" or name == "atan" or name == "atan2" or name == "log" or name == "log2" or name == "log10" or name == "exp" or name == "fmod" or name == "pow_f64" or

    // v0.96: Float ops — MIR names kept for type tracking (codegen maps to LLVM intrinsics)

    name == "bmb_f64_floor" or name == "bmb_f64_ceil" or name == "bmb_f64_round" or

    name == "bmb_f64_sqrt" or name == "bmb_f64_abs" or

    name == "bmb_f64_min" or name == "bmb_f64_max" or name == "f64_min" or name == "f64_max" or name == "parse_f64" or

    name == "fabs" or name == "floor" or name == "ceil" or name == "round";

// Check if a variable is marked as a string in the mapping

fn llvm_gen_string_cmp(pred: String, left: String, right: String, dest: String, mapping: String) -> String

  post it.len() >= 0

= let lptr = dest + "_lp";

    let rptr = dest + "_rp";

    let eq_dest = dest + "_streq";

    let conv_l = "  " + lptr + " = inttoptr i64 " + left + " to ptr";

    llvm_gen_string_cmp_2(pred, right, dest, mapping, lptr, rptr, eq_dest, conv_l);

fn llvm_gen_string_cmp_2(pred: String, right: String, dest: String, mapping: String, lptr: String, rptr: String, eq_dest: String, conv_l: String) -> String

  post it.len() >= 0

= let conv_r = "  " + rptr + " = inttoptr i64 " + right + " to ptr";

    let call_ln = "  " + eq_dest + " = call i64 @bmb_string_eq(ptr " + lptr + ", ptr " + rptr + ")";

    let cmp_ln = "  " + dest + "_cmp = icmp ne i64 " + eq_dest + ", 0";

    llvm_gen_string_cmp_3(pred, dest, mapping, conv_l, conv_r, call_ln, cmp_ln);

fn llvm_gen_string_cmp_3(pred: String, dest: String, _mapping: String, conv_l: String, conv_r: String, call_ln: String, cmp_ln: String) -> String

  post it.len() >= 0

= let res_ln = "  " + dest + " = zext i1 " + dest + "_cmp to i64";

    if pred == "ne" {

        let inv_cmp = "  " + dest + "_cmp = icmp eq i64 " + dest + "_streq, 0";

        same_mapping(conv_l + SEP() + conv_r + SEP() + call_ln + SEP() + inv_cmp + SEP() + res_ln)

    } else {

        same_mapping(conv_l + SEP() + conv_r + SEP() + call_ln + SEP() + cmp_ln + SEP() + res_ln)

    };

// Track string-returning function calls

// invariant: returns true iff name is a known stdlib/bootstrap fn that returns a heap-allocated String (ptr).

// Used for str_sb tracking (push_string_marker). Must stay in sync with get_call_return_type "ptr" branch.

fn is_string_returning_fn(name: String) -> bool

  pre name.len() > 0

  post it or not it

=

    is_string_fn_group1(name) or is_string_fn_group2(name) or is_string_fn_group3(name) or

    is_string_fn_group4(name) or is_string_fn_group5(name) or is_string_fn_group6(name);

fn is_string_fn_group1(name: String) -> bool

  post it == (name == "get_node_type" or name == "get_child" or name == "extract_name" or name == "bmb_string_slice" or name == "bmb_string_concat" or name == "bmb_string_from_cstr" or name == "bmb_chr" or name == "bmb_read_file" or name == "bmb_getenv" or name == "get_arg" or name == "int_to_string" or name == "chr" or name == "slice" or name == "bmb_string_concat3" or name == "bmb_string_concat5" or name == "bmb_string_concat7")

= name == "get_node_type" or name == "get_child" or name == "extract_name" or

    name == "bmb_string_slice" or name == "bmb_string_concat" or

    name == "bmb_string_from_cstr" or name == "bmb_chr" or name == "bmb_read_file" or

    name == "bmb_getenv" or name == "get_arg" or name == "int_to_string" or

    name == "chr" or name == "slice" or

    name == "bmb_string_concat3" or name == "bmb_string_concat5" or name == "bmb_string_concat7";

fn is_string_fn_group2(name: String) -> bool

  post it == (name == "sb_build" or name == "digit_char" or name == "escape_parens" or name == "unescape_parens_from_ast" or name == "extract_string_content" or name == "get_fn_return_type" or name == "collect_params" or name == "get_fn_body" or name == "lower_function_sb" or name == "lower_program_sb")

= name == "sb_build" or name == "digit_char" or name == "escape_parens" or

    name == "unescape_parens_from_ast" or name == "extract_string_content" or

    name == "get_fn_return_type" or name == "collect_params" or name == "get_fn_body" or

    name == "lower_function_sb" or name == "lower_program_sb";

fn is_string_fn_group3(name: String) -> bool

  post it == (name == "parse_source" or name == "gen_function" or name == "gen_program" or name == "read_file" or name == "gen_module_header" or name == "gen_runtime_decls" or name == "gen_string_globals" or name == "collect_strings_from_mir" or name == "compile_program")

= name == "parse_source" or name == "gen_function" or name == "gen_program" or

    name == "read_file" or

    name == "gen_module_header" or name == "gen_runtime_decls" or

    name == "gen_string_globals" or

    name == "collect_strings_from_mir" or name == "compile_program";

fn is_string_fn_group4(name: String) -> bool

  post it == (name == "gen_extern_println" or name == "gen_extern_print_str" or name == "llvm_gen_binop" or name == "llvm_gen_cmp" or name == "llvm_gen_call" or name == "llvm_gen_not" or name == "llvm_gen_neg" or name == "llvm_gen_phi" or name == "llvm_gen_branch" or name == "llvm_gen_goto" or name == "llvm_gen_return_typed" or name == "llvm_gen_string_ref" or name == "llvm_gen_line_with_ret")

= name == "gen_extern_println" or name == "gen_extern_print_str" or

    name == "llvm_gen_binop" or name == "llvm_gen_cmp" or name == "llvm_gen_call" or

    name == "llvm_gen_not" or name == "llvm_gen_neg" or name == "llvm_gen_phi" or

    name == "llvm_gen_branch" or name == "llvm_gen_goto" or name == "llvm_gen_return_typed" or

    name == "llvm_gen_string_ref" or name == "llvm_gen_line_with_ret";

fn is_string_fn_group5(name: String) -> bool

  post it == (name == "llvm_gen_assign_typed" or name == "llvm_gen_rhs_typed" or name == "gen_function_lines_typed" or name == "gen_function_sb_typed" or name == "llvm_gen_fn_line_typed" or name == "llvm_gen_fn_header" or name == "gen_all_externs" or name == "pack_result" or name == "unpack_ast" or name == "make_step" or name == "make_work" or name == "make_work3" or name == "make_work4" or name == "step_work" or name == "get_field" or name == "trim_end" or name == "i2s" or name == "sb_build" or name == "pack_lower_result" or name == "unescape_parens")

= name == "llvm_gen_assign_typed" or name == "llvm_gen_rhs_typed" or

    name == "gen_function_lines_typed" or name == "gen_function_sb_typed" or

    name == "llvm_gen_fn_line_typed" or name == "llvm_gen_fn_header" or

    name == "gen_all_externs" or name == "pack_result" or name == "unpack_ast" or

    name == "make_step" or name == "make_work" or name == "make_work3" or name == "make_work4" or

    name == "step_work" or name == "get_field" or name == "trim_end" or name == "i2s" or

    name == "sb_build" or name == "pack_lower_result" or name == "unescape_parens";

// v0.100.2: runtime String-returning builtins missing from str_sb tracking (Cycle 3073)

fn is_string_fn_group6(name: String) -> bool

  post it == (name == "bmb_string_reverse" or name == "bmb_string_substr" or name == "bmb_string_pad_left" or name == "bmb_string_pad_right" or name == "bmb_string_trim" or name == "bmb_string_replace" or name == "bmb_string_to_upper" or name == "bmb_string_to_lower" or name == "bmb_string_repeat" or name == "bmb_string_join" or name == "bmb_f64_to_string" or name == "bmb_int_to_string" or name == "bmb_to_hex" or name == "bmb_to_binary" or name == "bmb_to_octal" or name == "bmb_getcwd" or name == "bmb_exec_output" or name == "bmb_system_capture" or name == "bmb_read_line" or name == "bmb_exec_with_stdin" or name == "exec_with_stdin" or name == "bmb_svec_get" or name == "bmb_svec_join" or name == "bmb_string_split")

= name == "bmb_string_reverse" or name == "bmb_string_substr" or

    name == "bmb_string_pad_left" or name == "bmb_string_pad_right" or

    name == "bmb_string_trim" or name == "bmb_string_replace" or

    name == "bmb_string_to_upper" or name == "bmb_string_to_lower" or

    name == "bmb_string_repeat" or name == "bmb_string_join" or

    name == "bmb_f64_to_string" or name == "bmb_int_to_string" or

    name == "bmb_to_hex" or name == "bmb_to_binary" or name == "bmb_to_octal" or

    name == "bmb_getcwd" or name == "bmb_exec_output" or

    name == "bmb_system_capture" or name == "bmb_read_line" or

    name == "bmb_exec_with_stdin" or name == "exec_with_stdin" or

    name == "bmb_svec_get" or name == "bmb_svec_join" or

    name == "bmb_string_split";

// Extract function name from call instruction

fn extract_call_fn_name(line: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= let after_call = low_skip_ws(line, pos + 4);

    let at_pos = if line.byte_at(after_call) == 64 { after_call + 1 } else { after_call };

    let paren_pos = find_char(line, at_pos, 40);

    if paren_pos > at_pos { line.slice(at_pos, paren_pos) } else { "" };

// Check if a variable name is a user variable (not %_t)

// v0.92: Fixed to handle short names like %i (len=2) - they ARE user vars

fn is_user_variable(name: String) -> bool

  post it == (name.len() >= 2 and not name.starts_with("%_t"))

= if name.len() < 2 { false }

    else if name.len() == 2 { true }

    else {

        let after_pct = name.byte_at(1);

        // User vars don't start with _t after the %

        not (after_pct == 95 and name.byte_at(2) == 116)

    };

// Resolve a variable using the mapping

fn resolve_variable(varname: String, mapping: String) -> String

  post it.len() >= 0

= if is_user_variable(varname) { lookup_mapping(mapping, varname, varname) }

    else { varname };

// Look up a variable in the mapping, return default if not found

fn lookup_mapping(mapping: String, name: String, default_val: String) -> String

  post it.len() >= 0

= if mapping == "" { default_val }

    else { lookup_mapping_at(mapping, name, 0, default_val) };

fn lookup_mapping_at(mapping: String, name: String, pos: i64, default_val: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= mapping.len() { default_val }

    else {

        let comma = find_comma_or_end(mapping, pos);

        let colon = find_char(mapping, pos, 58);

        if colon - pos == name.len() and match_bytes(mapping, name, pos, 0) {

            mapping.slice(colon + 1, comma)

        } else if comma >= mapping.len() { default_val }

        else { lookup_mapping_at(mapping, name, comma + 1, default_val) }

    };

// Add a name:value pair to the mapping (prepend for O(1) recent lookup)

fn add_mapping(mapping: String, name: String, value: String) -> String

  post it.len() >= mapping.len()

= let entry = name + ":" + value;

    if mapping == "" { entry } else { entry + "," + mapping };

fn same_mapping(llvm_line: String) -> String

  post it == llvm_line

= llvm_line;

fn same_mapping_empty() -> String

  post it == ""

= "";

fn changed_mapping(new_mapping: String, llvm_line: String) -> String

  post it.len() >= new_mapping.len()

= "!" + int_to_string(new_mapping.len()) + ":" + new_mapping + llvm_line;

fn changed_mapping_empty(new_mapping: String) -> String

  post it.len() >= new_mapping.len()

= "!" + int_to_string(new_mapping.len()) + ":" + new_mapping;

fn extract_new_mapping(result: String) -> String

  post it.len() <= result.len()

= let colon_pos = find_char(result, 1, 58);

    let map_len = parse_len_at(result, 1, colon_pos);

    result.slice(colon_pos + 1, colon_pos + 1 + map_len);

fn extract_new_llvm_line(result: String) -> String

  post it.len() <= result.len()

= let colon_pos = find_char(result, 1, 58);

    let map_len = parse_len_at(result, 1, colon_pos);

    result.slice(colon_pos + 1 + map_len, result.len());

fn parse_len_at(s: String, start: i64, end_pos: i64) -> i64

  pre start >= 0 and end_pos >= 0

  post it >= 0

= parse_len_acc(s, start, end_pos, 0);

fn parse_len_acc(s: String, pos: i64, end_pos: i64, acc: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= end_pos { acc }

    else { parse_len_acc(s, pos + 1, end_pos, acc * 10 + s.byte_at(pos) - 48) };

// Extract single operand from "opcode %operand" format

// pos points to start of operand (after opcode + whitespace)

fn conc_extract_single_op(line: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= trim_end(line.slice(pos, line.len()));

// Extract two space-separated operands: "%op1 %op2"

fn conc_extract_two_ops_first(line: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= let sp = find_char(line, pos, 32);

    line.slice(pos, sp);

fn conc_extract_two_ops_second(line: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= let sp = find_char(line, pos, 32);

    let p2 = low_skip_ws(line, sp + 1);

    trim_end(line.slice(p2, line.len()));

// Extract three space-separated operands: "%op1 %op2 %op3"

fn conc_extract_three_first(line: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= let sp = find_char(line, pos, 32);

    line.slice(pos, sp);

fn conc_extract_three_second(line: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= let sp1 = find_char(line, pos, 32);

    let p2 = low_skip_ws(line, sp1 + 1);

    let sp2 = find_char(line, p2, 32);

    line.slice(p2, sp2);

fn conc_extract_three_third(line: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= let sp1 = find_char(line, pos, 32);

    let p2 = low_skip_ws(line, sp1 + 1);

    let sp2 = find_char(line, p2, 32);

    let p3 = low_skip_ws(line, sp2 + 1);

    trim_end(line.slice(p3, line.len()));

// Extract four space-separated operands

fn conc_gen_call_i64_1(dest: String, fn_name: String, op: String) -> String

  post it.len() == dest.len() + fn_name.len() + op.len() + 21

= "  " + dest + " = call i64 @" + fn_name + "(i64 " + op + ")";

// Generate i64 call with 2 args

fn conc_gen_call_i64_2(dest: String, fn_name: String, op1: String, op2: String) -> String

  post it.len() == dest.len() + fn_name.len() + op1.len() + op2.len() + 27

= "  " + dest + " = call i64 @" + fn_name + "(i64 " + op1 + ", i64 " + op2 + ")";

// Generate i64 call with 3 args

fn conc_gen_call_i64_3(dest: String, fn_name: String, op1: String, op2: String, op3: String) -> String

  post it.len() == dest.len() + fn_name.len() + op1.len() + op2.len() + op3.len() + 33

= "  " + dest + " = call i64 @" + fn_name + "(i64 " + op1 + ", i64 " + op2 + ", i64 " + op3 + ")";

// Generate void call with 1 arg

fn conc_gen_call_void_1(fn_name: String, op: String) -> String

  post it.len() == fn_name.len() + op.len() + 19

= "  call void @" + fn_name + "(i64 " + op + ")";

// Generate void call with 2 args

fn conc_gen_call_void_2(fn_name: String, op1: String, op2: String) -> String

  post it.len() == fn_name.len() + op1.len() + op2.len() + 25

= "  call void @" + fn_name + "(i64 " + op1 + ", i64 " + op2 + ")";

// Generate i64 call with 0 args

fn conc_gen_call_i64_0(dest: String, fn_name: String) -> String

  post it.len() == dest.len() + fn_name.len() + 17

= "  " + dest + " = call i64 @" + fn_name + "()";

// Input: line is full MIR line, pos points to start of RHS (after "= "), dest is "%varname"

fn llvm_gen_conc_rhs(line: String, pos: i64, dest: String) -> String

  pre pos >= 0

  post it.len() >= 1

= // Thread operations

    if low_starts_with_at(line, pos, "thread-spawn") {

        // Phase 1: synchronous. %dest = thread-spawn func(captures...)

        // The first capture is the pre-computed result

        let after = low_skip_ws(line, pos + 12);

        let paren = find_char(line, after, 40);

        let args_start = paren + 1;

        let args_end = find_char(line, args_start, 41);

        let args = line.slice(args_start, args_end);

        let first_arg = if args.len() > 0 {

            let c = find_comma_or_end(args, 0);

            trim_end(args.slice(0, c))

        } else { "0" };

        "  ; Phase 1: ThreadSpawn - body executed synchronously" + SEP() + "  " + dest + " = add i64 " + first_arg + ", 0"

    } else if low_starts_with_at(line, pos, "thread-join") {

        let op_start = low_skip_ws(line, pos + 11);

        let op = conc_extract_single_op(line, op_start);

        "  ; Phase 1: ThreadJoin - handle is the result" + SEP() + "  " + dest + " = add i64 " + op + ", 0"

    }

    // Mutex operations

    else if low_starts_with_at(line, pos, "mutex-new") {

        let op_start = low_skip_ws(line, pos + 9);

        let op = conc_extract_single_op(line, op_start);

        same_mapping(conc_gen_call_i64_1(dest, "bmb_mutex_new", op))

    } else if low_starts_with_at(line, pos, "mutex-try-lock") {

        let op_start = low_skip_ws(line, pos + 14);

        let op = conc_extract_single_op(line, op_start);

        same_mapping(conc_gen_call_i64_1(dest, "bmb_mutex_try_lock", op))

    } else if low_starts_with_at(line, pos, "mutex-lock") {

        let op_start = low_skip_ws(line, pos + 10);

        let op = conc_extract_single_op(line, op_start);

        same_mapping(conc_gen_call_i64_1(dest, "bmb_mutex_lock", op))

    }

    // Arc operations

    else if low_starts_with_at(line, pos, "arc-new") {

        let op_start = low_skip_ws(line, pos + 7);

        let op = conc_extract_single_op(line, op_start);

        same_mapping(conc_gen_call_i64_1(dest, "bmb_arc_new", op))

    } else if low_starts_with_at(line, pos, "arc-clone") {

        let op_start = low_skip_ws(line, pos + 9);

        let op = conc_extract_single_op(line, op_start);

        same_mapping(conc_gen_call_i64_1(dest, "bmb_arc_clone", op))

    } else if low_starts_with_at(line, pos, "arc-get") {

        let op_start = low_skip_ws(line, pos + 7);

        let op = conc_extract_single_op(line, op_start);

        same_mapping(conc_gen_call_i64_1(dest, "bmb_arc_get", op))

    } else if low_starts_with_at(line, pos, "arc-strong-count") {

        let op_start = low_skip_ws(line, pos + 16);

        let op = conc_extract_single_op(line, op_start);

        same_mapping(conc_gen_call_i64_1(dest, "bmb_arc_strong_count", op))

    }

    // Atomic operations

    else if low_starts_with_at(line, pos, "atomic-new") {

        let op_start = low_skip_ws(line, pos + 10);

        let op = conc_extract_single_op(line, op_start);

        // Allocate heap memory for atomic, store value, return as i64 ptr

        "  " + dest + "_ptr = call ptr @malloc(i64 8)" + SEP() + "  store atomic i64 " + op + ", ptr " + dest + "_ptr seq_cst, align 8" + SEP() + "  " + dest + " = ptrtoint ptr " + dest + "_ptr to i64"

    } else if low_starts_with_at(line, pos, "atomic-load") {

        let op_start = low_skip_ws(line, pos + 11);

        let op = conc_extract_single_op(line, op_start);

        "  " + dest + "_ptr = inttoptr i64 " + op + " to ptr" + SEP() + "  " + dest + " = load atomic i64, ptr " + dest + "_ptr seq_cst, align 8"

    } else if low_starts_with_at(line, pos, "atomic-fetch-add") {

        let op_start = low_skip_ws(line, pos + 16);

        let op1 = conc_extract_two_ops_first(line, op_start);

        let op2 = conc_extract_two_ops_second(line, op_start);

        "  " + dest + "_ptr = inttoptr i64 " + op1 + " to ptr" + SEP() + "  " + dest + " = atomicrmw add ptr " + dest + "_ptr, i64 " + op2 + " seq_cst, align 8"

    } else if low_starts_with_at(line, pos, "atomic-fetch-sub") {

        let op_start = low_skip_ws(line, pos + 16);

        let op1 = conc_extract_two_ops_first(line, op_start);

        let op2 = conc_extract_two_ops_second(line, op_start);

        "  " + dest + "_ptr = inttoptr i64 " + op1 + " to ptr" + SEP() + "  " + dest + " = atomicrmw sub ptr " + dest + "_ptr, i64 " + op2 + " seq_cst, align 8"

    } else if low_starts_with_at(line, pos, "atomic-swap") {

        let op_start = low_skip_ws(line, pos + 11);

        let op1 = conc_extract_two_ops_first(line, op_start);

        let op2 = conc_extract_two_ops_second(line, op_start);

        "  " + dest + "_ptr = inttoptr i64 " + op1 + " to ptr" + SEP() + "  " + dest + " = atomicrmw xchg ptr " + dest + "_ptr, i64 " + op2 + " seq_cst, align 8"

    } else if low_starts_with_at(line, pos, "atomic-cmpxchg") {

        let op_start = low_skip_ws(line, pos + 14);

        let op1 = conc_extract_three_first(line, op_start);

        let op2 = conc_extract_three_second(line, op_start);

        let op3 = conc_extract_three_third(line, op_start);

        "  " + dest + "_ptr = inttoptr i64 " + op1 + " to ptr" + SEP() + "  " + dest + "_result = cmpxchg ptr " + dest + "_ptr, i64 " + op2 + ", i64 " + op3 + " seq_cst seq_cst, align 8" + SEP() + "  " + dest + " = extractvalue { i64, i1 } " + dest + "_result, 0"

    }

    // Channel operations (assignment form)

    else if low_starts_with_at(line, pos, "channel-recv-timeout") {

        let op_start = low_skip_ws(line, pos + 20);

        let op1 = conc_extract_two_ops_first(line, op_start);

        let op2 = conc_extract_two_ops_second(line, op_start);

        "  " + dest + "_alloc = alloca i64, align 8" + SEP() + "  " + dest + "_success = call i64 @bmb_channel_recv_timeout(i64 " + op1 + ", i64 " + op2 + ", ptr " + dest + "_alloc)" + SEP() + "  " + dest + "_loaded = load i64, ptr " + dest + "_alloc" + SEP() + "  " + dest + "_is_success = icmp ne i64 " + dest + "_success, 0" + SEP() + "  " + dest + " = select i1 " + dest + "_is_success, i64 " + dest + "_loaded, i64 -1"

    } else if low_starts_with_at(line, pos, "channel-recv-opt") {

        let op_start = low_skip_ws(line, pos + 16);

        let op = conc_extract_single_op(line, op_start);

        "  " + dest + "_ptr = alloca i64, align 8" + SEP() + "  " + dest + "_success = call i64 @bmb_channel_recv_opt(i64 " + op + ", ptr " + dest + "_ptr)" + SEP() + "  " + dest + "_tmp = load i64, ptr " + dest + "_ptr" + SEP() + "  " + dest + "_cond = icmp eq i64 " + dest + "_success, 1" + SEP() + "  " + dest + " = select i1 " + dest + "_cond, i64 " + dest + "_tmp, i64 -1"

    } else if low_starts_with_at(line, pos, "channel-recv") {

        let op_start = low_skip_ws(line, pos + 12);

        let op = conc_extract_single_op(line, op_start);

        same_mapping(conc_gen_call_i64_1(dest, "bmb_channel_recv", op))

    } else if low_starts_with_at(line, pos, "channel-try-send") {

        let op_start = low_skip_ws(line, pos + 16);

        let op1 = conc_extract_two_ops_first(line, op_start);

        let op2 = conc_extract_two_ops_second(line, op_start);

        same_mapping(conc_gen_call_i64_2(dest, "bmb_channel_try_send", op1, op2))

    } else if low_starts_with_at(line, pos, "channel-try-recv") {

        let op_start = low_skip_ws(line, pos + 16);

        let op = conc_extract_single_op(line, op_start);

        "  " + dest + "_alloc = alloca i64, align 8" + SEP() + "  " + dest + "_success = call i64 @bmb_channel_try_recv(i64 " + op + ", ptr " + dest + "_alloc)" + SEP() + "  " + dest + " = load i64, ptr " + dest + "_alloc"

    } else if low_starts_with_at(line, pos, "channel-send-timeout") {

        let op_start = low_skip_ws(line, pos + 20);

        let op1 = conc_extract_three_first(line, op_start);

        let op2 = conc_extract_three_second(line, op_start);

        let op3 = conc_extract_three_third(line, op_start);

        same_mapping(conc_gen_call_i64_3(dest, "bmb_channel_send_timeout", op1, op2, op3))

    } else if low_starts_with_at(line, pos, "channel-is-closed") {

        let op_start = low_skip_ws(line, pos + 17);

        let op = conc_extract_single_op(line, op_start);

        same_mapping(conc_gen_call_i64_1(dest, "bmb_channel_is_closed", op))

    } else if low_starts_with_at(line, pos, "sender-clone") {

        let op_start = low_skip_ws(line, pos + 12);

        let op = conc_extract_single_op(line, op_start);

        same_mapping(conc_gen_call_i64_1(dest, "bmb_sender_clone", op))

    }

    // RwLock operations

    else if low_starts_with_at(line, pos, "rwlock-new") {

        let op_start = low_skip_ws(line, pos + 10);

        let op = conc_extract_single_op(line, op_start);

        same_mapping(conc_gen_call_i64_1(dest, "bmb_rwlock_new", op))

    } else if low_starts_with_at(line, pos, "rwlock-read") {

        let op_start = low_skip_ws(line, pos + 11);

        let op = conc_extract_single_op(line, op_start);

        same_mapping(conc_gen_call_i64_1(dest, "bmb_rwlock_read", op))

    } else if low_starts_with_at(line, pos, "rwlock-write") {

        let op_start = low_skip_ws(line, pos + 12);

        let op = conc_extract_single_op(line, op_start);

        same_mapping(conc_gen_call_i64_1(dest, "bmb_rwlock_write", op))

    }

    // Barrier operations

    else if low_starts_with_at(line, pos, "barrier-new") {

        let op_start = low_skip_ws(line, pos + 11);

        let op = conc_extract_single_op(line, op_start);

        same_mapping(conc_gen_call_i64_1(dest, "bmb_barrier_new", op))

    } else if low_starts_with_at(line, pos, "barrier-wait") {

        let op_start = low_skip_ws(line, pos + 12);

        let op = conc_extract_single_op(line, op_start);

        same_mapping(conc_gen_call_i64_1(dest, "bmb_barrier_wait", op))

    }

    // Condvar operations

    else if low_starts_with_at(line, pos, "condvar-new") {

        same_mapping(conc_gen_call_i64_0(dest, "bmb_condvar_new"))

    } else if low_starts_with_at(line, pos, "condvar-wait") {

        let op_start = low_skip_ws(line, pos + 12);

        let op1 = conc_extract_two_ops_first(line, op_start);

        let op2 = conc_extract_two_ops_second(line, op_start);

        same_mapping(conc_gen_call_i64_2(dest, "bmb_condvar_wait", op1, op2))

    }

    // Block-on

    else if low_starts_with_at(line, pos, "block-on") {

        let op_start = low_skip_ws(line, pos + 8);

        let op = conc_extract_single_op(line, op_start);

        same_mapping(conc_gen_call_i64_1(dest, "bmb_block_on", op))

    }

    // Async I/O operations

    else if low_starts_with_at(line, pos, "async-file-open") {

        let op_start = low_skip_ws(line, pos + 15);

        let op = conc_extract_single_op(line, op_start);

        same_mapping(conc_gen_call_i64_1(dest, "bmb_async_file_open", op))

    } else if low_starts_with_at(line, pos, "async-file-read") {

        let op_start = low_skip_ws(line, pos + 15);

        let op = conc_extract_single_op(line, op_start);

        same_mapping(conc_gen_call_i64_1(dest, "bmb_async_file_read", op))

    } else if low_starts_with_at(line, pos, "async-socket-connect") {

        let op_start = low_skip_ws(line, pos + 20);

        let op1 = conc_extract_two_ops_first(line, op_start);

        let op2 = conc_extract_two_ops_second(line, op_start);

        same_mapping(conc_gen_call_i64_2(dest, "bmb_async_socket_connect", op1, op2))

    } else if low_starts_with_at(line, pos, "async-socket-read") {

        let op_start = low_skip_ws(line, pos + 17);

        let op = conc_extract_single_op(line, op_start);

        same_mapping(conc_gen_call_i64_1(dest, "bmb_async_socket_read", op))

    }

    // ThreadPool

    else if low_starts_with_at(line, pos, "thread-pool-new") {

        let op_start = low_skip_ws(line, pos + 15);

        let op = conc_extract_single_op(line, op_start);

        same_mapping(conc_gen_call_i64_1(dest, "bmb_thread_pool_new", op))

    }

    // Scope

    else if low_starts_with_at(line, pos, "scope-new") {

        same_mapping(conc_gen_call_i64_0(dest, "bmb_scope_new"))

    }

    // Unknown concurrency instruction

    else { same_mapping("  ; unknown-conc: " + line) };

// Handles MIR lines like "mutex-unlock %h = %v", "channel-send %s %v", etc.

fn llvm_gen_conc_stmt(line: String, p: i64) -> String

  pre p >= 0

  post it.len() >= 1

= if low_starts_with_at(line, p, "mutex-unlock") {

        // mutex-unlock %handle = %value

        let op_start = low_skip_ws(line, p + 12);

        let eq_pos = find_eq(line, op_start);

        let handle = trim_end(line.slice(op_start, eq_pos - 1));

        let val_start = low_skip_ws(line, eq_pos + 1);

        let value = trim_end(line.slice(val_start, line.len()));

        conc_gen_call_void_2("bmb_mutex_unlock", handle, value)

    } else if low_starts_with_at(line, p, "mutex-free") {

        let op_start = low_skip_ws(line, p + 10);

        let op = conc_extract_single_op(line, op_start);

        conc_gen_call_void_1("bmb_mutex_free", op)

    } else if low_starts_with_at(line, p, "arc-drop") {

        let op_start = low_skip_ws(line, p + 8);

        let op = conc_extract_single_op(line, op_start);

        conc_gen_call_void_1("bmb_arc_drop", op)

    } else if low_starts_with_at(line, p, "atomic-store") {

        // atomic-store %ptr = %value

        let op_start = low_skip_ws(line, p + 12);

        let eq_pos = find_eq(line, op_start);

        let ptr_op = trim_end(line.slice(op_start, eq_pos - 1));

        let val_start = low_skip_ws(line, eq_pos + 1);

        let value = trim_end(line.slice(val_start, line.len()));

        "  %_atomic_store_ptr = inttoptr i64 " + ptr_op + " to ptr" + SEP() + "  store atomic i64 " + value + ", ptr %_atomic_store_ptr seq_cst, align 8"

    } else if low_starts_with_at(line, p, "channel-send") {

        let op_start = low_skip_ws(line, p + 12);

        let op1 = conc_extract_two_ops_first(line, op_start);

        let op2 = conc_extract_two_ops_second(line, op_start);

        conc_gen_call_void_2("bmb_channel_send", op1, op2)

    } else if low_starts_with_at(line, p, "channel-close") {

        let op_start = low_skip_ws(line, p + 13);

        let op = conc_extract_single_op(line, op_start);

        conc_gen_call_void_1("bmb_channel_close", op)

    } else if low_starts_with_at(line, p, "rwlock-read-unlock") {

        let op_start = low_skip_ws(line, p + 18);

        let op = conc_extract_single_op(line, op_start);

        conc_gen_call_void_1("bmb_rwlock_read_unlock", op)

    } else if low_starts_with_at(line, p, "rwlock-write-unlock") {

        let op_start = low_skip_ws(line, p + 19);

        let op1 = conc_extract_two_ops_first(line, op_start);

        let op2 = conc_extract_two_ops_second(line, op_start);

        conc_gen_call_void_2("bmb_rwlock_write_unlock", op1, op2)

    } else if low_starts_with_at(line, p, "condvar-notify-one") {

        let op_start = low_skip_ws(line, p + 18);

        let op = conc_extract_single_op(line, op_start);

        conc_gen_call_void_1("bmb_condvar_notify_one", op)

    } else if low_starts_with_at(line, p, "condvar-notify-all") {

        let op_start = low_skip_ws(line, p + 18);

        let op = conc_extract_single_op(line, op_start);

        conc_gen_call_void_1("bmb_condvar_notify_all", op)

    } else if low_starts_with_at(line, p, "async-file-write") {

        let op_start = low_skip_ws(line, p + 16);

        let op1 = conc_extract_two_ops_first(line, op_start);

        let op2 = conc_extract_two_ops_second(line, op_start);

        conc_gen_call_void_2("bmb_async_file_write", op1, op2)

    } else if low_starts_with_at(line, p, "async-file-close") {

        let op_start = low_skip_ws(line, p + 16);

        let op = conc_extract_single_op(line, op_start);

        conc_gen_call_void_1("bmb_async_file_close", op)

    } else if low_starts_with_at(line, p, "async-socket-write") {

        let op_start = low_skip_ws(line, p + 18);

        let op1 = conc_extract_two_ops_first(line, op_start);

        let op2 = conc_extract_two_ops_second(line, op_start);

        conc_gen_call_void_2("bmb_async_socket_write", op1, op2)

    } else if low_starts_with_at(line, p, "async-socket-close") {

        let op_start = low_skip_ws(line, p + 18);

        let op = conc_extract_single_op(line, op_start);

        conc_gen_call_void_1("bmb_async_socket_close", op)

    } else if low_starts_with_at(line, p, "thread-pool-execute") {

        let op_start = low_skip_ws(line, p + 19);

        let op1 = conc_extract_two_ops_first(line, op_start);

        let op2 = conc_extract_two_ops_second(line, op_start);

        conc_gen_call_void_2("bmb_thread_pool_execute", op1, op2)

    } else if low_starts_with_at(line, p, "thread-pool-join") {

        let op_start = low_skip_ws(line, p + 16);

        let op = conc_extract_single_op(line, op_start);

        conc_gen_call_void_1("bmb_thread_pool_join", op)

    } else if low_starts_with_at(line, p, "thread-pool-shutdown") {

        let op_start = low_skip_ws(line, p + 20);

        let op = conc_extract_single_op(line, op_start);

        conc_gen_call_void_1("bmb_thread_pool_shutdown", op)

    } else if low_starts_with_at(line, p, "scope-spawn") {

        let op_start = low_skip_ws(line, p + 11);

        let op1 = conc_extract_two_ops_first(line, op_start);

        let op2 = conc_extract_two_ops_second(line, op_start);

        conc_gen_call_void_2("bmb_scope_spawn", op1, op2)

    } else if low_starts_with_at(line, p, "scope-wait") {

        let op_start = low_skip_ws(line, p + 10);

        let op = conc_extract_single_op(line, op_start);

        conc_gen_call_void_1("bmb_scope_wait", op)

    } else if low_starts_with_at(line, p, "thread-join") {

        // thread-join without dest (discard result)

        let op_start = low_skip_ws(line, p + 11);

        let op = conc_extract_single_op(line, op_start);

        "  call i64 @bmb_thread_join(i64 " + op + ")"

    } else { "  ; unknown-conc-stmt: " + line };

fn llvm_gen_channel_new(line: String, p: i64) -> String

  pre p >= 0

  post it.len() >= 1

= // Parse: (%sender, %receiver) = channel-new %capacity

    let p1 = p + 1;

    let comma = find_comma(line, p1);

    let sender_dest = line.slice(p1, comma);

    let p2 = low_skip_ws(line, comma + 1);

    let rparen = find_char(line, p2, 41);

    let receiver_dest = line.slice(p2, rparen);

    let eq_pos = find_eq(line, rparen + 1);

    let rhs_start = low_skip_ws(line, eq_pos + 1);

    // Skip "channel-new"

    let cap_start = low_skip_ws(line, rhs_start + 11);

    let cap = trim_end(line.slice(cap_start, line.len()));

    // Generate alloca + call + load

    "  " + sender_dest + "_alloc = alloca i64, align 8" + SEP() + "  " + receiver_dest + "_alloc = alloca i64, align 8" + SEP() + "  call void @bmb_channel_new(i64 " + cap + ", ptr " + sender_dest + "_alloc, ptr " + receiver_dest + "_alloc)" + SEP() + "  " + sender_dest + " = load i64, ptr " + sender_dest + "_alloc" + SEP() + "  " + receiver_dest + " = load i64, ptr " + receiver_dest + "_alloc";

// Legacy versions for compatibility

fn llvm_gen_string_ref(dest: String, str_content: String, strings: String) -> String

  post it.len() >= 1

= let idx = find_string_index(strings, str_content);

    let idx_str = int_to_string(idx);

    "  " + dest + " = ptrtoint ptr @str_bmb_" + idx_str + " to i64";

// ============================================================================

// SECTION 12d: Contract-Based llvm.assume Injection (v0.96.24)

// ============================================================================

// Extract pre-condition ASTs from source at the position after return type

// Returns tab-separated AST S-expressions, e.g. "(>= (var x) (int 0))\t(< (var x) (var len))"

// Only extracts `pre` conditions (post conditions handled separately)

fn extract_pre_asts(src: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= let t = next_token_raw(src, pos);
    let k = tok_kind(t);
    if k == TK_EQ() or k == TK_EOF() or k == TK_LBRACE() { "" }
    else if k == TK_PRE() {
        let re = parse_expr(src, tok_end(t));
        if is_error(re) { "" }
        else {
            let ast = unpack_ast(re);
            let rest = extract_pre_asts(src, unpack_pos(re));
            if rest == "" { ast } else { ast + chr(9) + rest }
        }
    }
    else if k == TK_POST() {
        // Skip post-condition expression, continue scanning for more pre conditions
        let re = parse_expr(src, tok_end(t));
        if is_error(re) { extract_pre_asts(src, tok_end(t)) }
        else { extract_pre_asts(src, unpack_pos(re)) }
    }
    else if k == TK_WHERE() {
        // Skip where clause
        let after = skip_where_clause(src, tok_end(t));
        extract_pre_asts(src, after)
    }
    else if k == TK_IDENT() and get_ident_text(src, pos, t) == "intent" {
        // M13: skip intent: "..." annotation
        let t2 = next_token_raw(src, tok_end(t));
        if tok_kind(t2) == TK_COLON() {
            let t3 = next_token_raw(src, tok_end(t2));
            if tok_kind(t3) == TK_STRING_LIT() { extract_pre_asts(src, tok_end(t3)) }
            else { "" }
        } else { "" }
    }
    else { "" };

// Extract post-condition ASTs from source at the position after return type

// Extract post-condition ASTs from source at the position after return type

// Returns tab-separated AST S-expressions for post conditions

fn extract_post_asts(src: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= let t = next_token_raw(src, pos);
    let k = tok_kind(t);
    if k == TK_EQ() or k == TK_EOF() or k == TK_LBRACE() { "" }
    else if k == TK_POST() {
        let re = parse_expr(src, tok_end(t));
        if is_error(re) { "" }
        else {
            let ast = unpack_ast(re);
            let rest = extract_post_asts(src, unpack_pos(re));
            if rest == "" { ast } else { ast + chr(9) + rest }
        }
    }
    else if k == TK_PRE() {
        // Skip pre-condition expression, continue scanning for post conditions
        let re = parse_expr(src, tok_end(t));
        if is_error(re) { extract_post_asts(src, tok_end(t)) }
        else { extract_post_asts(src, unpack_pos(re)) }
    }
    else if k == TK_WHERE() {
        let after = skip_where_clause(src, tok_end(t));
        extract_post_asts(src, after)
    }
    else if k == TK_IDENT() and get_ident_text(src, pos, t) == "intent" {
        // M13: skip intent: "..." annotation
        let t2 = next_token_raw(src, tok_end(t));
        if tok_kind(t2) == TK_COLON() {
            let t3 = next_token_raw(src, tok_end(t2));
            if tok_kind(t3) == TK_STRING_LIT() { extract_post_asts(src, tok_end(t3)) }
            else { "" }
        } else { "" }
    }
    else { "" };

// M13 Phase 2: Check if intent: "..." annotation is present in function contract zone.
// Returns 1 if found, 0 otherwise.

fn has_intent_annotation(src: String, pos: i64) -> i64

  pre pos >= 0

  post it == 0 or it == 1

= let t = next_token_raw(src, pos);

    let k = tok_kind(t);

    if k == TK_EQ() or k == TK_EOF() or k == TK_LBRACE() { 0 }

    else if k == TK_IDENT() and get_ident_text(src, pos, t) == "intent" {

        let t2 = next_token_raw(src, tok_end(t));

        if tok_kind(t2) == TK_COLON() {

            let t3 = next_token_raw(src, tok_end(t2));

            if tok_kind(t3) == TK_STRING_LIT() { 1 } else { 0 }

        } else { 0 }

    }

    else if k == TK_PRE() or k == TK_POST() {

        let re = parse_expr(src, tok_end(t));

        if is_error(re) { 0 } else { has_intent_annotation(src, unpack_pos(re)) }

    }

    else if k == TK_WHERE() { has_intent_annotation(src, skip_where_clause(src, tok_end(t))) }

    else { 0 };

// Build a map of function names to their pre-condition ASTs
// Format: "fn_name\tast1\tast2\nfn_name2\tast1\n..."

// Build a map of function names to their pre-condition ASTs

// Format: "fn_name\tast1\tast2\nfn_name2\tast1\n..."

// Uses chr(10) between entries, chr(9) between name and ASTs

fn build_contracts_map(src: String) -> String

  post it.len() >= 0

= let sb = sb_new();

    let _w = build_contracts_map_scan(src, 0, sb);

    sb_build(sb);

// Scan source using string search to find "fn " declarations (avoids deep recursion)

// Jumps between function boundaries using find_pattern_noa instead of token-by-token

fn build_contracts_map_scan(src: String, pos: i64, sb: i64) -> i64

  pre pos >= 0

  post it >= 0

= // Find next "fn " in source (naive but bounded by function count, not token count)

    let fn_pos = find_pattern_noa(src, "fn ", pos);

    if fn_pos < 0 { 0 } else {

        // Verify this is a real fn keyword (not inside a string/comment) by checking

        // that it's preceded by a newline/space/; or is at start of file

        let is_real_fn = if fn_pos == 0 { true }

                        else {

                            let prev = src.byte_at(fn_pos - 1);

                            prev == 10 or prev == 13 or prev == 32 or prev == 59 or prev == 9

                        };

        if is_real_fn {

            // Extract function name

            let name_start = skip_ws_comments(src, fn_pos + 3);

            let name_end = scan_ident_end(src, name_start);

            let name = src.slice(name_start, name_end);

            if name != "" and name_end > name_start {

                // Try to parse function signature to extract contracts

                let t2 = next_token_raw(src, name_end);

                // Skip generic params if present

                let after_gen = if tok_kind(t2) == TK_LT() { skip_generic_params(src, tok_end(t2)) } else { name_end };

                let t2g = next_token_raw(src, after_gen);

                if tok_kind(t2g) == TK_LPAREN() {

                    let params = index_collect_params(src, tok_end(t2g), "");

                    let rtype = index_read_ret_type(src, unpack_pos(params));

                    let ret_pos = unpack_pos(rtype);

                    // Extract pre-condition ASTs

                    let asts = extract_pre_asts(src, ret_pos);

                    let _w = if asts != "" {

                        let len = sb_len(sb);

                        let _w1 = if len > 0 { sb_push(sb, chr(10)) } else { 0 };

                        let _w2 = sb_push(sb, name);

                        let _w3 = sb_push(sb, chr(9));

                        sb_push(sb, asts)

                    } else { 0 };

                    // Continue scanning after this function

                    build_contracts_map_scan(src, unpack_pos(rtype) + 1, sb)

                } else { build_contracts_map_scan(src, fn_pos + 3, sb) }

            } else { build_contracts_map_scan(src, fn_pos + 3, sb) }

        } else { build_contracts_map_scan(src, fn_pos + 3, sb) }

    };

// Build a map of function names to their post-condition ASTs

// Same format as pre map: "fn_name\tast1\tast2\nfn_name2\tast1\n..."

fn build_post_contracts_map(src: String) -> String

  post it.len() >= 0

= let sb = sb_new();

    let _w = build_post_contracts_map_scan(src, 0, sb);

    sb_build(sb);

fn build_post_contracts_map_scan(src: String, pos: i64, sb: i64) -> i64

  pre pos >= 0

  post it >= 0

= let fn_pos = find_pattern_noa(src, "fn ", pos);

    if fn_pos < 0 { 0 } else {

        let is_real_fn = if fn_pos == 0 { true }

                        else {

                            let prev = src.byte_at(fn_pos - 1);

                            prev == 10 or prev == 13 or prev == 32 or prev == 59 or prev == 9

                        };

        if is_real_fn {

            let name_start = skip_ws_comments(src, fn_pos + 3);

            let name_end = scan_ident_end(src, name_start);

            let name = src.slice(name_start, name_end);

            if name != "" and name_end > name_start {

                let t2 = next_token_raw(src, name_end);

                let after_gen = if tok_kind(t2) == TK_LT() { skip_generic_params(src, tok_end(t2)) } else { name_end };

                let t2g = next_token_raw(src, after_gen);

                if tok_kind(t2g) == TK_LPAREN() {

                    let params = index_collect_params(src, tok_end(t2g), "");

                    let rtype = index_read_ret_type(src, unpack_pos(params));

                    let ret_pos = unpack_pos(rtype);

                    let asts = extract_post_asts(src, ret_pos);

                    let _w = if asts != "" {

                        let len = sb_len(sb);

                        let _w1 = if len > 0 { sb_push(sb, chr(10)) } else { 0 };

                        let _w2 = sb_push(sb, name);

                        let _w3 = sb_push(sb, chr(9));

                        sb_push(sb, asts)

                    } else { 0 };

                    build_post_contracts_map_scan(src, unpack_pos(rtype) + 1, sb)

                } else { build_post_contracts_map_scan(src, fn_pos + 3, sb) }

            } else { build_post_contracts_map_scan(src, fn_pos + 3, sb) }

        } else { build_post_contracts_map_scan(src, fn_pos + 3, sb) }

    };

// Look up a function's pre-condition ASTs in the contracts map

// Returns tab-separated ASTs or "" if no contracts

fn lookup_contracts(map: String, fn_name: String) -> String

  post it.len() <= map.len()

= lookup_contracts_at(map, fn_name, 0);

fn lookup_contracts_at(map: String, fn_name: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= map.len() { "" } else {

        // Find next entry: starts at pos, find tab separator

        let tab = find_char(map, pos, 9);

        if tab >= map.len() { "" } else {

            let entry_name = map.slice(pos, tab);

            let nl = find_char(map, tab + 1, 10);

            let end = if nl >= map.len() { map.len() } else { nl };

            if entry_name == fn_name { map.slice(tab + 1, end) }

            else { lookup_contracts_at(map, fn_name, end + 1) }

        }

    };

// Convert comparison operator from AST to LLVM icmp predicate

fn ast_op_to_icmp(op: String) -> String

  post it.len() <= 3

= match op { ">=" => "sge", ">" => "sgt", "<" => "slt", "<=" => "sle", "==" => "eq", "!=" => "ne", _ => "" };

// Extract bare name from angle-bracketed AST var: "<name>" -> "name"

fn strip_angle_brackets(s: String) -> String

  post it.len() <= s.len()

= if s.len() >= 2 and s.byte_at(0) == 60 and s.byte_at(s.len() - 1) == 62 {

        s.slice(1, s.len() - 1)

    } else { s };

// Convert a single contract AST to llvm.assume IR text

// AST format: (binop >= (var <x>) (int 0)) or (binop and (...) (...))

// counter: assume counter for unique naming

// Returns: (counter, ir_text) packed as "counter:ir_text"

fn contract_ast_to_assumes(ast: String, counter: i64) -> String

  pre counter >= 0

  post it.len() >= 1

= let nt = get_node_type(ast);

    if nt == "binop" {

        let op = get_child(ast, 0);

        if op == "and" {

            // Split: (binop and left right) -> handle left, then right

            let left = get_child(ast, 1);

            let right = get_child(ast, 2);

            let left_result = contract_ast_to_assumes(left, counter);

            let left_counter = unpack_assume_counter(left_result);

            let left_ir = unpack_assume_ir(left_result);

            let right_result = contract_ast_to_assumes(right, left_counter);

            let right_counter = unpack_assume_counter(right_result);

            let right_ir = unpack_assume_ir(right_result);

            if left_ir == "" and right_ir == "" { pack_assume_result(right_counter, "") }

            else if left_ir == "" { pack_assume_result(right_counter, right_ir) }

            else if right_ir == "" { pack_assume_result(left_counter, left_ir) }

            else { pack_assume_result(right_counter, left_ir + SEP() + right_ir) }

        }

        else {

            // Comparison: (binop >= (var <x>) (int 0))

            let icmp_pred = ast_op_to_icmp(op);

            if icmp_pred == "" { pack_assume_result(counter, "") }

            else {

                let lhs_ast = get_child(ast, 1);

                let rhs_ast = get_child(ast, 2);

                let lhs_nt = get_node_type(lhs_ast);

                let rhs_nt = get_node_type(rhs_ast);

                // Generate: %_assume_N = icmp PRED i64 LHS, RHS

                //           call void @llvm.assume(i1 %_assume_N)

                let lhs_op = if lhs_nt == "var" { "%" + strip_angle_brackets(get_child(lhs_ast, 0)) }

                             else if lhs_nt == "int" { get_child(lhs_ast, 0) }

                             else { "" };

                let rhs_op = if rhs_nt == "var" { "%" + strip_angle_brackets(get_child(rhs_ast, 0)) }

                             else if rhs_nt == "int" { get_child(rhs_ast, 0) }

                             else { "" };

                if lhs_op == "" or rhs_op == "" { pack_assume_result(counter, "") }

                else {

                    let cname = "%_assume_" + int_to_string(counter);

                    let icmp = "  " + cname + " = icmp " + icmp_pred + " i64 " + lhs_op + ", " + rhs_op;

                    let assume = "  call void @llvm.assume(i1 " + cname + ")";

                    pack_assume_result(counter + 1, icmp + SEP() + assume)

                }

            }

        }

    }

    else { pack_assume_result(counter, "") };

fn pack_assume_result(counter: i64, ir: String) -> String

  pre counter >= 0

  post it.len() >= 1

= int_to_string(counter) + ":" + ir;

fn unpack_assume_counter(result: String) -> i64

  post it >= 0

= unpack_pos(result);  // Reuses same "number:text" format

fn unpack_assume_ir(result: String) -> String

  post it.len() <= result.len()

= unpack_ast(result);  // Reuses same "number:text" format

// Generate all llvm.assume IR for a function's contracts

// contracts: tab-separated AST strings

// Returns: LLVM IR text to inject after entry: label, or ""

fn gen_assumes_for_contracts(contracts: String) -> String

  post it.len() >= 0

= if contracts == "" { "" }

    else { gen_assumes_for_contracts_acc(contracts, 0, 0, "") };

fn gen_assumes_for_contracts_acc(contracts: String, pos: i64, counter: i64, acc: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= contracts.len() { acc } else {

        let tab = find_char(contracts, pos, 9);

        let end = if tab >= contracts.len() { contracts.len() } else { tab };

        let ast = contracts.slice(pos, end);

        let result = contract_ast_to_assumes(ast, counter);

        let new_counter = unpack_assume_counter(result);

        let ir = unpack_assume_ir(result);

        let new_acc = if ir == "" { acc }

                      else if acc == "" { ir }

                      else { acc + SEP() + ir };

        if end >= contracts.len() { new_acc }

        else { gen_assumes_for_contracts_acc(contracts, end + 1, new_counter, new_acc) }

    };

// Inject llvm.assume calls into a single function's LLVM IR

// Inserts assume IR right after the "entry:" label

fn inject_fn_assumes(fn_ir: String, assumes_ir: String) -> String

  post it.len() >= fn_ir.len()

= if assumes_ir == "" { fn_ir } else {

        // Find "entry:" in the IR

        let entry_pos = find_pattern_noa(fn_ir, "entry:", 0);

        if entry_pos < 0 { fn_ir } else {

            // Find the end of "entry:" line (next SEP)

            let after_entry = entry_pos + 6;

            let before = fn_ir.slice(0, after_entry);

            let after = fn_ir.slice(after_entry, fn_ir.len());

            before + SEP() + assumes_ir + after

        }

    };

// Post-processing pass: inject llvm.assume into all functions

// Iterates over DSEP-separated functions in the IR

fn inject_contract_assumes_all(ir: String, contracts_map: String) -> String

  post it.len() >= ir.len()

= if contracts_map == "" { ir } else {

        let sb = sb_new();

        let _w = inject_assumes_scan(ir, 0, contracts_map, sb);

        sb_build(sb)

    };

fn inject_assumes_scan(ir: String, pos: i64, contracts_map: String, sb: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= ir.len() { 0 } else {

        // Find next DSEP (double chr(31))

        let fn_end = find_double_pipe(ir, pos);

        let fn_ir = ir.slice(pos, fn_end);

        // Extract function name from "define ... @fn_name("

        let at_pos = find_char(fn_ir, 0, 64);  // 64 = '@'

        let fn_name = if at_pos < fn_ir.len() {

            let name_start = at_pos + 1;

            let paren_pos = find_char(fn_ir, name_start, 40);  // 40 = '('

            if paren_pos < fn_ir.len() { fn_ir.slice(name_start, paren_pos) } else { "" }

        } else { "" };

        // Look up contracts and inject assumes

        let contracts = lookup_contracts(contracts_map, fn_name);

        let assumes_ir = gen_assumes_for_contracts(contracts);

        let result_ir = inject_fn_assumes(fn_ir, assumes_ir);

        // Append to output

        let len = sb_len(sb);

        let _w1 = if len > 0 { sb_push(sb, DSEP()) } else { 0 };

        let _w2 = sb_push(sb, result_ir);

        if fn_end + 2 >= ir.len() { 0 }

        else { inject_assumes_scan(ir, fn_end + 2, contracts_map, sb) }

    };

// v0.96.24: Post-condition assume injection at call sites

// For each "call @fn_name" in the IR, inject llvm.assume for callee's postconditions

fn inject_post_assumes_all(ir: String, post_map: String) -> String

  post it.len() >= ir.len()

= if post_map == "" { ir } else {

        let sb = sb_new();

        let _w = inject_post_assumes_scan(ir, 0, post_map, sb);

        sb_build(sb)

    };

fn inject_post_assumes_scan(ir: String, pos: i64, post_map: String, sb: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= ir.len() { 0 } else {

        // Find next DSEP (double chr(31))

        let fn_end = find_double_pipe(ir, pos);

        let fn_ir = ir.slice(pos, fn_end);

        // Process this function's IR to inject post-assumes at call sites

        let result_ir = inject_post_assumes_in_fn(fn_ir, post_map, 0);

        let len = sb_len(sb);

        let _w1 = if len > 0 { sb_push(sb, DSEP()) } else { 0 };

        let _w2 = sb_push(sb, result_ir);

        if fn_end + 2 >= ir.len() { 0 }

        else { inject_post_assumes_scan(ir, fn_end + 2, post_map, sb) }

    };

// Inject post-assumes into a single function's IR

// Scans for "call" instructions and inserts assumes after them

fn inject_post_assumes_in_fn(fn_ir: String, post_map: String, counter: i64) -> String

  pre counter >= 0

  post it.len() >= fn_ir.len()

= // Find call patterns: "%_tN = call i64 @fn_name("

    let call_pos = find_pattern_noa(fn_ir, " = call i64 @", 0);

    if call_pos < 0 { fn_ir }

    else {

        let sb = sb_new();

        let _w = inject_post_assumes_in_fn_scan(fn_ir, post_map, 0, counter, sb);

        sb_build(sb)

    };

fn inject_post_assumes_in_fn_scan(fn_ir: String, post_map: String, pos: i64, counter: i64, sb: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= fn_ir.len() { counter } else {

        // Find next SEP (line separator)

        let sep = find_char(fn_ir, pos, 31);

        let line_end = if sep >= fn_ir.len() { fn_ir.len() } else { sep };

        let line = fn_ir.slice(pos, line_end);

        // Append this line

        let len = sb_len(sb);

        let _w1 = if len > 0 { sb_push(sb, SEP()) } else { 0 };

        let _w2 = sb_push(sb, line);

        // Check if this line is a call with result: "%_tN = call i64 @fn_name("

        let call_pat = find_pattern_noa(line, " = call i64 @", 0);

        let new_counter = if call_pat < 0 { counter }

        else {

            // Extract result register: from start of line (after spaces) to " = call"

            let reg_start = skip_spaces(line, 0);

            let result_reg = line.slice(reg_start, call_pat);

            // Extract callee name: after "@" to "("

            let at_off = call_pat + 13;  // " = call i64 @" is 13 chars

            let paren_off = find_char(line, at_off, 40);  // 40 = '('

            let callee_name = if paren_off < line.len() { line.slice(at_off, paren_off) } else { "" };

            // Look up postconditions

            let post_asts = lookup_contracts(post_map, callee_name);

            if post_asts == "" { counter }

            else {

                // Generate assumes with "ret" as variable name, then replace %ret with result_reg

                let raw_assumes = gen_assumes_for_post_contracts(post_asts, counter);

                let new_c = unpack_assume_counter(raw_assumes);

                let raw_ir = unpack_assume_ir(raw_assumes);

                let _w3 = if raw_ir != "" {

                    // Replace %it with the actual result register (post conditions use 'it' as the return value)

                    let fixed_ir = replace_all_str(raw_ir, "%it", result_reg);

                    // Safety: if the assume IR still references %param_name (letter after %)
                    // those are callee parameter names undefined in the calling function; skip.

                    if has_param_ref_in_ir(fixed_ir, 0) { 0 }

                    else { sb_push(sb, SEP() + fixed_ir) }

                } else { 0 };

                new_c

            }

        };

        if line_end >= fn_ir.len() { new_counter }

        else { inject_post_assumes_in_fn_scan(fn_ir, post_map, line_end + 1, new_counter, sb) }

    };

// Check if an LLVM IR snippet contains %name where 'name' starts with a letter (a-z|A-Z).
// Such references are callee parameter names that would be undefined in the caller's scope.
// Our generated names always start with '_' (e.g., %_t0, %_post_assume_1).

fn has_param_ref_in_ir(s: String, pos: i64) -> bool

  post not it or pos < s.len()

= if pos >= s.len() { false }

  else {

    let c = s.byte_at(pos);

    if c == 37 {

      if pos + 1 >= s.len() { has_param_ref_in_ir(s, pos + 1) }

      else {

        let next = s.byte_at(pos + 1);

        if (next >= 65 and next <= 90) or (next >= 97 and next <= 122) { true }

        else { has_param_ref_in_ir(s, pos + 1) }

      }

    }

    else { has_param_ref_in_ir(s, pos + 1) }

  };

// Skip leading spaces

fn skip_spaces(s: String, pos: i64) -> i64

    post it >= 0

= 

    if pos >= s.len() { pos }

    else if s.byte_at(pos) == 32 { skip_spaces(s, pos + 1) }

    else { pos };

// Generate assumes for post-conditions (uses "%ret" as placeholder for return value)

// Uses %_post_assume_ prefix to avoid name collision with pre-condition assumes

fn gen_assumes_for_post_contracts(contracts: String, counter: i64) -> String

  pre counter >= 0

  post it.len() >= 1

= let raw = gen_assumes_for_post_acc(contracts, 0, counter, "");

    let raw_counter = unpack_assume_counter(raw);

    let raw_ir = unpack_assume_ir(raw);

    // Rename %_assume_ to %_post_assume_ to avoid collision with pre-assumes

    let fixed = replace_all_str(raw_ir, "%_assume_", "%_post_assume_");

    pack_assume_result(raw_counter, fixed);

fn gen_assumes_for_post_acc(contracts: String, pos: i64, counter: i64, acc: String) -> String

  pre pos >= 0

  post it.len() >= 1

= if pos >= contracts.len() { pack_assume_result(counter, acc) } else {

        let tab = find_char(contracts, pos, 9);

        let end = if tab >= contracts.len() { contracts.len() } else { tab };

        let ast = contracts.slice(pos, end);

        let result = contract_ast_to_assumes(ast, counter);

        let new_counter = unpack_assume_counter(result);

        let ir = unpack_assume_ir(result);

        let new_acc = if ir == "" { acc }

                      else if acc == "" { ir }

                      else { acc + SEP() + ir };

        if end >= contracts.len() { pack_assume_result(new_counter, new_acc) }

        else { gen_assumes_for_post_acc(contracts, end + 1, new_counter, new_acc) }

    };

// Replace all occurrences of a pattern in a string

fn replace_all_str(s: String, old: String, new_s: String) -> String

  post it.len() >= 0

= let pos = find_pattern_noa(s, old, 0);

    if pos < 0 { s }

    else {

        let before = s.slice(0, pos);

        let after = s.slice(pos + old.len(), s.len());

        let result = before + new_s + after;

        replace_all_str(result, old, new_s)

    };

// ============================================================================

// Return Range Attribute — v0.96.30

// Computes LLVM range(i64 lo, hi) attributes from postconditions on return values.

// Scans function definitions in generated IR, looks up postconditions, and

// injects range() attribute before the return type.

// ============================================================================

// Convert string integer literal to i64 value

fn str_to_int(s: String) -> i64

  post it == it

= if s.len() == 0 { 0 }

    else if s.byte_at(0) == 45 { 0 - str_to_int_acc(s, 1, 0) }

    else { str_to_int_acc(s, 0, 0) };

fn str_to_int_acc(s: String, pos: i64, acc: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= s.len() { acc }

    else {

        let c = s.byte_at(pos);

        if is_digit(c) { str_to_int_acc(s, pos + 1, acc * 10 + (c - 48)) }

        else { acc }

    };

// Update range bounds in state vec from a single postcondition AST

// state: vec of 4 elements [has_lo, lo, has_hi, hi_inclusive]

// Handles compound "and" by recursing into both branches

fn update_range_from_ast(ast: String, state: i64) -> i64

  post it == 0

= let nt = get_node_type(ast);

    if nt == "binop" {

        let op = get_child(ast, 0);

        if op == "and" {

            let _l = update_range_from_ast(get_child(ast, 1), state);

            update_range_from_ast(get_child(ast, 2), state)

        }

        else {

            let lhs = get_child(ast, 1);

            let rhs = get_child(ast, 2);

            let lhs_nt = get_node_type(lhs);

            let rhs_nt = get_node_type(rhs);

            // Check for ret comparison with integer literal

            let ret_cmp = if lhs_nt == "var" and strip_angle_brackets(get_child(lhs, 0)) == "ret" and rhs_nt == "int" {

                op + ":" + get_child(rhs, 0)

            }

            else if rhs_nt == "var" and strip_angle_brackets(get_child(rhs, 0)) == "ret" and lhs_nt == "int" {

                let flipped = match op { ">=" => "<=", ">" => "<", "<=" => ">=", "<" => ">", _ => op };

                flipped + ":" + get_child(lhs, 0)

            }

            else { "" };

            if ret_cmp == "" { 0 }

            else {

                let colon = find_char(ret_cmp, 0, 58);

                let cmp_op = ret_cmp.slice(0, colon);

                let val = str_to_int(ret_cmp.slice(colon + 1, ret_cmp.len()));

                if cmp_op == ">=" {

                    let cur_lo = vec_get(state, 1);

                    let new_lo = if vec_get(state, 0) == 0 { val } else if val > cur_lo { val } else { cur_lo };

                    let _s0 = vec_set(state, 0, 1);

                    let _s1 = vec_set(state, 1, new_lo);

                    0

                }

                else { match cmp_op { ">" => let bound = val + 1;

                    let cur_lo = vec_get(state, 1);

                    let new_lo = if vec_get(state, 0) == 0 { bound } else if bound > cur_lo { bound } else { cur_lo };

                    let _s0 = vec_set(state, 0, 1);

                    let _s1 = vec_set(state, 1, new_lo);

                    0, "<=" => let cur_hi = vec_get(state, 3);

                    let new_hi = if vec_get(state, 2) == 0 { val } else if val < cur_hi { val } else { cur_hi };

                    let _s0 = vec_set(state, 2, 1);

                    let _s1 = vec_set(state, 3, new_hi);

                    0, _ => match cmp_op { "<" => let bound = val - 1;

                    let cur_hi = vec_get(state, 3);

                    let new_hi = if vec_get(state, 2) == 0 { bound } else if bound < cur_hi { bound } else { cur_hi };

                    let _s0 = vec_set(state, 2, 1);

                    let _s1 = vec_set(state, 3, new_hi);

                    0, "==" => let _s0 = vec_set(state, 0, 1);

                    let _s1 = vec_set(state, 1, val);

                    let _s2 = vec_set(state, 2, 1);

                    let _s3 = vec_set(state, 3, val);

                    0, _ => 0 } } }

            }

        }

    }

    else { 0 };

// Scan tab-separated postcondition ASTs and update range state

fn compute_ret_range_scan(asts: String, pos: i64, state: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= asts.len() { 0 }

    else {

        let tab = find_char(asts, pos, 9);

        let end = if tab >= asts.len() { asts.len() } else { tab };

        let ast = asts.slice(pos, end);

        let _update = update_range_from_ast(ast, state);

        if end >= asts.len() { 0 }

        else { compute_ret_range_scan(asts, end + 1, state) }

    };

// Format range attribute string from bounds

// Returns "range(i64 lo, hi_exclusive) " or ""

fn format_range_attr(has_lo: i64, lo: i64, has_hi: i64, hi_inclusive: i64) -> String

  post it.len() <= 54

= if has_lo == 0 and has_hi == 0 { "" }

    else {

        let lo_str = if has_lo == 1 { int_to_string(lo) } else { "-9223372036854775808" };

        let hi_str = if has_hi == 0 { "-9223372036854775808" }

                    else if hi_inclusive == i64_max() { "-9223372036854775808" }

                    else { int_to_string(hi_inclusive + 1) };

        "range(i64 " + lo_str + ", " + hi_str + ") "

    };

// Compute range attribute from postcondition ASTs

// asts: tab-separated postcondition AST S-expressions

// Returns "range(i64 lo, hi) " or ""

fn compute_ret_range(asts: String) -> String

  post it.len() <= 54

= if asts == "" { "" }

    else {

        let state = vec_new();

        let _p0 = vec_push(state, 0);

        let _p1 = vec_push(state, 0);

        let _p2 = vec_push(state, 0);

        let _p3 = vec_push(state, 0);

        let _scan = compute_ret_range_scan(asts, 0, state);

        format_range_attr(vec_get(state, 0), vec_get(state, 1), vec_get(state, 2), vec_get(state, 3))

    };

// Rebuild IR with range attributes on function definitions

fn range_rebuild(ir: String, pos: i64, sb: i64, post_map: String, count: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= ir.len() { count }

    else {

        let fn_end = find_double_pipe(ir, pos);

        let pipe = find_pipe_in_range(ir, pos, fn_end);

        let header = ir.slice(pos, pipe);

        let pat_pos = find_pattern_noa_range(header, "define private i64 @", 0, header.len());

        let section = if pat_pos >= 0 {

            let at_pos = pat_pos + 20;

            let paren_pos = find_byte_in_range(header, 40, at_pos, header.len());

            let fn_name = if paren_pos < header.len() { header.slice(at_pos, paren_pos) } else { "" };

            let post_asts = if fn_name != "" { lookup_contracts(post_map, fn_name) } else { "" };

            if post_asts == "" { ir.slice(pos, fn_end) }

            else {

                let range_attr = compute_ret_range(post_asts);

                if range_attr == "" { ir.slice(pos, fn_end) }

                else {

                    let insert_pos = pat_pos + 15;

                    let before = header.slice(0, insert_pos);

                    let after = header.slice(insert_pos, header.len());

                    let new_header = before + range_attr + after;

                    let rest = if pipe >= fn_end { "" } else { ir.slice(pipe, fn_end) };

                    new_header + rest

                }

            }

        } else { ir.slice(pos, fn_end) };

        let was_annotated = section.len() != (fn_end - pos);

        let new_count = if was_annotated { count + 1 } else { count };

        let len = sb_len(sb);

        let _w1 = if len > 0 { sb_push(sb, DSEP()) } else { 0 };

        let _w2 = sb_push(sb, section);

        if fn_end + 2 >= ir.len() { new_count }

        else { range_rebuild(ir, fn_end + 2, sb, post_map, new_count) }

    };

// Annotate return range attributes on function definitions from postconditions

fn annotate_return_ranges(module_ir: String, post_map: String) -> String

  post it.len() >= module_ir.len()

= if post_map == "" { module_ir }

    else {

        let sb = sb_new();

        let count = range_rebuild(module_ir, 0, sb, post_map, 0);

        if count == 0 { module_ir }

        else { sb_build(sb) }

    };

// ============================================================================

// String Concat Optimization (SCO) — v0.96.25

// Detects chains of @bmb_string_concat calls in LLVM IR and replaces them

// with @bmb_sb_new + @bmb_sb_push * N + @bmb_sb_build (single allocation).

// Works on the generated LLVM IR text (chr(31)-separated lines).

// ============================================================================

// Check if a trimmed IR line is a @bmb_string_concat call (not concat3/5/7)

// Pattern: "%dest = call ptr @bmb_string_concat(ptr arg1, ptr arg2)"

fn sco_is_concat(line: String) -> bool

  post it == (line.contains("@bmb_string_concat("))

= let p = find_substr_pos(line, "@bmb_string_concat(", 0);

    p >= 0;

// Extract destination from concat call line

// "  %_t2_c = call ptr @bmb_string_concat(ptr a, ptr b)" -> "%_t2_c"

fn sco_dest(line: String) -> String

  post it.len() <= line.len()

= let eq = find_char(line, 0, 61);

    if eq >= line.len() { "" }

    else { trim(line.slice(0, eq)) };

// Extract first arg from concat call

// Find "(ptr " after @bmb_string_concat, then extract until ", ptr "

fn sco_arg1(line: String) -> String

  post it.len() <= line.len()

= let p = find_substr_pos(line, "@bmb_string_concat(ptr ", 0);

    if p < 0 { "" }

    else {

        let start = p + 23;

        let comma = find_substr_pos(line, ", ptr ", start);

        if comma < 0 { "" }

        else { line.slice(start, comma) }

    };

// Extract second arg from concat call

// Find ", ptr " after first arg, then extract until ")"

fn sco_arg2(line: String) -> String

  post it.len() <= line.len()

= let p = find_substr_pos(line, "@bmb_string_concat(ptr ", 0);

    if p < 0 { "" }

    else {

        let start = p + 23;

        let comma = find_substr_pos(line, ", ptr ", start);

        if comma < 0 { "" }

        else {

            let arg2_start = comma + 6;

            let close = find_char(line, arg2_start, 41);

            if close >= line.len() { "" }

            else { line.slice(arg2_start, close) }

        }

    };

// Push a line to the output sb with chr(31) separator between lines

fn sco_push_line(sb: i64, line: String) -> i64

  post it >= 0

= let len = sb_len(sb);

    let _w0 = if len > 0 { sb_push(sb, SEP()) } else { 0 };

    sb_push(sb, line);

// Emit sb_push calls for all operands in a semicolon-separated list

// Returns counter for unique naming

fn sco_emit_pushes(sb: i64, operands: String, pos: i64, sb_var: String, sb_id: i64, counter: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= operands.len() { counter }

    else {

        let semi = find_char(operands, pos, 59);

        let operand = operands.slice(pos, semi);

        let push_line = "  %_sco_p" + i2s(sb_id) + "_" + i2s(counter) + " = call i64 @bmb_sb_push(i64 " + sb_var + ", ptr " + operand + ")";

        let _w = sco_push_line(sb, push_line);

        if semi >= operands.len() { counter + 1 }

        else { sco_emit_pushes(sb, operands, semi + 1, sb_var, sb_id, counter + 1) }

    };

// Count operands (semicolons + 1)

fn sco_count_operands(operands: String) -> i64

  post it >= 0

= sco_count_semis(operands, 0, 1);

fn sco_count_semis(s: String, pos: i64, count: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= s.len() { count }

    else if s.byte_at(pos) == 59 { sco_count_semis(s, pos + 1, count + 1) }

    else { sco_count_semis(s, pos + 1, count) };

// Flush a completed chain. If chain has 3+ operands, emit sb pattern.

// If only 2 operands (single concat), emit original line.

// chain_operands: semicolon-separated operand list

// chain_dest: dest of final concat in chain

// chain_orig: original single concat line (for 2-operand case)

// sb_id: unique StringBuilder ID for this chain

fn sco_flush_chain(sb: i64, chain_operands: String, chain_dest: String, chain_orig: String, sb_id: i64) -> i64

  post it >= 0

= let n = sco_count_operands(chain_operands);

    if n < 3 {

        // Single concat, emit original line

        let _w = sco_push_line(sb, chain_orig);

        sb_id

    } else {

        // Chain of 3+ operands: use StringBuilder pattern

        let sb_var = "%_sco_sb_" + i2s(sb_id);

        let new_line = "  " + sb_var + " = call i64 @bmb_sb_new()";

        let _w1 = sco_push_line(sb, new_line);

        let _w2 = sco_emit_pushes(sb, chain_operands, 0, sb_var, sb_id, 0);

        let build_line = "  " + chain_dest + " = call ptr @bmb_sb_build(i64 " + sb_var + ")";

        let _w3 = sco_push_line(sb, build_line);

        sb_id + 1

    };

// Process a function's IR lines, detecting and transforming concat chains

// State: chain_operands (""=no active chain), chain_dest, chain_orig, sb_id

fn sco_process_lines(ir: String, pos: i64, sb: i64, chain_ops: String, chain_dest: String, chain_orig: String, sb_id: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= ir.len() {

        // End of input, flush any pending chain

        if chain_ops == "" { sb_id }

        else { sco_flush_chain(sb, chain_ops, chain_dest, chain_orig, sb_id) }

    } else {

        let pipe = find_pipe_skip_quotes(ir, pos);

        let line = ir.slice(pos, pipe);

        let trimmed = trim(line);

        if sco_is_concat(trimmed) {

            let dest = sco_dest(trimmed);

            let arg1 = sco_arg1(trimmed);

            let arg2 = sco_arg2(trimmed);

            if chain_ops != "" and arg1 == chain_dest {

                // Extending existing chain: append arg2

                let new_ops = chain_ops + ";" + arg2;

                let next = if pipe >= ir.len() { pipe } else { pipe + 1 };

                sco_process_lines(ir, next, sb, new_ops, dest, chain_orig, sb_id)

            } else {

                // New chain; flush old one first

                let new_sb_id = if chain_ops == "" { sb_id }

                    else { sco_flush_chain(sb, chain_ops, chain_dest, chain_orig, sb_id) };

                // Start new chain with both operands

                let new_ops = arg1 + ";" + arg2;

                let next = if pipe >= ir.len() { pipe } else { pipe + 1 };

                sco_process_lines(ir, next, sb, new_ops, dest, line, new_sb_id)

            }

        } else {

            // Not a concat line; flush any pending chain, emit this line

            let new_sb_id = if chain_ops == "" { sb_id }

                else { sco_flush_chain(sb, chain_ops, chain_dest, chain_orig, sb_id) };

            let _w = sco_push_line(sb, line);

            let next = if pipe >= ir.len() { pipe } else { pipe + 1 };

            sco_process_lines(ir, next, sb, "", "", "", new_sb_id)

        }

    };

// Main entry point: optimize string concat chains in LLVM IR

fn optimize_ir_string_concat(ir: String) -> String

  post it.len() >= 0

= let sb = sb_new();

    let _w = sco_process_lines(ir, 0, sb, "", "", "", 0);

    let result = sb_build(sb);

    let _f = sb_free(sb);

    result;

// ============================================================================

// SECTION 12b: LinearRecurrenceToLoop (IR-level post-processing)

// Detects double-recursive fibonacci pattern:

//   fn fib(n) = if n <= 1 { n } else { fib(n-1) + fib(n-2) }

// Transforms O(2^n) to O(n) iterative loop using prev2, prev1, curr

// ============================================================================

// Extract function name from define line: "define ... @fname(...)" -> "fname"

fn lr2l_fn_name(def_line: String) -> String

  post it.len() <= def_line.len()

= let at = find_char(def_line, 0, 64);

    if at >= def_line.len() { "" }

    else {

        let paren = find_char(def_line, at, 40);

        if paren >= def_line.len() { "" }

        else { def_line.slice(at + 1, paren) }

    };

// Extract single i64 parameter name: "define ... @fn(i64 [noundef] %name) ..." -> "%name"

// Returns "" if not single i64 param

fn lr2l_param_name(def_line: String) -> String

  post it.len() <= def_line.len()

= let at = find_char(def_line, 0, 64);

    if at >= def_line.len() { "" }

    else {

        let open = find_char(def_line, at, 40);

        if open >= def_line.len() { "" }

        else {

            let close = find_char(def_line, open, 41);

            if close >= def_line.len() { "" }

            else {

                let params = trim(def_line.slice(open + 1, close));

                let has_i64 = find_substr_pos(params, "i64 ", 0) >= 0;

                if has_i64 {

                    let comma = find_char(params, 0, 44);

                    if comma < params.len() { "" }

                    else {

                        let pct = find_char(params, 0, 37);

                        if pct >= params.len() { "" }

                        else { params.slice(pct, params.len()) }

                    }

                } else { "" }

            }

        }

    };

// Check if fn_ir matches the fibonacci pattern:

// 1. icmp sle i64 %param, 1 (or slt i64 %param, 2) in entry

// 2. Exactly two self-recursive calls with sub %param, 1 and sub %param, 2

// 3. add nsw combining the two results

fn lr2l_detect(fn_ir: String, fn_name: String, param: String) -> bool

  post not it or fn_ir.contains(fn_name)

= let cmp_pat1 = "icmp sle i64 " + param + ", 1";

    let cmp_pat2 = "icmp slt i64 " + param + ", 2";

    let has_cmp = find_substr_pos(fn_ir, cmp_pat1, 0) >= 0 or find_substr_pos(fn_ir, cmp_pat2, 0) >= 0;

    if has_cmp {

        let call_pat = "call i64 @" + fn_name + "(";

        let first = find_substr_pos(fn_ir, call_pat, 0);

        if first < 0 { false }

        else {

            let second = find_substr_pos(fn_ir, call_pat, first + 1);

            if second < 0 { false }

            else {

                let third = find_substr_pos(fn_ir, call_pat, second + 1);

                if third >= 0 { false }

                else {

                    let sub1a = "sub nsw i64 " + param + ", 1";

                    let sub2a = "sub nsw i64 " + param + ", 2";

                    let sub1b = "sub i64 " + param + ", 1";

                    let sub2b = "sub i64 " + param + ", 2";

                    let has_sub1 = find_substr_pos(fn_ir, sub1a, 0) >= 0 or find_substr_pos(fn_ir, sub1b, 0) >= 0;

                    let has_sub2 = find_substr_pos(fn_ir, sub2a, 0) >= 0 or find_substr_pos(fn_ir, sub2b, 0) >= 0;

                    if not has_sub1 or not has_sub2 { false }

                    else {

                        let has_add = find_substr_pos(fn_ir, "add nsw i64", 0) >= 0 or find_substr_pos(fn_ir, "add i64", 0) >= 0;

                        has_add

                    }

                }

            }

        }

    } else { false };

// Build the transformed function IR with loop structure

fn lr2l_transform(fn_ir: String, _fn_name: String, param: String) -> String

  post it.len() >= 1

= let first_sep = find_pipe_skip_quotes(fn_ir, 0);

    let def_line = fn_ir.slice(0, first_sep);

    let sb = sb_new();

    let _w0 = sb_push(sb, def_line);

    let _w1 = sco_push_line(sb, "entry:");

    let _w2 = sco_push_line(sb, "  %_lr_cmp = icmp sle i64 " + param + ", 1");

    let _w3 = sco_push_line(sb, "  br i1 %_lr_cmp, label %lr_base, label %lr_setup");

    let _w4 = sco_push_line(sb, "lr_base:");

    let _w5 = sco_push_line(sb, "  ret i64 " + param);

    let _w6 = sco_push_line(sb, "lr_setup:");

    let _w7 = sco_push_line(sb, "  br label %lr_header");

    let _w8 = sco_push_line(sb, "lr_header:");

    let _w9 = sco_push_line(sb, "  %_lr_p2 = phi i64 [ 0, %lr_setup ], [ %_lr_p1, %lr_body ]");

    let _w10 = sco_push_line(sb, "  %_lr_p1 = phi i64 [ 1, %lr_setup ], [ %_lr_cur, %lr_body ]");

    let _w11 = sco_push_line(sb, "  %_lr_i = phi i64 [ 2, %lr_setup ], [ %_lr_inx, %lr_body ]");

    let _w12 = sco_push_line(sb, "  %_lr_cond = icmp sle i64 %_lr_i, " + param);

    let _w13 = sco_push_line(sb, "  br i1 %_lr_cond, label %lr_body, label %lr_exit");

    let _w14 = sco_push_line(sb, "lr_body:");

    let _w15 = sco_push_line(sb, "  %_lr_cur = add nsw i64 %_lr_p1, %_lr_p2");

    let _w16 = sco_push_line(sb, "  %_lr_inx = add nsw i64 %_lr_i, 1");


// v0.96.27: Format comma-separated args as i64-typed LLVM call args

// "a, b, c" -> "i64 a, i64 b, i64 c"

// Uses StringBuilder to avoid String-select codegen bug (IfElseToSelect ptr/i64 mismatch)

fn format_i64_args_sb(args: String, pos: i64, sb: i64, first: i64) -> i64

  pre pos >= 0

  post it >= 0

= if pos >= args.len() { 0 }

    else {

        let comma = find_char(args, pos, 44);

        let end_pos = if comma >= args.len() { args.len() } else { comma };

        let arg = trim(args.slice(pos, end_pos));

        let _s = if first == 0 { sb_push(sb, ", ") } else { 0 };

        let _w = sb_push(sb, "i64 ");

        let _w2 = sb_push(sb, arg);

        let next = if comma >= args.len() { args.len() } else { comma + 1 };

        format_i64_args_sb(args, next, sb, 0)

    };

fn format_i64_call_args(args: String) -> String

  post it.len() >= 0

= let sb = sb_new();

    let _w = format_i64_args_sb(args, 0, sb, 1);

    let result = sb_build(sb);

    let _f = sb_free(sb);

    result;

// v0.96.27: Check if a call has exactly 2 args (one comma)

fn call_has_two_args(line: String, paren_pos: i64, close_pos: i64) -> bool

  pre paren_pos >= 0

  post it or not it

= let args = line.slice(paren_pos + 1, close_pos);

    let comma = find_char(args, 0, 44);

    if comma >= args.len() { false }

    else {

        let rest = args.slice(comma + 1, args.len());

        let comma2 = find_char(rest, 0, 44);

        comma2 >= rest.len()

    };

// Cycle 2714: arity guard for 1-arg builtins.

// Returns true iff args slice has no commas (single argument).

fn call_has_one_arg(line: String, paren_pos: i64, close_pos: i64) -> bool

  pre paren_pos >= 0

  post it or not it

= let args = line.slice(paren_pos + 1, close_pos);

    if args.len() == 0 { false }

    else { find_char(args, 0, 44) >= args.len() };

// v0.96.27: Emit regular i64 call for user-defined function

fn emit_regular_i64_call(line: String, paren_pos: i64, close_pos: i64, fn_name: String, dest: String) -> String

  pre paren_pos >= 0

  post it.len() >= 1

= let args = line.slice(paren_pos + 1, close_pos);

    let all_args = format_i64_call_args(args);

    "  " + dest + " = call i64 " + fn_name + "(" + all_args + ")";

// v0.46: Handle different return types (i64, ptr, void)

fn llvm_gen_call(line: String, pos: i64, dest: String) -> String

  pre pos >= 0

  post it.len() >= 1

= let at_pos = find_char(line, pos, 64);

    let paren_pos = find_char(line, at_pos, 40);

    let close_pos = find_char(line, paren_pos, 41);

    let fn_name = line.slice(at_pos, paren_pos);

    if fn_name == "@store_u8" {

        let args = line.slice(paren_pos + 1, close_pos);

        let comma = find_char(args, 0, 44);

        let addr = trim_end(args.slice(0, comma));

        let value = trim(args.slice(comma + 1, args.len()));

        "  " + dest + "_p = inttoptr i64 " + addr + " to ptr" + SEP() + "  " + dest + "_v = trunc i64 " + value + " to i8" + SEP() + "  store i8 " + dest + "_v, ptr " + dest + "_p, align 1" + SEP() + "  " + dest + " = add nsw i64 0, 0"

    } else { match fn_name { "@load_u8" => let addr = trim_end(line.slice(paren_pos + 1, close_pos));

        "  " + dest + "_p = inttoptr i64 " + addr + " to ptr" + SEP() + "  " + dest + "_b = load i8, ptr " + dest + "_p, align 1" + SEP() + "  " + dest + " = zext i8 " + dest + "_b to i64", "@store_i64" => let args = line.slice(paren_pos + 1, close_pos);

        let comma = find_char(args, 0, 44);

        let addr = trim_end(args.slice(0, comma));

        let value = trim(args.slice(comma + 1, args.len()));

        // v0.96.46: TBAA metadata for alias analysis

        "  " + dest + "_p = inttoptr i64 " + addr + " to ptr" + SEP() + "  store i64 " + value + ", ptr " + dest + "_p, align 8, !tbaa !903" + SEP() + "  " + dest + " = add nsw i64 0, 0", "@load_i64" => let addr = trim_end(line.slice(paren_pos + 1, close_pos));

        // v0.96.46: TBAA metadata for alias analysis

        "  " + dest + "_p = inttoptr i64 " + addr + " to ptr" + SEP() + "  " + dest + " = load i64, ptr " + dest + "_p, align 8, !tbaa !903", "@store_f64" => // v0.96.46: Inline store double with TBAA

        let args = line.slice(paren_pos + 1, close_pos);

        let comma = find_char(args, 0, 44);

        let addr = trim_end(args.slice(0, comma));

        let value = trim(args.slice(comma + 1, args.len()));

        "  " + dest + "_p = inttoptr i64 " + addr + " to ptr" + SEP() + "  store double " + value + ", ptr " + dest + "_p, align 8, !tbaa !905" + SEP() + "  " + dest + " = add nsw i64 0, 0", "@load_f64" => // v0.96.46: Inline load double with TBAA

        let addr = trim_end(line.slice(paren_pos + 1, close_pos));

        "  " + dest + "_p = inttoptr i64 " + addr + " to ptr" + SEP() + "  " + dest + "_d = load double, ptr " + dest + "_p, align 8, !tbaa !905" + SEP() + "  " + dest + " = bitcast double " + dest + "_d to i64", "@store_i32" => // v0.96.46: Inline store i32 with TBAA

        let args = line.slice(paren_pos + 1, close_pos);

        let comma = find_char(args, 0, 44);

        let addr = trim_end(args.slice(0, comma));

        let value = trim(args.slice(comma + 1, args.len()));

        "  " + dest + "_p = inttoptr i64 " + addr + " to ptr" + SEP() + "  " + dest + "_v = trunc i64 " + value + " to i32" + SEP() + "  store i32 " + dest + "_v, ptr " + dest + "_p, align 4" + SEP() + "  " + dest + " = add nsw i64 0, 0", "@load_i32" => // v0.96.46: Inline load i32 with sext to i64

        let addr = trim_end(line.slice(paren_pos + 1, close_pos));

        "  " + dest + "_p = inttoptr i64 " + addr + " to ptr" + SEP() + "  " + dest + "_i32 = load i32, ptr " + dest + "_p, align 4" + SEP() + "  " + dest + " = sext i32 " + dest + "_i32 to i64", "@ord" => let arg = trim_end(line.slice(paren_pos + 1, close_pos));

        "  " + dest + " = add nsw i64 0, " + arg, "@i64_to_f64" => let arg = trim_end(line.slice(paren_pos + 1, close_pos));

        "  " + dest + " = sitofp i64 " + arg + " to double", "@f64_to_i64" => let arg = trim_end(line.slice(paren_pos + 1, close_pos));

        "  " + dest + " = fptosi double " + arg + " to i64", "@bmb_string_char_at" => // String struct: {ptr data, i64 len, i64 cap}, byte_at(s, idx) -> s.data[idx] as i64


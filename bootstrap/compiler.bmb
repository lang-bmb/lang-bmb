            let layer = layer_classify(entries, target, calls, callers_count);

            let _l = println_str("  Layer: " + layer_name(layer) + " (calls=" + int_to_string(outline_count_calls(calls, 0, 0)) + " callers=" + int_to_string(callers_count) + ")");

            // Body

            let _b1 = println_str("");


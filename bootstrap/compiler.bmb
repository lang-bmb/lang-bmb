// Emit typed call IR for a registry-resolved function
fn llvm_gen_typed_call(dest: String, fn_name: String, conv: String, args: String, ret_type: String) -> String

  post it.len() >= 1

= if ret_type == "void" {
      conv + "  call void " + fn_name + "(" + args + ")" + SEP() + "  " + dest + " = add nsw i64 0, 0"
  } else { match ret_type {
      "ptr" => conv + "  " + dest + "_ptr = call ptr " + fn_name + "(" + args + ")" + SEP() + "  " + dest + " = ptrtoint ptr " + dest + "_ptr to i64",
      "double" => conv + "  " + dest + " = call double " + fn_name + "(" + args + ")",
      "i32" => conv + "  " + dest + "_i32c = call i32 " + fn_name + "(" + args + ")" + SEP() + "  " + dest + " = sext i32 " + dest + "_i32c to i64",
      _ => conv + "  " + dest + " = call " + ret_type + " " + fn_name + "(" + args + ")"
  } };

fn get_call_arg_types(fn_name: String) -> String

  post it.len() <= fn_name.len()

= // String functions with ptr first arg

    match fn_name { "@stack_bytes_new" => "i", "@stack_i64_new" => "i", "@stack_f64_new" => "i", "@stack_u8_new" => "i", "@stack_i32_new" => "i", "@stack_bool_new" => "i", "@bmb_black_box" => "i", "@bmb_append_file" => "pp", "@bmb_arena_mode" => "i", "@bmb_array_concat" => "pp", "@bmb_array_len" => "p", "@bmb_array_pop" => "p", "@bmb_array_push" => "pi", "@bmb_array_slice" => "pii", "@bmb_delete_file" => "p", "@bmb_exec_output" => "pp", "@bmb_exit" => "i", "@bmb_f64_is_nan" => "d", "@bmb_f64_to_int" => "d", "@bmb_f64_to_string" => "d", "@bmb_file_exists" => "p", "@bmb_file_size" => "p", "@bmb_getenv" => "p", "@bmb_ord" => "p", "@bmb_panic" => "p", "@bmb_panic_bounds" => "ii", "@bmb_panic_divzero" => "", "@bmb_parse_f64" => "p", "@bmb_parse_int" => "p", "@bmb_print_i64" => "i", "@bmb_random_seed" => "i", "@bmb_read_file" => "p", "@bmb_read_line" => "", "@bmb_sb_contains" => "ip", "@bmb_sb_free" => "i", "@bmb_sb_push" => "ip", "@bmb_sb_push_escaped" => "ip", "@bmb_sb_push_f64" => "id", "@bmb_sleep_ms" => "i", "@bmb_str_lines" => "p", "@bmb_string_char_at" => "pi", "@bmb_string_cmp" => "pp", "@bmb_string_concat" => "pp", "@bmb_string_concat3" => "ppp", "@bmb_string_concat5" => "ppppp", "@bmb_string_concat7" => "ppppppp", "@bmb_string_contains" => "pp", "@bmb_string_count" => "pp", "@bmb_string_ends_with" => "pp", "@bmb_string_eq" => "pp", "@bmb_string_free" => "p", "@bmb_string_from_cstr" => "p", "@bmb_string_hash" => "p", "@bmb_string_index_of" => "pp", "@bmb_string_is_empty" => "p", "@bmb_string_join" => "ip", "@bmb_string_last_index_of" => "pp", "@bmb_string_len" => "p", "@bmb_string_new" => "pi", "@bmb_string_pad_left" => "pii", "@bmb_string_pad_right" => "pii", "@bmb_string_repeat" => "pi", "@bmb_string_replace" => "ppp", "@bmb_string_reverse" => "p", "@bmb_string_slice" => "pii", "@bmb_string_split" => "pp", "@bmb_string_starts_with" => "pp", "@bmb_string_substr" => "pii", "@bmb_string_to_lower" => "p", "@bmb_string_to_upper" => "p", "@bmb_string_trim" => "p", "@
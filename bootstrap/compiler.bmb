        let search = ";" + fn_name + ";";

        find_substr_pos(user_fn_names, search, 0) >= 0

    };

// Scan through declarations, keeping non-conflicting ones

fn filter_decls_scan(decls: String, pos: i64, user_fn_names: String, sb: i64) -> i64


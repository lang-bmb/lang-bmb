    // v0.96: LLVM intrinsics replace C runtime math functions

    "declare i64 @llvm.abs.i64(i64, i1)" + SEP() +

    "declare i64 @llvm.smin.i64(i64, i64)" + SEP() +

    "declare i64 @llvm.smax.i64(i64, i64)" + SEP() +


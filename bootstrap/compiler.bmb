            if n == name { callers_get_field(line, 1, 0, 0) + "\t" + callers_get_field(line, 2, 0, 0) }

            else { hot_get_detail(scored, eol + 1, name) }

        }

    };

fn hot_print_top(scored: String, exclude: String, remaining: i64, rank: i64) -> i64


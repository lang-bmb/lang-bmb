  post it == 0

= if pos >= s.len() { 0 }

    else {

        let c = s.byte_at(pos);

        // 92=\, 40=(, 41=), 76=L, 82=R, 66=B

        let _p2 = match c { 92 => let _p3 = sb_push(sb, chr(92));

            sb_push(sb, chr(66)), 40 => let _p4 = sb_push(sb, chr(92));

            sb_push(sb, chr(76)), 41 => let _p5 = sb_push(sb, chr(92));

            sb_push(sb, chr(82)), _ => sb_push(sb, chr(c)) };

        escape_parens_sb(s, pos + 1, sb)

    };

// \L -> (, \R -> ), \B -> \


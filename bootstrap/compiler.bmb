    else { find_field_sep(s, pos + 1) };

// ~ (126) -> \^ (92, 94), \ (92) -> \\ (92, 92)

fn make_work(t: String, f1: String, f2: String, f3: String, f4: String, f5: String) -> String

  post it.len() == t.len() + f1.len() + f2.len() + f3.len() + f4.len() + f5.len() + 5

= t + chr(1) + f1 + chr(1) + f2 + chr(1) + f3 + chr(1) + f4 + chr(1) + f5;

fn make_work3(t: String, f1: String, f2: String, f3: String) -> String

  post it.len() == t.len() + f1.len() + f2.len() + f3.len() + 3

= t + chr(1) + f1 + chr(1) + f2 + chr(1) + f3;

fn work3_get1(item: String) -> String

  post it.len() <= item.len()

= get_field(item, 1);

fn make_work4(t: String, f1: String, f2: String, f3: String, f4: String) -> String

  post it.len() == t.len() + f1.len() + f2.len() + f3.len() + f4.len() + 4

= t + chr(1) + f1 + chr(1) + f2 + chr(1) + f3 + chr(1) + f4;

fn make_work7(t: String, f1: String, f2: String, f3: String, f4: String, f5: String, f6: String, f7: String) -> String

  post it.len() == t.len() + f1.len() + f2.len() + f3.len() + f4.len() + f5.len() + f6.len() + f7.len() + 7

= t + chr(1) + f1 + chr(1) + f2 + chr(1) + f3 + chr(1) + f4 + chr(1) + f5 + chr(1) + f6 + chr(1) + f7;

fn i2s(n: i64) -> String

  pre n >= 0

  post it.len() >= 1

= int_to_string(n);

fn s2i(s: String) -> i64

  post it >= 0

= parse_int_simple(s, 0, 0);

fn parse_int_simple(s: String, pos: i64, acc: i64) -> i64

  pre pos >= 0 and acc >= 0

  post it >= 0

= if pos >= s.len() { acc }

    else {

        let c = s.byte_at(pos);

        if c >= 48 and c <= 57 { parse_int_simple(s, pos + 1, acc * 10 + (c - 48)) }

        else { acc }

    };

// Main iterative lowering entry point

// Uses a result-threaded trampoline: each step receives and returns (temp_id, block_id, exit_label)

fn lower_expr_iter(ast: String, temp_id: i64, block_id: i64, sb: i64) -> i64

  pre temp_id >= 0 and block_id >= 0

  post it >= 0

= let init_work = make_work3("EX", ast, i2s(temp_id), i2s(block_id));

    let exit_sb = sb_new();

    let work_sb = sb_new();

    let result = trampoline_v3(init_work, temp_id, block_id, "", sb, exit_sb, work_sb);

    let _ef = sb_free(exit_sb);

    let _wf = sb_free(work_sb);

    result;

// Trampoline v3: Optimized with reusable SBs and leaf step fast path

// Key optimizations over v2:

// 1. exit_sb and work_sb are reused across steps (clear instead of alloc/free)

// 2. Leaf steps (no new work, unchanged exit/block) use fast path

// 3. Single-pass pipe parsing for step results

fn trampoline_v3(work_stack: String, cur_temp: i64, cur_block: i64, cur_exit_label: String, sb: i64, exit_sb: i64, work_sb: i64) -> i64

  pre cur_temp >= 0 and cur_block >= 0

  post it >= 0

= if work_stack == "" { pack_ids(cur_temp, cur_block) }

    else {

        let _save = bmb_arena_save();

        let item = pop_work_item(work_stack);

        let rest = pop_work_rest(work_stack);

        // Process item with current result (MIR pushed to sb which is malloc-based)

        let step = do_step(item, cur_temp, cur_block, cur_exit_label, sb);

        // Check for leaf step: no pipes = leaf (just temp integer)

        let p1 = find_single_pipe(step, 0);

        if p1 >= step.len() {

            // LEAF FAST PATH: step = just new_temp as string

            // No new work, block and exit_label unchanged

            let new_temp = s2i(step);

            // Only need to preserve rest of work stack

            let _wc = sb_clear(work_sb);

            let _wp = if rest.len() > 0 { sb_push(work_sb, rest) } else { 0 };

            let _restore = bmb_arena_restore();

            let combined = if sb_len(work_sb) == 0 { "" } else { sb_build(work_sb) };

            trampoline_v3(combined, new_temp, cur_block, cur_exit_label, sb, exit_sb, work_sb)

        } else {

            // FULL PATH: parse step result "temp|block|exit_label|work"

            let new_temp = s2i(step.slice(0, p1));

            let p2 = find_single_pipe(step, p1 + 1);

            let new_block = s2i(step.slice(p1 + 1, p2));

            let p3 = find_single_pipe(step, p2 + 1);

            // Copy exit_label to reusable SB (survives restore)

            let _ec = sb_clear(exit_sb);

            let _ep = sb_push(exit_sb, step.slice(p2 + 1, p3));

            // Build combined work stack in reusable SB (survives restore)

            let _wc = sb_clear(work_sb);

            let new_work = if p3 >= step.len() { "" } else { step.slice(p3 + 1, step.len()) };

            let _wp = if new_work == "" and rest == "" { 0 }

                      else if new_work == "" { sb_push(work_sb, rest) }

                      else if rest == "" { sb_push(work_sb, new_work) }

                      else { let _a = sb_push(work_sb, new_work); let _b = sb_push(work_sb, work_sep()); sb_push(work_sb, rest) };

            let _restore = bmb_arena_restore();

            // Rebuild strings from SBs in fresh arena

            let new_exit_label = sb_build(exit_sb);

            let combined = if sb_len(work_sb) == 0 { "" } else { sb_build(work_sb) };

            trampoline_v3(combined, new_temp, new_block, new_exit_label, sb, exit_sb, work_sb)

        }

    };

// Step result: encodes new work items and result

// Format: "new_temp|new_block|exit_label|new_work"

fn make_step(temp: i64, block: i64, exit_label: String, work: String) -> String

  pre temp >= 0

  post it.len() >= 1

= i2s(temp) + SEP() + i2s(block) + SEP() + exit_label + SEP() + work;

// Used by steps that: (1) have no new work, (2) don't change block_id, (3) don't change exit_label

fn make_step_leaf(temp: i64) -> String

  pre temp >= 0

  post it.len() >= 1

= i2s(temp);

fn find_single_pipe(s: String, pos: i64) -> i64

    post it >= -1

= 

    if pos >= s.len() { s.len() }

    else if s.byte_at(pos) == 31 { pos }

    else { find_single_pipe(s, pos + 1) };

// Process a single work item with current result

// Uses first two bytes of work item directly for O(1) dispatch via nested if/else on bytes

fn do_step(item: String, cur_temp: i64, cur_block: i64, cur_exit_label: String, sb: i64) -> String

  pre cur_temp >= 0 and cur_block >= 0

  post it.len() >= 1

= let b0 = item.byte_at(0);

    if b0 == 69 { step_expr(item, cur_temp, cur_block, cur_exit_label, sb) }

    else if b0 == 66 or b0 == 73 { do_step_bi(item, cur_temp, cur_block, cur_exit_label, sb, b0) }

    else if b0 == 83 or b0 == 67 { do_step_sc(item, cur_temp, cur_block, cur_exit_label, sb, b0) }

    else if b0 == 76 or b0 == 65 or b0 == 77 or b0 == 78 or b0 == 86 { do_step_lamv(item, cur_temp, cur_block, cur_exit_label, sb, b0) }

    else { do_step_ufrgtwx(item, cur_temp, cur_block, cur_exit_label, sb, b0) };

fn do_step_bi(item: String, cur_temp: i64, cur_block: i64, cur_exit_label: String, sb: i64, b0: i64) -> String

  pre cur_temp >= 0 and cur_block >= 0

  post it.len() >= 1

= let b1 = item.byte_at(1);

    if b0 == 66 {

        if b1 == 73 { step_binop_start(item, cur_temp, cur_block, cur_exit_label, sb) }

        else { match b1 { 82 => step_binop_right(item, cur_temp, cur_block, cur_exit_label, sb), 70 => step_binop_final(item, cur_temp, cur_block, cur_exit_label, sb), 79 => step_bool(item, cur_temp, cur_block, cur_exit_label, sb), 75 => step_break(item, cur_temp, cur_block, cur_exit_label, sb), _ => make_step_leaf(cur_temp) } }

    } else {

        if b1 == 78 { step_int(item, cur_temp, cur_block, cur_exit_label, sb) }

        else if b1 == 83 { step_if_start(item, cur_temp, cur_block, cur_exit_label, sb) }

        else { match b1 { 84 => step_if_then(item, cur_temp, cur_block, cur_exit_label, sb), 69 => step_if_else(item, cur_temp, cur_block, cur_exit_label, sb), 88 => step_if_final(item, cur_temp, cur_block, cur_exit_label, sb), 90 => step_if_select(item, cur_temp, cur_block, cur_exit_label, sb), _ => make_step_leaf(cur_temp) } }

    };

fn do_step_sc(item: String, cur_temp: i64, cur_block: i64, cur_exit_label: String, sb: i64, b0: i64) -> String

  pre cur_temp >= 0 and cur_block >= 0

  post it.len() >= 1

= let b1 = item.byte_at(1);

    if b0 == 83 {

        if b1 == 84 { step_string(item, cur_temp, cur_block, cur_exit_label, sb) }

        else if b1 == 81 { step_seq_start(item, cur_temp, cur_block, cur_exit_label, sb) }

        else { match b1 { 50 => step_seq_second(item, cur_temp, cur_block, cur_exit_label, sb), 73 => step_set_index_start(item, cur_temp, cur_block, cur_exit_label, sb), 51 => step_set_index_idx(item, cur_temp, cur_block, cur_exit_label, sb), 52 => step_set_index_val(item, cur_temp, cur_block, cur_exit_label, sb), 53 => step_set_index_final(item, cur_temp, cur_block, cur_exit_label, sb), 70 => step_set_field_start(item, cur_temp, cur_block, cur_exit_label, sb), 86 => step_set_var_start(item, cur_temp, cur_block, cur_exit_label, sb), 87 => step_set_var_final(item, cur_temp, cur_block, cur_exit_label, sb), _ => make_step_leaf(cur_temp) } }

    } else {

        if b1 == 83 { step_call_start(item, cur_temp, cur_block, cur_exit_label, sb) }

        else { match b1 { 65 => step_call_arg(item, cur_temp, cur_block, cur_exit_label, sb), 70 => step_call_final(item, cur_temp, cur_block, cur_exit_label, sb), 78 => step_continue(item, cur_temp, cur_block, cur_exit_label, sb), 54 => step_cast_to_i64(item, cur_temp, cur_block, cur_exit_label, sb), _ => make_step_leaf(cur_temp) } }

    };

fn do_step_lamv(item: String, cur_temp: i64, cur_block: i64, cur_exit_label: String, sb: i64, b0: i64) -> String

  pre cur_temp >= 0 and cur_block >= 0

  post it.len() >= 1

= let b1 = item.byte_at(1);

    if b0 == 76 {

        if b1 == 83 { step_let_start(item, cur_temp, cur_block, cur_exit_label, sb) }

        else if b1 == 66 { step_let_body(item, cur_temp, cur_block, cur_exit_label, sb) }

        else { make_step_leaf(cur_temp) }

    } else if b0 == 65 {

        if b1 == 83 { step_assign_start(item, cur_temp, cur_block, cur_exit_label, sb) }

        else if b1 == 70 { step_assign_final(item, cur_temp, cur_block, cur_exit_label, sb) }

        else { match b1 { 73 => step_array_index_start(item, cur_temp, cur_block, cur_exit_label, sb), 50 => step_array_index_idx(item, cur_temp, cur_block, cur_exit_label, sb), 51 => step_array_index_final(item, cur_temp, cur_block, cur_exit_label, sb), 76 => step_array_literal(item, cur_temp, cur_block, cur_exit_label, sb), 82 => step_array_repeat(item, cur_temp, cur_block, cur_exit_label, sb), _ => make_step_leaf(cur_temp) } }

    } else if b0 == 77 {

        if b1 == 83 { step_method_start(item, cur_temp, cur_block, cur_exit_label, sb) }

        else { match b1 { 65 => step_method_arg(item, cur_temp, cur_block, cur_exit_label, sb), 70 => step_method_final(item, cur_temp, cur_block, cur_exit_label, sb), _ => make_step_leaf(cur_temp) } }

    } else if b0 == 78 {

        if b1 == 82 { step_nullable_result(item, cur_temp, cur_block, cur_exit_label, sb) }

        else if b1 == 79 { step_nullable_or(item, cur_temp, cur_block, cur_exit_label, sb) }

        else { make_step_leaf(cur_temp) }

    } else {

        if b1 == 65 { step_var(item, cur_temp, cur_block, cur_exit_label, sb) }

        else { match b1 { 77 => step_mut_start(item, cur_temp, cur_block, cur_exit_label, sb), 66 => step_mut_body(item, cur_temp, cur_block, cur_exit_label, sb), _ => make_step_leaf(cur_temp) } }

    };

fn do_step_ufrgtwx(item: String, cur_temp: i64, cur_block: i64, cur_exit_label: String, sb: i64, b0: i64) -> String

  pre cur_temp >= 0 and cur_block >= 0

  post it.len() >= 1

= let b1 = item.byte_at(1);

    if b0 == 85 {

        if b1 == 78 { step_unary_start(item, cur_temp, cur_block, cur_exit_label, sb) }

        else { match b1 { 70 => step_unary_final(item, cur_temp, cur_block, cur_exit_label, sb), 84 => step_unit(item, cur_temp, cur_block, cur_exit_label, sb), _ => make_step_leaf(cur_temp) } }

    } else if b0 == 70 {

        if b1 == 76 { step_float(item, cur_temp, cur_block, cur_exit_label, sb) }

        else { match b1 { 65 => step_field_access_start(item, cur_temp, cur_block, cur_exit_label, sb), 50 => step_field_access_final(item, cur_temp, cur_block, cur_exit_label, sb), 80 => step_cast_ptr_f64_start(item, cur_temp, cur_block, cur_exit_label, sb), 81 => step_cast_ptr_f64_finish(item, cur_temp, cur_block, cur_exit_label, sb), _ => make_step_leaf(cur_temp) } }

    } else if b0 == 82 {

        if b1 == 84 { step_return(item, cur_temp, cur_block, cur_exit_label, sb) }

        else if b1 == 86 { step_return_value(item, cur_temp, cur_block, cur_exit_label, sb) }

        else { make_step_leaf(cur_temp) }

    } else if b0 == 71 {

        if b1 == 50 { step_set_field_val(item, cur_temp, cur_block, cur_exit_label, sb) }

        else if b1 == 51 { step_set_field_final(item, cur_temp, cur_block, cur_exit_label, sb) }

        else { make_step_leaf(cur_temp) }

    } else if b0 == 84 { step_tuple(item, cur_temp, cur_block, cur_exit_label, sb) }

    else if b0 == 87 { step_cast_to_i32(item, cur_temp, cur_block, cur_exit_label, sb) }

    else if b0 == 88 { step_cast_to_f64(item, cur_temp, cur_block, cur_exit_label, sb) }

    else { make_step_leaf(cur_temp) };


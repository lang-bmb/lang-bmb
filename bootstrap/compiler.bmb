  post it == 0

= if pos >= s.len() { 0 }

    else if s.byte_at(pos) == 92 and pos + 1 < s.len() {

        let next = s.byte_at(pos + 1);

        // 76=L -> 40=(, 82=R -> 41=), 66=B -> 92=\

        let _q2 = match next { 76 => sb_push(sb, chr(40)), 82 => sb_push(sb, chr(41)), 66 => sb_push(sb, chr(92)), _ => let _q3 = sb_push(sb, chr(92));


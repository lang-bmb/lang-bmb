// ============================================================================

// v0.95: For-Loop Range Lowering

// ============================================================================

// AST: (for <varname> start_ast end_ast body_ast)

// MIR:

//   alloca %varname

//   <start code> -> %_tS

//   store %varname, %_tS

//   <end code> -> %_tE

//   goto for_start_N

// for_start_N:

//   %_tL = load %varname -> resolves via alloca/load in codegen

//   %_tC = < %_tL, %_tE

//   branch %_tC, for_body_N, for_end_N

// for_body_N:

//   <body code>

//   %_tI = load %varname

//   %_tI+1 = const 1

//   %_tI+2 = + %_tI, %_tI+1

//   store %varname, %_tI+2

//   goto for_start_N

// for_end_N:

//   %_tR = const 0  ; for returns unit

fn extract_for_varname_from_ast(ast: String) -> String

  post it.len() <= ast.len()

= let raw = get_child(ast, 0);

    if raw.len() < 3 { "" } else if raw.byte_at(0) != 60 { raw } else { raw.slice(1, raw.len() - 1) };

// cmp_op: "< " for exclusive (..), "<= " for inclusive (..=)

fn lower_for_range_sb(ast: String, temp_id: i64, block_id: i64, sb: i64, _loop_exit: String, cmp_op: String) -> i64

  pre temp_id >= 0 and block_id >= 0

  post it >= 0

= let varname = extract_for_varname_from_ast(ast);

    let unique_var = varname + "_" + int_to_string(temp_id);

    let start_ast = get_child(ast, 1);

    let end_ast = get_child(ast, 2);

    let body_raw = get_child(ast, 3);

    // Rename all <varname> references in body to <unique_var>

    let body_ast = rename_name_in_ast(body_raw, varname, unique_var);

    let for_start_lbl = "for_start_" + int_to_string(block_id);

    let for_body_lbl = "for_body_" + int_to_string(block_id);

    let for_end_lbl = "for_end_" + int_to_string(block_id);

    let _w0 = sb_push_mir(sb, "  alloca %" + unique_var);

    let start_result = lower_expr_sb(start_ast, temp_id, block_id + 1, sb, "");

    let start_temp = unpack_temp(start_result);

    let start_block = unpack_block(start_result);

    let start_id = start_temp - 1;

    let _w1 = sb_push_mir(sb, "  store %" + unique_var + ", %_t" + int_to_string(start_id));

    let end_result = lower_expr_sb(end_ast, start_temp, start_block, sb, "");

    let end_temp = unpack_temp(end_result);

    let end_block = unpack_block(end_result);

    let end_id = end_temp - 1;

    let goto_start = "  goto " + for_start_lbl;

    let _w2 = sb_push_mir(sb, goto_start);

    let start_label_text = for_start_lbl + ":";

    let _w3 = sb_push_mir(sb, start_label_text);

    let load_tmp = "%_t" + int_to_string(end_temp);

    let load_text = "  " + load_tmp + " = copy %" + unique_var;

    let _w4 = sb_push_mir(sb, load_text);

    let cmp_tmp = "%_t" + int_to_string(end_temp + 1);

    let cmp_text = "  " + cmp_tmp + " = " + cmp_op + load_tmp + ", %_t" + int_to_string(end_id);

    let _w5 = sb_push_mir(sb, cmp_text);

    let branch_text = "  branch " + cmp_tmp + ", " + for_body_lbl + ", " + for_end_lbl;

    let _w6 = sb_push_mir(sb, branch_text);

    let body_label_text = for_body_lbl + ":";

    let _w7 = sb_push_mir(sb, body_label_text);

    // Lower body - pass THIS for's end label so break can jump to it

    let body_result = lower_expr_sb(body_ast, end_temp + 2, end_block, sb, for_end_lbl);

    let body_temp = unpack_temp(body_result);

    let body_block = unpack_block(body_result);

    // for_inc_N label: continue jumps here (before increment, not for_start)

    // Need goto before label to satisfy LLVM basic block terminator requirement

    let for_inc_lbl = "for_inc_" + int_to_string(block_id);

    let goto_inc = "  goto " + for_inc_lbl;

    let _w7b = sb_push_mir(sb, goto_inc);

    let inc_label_text = for_inc_lbl + ":";

    let _w7c = sb_push_mir(sb, inc_label_text);

    let inc_load_tmp = "%_t" + int_to_string(body_temp);

    let inc_load_text = "  " + inc_load_tmp + " = copy %" + unique_var;

    let _w8 = sb_push_mir(sb, inc_load_text);

    let one_tmp = "%_t" + int_to_string(body_temp + 1);

    let one_text = "  " + one_tmp + " = const 1";

    let _w9 = sb_push_mir(sb, one_text);

    let inc_tmp = "%_t" + int_to_string(body_temp + 2);

    let inc_text = "  " + inc_tmp + " = + " + inc_load_tmp + ", " + one_tmp;

    let _w10 = sb_push_mir(sb, inc_text);

    let store_text = "  store %" + unique_var + ", " + inc_tmp;

    let _w11 = sb_push_mir(sb, store_text);

    let goto_start2 = "  goto " + for_start_lbl;

    let _w12 = sb_push_mir(sb, goto_start2);

    let end_label_text = for_end_lbl + ":";

    let _w13 = sb_push_mir(sb, end_label_text);

    let result_tmp = "%_t" + int_to_string(body_temp + 3);

    let result_text = "  " + result_tmp + " = const 0";

    let _w14 = sb_push_mir(sb, result_text);

    pack_ids(body_temp + 4, body_block);

fn lower_for_sb(ast: String, temp_id: i64, block_id: i64, sb: i64, loop_exit: String) -> i64

  pre temp_id >= 0 and block_id >= 0

  post it >= 0

= lower_for_range_sb(ast, temp_id, block_id, sb, loop_exit, "< ");

fn lower_for_incl_sb(ast: String, temp_id: i64, block_id: i64, sb: i64, loop_exit: String) -> i64

  pre temp_id >= 0 and block_id >= 0

  post it >= 0

= lower_for_range_sb(ast, temp_id, block_id, sb, loop_exit, "<= ");

// for_step: (for_step <var> start end step body) — children: 1=start, 2=end, 3=step, 4=body

fn lower_for_step_range_sb(ast: String, temp_id: i64, block_id: i64, sb: i64, _loop_exit: String, cmp_op: String) -> i64

  pre temp_id >= 0 and block_id >= 0

  post it >= 0

= let varname = extract_for_varname_from_ast(ast);

    let unique_var = varname + "_" + int_to_string(temp_id);

    let start_ast = get_child(ast, 1);

    let end_ast = get_child(ast, 2);

    let step_ast = get_child(ast, 3);

    let body_raw = get_child(ast, 4);

    let body_ast = rename_name_in_ast(body_raw, varname, unique_var);

    let for_start_lbl = "for_start_" + int_to_string(block_id);

    let for_body_lbl = "for_body_" + int_to_string(block_id);

    let for_end_lbl = "for_end_" + int_to_string(block_id);

    let _w0 = sb_push_mir(sb, "  alloca %" + unique_var);

    let start_result = lower_expr_sb(start_ast, temp_id, block_id + 1, sb, "");

    let start_temp = unpack_temp(start_result);

    let start_block = unpack_block(start_result);

    let start_id = start_temp - 1;

    let _w1 = sb_push_mir(sb, "  store %" + unique_var + ", %_t" + int_to_string(start_id));

    let end_result = lower_expr_sb(end_ast, start_temp, start_block, sb, "");

    let end_temp = unpack_temp(end_result);

    let end_block = unpack_block(end_result);

    let end_id = end_temp - 1;

    // Lower step expression

    let step_result = lower_expr_sb(step_ast, end_temp, end_block, sb, "");

    let step_temp = unpack_temp(step_result);

    let step_block = unpack_block(step_result);

    let step_id = step_temp - 1;

    let goto_start = "  goto " + for_start_lbl;

    let _w2 = sb_push_mir(sb, goto_start);

    let start_label_text = for_start_lbl + ":";

    let _w3 = sb_push_mir(sb, start_label_text);

    let load_tmp = "%_t" + int_to_string(step_temp);

    let load_text = "  " + load_tmp + " = copy %" + unique_var;

    let _w4 = sb_push_mir(sb, load_text);

    let cmp_tmp = "%_t" + int_to_string(step_temp + 1);

    let cmp_text = "  " + cmp_tmp + " = " + cmp_op + load_tmp + ", %_t" + int_to_string(end_id);

    let _w5 = sb_push_mir(sb, cmp_text);

    let branch_text = "  branch " + cmp_tmp + ", " + for_body_lbl + ", " + for_end_lbl;

    let _w6 = sb_push_mir(sb, branch_text);

    let body_label_text = for_body_lbl + ":";

    let _w7 = sb_push_mir(sb, body_label_text);

    let body_result = lower_expr_sb(body_ast, step_temp + 2, step_block, sb, for_end_lbl);

    let body_temp = unpack_temp(body_result);

    let body_block = unpack_block(body_result);

    let for_inc_lbl = "for_inc_" + int_to_string(block_id);

    let goto_inc = "  goto " + for_inc_lbl;

    let _w7b = sb_push_mir(sb, goto_inc);

    let inc_label_text = for_inc_lbl + ":";

    let _w7c = sb_push_mir(sb, inc_label_text);

    let inc_load_tmp = "%_t" + int_to_string(body_temp);

    let inc_load_text = "  " + inc_load_tmp + " = copy %" + unique_var;

    let _w8 = sb_push_mir(sb, inc_load_text);

    // Use step expression result instead of const 1

    let inc_tmp = "%_t" + int_to_string(body_temp + 1);

    let inc_text = "  " + inc_tmp + " = + " + inc_load_tmp + ", %_t" + int_to_string(step_id);

    let _w10 = sb_push_mir(sb, inc_text);

    let store_text = "  store %" + unique_var + ", " + inc_tmp;

    let _w11 = sb_push_mir(sb, store_text);

    let goto_start2 = "  goto " + for_start_lbl;

    let _w12 = sb_push_mir(sb, goto_start2);

    let end_label_text = for_end_lbl + ":";

    let _w13 = sb_push_mir(sb, end_label_text);

    let result_tmp = "%_t" + int_to_string(body_temp + 2);

    let result_text = "  " + result_tmp + " = const 0";

    let _w14 = sb_push_mir(sb, result_text);

    pack_ids(body_temp + 3, body_block);

fn lower_for_step_sb(ast: String, temp_id: i64, block_id: i64, sb: i64, loop_exit: String) -> i64

  pre temp_id >= 0 and block_id >= 0

  post it >= 0

= lower_for_step_range_sb(ast, temp_id, block_id, sb, loop_exit, "< ");

fn lower_for_step_incl_sb(ast: String, temp_id: i64, block_id: i64, sb: i64, loop_exit: String) -> i64

  pre temp_id >= 0 and block_id >= 0

  post it >= 0

= lower_for_step_range_sb(ast, temp_id, block_id, sb, loop_exit, "<= ");

// Extract lhs from (assign lhs rhs)

fn assign_lhs_expr(ast: String) -> String

  post it.len() <= ast.len()

= let len = ast.len();

    if len < 15 { "" } else {

        let content = ast.slice(8, len - 1);

        find_first_balanced(content, 0, 0, "")

    };

// Extract rhs from (assign lhs rhs)

fn assign_rhs_expr(ast: String) -> String

  post it.len() <= ast.len()

= let len = ast.len();

    if len < 15 { "" } else {

        let content = ast.slice(8, len - 1);

        find_rest_balanced(content, 0, 0)

    };

// Extract variable name from (var <name>)

// v0.92: Fixed guard from < 10 to < 9 to handle single-char variable names

fn extract_var_from_assign(ast: String) -> String

  post it.len() <= ast.len()

= let len = ast.len();

    if len < 9 { "" } else {

        // (var <name>) -> skip "(var <" = 6, remove ">)" = 2

        ast.slice(6, len - 2)

    };

fn get_fn_annotation(ast: String) -> String

  post it.len() <= ast.len()

= let nt = get_node_type(ast);

    if nt == "fn-pure" { "pure" }

    else { match nt { "fn-const" => "const", "fn-inline" => "inline", _ => "" } };

// M12 Phase 2: Extract the effect row string from a fn AST node.
// Returns e.g. "IO Net" if the fn has (eff IO Net) child, "" otherwise.

fn get_fn_effect_row(ast: String) -> String

  post it.len() >= 0

= let content = extract_paren_content(ast);

    get_fn_eff_scan(content, 0);

fn get_fn_eff_scan(content: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= let p = low_skip_ws(content, pos);

    if p >= content.len() { "" } else {

        let child = read_sexp_at(content, p);

        if child == "" { "" }

        else if child.len() > 0 and child.byte_at(0) == 40 {

            let ntype = get_node_type(child);

            if ntype == "eff" {
                // (eff IO Net) -> skip "eff " prefix -> "IO Net"
                let inner = extract_paren_content(child);
                let after_eff = low_skip_ws(inner, 3);  // skip "eff"
                str_trim(inner.slice(after_eff, inner.len()))
            }

            else if ntype == "param" { get_fn_eff_scan(content, p + child.len()) }

            else { "" }

        } else { get_fn_eff_scan(content, p + child.len()) }

    };

// Rewrite (index (var <name>)) to (ptr_index (var <name>)) for raw pointer params

// This ensures raw pointer indexing skips the +2 array header offset

fn rewrite_ptr_index(body: String, ast: String, idx: i64) -> String

  pre idx >= 0

  post it.len() >= 0

= let child = get_child(ast, idx);

    if child == "" or get_node_type(child) != "param" { body } else {

        let param_name_raw = get_child(child, 0);

        let name = if param_name_raw.len() >= 2 and param_name_raw.byte_at(0) == 60 { param_name_raw.slice(1, param_name_raw.len() - 1) } else { param_name_raw };

        let param_type_raw = get_child(child, 1);

        // M11-C Phase 8: typed pointer parameter subscript
        // get_child(child, 1) always returns "*" for pointer params (op-char scan stops at ident)
        // get_child(child, 2) gives the type suffix: "", "u8", "i32", "i64", "f64", "bool", "StructName"
        // Bare * (suffix="")   : i64 stride (ptr_index/set_ptr_index)
        // *i64  (suffix="i64") : i64 stride (same as bare *)
        // *StructName          : i64 stride (struct ptr, no subscript rewrite needed but same path)
        // *u8   (suffix="u8")  : 1-byte stride (ptr_index_u8/set_ptr_index_u8)
        // *i32  (suffix="i32") : 4-byte stride (ptr_index_i32/set_ptr_index_i32)
        // *bool (suffix="bool"): 1-byte stride (ptr_index_bool/set_ptr_index_bool)
        // *f64  (suffix="f64") : 8-byte double stride (ptr_index_f64/set_ptr_index_f64)

        let new_body = if param_type_raw == "*" {

            let type_suffix = get_child(child, 2);

            if type_suffix == "u8" {

                let b2 = body.replace("(index (var <" + name + ">)", "(ptr_index_u8 (var <" + name + ">)");

                b2.replace("(set_index (var <" + name + ">)", "(set_ptr_index_u8 (var <" + name + ">)")

            } else if type_suffix == "i32" {

                let b2 = body.replace("(index (var <" + name + ">)", "(ptr_index_i32 (var <" + name + ">)");

                b2.replace("(set_index (var <" + name + ">)", "(set_ptr_index_i32 (var <" + name + ">)")

            } else if type_suffix == "f64" {

                let b2 = body.replace("(index (var <" + name + ">)", "(ptr_index_f64 (var <" + name + ">)");

                b2.replace("(set_index (var <" + name + ">)", "(set_ptr_index_f64 (var <" + name + ">)")

            } else if type_suffix == "bool" {

                let b2 = body.replace("(index (var <" + name + ">)", "(ptr_index_bool (var <" + name + ">)");

                b2.replace("(set_index (var <" + name + ">)", "(set_ptr_index_bool (var <" + name + ">)")

            } else {

                -- bare *, *i64, *StructName — all use i64 stride (existing behavior)

                let b2 = body.replace("(index (var <" + name + ">)", "(ptr_index (var <" + name + ">)");

                b2.replace("(set_index (var <" + name + ">)", "(set_ptr_index (var <" + name + ">)")

            }

        } else { body };

        rewrite_ptr_index(new_body, ast, idx + 1)

    };

// M11-C Phase 3: scan backwards for character (used by rewrite_stack_i64_index)

fn find_char_back(s: String, ch: i64, pos: i64) -> i64

  pre pos >= -1

  post it >= -1

= if pos < 0 { -1 }

    else if s.byte_at(pos) == ch { pos }

    else { find_char_back(s, ch, pos - 1) };

// M11-C Phase 3: rewrite (index (var <name>)) -> (ptr_index (var <name>)) for [i64; N] stack arrays

// Scans body for "> (call <stack_i64_new>" pattern to find binding names

fn rewrite_stack_i64_index(body: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= let needle = "> (call <stack_i64_new>";

    let found = find_pattern_at(body, needle, pos);

    if found < 0 { body }

    else {

        let lt_pos = find_char_back(body, 60, found - 1);

        if lt_pos < 0 { rewrite_stack_i64_index(body, found + 1) }

        else {

            let name = body.slice(lt_pos + 1, found);

            let b2 = body.replace("(index (var <" + name + ">)", "(ptr_index (var <" + name + ">)");

            let b3 = b2.replace("(set_index (var <" + name + ">)", "(set_ptr_index (var <" + name + ">)");

            rewrite_stack_i64_index(b3, found + needle.len())

        }

    };

// M11-C Phase 4: rewrite (index (var <name>)) -> (ptr_index_u8 (var <name>)) for [u8; N] stack arrays

fn rewrite_stack_u8_index(body: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= let needle = "> (call <stack_u8_new>";

    let found = find_pattern_at(body, needle, pos);

    if found < 0 { body }

    else {

        let lt_pos = find_char_back(body, 60, found - 1);

        if lt_pos < 0 { rewrite_stack_u8_index(body, found + 1) }

        else {

            let name = body.slice(lt_pos + 1, found);

            let b2 = body.replace("(index (var <" + name + ">)", "(ptr_index_u8 (var <" + name + ">)");

            let b3 = b2.replace("(set_index (var <" + name + ">)", "(set_ptr_index_u8 (var <" + name + ">)");

            rewrite_stack_u8_index(b3, found + needle.len())

        }

    };

// M11-C Phase 5: rewrite (index (var <name>)) -> (ptr_index_i32 (var <name>)) for [i32; N] stack arrays

fn rewrite_stack_i32_index(body: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= let needle = "> (call <stack_i32_new>";

    let found = find_pattern_at(body, needle, pos);

    if found < 0 { body }

    else {

        let lt_pos = find_char_back(body, 60, found - 1);

        if lt_pos < 0 { rewrite_stack_i32_index(body, found + 1) }

        else {

            let name = body.slice(lt_pos + 1, found);

            let b2 = body.replace("(index (var <" + name + ">)", "(ptr_index_i32 (var <" + name + ">)");

            let b3 = b2.replace("(set_index (var <" + name + ">)", "(set_ptr_index_i32 (var <" + name + ">)");

            rewrite_stack_i32_index(b3, found + needle.len())

        }

    };

// M11-C Phase 6: rewrite (index (var <name>)) -> (ptr_index_bool (var <name>)) for [bool; N] stack arrays

fn rewrite_stack_bool_index(body: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= let needle = "> (call <stack_bool_new>";

    let found = find_pattern_at(body, needle, pos);

    if found < 0 { body }

    else {

        let lt_pos = find_char_back(body, 60, found - 1);

        if lt_pos < 0 { rewrite_stack_bool_index(body, found + 1) }

        else {

            let name = body.slice(lt_pos + 1, found);

            let b2 = body.replace("(index (var <" + name + ">)", "(ptr_index_bool (var <" + name + ">)");

            let b3 = b2.replace("(set_index (var <" + name + ">)", "(set_ptr_index_bool (var <" + name + ">)");

            rewrite_stack_bool_index(b3, found + needle.len())

        }

    };

// M11-C Phase 7: rewrite (index (var <name>)) -> (ptr_index_f64 (var <name>)) for [f64; N] stack arrays

fn rewrite_stack_f64_index(body: String, pos: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= let needle = "> (call <stack_f64_new>";

    let found = find_pattern_at(body, needle, pos);

    if found < 0 { body }

    else {

        let lt_pos = find_char_back(body, 60, found - 1);

        if lt_pos < 0 { rewrite_stack_f64_index(body, found + 1) }

        else {

            let name = body.slice(lt_pos + 1, found);

            let b2 = body.replace("(index (var <" + name + ">)", "(ptr_index_f64 (var <" + name + ">)");

            let b3 = b2.replace("(set_index (var <" + name + ">)", "(set_ptr_index_f64 (var <" + name + ">)");

            rewrite_stack_f64_index(b3, found + needle.len())

        }

    };

fn rewrite_all_stack_index(body: String) -> String

  post it.len() >= 0

= let b_i64 = rewrite_stack_i64_index(body, 0);

    let b_u8 = rewrite_stack_u8_index(b_i64, 0);

    let b_i32 = rewrite_stack_i32_index(b_u8, 0);

    let b_bool = rewrite_stack_bool_index(b_i32, 0);

    rewrite_stack_f64_index(b_bool, 0);

fn lower_function_sb(ast: String, safe: i64) -> String

  pre safe >= 0

  post it.len() >= 1

= let name = extract_name(ast);

    let params = collect_params(ast, 1, "");

    let ret_type = get_fn_return_type(ast);

    let ann = get_fn_annotation(ast);

    let body_ast_raw = get_fn_body(ast);

    // Rewrite index/set_index to ptr_index/set_ptr_index for raw pointer params

    let body_ast_ptr = rewrite_ptr_index(body_ast_raw, ast, 1);

    // M11-C Phase 3-7: rewrite stack [i64/u8/i32/bool/f64;N] subscripts to ptr_index

    let body_ast = rewrite_all_stack_index(body_ast_ptr);

    let sb_raw = sb_new();

    // Cycle 3235: sb = sb_raw * 4 + is_inline * 2 + safe (bit0=safe, bit1=is_inline)

    let is_inline = if ann == "inline" { 1 } else { 0 };

    let sb = sb_raw * 4 + is_inline * 2 + safe;

    let final_result = lower_expr_iter(body_ast, 0, 0, sb);

    let final_temp = unpack_temp(final_result);

    let result_id = final_temp - 1;

    let _w1 = sb_push_mir(sb, "  return %_t" + int_to_string(result_id));

    let body_mir_raw = sb_build(sb_raw);

    let ann_suffix = if ann == "" { "" } else { " @" + ann };

    // M12 Phase 2: Add @effect attribute if function has effect row annotation
    let eff_row = get_fn_effect_row(ast);
    let ann_suffix2 = if eff_row == "" { ann_suffix } else { ann_suffix + " @effect:" + eff_row };

    // v0.95: Extract lambda functions delimited by chr(1) markers

    let lambda_fns = extract_lambda_fns(body_mir_raw, 0, "");

    let body_mir = remove_lambda_markers(body_mir_raw, 0, sb_new());

    let main_fn = "fn " + name + "(" + params + ") -> " + ret_type + ann_suffix2 + " {" + SEP() + "entry:" + SEP() + body_mir + SEP() + "}";

    if lambda_fns == "" { main_fn } else { main_fn + DSEP() + lambda_fns };

// v0.95: Extract lambda function MIR from chr(1)-delimited markers

// Scans body_mir for chr(1)...chr(1) pairs and collects the content

fn extract_lambda_fns(s: String, pos: i64, acc: String) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= s.len() { acc }

    else if s.byte_at(pos) == 1 {

        // Found start marker, find end marker

        let end = find_char(s, pos + 1, 1);

        let lambda_fn = s.slice(pos + 1, end);

        let new_acc = if acc == "" { lambda_fn } else { acc + DSEP() + lambda_fn };

        if end + 1 >= s.len() { new_acc } else { extract_lambda_fns(s, end + 1, new_acc) }

    }

    else { extract_lambda_fns(s, pos + 1, acc) };

// v0.95: Remove chr(1)-delimited lambda markers from body MIR

// Returns the body with all chr(1)...chr(1) sections removed

fn remove_lambda_markers(s: String, pos: i64, out_sb: i64) -> String

  pre pos >= 0

  post it.len() >= 0

= if pos >= s.len() { sb_build(out_sb) }

    else if s.byte_at(pos) == 1 {

        // Skip chr(1)...chr(1) section

        let end = find_char(s, pos + 1, 1);

        if end + 1 >= s.len() { sb_build(out_sb) }

        else { remove_lambda_markers(s, end + 1, out_sb) }

    }

    else {

        let _w = sb_push_char(out_sb, s.byte_at(pos));

        remove_lambda_markers(s, pos + 1, out_sb)

    };

fn lower_program_sb(ast: String, safe: i64) -> String

  pre safe >= 0

  post it.len() >= 0

= let sb = sb_new();

    let _w1 = lower_program_inner_sb(ast, 0, sb, safe);

    sb_build(sb);

fn lower_program_inner_sb(ast: String, idx: i64, sb: i64, safe: i64) -> i64

  pre idx >= 0 and safe >= 0

  post it >= 0

= let fn_ast = get_child(ast, idx);

    if fn_ast.len() == 0 or fn_ast == "" { 0 } else if is_fn_node(fn_ast) {

        let _save = bmb_arena_save();

        let fn_mir = lower_function_sb(fn_ast, safe);

        let len = sb_len(sb);

        let _w1 = if len > 0 { sb_push(sb, DSEP()) } else { 0 };

        let _w2 = sb_push(sb, fn_mir);

        let _restore = bmb_arena_restore();

        lower_program_inner_sb(ast, idx + 1, sb, safe)

    } else { 0 };

// ============================================================================

// SECTION 9: Expression Lowering

// ============================================================================

fn collect_params(ast: String, idx: i64, acc: String) -> String

    pre idx >= 0

    post it.len() >= 0

=

    let child = get_child(ast, idx);

    if child == "" or get_node_type(child) != "param" { acc } else {

        let param_name = get_child(child, 0);

        let name = if param_name.len() >= 2 and param_name.byte_at(0) == 60 { param_name.slice(1, param_name.len() - 1) } else { param_name };

        let param_type_raw = get_child(child, 1);

        let param_type = if param_type_raw == "*" { let sname = get_child(child, 2); "*" + sname } else { param_type_raw };

        let entry = name + ": " + param_type;

        let new_acc = if acc == "" { entry } else { acc + ", " + entry };

        collect_params(ast, idx + 1, new_acc)

    };

fn get_fn_return_type(ast: String) -> String

  post it.len() <= ast.len()

= let content = extract_paren_content(ast);

    get_fn_return_scan(content, 0);

// v0.46: Added String return type support

// M5-5c: recognize "Array<String>" — emitted by parse_return_type as two sexp tokens:

// "Array" followed by "<String>" because read_sexp_at stops ident at '<'

fn get_fn_return_scan(content: String, pos: i64) -> String

    pre pos >= 0

    post it.len() >= 1

=

    let p = low_skip_ws(content, pos);

    if p >= content.len() { "i64" } else {

        if content.byte_at(p) == 42 {

            // Read the struct name after *

            let name_start = p + 1;

            let name_end = low_find_ident_end(content, name_start);

            if name_end > name_start { "*" + content.slice(name_start, name_end) }

            else { "i64" }

        } else {

            let child = read_sexp_at(content, p);

            if child == "" { "i64" }

            else if child == "i32" or child == "i64" or child == "f64" or child == "bool" or child == "String" or child == "ptr" { child }

            else if child == "Array" {

                // Check if next token is "<String>" or "<f64>" (Cycle 2682)

                let after = low_skip_ws(content, p + child.len());

                let next_sexp = read_sexp_at(content, after);

                if next_sexp == "<String>" { "Array<String>" }

                else if next_sexp == "<f64>" { "Array<f64>" }

                else { get_fn_return_scan(content, p + child.len()) }

            }

            else if child.byte_at(0) == 40 { get_fn_return_scan(content, p + child.len()) }

            else if child.byte_at(0) == 60 { get_fn_return_scan(content, p + child.len()) }

            else { get_fn_return_scan(content, p + child.len()) }

        }

    };

fn get_fn_body(ast: String) -> String

  post it.len() <= ast.len()

= let content = extract_paren_content(ast);

    get_fn_body_scan(content, 0, "");

fn get_fn_body_scan(content: String, pos: i64, last_expr: String) -> String

    pre pos >= 0

    post it.len() >= 0

=

    let p = low_skip_ws(content, pos);

    if p >= content.len() { last_expr } else {

        let child = read_sexp_at(content, p);

        if child == "" { last_expr } else if child.len() > 0 and child.byte_at(0) == 40 {

            let ntype = get_node_type(child);

            if ntype == "param" or ntype == "eff" { get_fn_body_scan(content, p + child.len(), last_expr) } else { get_fn_body_scan(content, p + child.len(), child) }

        } else {

            get_fn_body_scan(content, p + child.len(), last_expr)

        }

    };

fn find_pipe_skip_quotes(s: String, pos: i64) -> i64

    post it >= -1

= 

    if pos >= s.len() { pos }

    else if s.byte_at(pos) == 31 { pos }

    else if s.byte_at(pos) == 34 { find_pipe_skip_quotes(s, skip_quoted_string(s, pos + 1)) }

    else { find_pipe_skip_quotes(s, pos + 1) };

fn skip_quoted_string(s: String, pos: i64) -> i64

    post it >= 0

= 

    if pos >= s.len() { pos }

    else if s.byte_at(pos) == 34 { pos + 1 }

    else if s.byte_at(pos) == 92 { skip_quoted_string(s, pos + 2) }

    else { skip_quoted_string(s, pos + 1) };

// v0.46: Extract return type from MIR function signature

// MIR format: fn name(params) -> RetType {|...|}

fn extract_mir_return_type(mir: String) -> String

  post it.len() <= mir.len()

= let arrow_pos = find_arrow(mir, 0);

    let brace_pos = find_char(mir, arrow_pos, 123);

    if arrow_pos >= mir.len() or brace_pos <= arrow_pos + 2 { "i64" }

    else {

        let raw = trim(mir.slice(arrow_pos + 2, brace_pos));

        let ann = find_mir_annotation(raw);

        if ann == "" { raw } else { strip_annotation(raw) }

    };

fn find_eq(s: String, pos: i64) -> i64

    post it >= -1

= 

    if pos >= s.len() { pos } else if s.byte_at(pos) == 61 { pos } else { find_eq(s, pos + 1) };

fn llvm_gen_binop(op: String, line: String, pos: i64, dest: String) -> String

  pre pos >= 0

  post it.len() >= 1

= let p1 = low_skip_ws(line, pos);

    let comma = find_comma(line, p1);

    let left = line.slice(p1, comma);

    let p2 = low_skip_ws(line, comma + 1);

    let right = line.slice(p2, line.len());

    let op_with_nsw = match op { "add" => "add nsw", "sub" => "sub nsw", "mul" => "mul nsw", _ => op };

    "  " + dest + " = " + op_with_nsw + " i64 " + trim_end(left) + ", " + trim_end(right);

// v0.96: Saturating add/sub via LLVM intrinsic: call i64 @llvm.sadd.sat.i64(i64 %a, i64 %b)

fn llvm_gen_sat_binop(intrinsic: String, line: String, pos: i64, dest: String) -> String

  pre pos >= 0

  post it.len() >= 1

= let p1 = low_skip_ws(line, pos);

    let comma = find_comma(line, p1);

    let left = trim_end(line.slice(p1, comma));

    let p2 = low_skip_ws(line, comma + 1);

    let right = trim_end(line.slice(p2, line.len()));

    "  " + dest + " = call i64 @" + intrinsic + "(i64 " + left + ", i64 " + right + ")";

// v0.96: Saturating mul via smul.with.overflow + select

fn llvm_gen_sat_mul(line: String, pos: i64, dest: String) -> String

  pre pos >= 0

  post it.len() >= 1

= let p1 = low_skip_ws(line, pos);

    let comma = find_comma(line, p1);

    let left = trim_end(line.slice(p1, comma));

    let p2 = low_skip_ws(line, comma + 1);

    let right = trim_end(line.slice(p2, line.len()));

    "  " + dest + ".res = call {i64, i1} @llvm.smul.with.overflow.i64(i64 " + left + ", i64 " + right + ")" + SEP() +

    "  " + dest + ".val = extractvalue {i64, i1} " + dest + ".res, 0" + SEP() +

    "  " + dest + ".ovf = extractvalue {i64, i1} " + dest + ".res, 1" + SEP() +

    "  " + dest + ".a_neg = icmp slt i64 " + left + ", 0" + SEP() +

    "  " + dest + ".b_neg = icmp slt i64 " + right + ", 0" + SEP() +

    "  " + dest + ".neg = xor i1 " + dest + ".a_neg, " + dest + ".b_neg" + SEP() +

    "  " + dest + ".sat = select i1 " + dest + ".neg, i64 -9223372036854775808, i64 9223372036854775807" + SEP() +

    "  " + dest + " = select i1 " + dest + ".ovf, i64 " + dest + ".sat, i64 " + dest + ".val";

// v0.96: Wrapping arithmetic: add/sub/mul WITHOUT nsw (allows overflow wrapping)

fn llvm_gen_wrap_binop(op: String, line: String, pos: i64, dest: String) -> String

  pre pos >= 0

  post it.len() >= 1

= let p1 = low_skip_ws(line, pos);

    let comma = find_comma(line, p1);

    let left = trim_end(line.slice(p1, comma));

    let p2 = low_skip_ws(line, comma + 1);

    let right = trim_end(line.slice(p2, line.len()));

    "  " + dest + " = " + op + " i64 " + left + ", " + right;

fn llvm_gen_cmp(pred: String, line: String, pos: i64, dest: String) -> String

  pre pos >= 0

  post it.len() >= 1

= let p1 = low_skip_ws(line, pos);

    let comma = find_comma(line, p1);

    let left = line.slice(p1, comma);

    let p2 = low_skip_ws(line, comma + 1);

    let right = line.slice(p2, line.len());

    "  " + dest + "_cmp = icmp " + pred + " i64 " + trim_end(left) + ", " + trim_end(right) + SEP() + "  " + dest + " = zext i1 " + dest + "_cmp to i64";

fn llvm_gen_not(line: String, pos: i64, dest: String) -> String

  pre pos >= 0

  post it.len() >= 1

= let p = low_skip_ws(line, pos);

    let operand = line.slice(p, line.len());

    "  " + dest + " = xor i64 " + trim_end(operand) + ", 1";

fn llvm_gen_bnot(line: String, pos: i64, dest: String) -> String

  pre pos >= 0

  post it.len() >= 1

= let p = low_skip_ws(line, pos);

    let operand = line.slice(p, line.len());

    "  " + dest + " = xor i64 " + trim_end(operand) + ", -1";

// MIR: gep %base, %idx -> LLVM: getelementptr i64, ptr %base, i64 %idx

fn llvm_gen_gep(line: String, pos: i64, dest: String) -> String

  pre pos >= 0

  post it.len() >= 1

= let p1 = low_skip_ws(line, pos);

    let comma = find_comma(line, p1);

    let base = trim_end(line.slice(p1, comma));

    let p2 = low_skip_ws(line, comma + 1);

    let idx = trim_end(line.slice(p2, line.len()));

    let conv = "  " + dest + "_gp = inttoptr i64 " + base + " to ptr";

    let gep = "  " + dest + " = getelementptr inbounds nuw i64, ptr " + dest + "_gp, i64 " + idx;

    conv + SEP() + gep;

fn llvm_gen_store_ptr_sb(line: String, pos: i64, str_sb: i64) -> String

  pre pos >= 0

  post it.len() >= 1

= let p1 = low_skip_ws(line, pos);

    let comma = find_comma(line, p1);

    let ptr = line.slice(p1, comma);

    let p2 = low_skip_ws(line, comma + 1);

    let val = trim_end(line.slice(p2, line.len()));

    let val_is_double = is_double_var_sb(val, str_sb);

    let ptr_is_f64 = is_f64_ptr_sb(trim_end(ptr), str_sb);

    if val_is_double or ptr_is_f64 {

        same_mapping("  store double " + val + ", ptr " + trim_end(ptr))

    } else {

        same_mapping("  store i64 " + val + ", ptr " + trim_end(ptr))

    };

fn llvm_gen_load_ptr_sb(line: String, pos: i64, dest: String, str_sb: i64) -> String

  pre pos >= 0

  post it.len() >= 1

= let p = low_skip_ws(line, pos);

    let ptr = trim_end(line.slice(p, line.len()));

    let ptr_is_f64 = is_f64_ptr_sb(ptr, str_sb);

    let ptr_is_str = is_str_ptr_sb(ptr, str_sb);

    if ptr_is_f64 {

        let _w = push_double_marker(str_sb, dest);

        same_mapping("  " + dest + " = load double, ptr " + ptr)

    } else if ptr_is_str {

        let _w = push_string_marker(str_sb, dest);

        same_mapping("  " + dest + " = load i64, ptr " + ptr)

    } else {

        same_mapping("  " + dest + " = load i64, ptr " + ptr)

    };

fn llvm_gen_gep_sb(line: String, pos: i64, dest: String, str_sb: i64) -> String

  pre pos >= 0

  post it.len() >= 1

= let p1 = low_skip_ws(line, pos);

    let comma = find_comma(line, p1);

    let base = trim_end(line.slice(p1, comma));

    let p2 = low_skip_ws(line, comma + 1);

    let _idx = trim_end(line.slice(p2, line.len()));

    let base_is_f64 = is_f64_ptr_sb(base, str_sb);

    let base_is_str = is_str_ptr_sb(base, str_sb);

    // Propagate *f64 or *string marker to GEP result

    let _w = if base_is_f64 { push_f64_ptr_marker(str_sb, dest) } else if base_is_str { push_str_ptr_marker(str_sb, dest) } else { 0 };

    // Both i64 and f64 are 8 bytes, GEP scaling is the same

    same_mapping(llvm_gen_gep(line, pos, dest));

// M11-C Phase 4: gep_u8 base, idx — GEP with i8 element stride (1 byte)

fn llvm_gen_gep_u8_sb(line: String, pos: i64, dest: String, _str_sb: i64) -> String

  pre pos >= 0

  post it.len() >= 1

= let p1 = low_skip_ws(line, pos);

    let comma = find_comma(line, p1);

    let base = trim_end(line.slice(p1, comma));

    let p2 = low_skip_ws(line, comma + 1);

    let idx = trim_end(line.slice(p2, line.len()));

    let conv = "  " + dest + "_gp = inttoptr i64 " + base + " to ptr";

    let gep = "  " + dest + " = getelementptr inbounds nuw i8, ptr " + dest + "_gp, i64 " + idx;

    same_mapping(conv + SEP() + gep);

// M11-C Phase 4: load_ptr_u8 ptr — load i8 and zext to i64

fn llvm_gen_load_ptr_u8_sb(line: String, pos: i64, dest: String, _str_sb: i64) -> String

  pre pos >= 0

  post it.len() >= 1

= let p = low_skip_ws(line, pos);

    let ptr = trim_end(line.slice(p, line.len()));

    let load_line = "  " + dest + "_b = load i8, ptr " + ptr + ", align 1";

    let zext_line = "  " + dest + " = zext i8 " + dest + "_b to i64";

    same_mapping(load_line + SEP() + zext_line);

// M11-C Phase 4: store_ptr_u8 ptr, val — trunc i64 to i8 and store

fn llvm_gen_store_ptr_u8_sb(line: String, pos: i64, _str_sb: i64) -> String

  pre pos >= 0

  post it.len() >= 1

= let p1 = low_skip_ws(line, pos);

    let comma = find_comma(line, p1);

    let ptr = trim_end(line.slice(p1, comma));

    let p2 = low_skip_ws(line, comma + 1);

    let val = trim_end(line.slice(p2, line.len()));

    let trunc_line = if val.ends_with("_cmp") { "  " + ptr + "_v = zext i1 " + val + " to i8" } else { "  " + ptr + "_v = trunc i64 " + val + " to i8" };

    let store_line = "  store i8 " + ptr + "_v, ptr " + ptr + ", align 1";

    same_mapping(trunc_line + SEP() + store_line);

// M11-C Phase 5: gep_i32 base, idx — GEP with i32 element stride (4 bytes)

fn llvm_gen_gep_i32_sb(line: String, pos: i64, dest: String, _str_sb: i64) -> String

  pre pos >= 0

  post it.len() >= 1

= let p1 = low_skip_ws(line, pos);

    let comma = find_comma(line, p1);

    let base = trim_end(line.slice(p1, comma));

    let p2 = low_skip_ws(line, comma + 1);

    let idx = trim_end(line.slice(p2, line.len()));

    let conv = "  " + dest + "_gp = inttoptr i64 " + base + " to ptr";

    let gep = "  " + dest + " = getelementptr inbounds nuw i32, ptr " + dest + "_gp, i64 " + idx;

    same_mapping(conv + SEP() + gep);

// M11-C Phase 5: load_ptr_i32 ptr — load i32 and sext to i64

fn llvm_gen_load_ptr_i32_sb(line: String, pos: i64, dest: String, _str_sb: i64) -> String

  pre pos >= 0

  post it.len() >= 1

= let p = low_skip_ws(line, pos);

    let ptr = trim_end(line.slice(p, line.len()));

    let load_line = "  " + dest + "_b = load i32, ptr " + ptr + ", align 4";

    let sext_line = "  " + dest + " = sext i32 " + dest + "_b to i64";

    same_mapping(load_line + SEP() + sext_line);

// M11-C Phase 5: store_ptr_i32 ptr, val — trunc i64 to i32 and store

fn llvm_gen_store_ptr_i32_sb(line: String, pos: i64, _str_sb: i64) -> String

  pre pos >= 0

  post it.len() >= 1

= let p1 = low_skip_ws(line, pos);

    let comma = find_comma(line, p1);

    let ptr = trim_end(line.slice(p1, comma));

    let p2 = low_skip_ws(line, comma + 1);

    let val = trim_end(line.slice(p2, line.len()));

    let trunc_line = if val.ends_with("_cmp") { "  " + ptr + "_v = zext i1 " + val + " to i32" } else { "  " + ptr + "_v = trunc i64 " + val + " to i32" };

    let store_line = "  store i32 " + ptr + "_v, ptr " + ptr + ", align 4";

    same_mapping(trunc_line + SEP() + store_line);

// M11-C Phase 6: gep_bool base, idx — GEP with i8 element stride (1 byte); same layout as u8

fn llvm_gen_gep_bool_sb(line: String, pos: i64, dest: String, _str_sb: i64) -> String

  pre pos >= 0

  post it.len() >= 1

= let p1 = low_skip_ws(line, pos);

    let comma = find_comma(line, p1);

    let base = trim_end(line.slice(p1, comma));

    let p2 = low_skip_ws(line, comma + 1);

    let idx = trim_end(line.slice(p2, line.len()));

    let conv = "  " + dest + "_gp = inttoptr i64 " + base + " to ptr";

    let gep = "  " + dest + " = getelementptr inbounds nuw i8, ptr " + dest + "_gp, i64 " + idx;

    same_mapping(conv + SEP() + gep);

// M11-C Phase 6: load_ptr_bool ptr — load i8 and zext to i64 (bool is 0 or 1, unsigned)

fn llvm_gen_load_ptr_bool_sb(line: String, pos: i64, dest: String, _str_sb: i64) -> String

  pre pos >= 0

  post it.len() >= 1

= let p = low_skip_ws(line, pos);

    let ptr = trim_end(line.slice(p, line.len()));

    let load_line = "  " + dest + "_b = load i8, ptr " + ptr + ", align 1";

    let zext_line = "  " + dest + " = zext i8 " + dest + "_b to i64";

    same_mapping(load_line + SEP() + zext_line);

// M11-C Phase 6: store_ptr_bool ptr, val — trunc i64 to i8 and store (bool: 0=false, 1=true)

fn llvm_gen_store_ptr_bool_sb(line: String, pos: i64, _str_sb: i64) -> String

  pre pos >= 0

  post it.len() >= 1

= let p1 = low_skip_ws(line, pos);

    let comma = find_comma(line, p1);

    let ptr = trim_end(line.slice(p1, comma));

    let p2 = low_skip_ws(line, comma + 1);

    let val = trim_end(line.slice(p2, line.len()));

    let trunc_line = if val.ends_with("_cmp") { "  " + ptr + "_v = zext i1 " + val + " to i8" } else { "  " + ptr + "_v = trunc i64 " + val + " to i8" };

    let store_line = "  store i8 " + ptr + "_v, ptr " + ptr + ", align 1";

    same_mapping(trunc_line + SEP() + store_line);

// M11-C Phase 7: gep_f64 base, idx — GEP with double element stride (8 bytes)

fn llvm_gen_gep_f64_sb(line: String, pos: i64, dest: String, _str_sb: i64) -> String

  pre pos >= 0

  post it.len() >= 1

= let p1 = low_skip_ws(line, pos);

    let comma = find_comma(line, p1);

    let base = trim_end(line.slice(p1, comma));

    let p2 = low_skip_ws(line, comma + 1);

    let idx = trim_end(line.slice(p2, line.len()));

    let conv = "  " + dest + "_gp = inttoptr i64 " + base + " to ptr";

    let gep = "  " + dest + " = getelementptr inbounds nuw double, ptr " + dest + "_gp, i64 " + idx;

    same_mapping(conv + SEP() + gep);

// M11-C Phase 7: load_ptr_f64 ptr — load double and push double_marker

fn llvm_gen_load_ptr_f64_sb(line: String, pos: i64, dest: String, str_sb: i64) -> String

  pre pos >= 0

  post it.len() >= 1

= let p = low_skip_ws(line, pos);

    let ptr = trim_end(line.slice(p, line.len()));

    let load_line = "  " + dest + " = load double, ptr " + ptr + ", align 8";

    let _mark = push_double_marker(str_sb, dest);

    same_mapping(load_line);

// M11-C Phase 7+: store_ptr_f64 ptr, val — val may be double register, float literal, or i64 (cmp/int literal)

fn llvm_gen_store_ptr_f64_sb(line: String, pos: i64, str_sb: i64) -> String

  pre pos >= 0

  post it.len() >= 1

= let p1 = low_skip_ws(line, pos);

    let comma = find_comma(line, p1);

    let ptr = trim_end(line.slice(p1, comma));

    let p2 = low_skip_ws(line, comma + 1);

    let val = trim_end(line.slice(p2, line.len()));

    // val may be: double register (in double_marker), float literal, or i64 value (cmp result / int literal)
    if low_starts_with_at(val, 0, "%") {
        // LLVM register: check if tracked as double
        if is_double_var_sb(val, str_sb) {
            same_mapping("  store double " + val + ", ptr " + ptr + ", align 8")
        } else {
            // Integer register (e.g. zext i1 to i64): emit sitofp first
            let conv = ptr + "_si";
            same_mapping("  " + conv + " = sitofp i64 " + val + " to double" + SEP() + "  store double " + conv + ", ptr " + ptr + ", align 8")
        }
    } else if find_pattern_at_slow(val, ".", 0) >= 0 {
        // Float literal (e.g. 1.5, 0.0): store directly
        same_mapping("  store double " + val + ", ptr " + ptr + ", align 8")
    } else {
        // Integer literal (e.g. 0, 1): emit sitofp
        let conv = ptr + "_si";
        same_mapping("  " + conv + " = sitofp i64 " + val + " to double" + SEP() + "  store double " + conv + ", ptr " + ptr + ", align 8")
    };

fn llvm_gen_phi(line: String, pos: i64, dest: String) -> String

  pre pos >= 0

  post it.len() >= 1

= llvm_gen_phi_typed(line, pos, dest, "i64");

// Returns tagged result: llvm_line directly (mapping unchanged) or "!len:mapping+llvm_line" (mapping changed)

fn extract_phi_val(content: String) -> String

  post it.len() <= content.len()

= let comma_pos = find_char(content, 0, 44);

    content.slice(0, comma_pos);

fn llvm_gen_phi_typed(line: String, pos: i64, dest: String, ret_type: String) -> String

  pre pos >= 0

  post it.len() >= 1

= let bracket_start = find_char(line, pos, 91);

    let first_end = find_char(line, bracket_start, 93);

    let first_content = line.slice(bracket_start + 1, first_end);

    let second_start = find_char(line, first_end, 91);

    let second_end = find_char(line, second_start, 93);

    let second_content = line.slice(second_start + 1, second_end);

    let first_fixed = fix_phi_label(first_content);

    let second_fixed = fix_phi_label(second_content);

    let llvm_type = if ret_type == "String" { "ptr" } else if ret_type == "f64" { "double" } else { "i64" };

    "  " + dest + " = phi " + llvm_type + " [ " + first_fixed + " ], [ " + second_fixed + " ]";

fn fix_phi_label(content: String) -> String

  post it.len() == content.len() + 1

= let comma_pos = find_char(content, 0, 44);

    let val = content.slice(0, comma_pos);

    let label = content.slice(comma_pos + 2, content.len());

    val + ", %" + label;

// invariant: ret ∈ {"void", "ptr", "i64", "double"} — exhaustive over all known runtime fn names; unknown fns -> "i64"

// v0.46: Determine LLVM return type from function name

fn get_call_return_type(fn_name: String) -> String

  pre fn_name.len() > 0

  post it.len() >= 1

=

    // Void functions (no return value assignment)

    if fn_name == "@println" or fn_name == "@print_str" or fn_name == "@println_str" or fn_name == "@eprint" or fn_name == "@eprintln" or fn_name == "@eprint_str" or fn_name == "@eprintln_str" or fn_name == "@eprint_f64" or fn_name == "@eprintln_f64" or fn_name == "@bmb_panic" { "void" }

    else if fn_name == "@free" or fn_name == "@print_f64" or fn_name == "@println_f64" or fn_name == "@bmb_print_i64" or fn_name == "@puts_cstr" { "void" }

    else if fn_name == "@store_u8" or fn_name == "@store_i64" { "void" }

    else if fn_name == "@hashmap_insert" or fn_name == "@hashmap_free" { "void" }

    else if fn_name == "@str_hashmap_free" or fn_name == "@strmap_free" { "void" }

    else if fn_name == "@vec_set" or fn_name == "@vec_free" or fn_name == "@vec_reverse" or fn_name == "@vec_swap" or fn_name == "@vec_sort" or fn_name == "@vec_clear" or fn_name == "@vec_extend" or fn_name == "@vec_insert" or fn_name == "@vec_dedup" or fn_name == "@vec_fill" { "void" }

    else if fn_name == "@bmb_exit" or fn_name == "@bmb_sleep_ms" or fn_name == "@bmb_random_seed" or fn_name == "@bmb_panic_bounds" or fn_name == "@bmb_panic_divzero" { "void" }

    else if fn_name == "@bmb_mutex_unlock" or fn_name == "@bmb_mutex_free" { "void" }

    else if fn_name == "@bmb_channel_send" or fn_name == "@bmb_channel_close" { "void" }

    else if fn_name == "@bmb_arc_drop" { "void" }

    else if fn_name == "@bmb_rwlock_read_unlock" or fn_name == "@bmb_rwlock_write_unlock" or fn_name == "@bmb_rwlock_free" { "void" }

    else if fn_name == "@bmb_barrier_free" or fn_name == "@bmb_condvar_notify_one" or fn_name == "@bmb_condvar_notify_all" or fn_name == "@bmb_condvar_free" { "void" }

    else if fn_name == "@bmb_async_file_write" or fn_name == "@bmb_async_file_close" { "void" }

    else if fn_name == "@bmb_async_socket_write" or fn_name == "@bmb_async_socket_close" { "void" }

    else if fn_name == "@bmb_thread_pool_execute" or fn_name == "@bmb_thread_pool_join" or fn_name == "@bmb_thread_pool_shutdown" { "void" }

    else if fn_name == "@bmb_scope_spawn" or fn_name == "@bmb_scope_wait" { "void" }

    // Pointer-returning functions (String type)

    else if fn_name == "@get_arg" or fn_name == "@bmb_read_file" or fn_name == "@bmb_getenv" or fn_name == "@bmb_system_capture" or fn_name == "@bmb_read_line" or fn_name == "@exec_with_stdin" or fn_name == "@bmb_exec_with_stdin" { "ptr" }

    else if fn_name == "@bmb_string_new" or fn_name == "@bmb_string_from_cstr" or fn_name == "@bmb_string_slice" { "ptr" }

    else if fn_name == "@bmb_string_concat" or fn_name == "@bmb_chr" or fn_name == "@bmb_int_to_string" { "ptr" }

    else if fn_name == "@bmb_string_concat3" or fn_name == "@bmb_string_concat5" or fn_name == "@bmb_string_concat7" { "ptr" }

    else if fn_name == "@bmb_sb_build" or fn_name == "@bmb_read_file" or fn_name == "@bmb_getenv" or fn_name == "@get_arg" { "ptr" }

    else if fn_name == "@malloc" or fn_name == "@calloc" or fn_name == "@stack_bytes_new" or fn_name == "@stack_i64_new" or fn_name == "@stack_f64_new" or fn_name == "@stack_u8_new" or fn_name == "@stack_i32_new" or fn_name == "@stack_bool_new" { "ptr" }

    else if fn_name == "@hashmap_new" or fn_name == "@vec_new" or fn_name == "@vec_with_capacity" or fn_name == "@str_hashmap_new" or fn_name == "@reg_cached_lookup" { "ptr" }

    else if fn_name == "@bmb_string_trim" or fn_name == "@bmb_string_replace" or fn_name == "@bmb_f64_to_string" or fn_name == "@bmb_string_reverse" or fn_name == "@bmb_string_pad_left" or fn_name == "@bmb_string_pad_right" or fn_name == "@bmb_to_hex" or fn_name == "@bmb_to_binary" or fn_name == "@bmb_to_octal" or fn_name == "@bmb_getcwd" or fn_name == "@bmb_exec_output" or fn_name == "@bmb_string_join" { "ptr" }

    else if fn_name == "@bmb_string_to_upper" or fn_name == "@bmb_string_to_lower" or fn_name == "@bmb_string_repeat" { "ptr" }

    else if fn_name == "@bmb_string_substr" { "ptr" }   // v0.100.2: Cycle 3073 — was missing, caused call i64 on ptr-returning fn

    else if fn_name == "@bmb_array_push" or fn_name == "@bmb_array_pop" { "ptr" }

    else if fn_name == "@bmb_array_concat" or fn_name == "@bmb_array_slice" { "ptr" }

    else if fn_name == "@list_dir" { "ptr" }

    // v0.100: svec ptr-returning functions

    else if fn_name == "@bmb_svec_get" or fn_name == "@bmb_svec_join" { "ptr" }

    // v0.96: sin/cos/tan/atan/atan2/log/log2/log10/exp/pow_f64/sqrt/fmod now LLVM intrinsics

    else if fn_name == "@i64_to_f64" { "double" }

    // v0.96: f64_floor/ceil/round/sqrt/abs/min/max now use LLVM intrinsics (handled in special cases)

    else { if fn_name == "@bmb_parse_f64" { "double" } else { "i64" } };

fn map_runtime_fn(fn_name: String) -> String

  post it.len() >= 0

= if fn_name.len() < 2 { fn_name }

    else {

        let c = fn_name.byte_at(1);

        // Fast reject: chars that can never be runtime functions

        if c < 97 or c > 119 { fn_name }           // outside a-w

        else if c >= 100 and c <= 101 { fn_name }   // d, e

        else if c == 104 { fn_name }                   // h

        else if c >= 106 and c <= 108 { fn_name }   // j, k, l

        else if c == 110 { fn_name }                 // n

        else if c == 113 { fn_name }                 // q

        else if c >= 117 and c <= 118 { fn_name }    // u, v

        else { map_runtime_fn_full(fn_name) }

    };

fn map_runtime_fn_full(fn_name: String) -> String


    let _w2 = sb_push_mir(sb, "  " + dest + " = const 0");

    pack_ids(val_temp + 1, val_block);

// v0.96.24: Safe mode bounds check for recursive lowering path (while/for/loop bodies)

fn lower_index_sb(ast: String, temp_id: i64, block_id: i64, sb: i64, loop_exit: String) -> i64

  pre temp_id >= 0 and block_id >= 0

  post it >= 0

= let base_expr = get_child(ast, 0);

    let idx_expr = get_child(ast, 1);

    let base_result = lower_expr_sb(base_expr, temp_id, block_id, sb, loop_exit);

    let base_temp = unpack_temp(base_result);

    let base_block = unpack_block(base_result);

    let base_id = base_temp - 1;

    let idx_result = lower_expr_sb(idx_expr, base_temp, base_block, sb, loop_exit);

    let idx_temp = unpack_temp(idx_result);

    let idx_block = unpack_block(idx_result);

    let idx_id = idx_temp - 1;

    // v0.96.24: Safe mode bounds check (matches step_array_index_final behavior)

    let is_safe = sb % 2 == 1;

    let t = if is_safe { safe_bounds_check(sb, idx_temp, int_to_string(base_id), idx_id) } else { idx_temp };

    // Add 2 to index to skip array header

    let hdr_const = "%_t" + int_to_string(t);

    let _w0a = sb_push_mir(sb, "  " + hdr_const + " = const 2");

    let offset_tmp = "%_t" + int_to_string(t + 1);

    let _w0b = sb_push_mir(sb, "  " + offset_tmp + " = + %_t" + int_to_string(idx_id) + ", " + hdr_const);

    let gep_dest = "%_t" + int_to_string(t + 2);

    let load_dest = "%_t" + int_to_string(t + 3);

    let _w1 = sb_push_mir(sb, "  " + gep_dest + " = gep %_t" + int_to_string(base_id) + ", " + offset_tmp);

    let _w2 = sb_push_mir(sb, "  " + load_dest + " = load_ptr " + gep_dest);

    pack_ids(t + 4, idx_block);

// v0.96.24: Safe mode bounds check for recursive lowering path (while/for/loop bodies)

fn lower_set_index_sb(ast: String, temp_id: i64, block_id: i64, sb: i64, loop_exit: String) -> i64

  pre temp_id >= 0 and block_id >= 0

  post it >= 0

= let base_expr = get_child(ast, 0);

    let idx_expr = get_child(ast, 1);

    let val_expr = get_child(ast, 2);

    let base_result = lower_expr_sb(base_expr, temp_id, block_id, sb, loop_exit);

    let base_temp = unpack_temp(base_result);

    let base_block = unpack_block(base_result);

    let base_id = base_temp - 1;

    let idx_result = lower_expr_sb(idx_expr, base_temp, base_block, sb, loop_exit);

    let idx_temp = unpack_temp(idx_result);

    let idx_block = unpack_block(idx_result);

    let idx_id = idx_temp - 1;

    let val_result = lower_expr_sb(val_expr, idx_temp, idx_block, sb, loop_exit);

    let val_temp = unpack_temp(val_result);

    let val_block = unpack_block(val_result);

    let val_id = val_temp - 1;

    // v0.96.24: Safe mode bounds check (matches step_set_index_final behavior)

    let is_safe = sb % 2 == 1;

    let t = if is_safe { safe_bounds_check(sb, val_temp, int_to_string(base_id), idx_id) } else { val_temp };

    // Add 2 to index to skip array header

    let hdr_const = "%_t" + int_to_string(t);

    let _w0a = sb_push_mir(sb, "  " + hdr_const + " = const 2");

    let offset_tmp = "%_t" + int_to_string(t + 1);

    let _w0b = sb_push_mir(sb, "  " + offset_tmp + " = + %_t" + int_to_string(idx_id) + ", " + hdr_const);

    let gep_dest = "%_t" + int_to_string(t + 2);

    let _w1 = sb_push_mir(sb, "  " + gep_dest + " = gep %_t" + int_to_string(base_id) + ", " + offset_tmp);

    let _w2 = sb_push_mir(sb, "  store_ptr " + gep_dest + ", %_t" + int_to_string(val_id));

    let result_dest = "%_t" + int_to_string(t + 3);

    let _w3 = sb_push_mir(sb, "  " + result_dest + " = const 0");

    pack_ids(t + 4, val_block);

// Raw pointer index: direct GEP without +2 array header offset


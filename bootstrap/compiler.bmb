    else if fn_name == "@chr" { "@bmb_chr" }

    else { match fn_name { "@ord" => "@bmb_ord", "@println" => "@println", "@print" => "@bmb_print_i64", "@print_str" => "@print_str", "@println_str" => "@println_str", "@eprint" => "@eprint", "@eprintln" => "@eprintln", "@eprint_str" => "@eprint_str", "@eprintln_str" => "@eprintln_str", "@eprint_f64" => "@eprint_f64", "@eprintln_f64" => "@eprintln_f64", "@read_file" => "@bmb_read_file", "@write_file" => "@bmb_write_file", "@write_file_newlines" => "@write_file_newlines", "@file_exists" => "@bmb_file_exists", "@sb_new" => "@bmb_sb_new", "@sb_push" => "@bmb_sb_push", "@sb_push_range" => "@sb_push_range", "@sb_push_int" => "@bmb_sb_push_int", "@sb_push_char" => "@bmb_sb_push_char", "@sb_push_escaped" => "@bmb_sb_push_escaped", "@sb_len" => "@bmb_sb_len", "@sb_build" => "@bmb_sb_build", "@sb_clear" => "@bmb_sb_clear", "@sb_contains" => "@bmb_sb_contains", "@arg_count" => "@arg_count", "@get_arg" => "@get_arg", "@getenv" => "@bmb_getenv", "@system" => "@bmb_system", "@system_capture" => "@bmb_system_capture", "@read_line" => "@bmb_read_line", "@free_string" => "@bmb_string_free", "@sb_free" => "@bmb_sb_free", "@arena_mode" => "@bmb_arena_mode", "@pow" => "@bmb_pow", "@concat3" => "@bmb_string_concat3", "@concat5" => "@bmb_string_concat5", "@concat7" => "@bmb_string_concat7", "@arena_reset" => "@bmb_arena_reset", "@arena_save" => "@bmb_arena_save", "@arena_restore" => "@bmb_arena_restore", "@arena_usage" => "@bmb_arena_usage", "@thread_spawn" => "@bmb_thread_spawn", "@thread_join" => "@bmb_thread_join", "@mutex_new" => "@bmb_mutex_new", "@mutex_lock" => "@bmb_mutex_lock", "@mutex_unlock" => "@bmb_mutex_unlock", "@mutex_try_lock" => "@bmb_mutex_try_lock", "@mutex_free" => "@bmb_mutex_free", "@channel_new" => "@bmb_channel_new", "@channel_send" => "@bmb_channel_send", "@channel_recv" => "@bmb_channel_recv", "@channel_try_send" => "@bmb_channel_try_send", "@channel_try_recv" => "@bmb_channel_try_recv", "@channel_recv_timeout" => "@bmb_channel_recv_timeout", "@channel_send_t
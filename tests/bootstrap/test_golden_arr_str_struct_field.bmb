// M5-5d golden: struct field Array<String> dispatch
// Expected: "red\ngreen\nblue\n", exit 42
struct Tagged { id: i64, tags: Array<String> }

fn main() -> i64 = {
    let p = Tagged { id: 1, tags: ["red", "green", "blue"] };
    let _p0 = println(p.tags[0]);
    let _p1 = println(p.tags[1]);
    let _p2 = println(p.tags[2]);
    42
};

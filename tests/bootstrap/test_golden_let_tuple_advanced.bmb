// Golden test: let-tuple destructuring edge cases
// Tests: nested function returns, tuple in loops, combined with static methods
// Expected output: 42

fn divmod(a: i64, b: i64) -> (i64, i64) = (a / b, a % b);

fn minmax(arr: [i64; 4]) -> (i64, i64) = {
    let mut mn = arr[0];
    let mut mx = arr[0];
    let mut i = 1;
    while i < 4 {
        if arr[i] < mn { mn = arr[i]; };
        if arr[i] > mx { mx = arr[i]; };
        i = i + 1;
    };
    (mn, mx)
};

fn swap(a: i64, b: i64) -> (i64, i64) = (b, a);

fn main() -> i64 = {
    // divmod: quotient + remainder
    let (q, r) = divmod(100, 7);
    // q=14, r=2, q+r=16
    let sum1 = q + r;

    // minmax of array
    let arr = [3, 1, 4, 2];
    let (mn, mx) = minmax(arr);
    // mn=1, mx=4, mx-mn=3
    let diff = mx - mn;

    // swap values
    let (x, y) = swap(10, 30);
    // x=30, y=10
    let sum2 = x + y;

    // Chain: let-tuple in expression
    let (a, b) = (7, 6);
    let product = a * b;

    // Total: 16 + 3 + 40 - 17 = 42
    let result = sum1 + diff + sum2 - product + 1;
    // 16 + 3 + 40 - 42 + 25 = 42
    // Let me recalculate:
    // sum1 = 14 + 2 = 16
    // diff = 4 - 1 = 3
    // sum2 = 30 + 10 = 40
    // product = 7 * 6 = 42
    // result = 16 + 3 + 40 - 42 + 25 = 42
    let final_val = sum1 + diff + sum2 - product + 25;
    println(final_val);
    0
};

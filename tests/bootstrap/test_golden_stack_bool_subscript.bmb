fn main() -> i64 = {
    let flags: [bool; 4];
    let mut i = 0;
    while i < 4 { set flags[i] = true; i = i + 1 };
    set flags[1] = false;
    let b0 = if flags[0] { 1 } else { 0 };
    let b1 = if flags[1] { 1 } else { 0 };
    let b2 = if flags[2] { 1 } else { 0 };
    let b3 = if flags[3] { 1 } else { 0 };
    println(b0 + b1 + b2 + b3)
};

// Test: for-in-vec with vec_with_capacity + nested body (Cycle 2885)
// Expected output: 60 (sum: 10+20+30 = 60)

fn main() -> i64 = {
    let v = vec_with_capacity(3);
    vec_push(v, 10);
    vec_push(v, 20);
    vec_push(v, 30);

    let total = [0; 1];
    for item in v {
        set total[0] = total[0] + item;
    };

    println(total[0]);
    total[0]
};

// Scalar dot product baseline (Cycle 2250 — Task-B6 perf bench).
// Paired with `simd_dot_simd.bmb`. Both do identical work; only loop shape differs.
// N and REPS chosen to give ~0.5s runtime on modern x86 at -O2.

extern fn malloc(n: i64) -> i64;
extern fn free(p: i64) -> i64;
extern fn store_f64(ptr: i64, v: f64) -> i64;
extern fn load_f64(ptr: i64) -> f64;
extern fn i64_to_f64(n: i64) -> f64;
extern fn f64_to_i64(x: f64) -> i64;
extern fn println(n: i64) -> i64;

fn init_array(ptr: i64, n: i64, offset: f64) -> i64 = {
    let mut i: i64 = 0;
    while i < n {
        let x = i64_to_f64(i) * 0.5 + offset;
        let _s = store_f64(ptr + i * 8, x);
        set i = i + 1;
    };
    0
};

fn dot_scalar(a: i64, b: i64, n: i64) -> f64 = {
    let mut sum: f64 = 0.0;
    let mut i: i64 = 0;
    while i < n {
        let av = load_f64(a + i * 8);
        let bv = load_f64(b + i * 8);
        set sum = sum + av * bv;
        set i = i + 1;
    };
    sum
};

fn main() -> i64 = {
    let n: i64 = 4096;
    let reps: i64 = 10000;

    let a = malloc(n * 8);
    let b = malloc(n * 8);
    let _ia = init_array(a, n, 1.0);
    let _ib = init_array(b, n, 2.0);

    let mut total: f64 = 0.0;
    let mut r: i64 = 0;
    while r < reps {
        set total = total + dot_scalar(a, b, n);
        set r = r + 1;
    };

    // Print low 16 bits of integer part so output is verifiable but not huge.
    let tail = f64_to_i64(total) % 65536;
    let _p = println(tail);

    let _fa = free(a);
    let _fb = free(b);
    0
};

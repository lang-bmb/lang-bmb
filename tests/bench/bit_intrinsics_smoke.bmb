// Cycle 2384: Bootstrap lowering of i64 bit-manipulation method calls.
// Each method routes to a direct LLVM instruction (or intrinsic) via the
// bootstrap's @popcount/@clz/@ctz/@bit_reverse/@bswap/@bit_not/@bit_and/... dispatch.

fn main() -> i64 =
    let a = (255).bit_count();          // 8
    let b = (1).leading_zeros();         // 63
    let c = (8).trailing_zeros();        // 3
    let d = (0).bit_count();             // 0
    let e = (-1).bit_count();            // 64
    let f = (5).bit_not();               // -6
    let g = (12).bit_and(10);            // 8
    let h = (12).bit_or(10);             // 14
    let i = (12).bit_xor(10);            // 6
    let j = (3).bit_shift_left(2);       // 12
    let k = (12).bit_shift_right(1);     // 6
    // Cycle 2388: number predicates backed by runtime helpers.
    let p = (8).is_power_of_two();        // 1 (true)
    let q = (7).is_power_of_two();        // 0 (false)
    let r = (5).next_power_of_two();      // 8
    let s = (17).is_prime();              // 1 (true)
    let t = (15).is_prime();              // 0 (false)
    // Return 0 on success, non-zero on first failure.
    if a != 8 { 1 }
    else if b != 63 { 2 }
    else if c != 3 { 3 }
    else if d != 0 { 4 }
    else if e != 64 { 5 }
    else if f != -6 { 6 }
    else if g != 8 { 7 }
    else if h != 14 { 8 }
    else if i != 6 { 9 }
    else if j != 12 { 10 }
    else if k != 6 { 11 }
    else if p != 1 { 12 }
    else if q != 0 { 13 }
    else if r != 8 { 14 }
    else if s != 1 { 15 }
    else if t != 0 { 16 }
    else { 0 };

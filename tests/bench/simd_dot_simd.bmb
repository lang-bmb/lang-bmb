// SIMD dot product (Cycle 2250 — Task-B6 perf bench).
// Identical input shape to `simd_dot_scalar.bmb`; inner loop processes 4 f64 per step.

@include "stdlib/simd/mod.bmb"

extern fn malloc(n: i64) -> i64;
extern fn free(p: i64) -> i64;
extern fn store_f64(ptr: i64, v: f64) -> i64;
extern fn i64_to_f64(n: i64) -> f64;
extern fn f64_to_i64(x: f64) -> i64;
extern fn println(n: i64) -> i64;

fn init_array(ptr: i64, n: i64, offset: f64) -> i64 = {
    let mut i: i64 = 0;
    while i < n {
        let x = i64_to_f64(i) * 0.5 + offset;
        let _s = store_f64(ptr + i * 8, x);
        set i = i + 1;
    };
    0
};

fn dot_simd(a: i64, b: i64, n: i64) -> f64 = {
    // Four independent accumulators × 4-wide = 16 doubles per iteration.
    // Exposes enough ILP to keep both FMA ports saturated on Zen3/Skylake-class CPUs.
    let mut acc0: f64x4 = load_f64x4(a, 0) * load_f64x4(b, 0);
    let mut acc1: f64x4 = load_f64x4(a, 4) * load_f64x4(b, 4);
    let mut acc2: f64x4 = load_f64x4(a, 8) * load_f64x4(b, 8);
    let mut acc3: f64x4 = load_f64x4(a, 12) * load_f64x4(b, 12);
    let mut i: i64 = 16;
    while i < n {
        set acc0 = acc0 + load_f64x4(a, i) * load_f64x4(b, i);
        set acc1 = acc1 + load_f64x4(a, i + 4) * load_f64x4(b, i + 4);
        set acc2 = acc2 + load_f64x4(a, i + 8) * load_f64x4(b, i + 8);
        set acc3 = acc3 + load_f64x4(a, i + 12) * load_f64x4(b, i + 12);
        set i = i + 16;
    };
    hsum_f64x4(acc0) + hsum_f64x4(acc1) + hsum_f64x4(acc2) + hsum_f64x4(acc3)
};

fn main() -> i64 = {
    let n: i64 = 4096;
    let reps: i64 = 10000;

    let a = malloc(n * 8);
    let b = malloc(n * 8);
    let _ia = init_array(a, n, 1.0);
    let _ib = init_array(b, n, 2.0);

    let mut total: f64 = 0.0;
    let mut r: i64 = 0;
    while r < reps {
        set total = total + dot_simd(a, b, n);
        set r = r + 1;
    };

    let tail = f64_to_i64(total) % 65536;
    let _p = println(tail);

    let _fa = free(a);
    let _fb = free(b);
    0
};

// SIMD horizontal sum + splat smoke test (Cycles 2246-2247, refactored 2276).
// Verifies stdlib/simd hsum_* → `llvm.vector.reduce.*`
//                  and splat_* → `insertelement + shufflevector`.

@include "stdlib/simd/mod.bmb"

fn add_at(base: i64, idx: i64, k: f64) -> f64x4 =
    load_f64x4(base, idx) + splat_f64x4(k);

fn write_scaled(base: i64, idx: i64, v: f64x4, k: f64) -> i64 = {
    store_f64x4(base, idx, v * splat_f64x4(k));
    0
};

// Cycle 2249: dot_f64x4 composition is exercised via `vdot` → `dot_f64x4` from stdlib.
fn vdot(a: f64x4, b: f64x4) -> f64 = dot_f64x4(a, b);

// Cycle 2253: FMA smoke.
fn fma_smoke(a: f64x4, b: f64x4, c: f64x4) -> f64 = hsum_f64x4(fma_f64x4(a, b, c));

// Cycle 2254: min/max smoke.
fn clamp_f64x4(v: f64x4, lo: f64x4) -> f64 = hsum_f64x4(min_f64x4(v, lo));
fn max_sum_i32x8(a: i32x8, b: i32x8) -> i32 = hsum_i32x8(max_i32x8(a, b));

fn scale_f64x4(v: f64x4, k: f64) -> f64x4
= v * splat_f64x4(k);

fn add_const_i64x2(v: i64x2, c: i64) -> i64x2
= v + splat_i64x2(c);

fn sum_f64x4(a: f64x4, b: f64x4) -> f64
= hsum_f64x4(a + b);

fn sum_f64x8(a: f64x8, b: f64x8) -> f64
= hsum_f64x8(a + b);

fn sum_i32x8(a: i32x8, b: i32x8) -> i32
= hsum_i32x8(a + b);

fn sum_i64x2(a: i64x2, b: i64x2) -> i64
= hsum_i64x2(a + b);

fn main() -> i64 = 0;

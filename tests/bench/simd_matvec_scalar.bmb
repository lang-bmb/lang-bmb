// Matrix-vector multiply scalar baseline (Cycle 2274, Task-B9).
// y = A*x where A is M×N, x is N-vector. High arithmetic intensity — M*N multiplies
// + M*(N-1) adds, vs only M+N loads. Ratio favors SIMD when N is cache-resident.

extern fn malloc(n: i64) -> i64;
extern fn free(p: i64) -> i64;
extern fn store_f64(ptr: i64, v: f64) -> i64;
extern fn load_f64(ptr: i64) -> f64;
extern fn i64_to_f64(n: i64) -> f64;
extern fn f64_to_i64(x: f64) -> i64;
extern fn println(n: i64) -> i64;

fn init_dense(ptr: i64, n: i64, offset: f64) -> i64 = {
    let mut i: i64 = 0;
    while i < n {
        let x = i64_to_f64(i) * 0.125 + offset;
        let _s = store_f64(ptr + i * 8, x);
        set i = i + 1;
    };
    0
};

fn matvec_scalar(a: i64, x: i64, y: i64, m: i64, n: i64) -> i64 = {
    let mut row: i64 = 0;
    while row < m {
        let row_base = a + row * n * 8;
        let mut dot: f64 = 0.0;
        let mut col: i64 = 0;
        while col < n {
            let ax = load_f64(row_base + col * 8);
            let xv = load_f64(x + col * 8);
            set dot = dot + ax * xv;
            set col = col + 1;
        };
        let _s = store_f64(y + row * 8, dot);
        set row = row + 1;
    };
    0
};

fn checksum(ptr: i64, n: i64) -> f64 = {
    let mut sum: f64 = 0.0;
    let mut i: i64 = 0;
    while i < n {
        set sum = sum + load_f64(ptr + i * 8);
        set i = i + 1;
    };
    sum
};

fn main() -> i64 = {
    let m: i64 = 128;
    let n: i64 = 256;
    let reps: i64 = 2000;

    let mat = malloc(m * n * 8);
    let x = malloc(n * 8);
    let y = malloc(m * 8);
    let _im = init_dense(mat, m * n, 0.5);
    let _ix = init_dense(x, n, 1.5);

    let mut r: i64 = 0;
    while r < reps {
        let _s = matvec_scalar(mat, x, y, m, n);
        set r = r + 1;
    };

    let tail = f64_to_i64(checksum(y, m)) % 65536;
    let _p = println(tail);

    let _fm = free(mat);
    let _fx = free(x);
    let _fy = free(y);
    0
};

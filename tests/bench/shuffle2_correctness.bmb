// Cycle 2316 (Task B-11.5): 2-source shuffle family runtime correctness.
// Exercises slide_left2 / slide_right2 / concat_lo_hi / concat_hi_lo across
// f64x4, f64x8, i64x4. Returns 0 on success; first mismatch exits with a
// unique non-zero code.
//
// Both text and inkwell backends must exit 0 (Rule 7 parity).

@include "stdlib/simd/mod.bmb"

extern fn malloc(n: i64) -> i64;
extern fn free(p: i64) -> i64;
extern fn store_f64(ptr: i64, v: f64) -> i64;
extern fn load_f64(ptr: i64) -> f64;
extern fn store_i64(ptr: i64, v: i64) -> i64;
extern fn load_i64(ptr: i64) -> i64;
extern fn f64_to_i64(x: f64) -> i64;

// ===== f64x4 =====

fn init_f64x4_a(ptr: i64) -> i64 = {
    let _s0 = store_f64(ptr + 0,  1.0);
    let _s1 = store_f64(ptr + 8,  2.0);
    let _s2 = store_f64(ptr + 16, 3.0);
    let _s3 = store_f64(ptr + 24, 4.0);
    0
};

fn init_f64x4_b(ptr: i64) -> i64 = {
    let _s0 = store_f64(ptr + 0,  5.0);
    let _s1 = store_f64(ptr + 8,  6.0);
    let _s2 = store_f64(ptr + 16, 7.0);
    let _s3 = store_f64(ptr + 24, 8.0);
    0
};

fn check_slide_left2_f64x4() -> i64 = {
    // a = [1,2,3,4], b = [5,6,7,8], shift=1 → [2,3,4,5]
    let a_buf = malloc(32);
    let b_buf = malloc(32);
    let _i1 = init_f64x4_a(a_buf);   // [1,2,3,4]
    let _i2 = init_f64x4_b(b_buf);   // [5,6,7,8]
    let a = load_f64x4(a_buf, 0);
    let b = load_f64x4(b_buf, 0);
    let r = slide_left2_f64x4(a, b, 1);
    let out = malloc(32);
    store_f64x4(out, 0, r);
    let v0 = f64_to_i64(load_f64(out + 0));
    let v1 = f64_to_i64(load_f64(out + 8));
    let v2 = f64_to_i64(load_f64(out + 16));
    let v3 = f64_to_i64(load_f64(out + 24));
    let _f1 = free(a_buf);
    let _f2 = free(b_buf);
    let _f3 = free(out);
    if v0 == 2 && v1 == 3 && v2 == 4 && v3 == 5 { 0 } else { 11 }
};

fn check_slide_right2_f64x4() -> i64 = {
    // a = [1,2,3,4], b = [5,6,7,8], shift=1 → [4,5,6,7]
    //   mask[i] = N-shift+i = 4-1+i = 3,4,5,6 → a[3]=4, b[0]=5, b[1]=6, b[2]=7
    let a_buf = malloc(32);
    let b_buf = malloc(32);
    let _i1 = init_f64x4_a(a_buf);
    let _i2 = init_f64x4_b(b_buf);
    let a = load_f64x4(a_buf, 0);
    let b = load_f64x4(b_buf, 0);
    let r = slide_right2_f64x4(a, b, 1);
    let out = malloc(32);
    store_f64x4(out, 0, r);
    let v0 = f64_to_i64(load_f64(out + 0));
    let v1 = f64_to_i64(load_f64(out + 8));
    let v2 = f64_to_i64(load_f64(out + 16));
    let v3 = f64_to_i64(load_f64(out + 24));
    let _f1 = free(a_buf);
    let _f2 = free(b_buf);
    let _f3 = free(out);
    if v0 == 4 && v1 == 5 && v2 == 6 && v3 == 7 { 0 } else { 12 }
};

fn check_slide_left2_f64x4_shift3() -> i64 = {
    // a = [1,2,3,4], b = [5,6,7,8], shift=3 → [4,5,6,7]
    let a_buf = malloc(32);
    let b_buf = malloc(32);
    let _i1 = init_f64x4_a(a_buf);
    let _i2 = init_f64x4_b(b_buf);
    let a = load_f64x4(a_buf, 0);
    let b = load_f64x4(b_buf, 0);
    let r = slide_left2_f64x4(a, b, 3);
    let out = malloc(32);
    store_f64x4(out, 0, r);
    let v0 = f64_to_i64(load_f64(out + 0));
    let v3 = f64_to_i64(load_f64(out + 24));
    let _f1 = free(a_buf);
    let _f2 = free(b_buf);
    let _f3 = free(out);
    if v0 == 4 && v3 == 7 { 0 } else { 13 }
};

fn check_concat_lo_hi_f64x4() -> i64 = {
    // a = [1,2,3,4], b = [5,6,7,8] → [a[0], a[1], b[0], b[1]] = [1,2,5,6]
    let a_buf = malloc(32);
    let b_buf = malloc(32);
    let _i1 = init_f64x4_a(a_buf);
    let _i2 = init_f64x4_b(b_buf);
    let a = load_f64x4(a_buf, 0);
    let b = load_f64x4(b_buf, 0);
    let r = concat_lo_hi_f64x4(a, b);
    let out = malloc(32);
    store_f64x4(out, 0, r);
    let v0 = f64_to_i64(load_f64(out + 0));
    let v1 = f64_to_i64(load_f64(out + 8));
    let v2 = f64_to_i64(load_f64(out + 16));
    let v3 = f64_to_i64(load_f64(out + 24));
    let _f1 = free(a_buf);
    let _f2 = free(b_buf);
    let _f3 = free(out);
    if v0 == 1 && v1 == 2 && v2 == 5 && v3 == 6 { 0 } else { 14 }
};

fn check_concat_hi_lo_f64x4() -> i64 = {
    // a = [1,2,3,4], b = [5,6,7,8] → [a[2], a[3], b[2], b[3]] = [3,4,7,8]
    let a_buf = malloc(32);
    let b_buf = malloc(32);
    let _i1 = init_f64x4_a(a_buf);
    let _i2 = init_f64x4_b(b_buf);
    let a = load_f64x4(a_buf, 0);
    let b = load_f64x4(b_buf, 0);
    let r = concat_hi_lo_f64x4(a, b);
    let out = malloc(32);
    store_f64x4(out, 0, r);
    let v0 = f64_to_i64(load_f64(out + 0));
    let v1 = f64_to_i64(load_f64(out + 8));
    let v2 = f64_to_i64(load_f64(out + 16));
    let v3 = f64_to_i64(load_f64(out + 24));
    let _f1 = free(a_buf);
    let _f2 = free(b_buf);
    let _f3 = free(out);
    if v0 == 3 && v1 == 4 && v2 == 7 && v3 == 8 { 0 } else { 15 }
};

// ===== f64x8 =====

fn init_f64x8_a(ptr: i64) -> i64 = {
    let _s0 = store_f64(ptr + 0,  1.0);
    let _s1 = store_f64(ptr + 8,  2.0);
    let _s2 = store_f64(ptr + 16, 3.0);
    let _s3 = store_f64(ptr + 24, 4.0);
    let _s4 = store_f64(ptr + 32, 5.0);
    let _s5 = store_f64(ptr + 40, 6.0);
    let _s6 = store_f64(ptr + 48, 7.0);
    let _s7 = store_f64(ptr + 56, 8.0);
    0
};

fn init_f64x8_b(ptr: i64) -> i64 = {
    let _s0 = store_f64(ptr + 0,  9.0);
    let _s1 = store_f64(ptr + 8,  10.0);
    let _s2 = store_f64(ptr + 16, 11.0);
    let _s3 = store_f64(ptr + 24, 12.0);
    let _s4 = store_f64(ptr + 32, 13.0);
    let _s5 = store_f64(ptr + 40, 14.0);
    let _s6 = store_f64(ptr + 48, 15.0);
    let _s7 = store_f64(ptr + 56, 16.0);
    0
};

fn check_slide_left2_f64x8_shift4() -> i64 = {
    // a = [1..8], b = [9..16], shift=4 → [5,6,7,8,9,10,11,12]
    let a_buf = malloc(64);
    let b_buf = malloc(64);
    let _i1 = init_f64x8_a(a_buf);
    let _i2 = init_f64x8_b(b_buf);
    let a = load_f64x8(a_buf, 0);
    let b = load_f64x8(b_buf, 0);
    let r = slide_left2_f64x8(a, b, 4);
    let out = malloc(64);
    store_f64x8(out, 0, r);
    let v0 = f64_to_i64(load_f64(out + 0));
    let v7 = f64_to_i64(load_f64(out + 56));
    let _f1 = free(a_buf);
    let _f2 = free(b_buf);
    let _f3 = free(out);
    if v0 == 5 && v7 == 12 { 0 } else { 21 }
};

// ===== i64x4 =====

fn init_i64x4_a(ptr: i64) -> i64 = {
    let _s0 = store_i64(ptr + 0,  10);
    let _s1 = store_i64(ptr + 8,  20);
    let _s2 = store_i64(ptr + 16, 30);
    let _s3 = store_i64(ptr + 24, 40);
    0
};

fn init_i64x4_b(ptr: i64) -> i64 = {
    let _s0 = store_i64(ptr + 0,  110);
    let _s1 = store_i64(ptr + 8,  120);
    let _s2 = store_i64(ptr + 16, 130);
    let _s3 = store_i64(ptr + 24, 140);
    0
};

fn check_slide_left2_i64x4() -> i64 = {
    // a = [10,20,30,40], b = [110,120,130,140], shift=2 → [30,40,110,120]
    let a_buf = malloc(32);
    let b_buf = malloc(32);
    let _i1 = init_i64x4_a(a_buf);
    let _i2 = init_i64x4_b(b_buf);
    let a = load_i64x4(a_buf, 0);
    let b = load_i64x4(b_buf, 0);
    let r = slide_left2_i64x4(a, b, 2);
    let out = malloc(32);
    store_i64x4(out, 0, r);
    let v0 = load_i64(out + 0);
    let v1 = load_i64(out + 8);
    let v2 = load_i64(out + 16);
    let v3 = load_i64(out + 24);
    let _f1 = free(a_buf);
    let _f2 = free(b_buf);
    let _f3 = free(out);
    if v0 == 30 && v1 == 40 && v2 == 110 && v3 == 120 { 0 } else { 31 }
};

fn check_slide_right2_i64x4() -> i64 = {
    // a = [10,20,30,40], b = [110,120,130,140], shift=2 → [30,40,110,120]
    // Actually: mask[i] = N-shift+i = 4-2+i = 2,3,4,5 → a[2]=30, a[3]=40, b[0]=110, b[1]=120
    let a_buf = malloc(32);
    let b_buf = malloc(32);
    let _i1 = init_i64x4_a(a_buf);
    let _i2 = init_i64x4_b(b_buf);
    let a = load_i64x4(a_buf, 0);
    let b = load_i64x4(b_buf, 0);
    let r = slide_right2_i64x4(a, b, 2);
    let out = malloc(32);
    store_i64x4(out, 0, r);
    let v0 = load_i64(out + 0);
    let v3 = load_i64(out + 24);
    let _f1 = free(a_buf);
    let _f2 = free(b_buf);
    let _f3 = free(out);
    if v0 == 30 && v3 == 120 { 0 } else { 32 }
};

fn check_concat_lo_hi_i64x4() -> i64 = {
    // a = [10,20,30,40], b = [110,120,130,140] → [10,20,110,120]
    let a_buf = malloc(32);
    let b_buf = malloc(32);
    let _i1 = init_i64x4_a(a_buf);
    let _i2 = init_i64x4_b(b_buf);
    let a = load_i64x4(a_buf, 0);
    let b = load_i64x4(b_buf, 0);
    let r = concat_lo_hi_i64x4(a, b);
    let out = malloc(32);
    store_i64x4(out, 0, r);
    let v0 = load_i64(out + 0);
    let v2 = load_i64(out + 16);
    let _f1 = free(a_buf);
    let _f2 = free(b_buf);
    let _f3 = free(out);
    if v0 == 10 && v2 == 110 { 0 } else { 33 }
};

// Identity checks: shift=0 → a, shift=N → b
fn check_slide_left2_shift0_identity() -> i64 = {
    let a_buf = malloc(32);
    let b_buf = malloc(32);
    let _i1 = init_f64x4_a(a_buf);
    let _i2 = init_f64x4_b(b_buf);
    let a = load_f64x4(a_buf, 0);
    let b = load_f64x4(b_buf, 0);
    let r = slide_left2_f64x4(a, b, 0);
    let out = malloc(32);
    store_f64x4(out, 0, r);
    let v0 = f64_to_i64(load_f64(out + 0));
    let v3 = f64_to_i64(load_f64(out + 24));
    let _f1 = free(a_buf);
    let _f2 = free(b_buf);
    let _f3 = free(out);
    if v0 == 1 && v3 == 4 { 0 } else { 41 }
};

fn check_slide_left2_shiftN_identity() -> i64 = {
    let a_buf = malloc(32);
    let b_buf = malloc(32);
    let _i1 = init_f64x4_a(a_buf);
    let _i2 = init_f64x4_b(b_buf);
    let a = load_f64x4(a_buf, 0);
    let b = load_f64x4(b_buf, 0);
    let r = slide_left2_f64x4(a, b, 4);
    let out = malloc(32);
    store_f64x4(out, 0, r);
    let v0 = f64_to_i64(load_f64(out + 0));
    let v3 = f64_to_i64(load_f64(out + 24));
    let _f1 = free(a_buf);
    let _f2 = free(b_buf);
    let _f3 = free(out);
    if v0 == 5 && v3 == 8 { 0 } else { 42 }
};

fn main() -> i64 = {
    let r1  = check_slide_left2_f64x4();
    if r1  != 0 { return r1  } else { 0 };
    let r2  = check_slide_right2_f64x4();
    if r2  != 0 { return r2  } else { 0 };
    let r3  = check_slide_left2_f64x4_shift3();
    if r3  != 0 { return r3  } else { 0 };
    let r4  = check_concat_lo_hi_f64x4();
    if r4  != 0 { return r4  } else { 0 };
    let r5  = check_concat_hi_lo_f64x4();
    if r5  != 0 { return r5  } else { 0 };
    let r6  = check_slide_left2_f64x8_shift4();
    if r6  != 0 { return r6  } else { 0 };
    let r7  = check_slide_left2_i64x4();
    if r7  != 0 { return r7  } else { 0 };
    let r8  = check_slide_right2_i64x4();
    if r8  != 0 { return r8  } else { 0 };
    let r9  = check_concat_lo_hi_i64x4();
    if r9  != 0 { return r9  } else { 0 };
    let r10 = check_slide_left2_shift0_identity();
    if r10 != 0 { return r10 } else { 0 };
    let r11 = check_slide_left2_shiftN_identity();
    if r11 != 0 { return r11 } else { 0 };
    0
};

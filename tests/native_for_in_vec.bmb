// Test: for-in-vec native porting (Cycle 2885)
// for x in vec_var generates index loop in native; works with bmb build
// Expected output: 15 (sum of 1+2+3+4+5)

fn main() -> i64 = {
    let v = vec_new();
    vec_push(v, 1);
    vec_push(v, 2);
    vec_push(v, 3);
    vec_push(v, 4);
    vec_push(v, 5);

    let acc = [0; 1];
    for x in v {
        set acc[0] = acc[0] + x;
    };

    let result = acc[0];
    println(result);
    result
};

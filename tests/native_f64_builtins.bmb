fn main() -> i64 = {
  let r1 = log(1.0);
  let n1 = if f64_to_i64(r1) == 0 { 10 } else { 0 };

  let r2 = log2(4.0);
  let n2 = if f64_to_i64(r2) == 2 { 10 } else { 0 };

  let r3 = log10(100.0);
  let n3 = if f64_to_i64(r3) == 2 { 10 } else { 0 };

  let r4 = exp(0.0);
  let n4 = if f64_to_i64(r4) == 1 { 10 } else { 0 };

  let r5 = round(2.9);
  let n5 = if f64_to_i64(r5) == 3 { 10 } else { 0 };

  let r6 = tan(0.0);
  let n6 = if f64_to_i64(r6) == 0 { 10 } else { 0 };

  let r7 = atan(0.0);
  let n7 = if f64_to_i64(r7) == 0 { 10 } else { 0 };

  let r8 = atan2(0.0, 1.0);
  let n8 = if f64_to_i64(r8) == 0 { 10 } else { 0 };

  let r9 = min_f64(3.0, 5.0);
  let n9 = if f64_to_i64(r9) == 3 { 10 } else { 0 };

  let r10 = max_f64(3.0, 5.0);
  let n10 = if f64_to_i64(r10) == 5 { 10 } else { 0 };

  let r11 = clamp_f64(10.0, 0.0, 5.0);
  let n11 = if f64_to_i64(r11) == 5 { 10 } else { 0 };

  println(n1 + n2 + n3 + n4 + n5 + n6 + n7 + n8 + n9 + n10 + n11);
  0
};

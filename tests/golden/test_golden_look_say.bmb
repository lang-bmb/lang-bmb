// Golden Test: Look-and-Say Sequence
// Each term describes the previous: 1 -> 11 -> 21 -> 1211 -> 111221 -> ...
// Represented as integer arrays using vecs

// Generate next look-and-say term from current
// src and dst are vecs. Returns length of new term
fn look_say_next(src: i64, dst: i64) -> i64 = {
    let n = vec_len(src);
    if n == 0 { return 0 } else { () };
    let mut i = 0;
    let mut len = 0;
    loop {
        if i >= n { break } else { () };
        let digit = vec_get(src, i);
        let mut count = 1;
        let mut done = 0;
        loop {
            if done == 1 { break } else { () };
            if i + count >= n { done = 1 }
            else if vec_get(src, i + count) == digit { count = count + 1 }
            else { done = 1 }
        };
        vec_push(dst, count);
        vec_push(dst, digit);
        len = len + 2;
        i = i + count
    };
    len
};

// Encode a vec as a single integer (digits concatenated)
fn vec_to_num(v: i64) -> i64 = {
    let n = vec_len(v);
    let mut result = 0;
    let mut i = 0;
    loop {
        if i >= n { break } else { () };
        result = result * 10 + vec_get(v, i);
        i = i + 1
    };
    result
};

fn main() -> i64 = {
    // Start with [1]
    let t1 = vec_new();
    vec_push(t1, 1);
    let _p1 = println(vec_to_num(t1));  // 1

    // Term 2: describe "1" -> "one 1" -> [1,1] -> 11
    let t2 = vec_new();
    let _l2 = look_say_next(t1, t2);
    let _p2 = println(vec_to_num(t2));  // 11

    // Term 3: describe "11" -> "two 1s" -> [2,1] -> 21
    let t3 = vec_new();
    let _l3 = look_say_next(t2, t3);
    let _p3 = println(vec_to_num(t3));  // 21

    // Term 4: describe "21" -> "one 2, one 1" -> [1,2,1,1] -> 1211
    let t4 = vec_new();
    let _l4 = look_say_next(t3, t4);
    let _p4 = println(vec_to_num(t4));  // 1211

    // Term 5: describe "1211" -> "one 1, one 2, two 1s" -> [1,1,1,2,2,1] -> 111221
    let t5 = vec_new();
    let _l5 = look_say_next(t4, t5);
    let _p5 = println(vec_to_num(t5));  // 111221

    // Term 6: describe "111221" -> "three 1s, two 2s, one 1" -> [3,1,2,2,1,1] -> 312211
    let t6 = vec_new();
    let _l6 = look_say_next(t5, t6);
    let _p6 = println(vec_to_num(t6));  // 312211

    // Term 7: describe "312211"
    // 3: one 3 -> 1,3
    // 1: one 1 -> 1,1
    // 22: two 2s -> 2,2
    // 11: two 1s -> 2,1
    // -> [1,3,1,1,2,2,2,1] -> 13112221
    let t7 = vec_new();
    let _l7 = look_say_next(t6, t7);
    let _p7 = println(vec_to_num(t7));  // 13112221

    // Length of each term
    let _p8 = println(vec_len(t5));  // 6
    let _p9 = println(vec_len(t6));  // 6
    let _p10 = println(vec_len(t7));  // 8

    // Term 8 length
    let t8 = vec_new();
    let l8 = look_say_next(t7, t8);
    let _p11 = println(l8);  // length of term 8

    vec_free(t1); vec_free(t2); vec_free(t3); vec_free(t4);
    vec_free(t5); vec_free(t6); vec_free(t7); vec_free(t8);
    0
};

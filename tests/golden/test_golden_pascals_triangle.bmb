// Golden Test: Pascal's triangle
// Generates rows of Pascal's triangle and verifies binomial coefficients

// Compute binomial coefficient C(n, k) using multiplicative formula
// C(n, k) = n! / (k! * (n-k)!) = n*(n-1)*...*(n-k+1) / k!
fn binomial(n: i64, k: i64) -> i64 = {
    let kk = if k > n - k { n - k } else { k };
    let mut result = 1;
    for i in 0..kk {
        result = result * (n - i);
        result = result / (i + 1)
    };
    result
    };

// Print a single row of Pascal's triangle (row n, 0-indexed)
// Row n has n+1 elements: C(n,0), C(n,1), ..., C(n,n)
fn print_row(n: i64) -> i64 = {
    for k in 0..=n {
        let val = binomial(n, k);
        let _sp = if k > 0 { print_str(" ") } else { print_str("") };
        print(val)
    };
    let _nl = println_str("");
    0
    };

// Sum of row n = 2^n
fn row_sum(n: i64) -> i64 = {
    let mut total = 0;
    for k in 0..=n {
        total = total + binomial(n, k)
    };
    total
    };

// Power of 2
fn pow2(n: i64) -> i64 = {
    let mut result = 1;
    for _i in 0..n {
        result = result * 2
    };
    result
    };

// Alternating sum of row n: C(n,0) - C(n,1) + C(n,2) - ... = 0 for n>0
fn alternating_sum(n: i64) -> i64 = {
    let mut total = 0;
    let mut sign = 1;
    for k in 0..=n {
        total = total + sign * binomial(n, k);
        sign = 0 - sign
    };
    total
    };

// Count odd entries in row n
fn count_odd_in_row(n: i64) -> i64 = {
    let mut count = 0;
    for k in 0..=n {
        let val = binomial(n, k);
        let rem = val - (val / 2) * 2;
        if rem != 0 { count = count + 1 } else { () }
    };
    count
    };

fn main() -> i64 = {
    // --- Print first 8 rows (rows 0-7) ---
    println_str("=== Pascal Triangle Rows 0-7 ===");
    let _r0 = print_row(0);
    let _r1 = print_row(1);
    let _r2 = print_row(2);
    let _r3 = print_row(3);
    let _r4 = print_row(4);
    let _r5 = print_row(5);
    let _r6 = print_row(6);
    let _r7 = print_row(7);

    // --- Specific binomial coefficients ---
    println_str("=== Specific Values ===");
    println(binomial(10, 5));    // 252
    println(binomial(10, 0));    // 1
    println(binomial(10, 10));   // 1
    println(binomial(20, 10));   // 184756
    println(binomial(15, 7));    // 6435
    println(binomial(6, 3));     // 20

    // --- Row sums = 2^n ---
    println_str("=== Row Sums ===");
    println(row_sum(0));    // 1 = 2^0
    println(row_sum(5));    // 32 = 2^5
    println(row_sum(10));   // 1024 = 2^10

    // --- Verify row_sum == 2^n ---
    println_str("=== Sum == 2^n ===");
    let mut all_match = 1;
    for n in 0..15 {
        if row_sum(n) != pow2(n) { all_match = 0 } else { () }
    };
    println(all_match);    // 1 (all match)

    // --- Alternating sums ---
    println_str("=== Alternating Sums ===");
    println(alternating_sum(0));    // 1 (only C(0,0)=1)
    println(alternating_sum(1));    // 0
    println(alternating_sum(5));    // 0
    println(alternating_sum(10));   // 0

    // --- Count odd entries ---
    println_str("=== Odd Entry Counts ===");
    println(count_odd_in_row(0));   // 1
    println(count_odd_in_row(1));   // 2
    println(count_odd_in_row(3));   // 4 (row 3: 1,3,3,1 - all odd)
    println(count_odd_in_row(4));   // 2 (row 4: 1,4,6,4,1 - 1 and 1)
    println(count_odd_in_row(7));   // 8 (row 7: 1,7,21,35,35,21,7,1 - all odd)

    0
    };

// Test formatter handles contracts (pre/post) correctly

fn clamp(x: i64, lo: i64, hi: i64) -> i64
  pre lo <= hi
  post ret >= lo and ret <= hi
= if x < lo { lo }
    else if x > hi { hi }
    else { x };

fn abs_val(x: i64) -> i64
  post ret >= 0
= if x < 0 { 0 - x } else { x };

fn simple(x: i64) -> i64 = x + 1;

fn main() -> i64 =
    let a = clamp(10, 0, 5);
    let b = abs_val(0 - 3);
    let c = simple(1);
    let _p = print(a + b + c);
    0;

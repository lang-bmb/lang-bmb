// Golden Test: Centroid decomposition of a tree
// Tree stored as adjacency list using flat vec pairs (adj_list, adj_offset)
// Centroid decomposition: recursively find centroid, remove it, recurse on subtrees
// Output: centroid tree parent relationships and decomposition order

// Adjacency list: edges stored in flat vec, offsets index into it
// For tree with n nodes: adj_offset[i] = start index of neighbors of i
// adj_offset[n] = total edges (sentinel)
// adj_list[adj_offset[i]..adj_offset[i+1]] = neighbors of i

// Compute subtree sizes via DFS (ignoring removed nodes)
fn compute_size(adj_list: i64, adj_off: i64, removed: i64, node: i64, parent: i64) -> i64 = {
    if vec_get(removed, node) == 1 { return 0 } else { () };
    let mut sz = 1;
    let start = vec_get(adj_off, node);
    let end_val = vec_get(adj_off, node + 1);
    let mut j = start;
    while j < end_val {
        let nb = vec_get(adj_list, j);
        let _x = if nb != parent and vec_get(removed, nb) == 0 {
            set sz = sz + compute_size(adj_list, adj_off, removed, nb, node);
            0
        } else { 0 };
        set j = j + 1
    };
    sz
    };

// Find centroid: node where max subtree size <= tree_size/2
fn find_centroid_dfs(adj_list: i64, adj_off: i64, removed: i64, sizes: i64,
    node: i64, parent: i64, tree_size: i64) -> i64 = {
    if vec_get(removed, node) == 1 { return 0 - 1 } else { () };
    // First compute sizes
    let my_size = fill_sizes(adj_list, adj_off, removed, sizes, node, parent);
    // Then find centroid
    find_centroid_inner(adj_list, adj_off, removed, sizes, node, parent, tree_size)
    };

// Fill sizes array via DFS
fn fill_sizes(adj_list: i64, adj_off: i64, removed: i64, sizes: i64, node: i64, parent: i64) -> i64 = {
    if vec_get(removed, node) == 1 { return 0 } else { () };
    let mut sz = 1;
    let start = vec_get(adj_off, node);
    let end_val = vec_get(adj_off, node + 1);
    let mut j = start;
    while j < end_val {
        let nb = vec_get(adj_list, j);
        let _x = if nb != parent and vec_get(removed, nb) == 0 {
            set sz = sz + fill_sizes(adj_list, adj_off, removed, sizes, nb, node);
            0
        } else { 0 };
        set j = j + 1
    };
    let _s = vec_set(sizes, node, sz);
    sz
    };

// Find centroid given filled sizes array
fn find_centroid_inner(adj_list: i64, adj_off: i64, removed: i64, sizes: i64,
    node: i64, parent: i64, tree_size: i64) -> i64 = {
    if vec_get(removed, node) == 1 { return 0 - 1 } else { () };
    let half = tree_size / 2;
    let my_size = vec_get(sizes, node);
    // max child subtree
    let mut max_child = tree_size - my_size;  // "parent side" subtree
    let start = vec_get(adj_off, node);
    let end_val = vec_get(adj_off, node + 1);
    let mut j = start;
    while j < end_val {
        let nb = vec_get(adj_list, j);
        let _x = if nb != parent and vec_get(removed, nb) == 0 {
            let child_sz = vec_get(sizes, nb);
            let _y = if child_sz > max_child { set max_child = child_sz; 0 } else { 0 };
            0
        } else { 0 };
        set j = j + 1
    };
    if max_child <= half { node }
    else {
        // Go deeper into largest child
        let mut best = 0 - 1;
        let mut jj = start;
        while jj < end_val {
            let nb2 = vec_get(adj_list, jj);
            let _x2 = if nb2 != parent and vec_get(removed, nb2) == 0 {
                let child_sz2 = vec_get(sizes, nb2);
                let _y2 = if child_sz2 > half and best == 0 - 1 {
                    set best = find_centroid_inner(adj_list, adj_off, removed, sizes, nb2, node, tree_size);
                    0
                } else { 0 };
                0
            } else { 0 };
            set jj = jj + 1
        };
        if best == 0 - 1 { node } else { best }
    }
    };

// Centroid decomposition: find centroid, record parent, recurse
fn decompose(adj_list: i64, adj_off: i64, removed: i64, sizes: i64,
    cd_parent: i64, cd_order: i64, cd_idx: i64, node: i64, par: i64) -> i64 = {
    let tree_sz = compute_size(adj_list, adj_off, removed, node, 0 - 1);
    if tree_sz == 0 { return cd_idx } else { () };

    // Find centroid
    let _fs = fill_sizes(adj_list, adj_off, removed, sizes, node, 0 - 1);
    let c = find_centroid_inner(adj_list, adj_off, removed, sizes, node, 0 - 1, tree_sz);

    // Record
    let _sp = vec_set(cd_parent, c, par);
    let _so = vec_set(cd_order, cd_idx, c);
    let _sr = vec_set(removed, c, 1);

    // Recurse on each subtree
    let start = vec_get(adj_off, c);
    let end_val = vec_get(adj_off, c + 1);
    let mut cur_idx = cd_idx + 1;
    let mut j = start;
    while j < end_val {
        let nb = vec_get(adj_list, j);
        let _x = if vec_get(removed, nb) == 0 {
            set cur_idx = decompose(adj_list, adj_off, removed, sizes, cd_parent, cd_order, cur_idx, nb, c);
            0
        } else { 0 };
        set j = j + 1
    };
    cur_idx
    };

fn make_zeros(n: i64) -> i64 = {
    let v = vec_new();
    for _i in 0..n { vec_push(v, 0) };
    v
    };

fn make_neg_ones(n: i64) -> i64 = {
    let v = vec_new();
    for _i in 0..n { vec_push(v, 0 - 1) };
    v
    };

// Build adjacency list for undirected tree from edge list
// edges = flat vec [u0,v0, u1,v1, ...]
fn build_adj(n: i64, edges: i64, num_edges: i64) -> i64 = {
    // Count degree of each node
    let degree = make_zeros(n);
    let mut i = 0;
    while i < num_edges * 2 {
        let u = vec_get(edges, i);
        let v = vec_get(edges, i + 1);
        let _s1 = vec_set(degree, u, vec_get(degree, u) + 1);
        let _s2 = vec_set(degree, v, vec_get(degree, v) + 1);
        set i = i + 2
    };

    // Build offset array (prefix sum)
    let adj_off = make_zeros(n + 1);
    let mut j = 0;
    while j < n {
        let _s = vec_set(adj_off, j + 1, vec_get(adj_off, j) + vec_get(degree, j));
        set j = j + 1
    };

    // Build adjacency list
    let total_slots = vec_get(adj_off, n);
    let adj_list = make_zeros(total_slots);
    let pos = make_zeros(n);  // current insertion position for each node
    let mut k = 0;
    while k < num_edges * 2 {
        let u2 = vec_get(edges, k);
        let v2 = vec_get(edges, k + 1);
        let pu = vec_get(adj_off, u2) + vec_get(pos, u2);
        let _s3 = vec_set(adj_list, pu, v2);
        let _s4 = vec_set(pos, u2, vec_get(pos, u2) + 1);
        let pv = vec_get(adj_off, v2) + vec_get(pos, v2);
        let _s5 = vec_set(adj_list, pv, u2);
        let _s6 = vec_set(pos, v2, vec_get(pos, v2) + 1);
        set k = k + 2
    };

    // Return both as a "pair": adj_list handle * 1000 + adj_off handle
    // Actually, just use global-like approach: return adj_list, adj_off via side channel
    // Simpler: store adj_off handle at adj_list index (total_slots)
    // We'll just return a vec containing [adj_list_handle, adj_off_handle]
    let result = vec_new();
    vec_push(result, adj_list);
    vec_push(result, adj_off);
    result
    };

fn main() -> i64 = {
    // Tree 1: Path graph 0-1-2-3-4 (5 nodes)
    // Edges: (0,1), (1,2), (2,3), (3,4)
    let n1 = 5;
    let edges1 = vec_new();
    vec_push(edges1, 0); vec_push(edges1, 1);
    vec_push(edges1, 1); vec_push(edges1, 2);
    vec_push(edges1, 2); vec_push(edges1, 3);
    vec_push(edges1, 3); vec_push(edges1, 4);

    let adj_pair1 = build_adj(n1, edges1, 4);
    let adj_list1 = vec_get(adj_pair1, 0);
    let adj_off1 = vec_get(adj_pair1, 1);

    let removed1 = make_zeros(n1);
    let sizes1 = make_zeros(n1);
    let cd_parent1 = make_neg_ones(n1);
    let cd_order1 = make_neg_ones(n1);

    let total1 = decompose(adj_list1, adj_off1, removed1, sizes1, cd_parent1, cd_order1, 0, 0, 0 - 1);

    // Centroid of path 0-1-2-3-4 is node 2
    let _sp1 = print_str("path5:");
    let _p1 = println(vec_get(cd_order1, 0));  // First centroid = 2
    let _p2 = println(total1);  // 5 nodes processed

    // Print centroid tree parent for each node
    let _sp2 = print_str("parents:");
    let _p3 = println(vec_get(cd_parent1, 2));  // centroid 2 has parent -1 (root)

    // Tree 2: Star graph: 0 connected to 1,2,3,4,5,6
    let n2 = 7;
    let edges2 = vec_new();
    vec_push(edges2, 0); vec_push(edges2, 1);
    vec_push(edges2, 0); vec_push(edges2, 2);
    vec_push(edges2, 0); vec_push(edges2, 3);
    vec_push(edges2, 0); vec_push(edges2, 4);
    vec_push(edges2, 0); vec_push(edges2, 5);
    vec_push(edges2, 0); vec_push(edges2, 6);

    let adj_pair2 = build_adj(n2, edges2, 6);
    let adj_list2 = vec_get(adj_pair2, 0);
    let adj_off2 = vec_get(adj_pair2, 1);

    let removed2 = make_zeros(n2);
    let sizes2 = make_zeros(n2);
    let cd_parent2 = make_neg_ones(n2);
    let cd_order2 = make_neg_ones(n2);

    let total2 = decompose(adj_list2, adj_off2, removed2, sizes2, cd_parent2, cd_order2, 0, 0, 0 - 1);

    // Star: centroid is node 0 (center)
    let _sp3 = print_str("star7:");
    let _p4 = println(vec_get(cd_order2, 0));  // First centroid = 0
    let _p5 = println(total2);  // 7 nodes processed

    // All leaves should have centroid-parent = 0
    let _p6 = println(vec_get(cd_parent2, 0));  // -1 (root of centroid tree)
    let _p7 = println(vec_get(cd_parent2, 1));  // 0
    let _p8 = println(vec_get(cd_parent2, 2));  // 0

    // Tree 3: Binary tree:     0
    //                        /   \
    //                       1     2
    //                      / \
    //                     3   4
    let n3 = 5;
    let edges3 = vec_new();
    vec_push(edges3, 0); vec_push(edges3, 1);
    vec_push(edges3, 0); vec_push(edges3, 2);
    vec_push(edges3, 1); vec_push(edges3, 3);
    vec_push(edges3, 1); vec_push(edges3, 4);

    let adj_pair3 = build_adj(n3, edges3, 4);
    let adj_list3 = vec_get(adj_pair3, 0);
    let adj_off3 = vec_get(adj_pair3, 1);

    let removed3 = make_zeros(n3);
    let sizes3 = make_zeros(n3);
    let cd_parent3 = make_neg_ones(n3);
    let cd_order3 = make_neg_ones(n3);

    let total3 = decompose(adj_list3, adj_off3, removed3, sizes3, cd_parent3, cd_order3, 0, 0, 0 - 1);

    // Centroid of this tree: node 1 (subtrees: {3},{4},{0,2} all size <= 2)
    // or node 0 (subtrees: {2},{1,3,4} max=3) - not centroid since 3 > 5/2=2
    // node 1: subtrees {3}=1, {4}=1, {0,2}=2, max=2 <= 5/2=2 => centroid
    let _sp4 = print_str("btree5:");
    let _p9 = println(vec_get(cd_order3, 0));  // First centroid = 1
    let _p10 = println(total3);  // 5 nodes processed

    // Verify: count how many nodes have centroid-parent = -1 (should be exactly 1)
    let mut root_count = 0;
    for i in 0..n3 {
        let _x = if vec_get(cd_parent3, i) == 0 - 1 { set root_count = root_count + 1; 0 } else { 0 };
        0
    };
    let _p11 = println(root_count);  // 1

    0
    };

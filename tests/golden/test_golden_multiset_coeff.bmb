// Golden Test: Multiset Coefficient / Stars and Bars
// C(n+k-1, k) = number of ways to choose k items from n types with repetition
// Also known as "stars and bars" theorem

// Binomial coefficient using iterative multiplication
fn binomial(n: i64, k: i64) -> i64 = {
    if k < 0 or k > n { return 0 } else { () };
    if k == 0 or k == n { return 1 } else { () };
    let kk = if k > n - k { n - k } else { k };
    let mut result = 1;
    let mut i = 0;
    loop {
        if i >= kk { break } else { () };
        result = result * (n - i) / (i + 1);
        i = i + 1
    };
    result
};

// Multiset coefficient: ((n choose k)) = C(n+k-1, k)
// Ways to choose k items from n types with repetition allowed
fn multiset(n: i64, k: i64) -> i64 =
    binomial(n + k - 1, k);

// Stars and bars: distribute k identical balls into n distinct bins
// Same as multiset(n, k) = C(n+k-1, k)
fn stars_bars(n_bins: i64, k_balls: i64) -> i64 =
    binomial(n_bins + k_balls - 1, k_balls);

// Distribute k identical balls into n bins, each bin has at least 1
// = C(k-1, n-1) (place dividers in gaps between balls)
fn stars_bars_nonempty(n_bins: i64, k_balls: i64) -> i64 =
    if k_balls < n_bins { 0 }
    else { binomial(k_balls - 1, n_bins - 1) };

// Number of non-negative integer solutions to x1+x2+...+xn = k
fn nonneg_solutions(n: i64, k: i64) -> i64 =
    stars_bars(n, k);

// Number of solutions with upper bound: xi <= max_val
// Using inclusion-exclusion: sum_{j=0}^{n} (-1)^j * C(n,j) * C(n+k-j*(max_val+1)-1, k-j*(max_val+1))
fn bounded_solutions(n: i64, k: i64, max_val: i64) -> i64 = {
    let mut sum = 0;
    let mut j = 0;
    loop {
        if j > n { break } else { () };
        let excess = j * (max_val + 1);
        let _x = if excess > k {
            // remaining terms are zero
            j = n + 1;  // break
            0
        } else {
            let sign = if j - 2 * (j / 2) == 0 { 1 } else { 0 - 1 };
            let ways = binomial(n + k - excess - 1, k - excess);
            sum = sum + sign * binomial(n, j) * ways;
            j = j + 1;
            0
        };
        0
    };
    sum
};

// Composition count: ordered ways to write n as sum of k positive integers
// = C(n-1, k-1)
fn composition_count(n: i64, k: i64) -> i64 =
    if n < k { 0 }
    else { binomial(n - 1, k - 1) };

// Weak composition: ordered ways to write n as sum of k non-negative integers
// = C(n+k-1, k-1)
fn weak_composition(n: i64, k: i64) -> i64 =
    binomial(n + k - 1, k - 1);

fn main() -> i64 = {
    // Multiset coefficients
    // ((3 choose 2)) = C(4,2) = 6: choose 2 from {a,b,c} with repetition
    let _p1 = println(multiset(3, 2));   // 6
    // ((4 choose 3)) = C(6,3) = 20
    let _p2 = println(multiset(4, 3));   // 20
    // ((2 choose 5)) = C(6,5) = 6
    let _p3 = println(multiset(2, 5));   // 6

    // Stars and bars: distribute balls into bins
    // 3 balls, 2 bins: {(0,3),(1,2),(2,1),(3,0)} = 4
    let _p4 = println(stars_bars(2, 3)); // 4
    // 5 balls, 3 bins: C(7,5) = 21
    let _p5 = println(stars_bars(3, 5)); // 21

    // Stars and bars with non-empty bins
    // 6 balls, 3 bins, each >= 1: C(5,2) = 10
    let _p6 = println(stars_bars_nonempty(3, 6));  // 10
    // 4 balls, 4 bins, each >= 1: C(3,3) = 1
    let _p7 = println(stars_bars_nonempty(4, 4));  // 1
    // 2 balls, 3 bins (impossible): 0
    let _p8 = println(stars_bars_nonempty(3, 2));  // 0

    // Non-negative integer solutions: x1+x2+x3 = 4
    // = C(6,4) = 15
    let _p9 = println(nonneg_solutions(3, 4));  // 15

    // Bounded solutions: x1+x2+x3 = 4, each xi <= 2
    // By inclusion-exclusion: C(6,4) - 3*C(3,1) + 0 = 15 - 9 = 6
    let _p10 = println(bounded_solutions(3, 4, 2));  // 6

    // Bounded: x1+x2 = 5, each xi <= 3
    // C(6,5) - 2*C(2,1) = 6 - 4 = 2: {(2,3),(3,2)}
    let _p11 = println(bounded_solutions(2, 5, 3));  // 2

    // Bounded: x1+x2+x3 = 6, each xi <= 3
    // C(8,6) - 3*C(4,2) + 3*C(0,-2)... = 28 - 18 + 0 = 10
    let _p12 = println(bounded_solutions(3, 6, 3));  // 10

    // Compositions: write 5 as sum of 3 positive integers
    // C(4,2) = 6: {1+1+3, 1+2+2, 1+3+1, 2+1+2, 2+2+1, 3+1+1}
    let _p13 = println(composition_count(5, 3));  // 6

    // Weak compositions: write 3 as sum of 3 non-negative integers
    // C(5,2) = 10
    let _p14 = println(weak_composition(3, 3));  // 10

    // Edge cases
    let _p15 = println(multiset(1, 10));  // C(10,10) = 1 (only one type)
    let _p16 = println(multiset(10, 0));  // C(9,0) = 1 (choose nothing)
    let _p17 = println(stars_bars(1, 7)); // C(7,7) = 1 (all in one bin)
    let _p18 = println(composition_count(4, 1)); // 1 (just "4")

    0
};

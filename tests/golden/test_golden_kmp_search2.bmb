// Golden Test: KMP String Search (integer array version)
// Builds failure function, then searches for pattern in text

// Build KMP failure table
fn kmp_failure(pat: i64, m: i64) -> i64 = {
    let fail = vec_new();
    vec_push(fail, 0);  // fail[0] = 0
    let mut len = 0;
    let mut i = 1;
    loop {
        if i >= m { break } else { () };
        if vec_get(pat, i) == vec_get(pat, len) {
            set len = len + 1;
            vec_push(fail, len);
            set i = i + 1;
        } else if len > 0 {
            set len = vec_get(fail, len - 1);
            0
        } else {
            vec_push(fail, 0);
            set i = i + 1;
        };
    };
    fail
};

// KMP search: returns first match index or -1
fn kmp_search(text: i64, n: i64, pat: i64, m: i64) -> i64 = {
    let fail = kmp_failure(pat, m);
    let mut i = 0;
    let mut j = 0;
    let mut result = 0 - 1;
    loop {
        if i >= n or result >= 0 { break } else { () };
        if vec_get(text, i) == vec_get(pat, j) {
            set i = i + 1;
            set j = j + 1;
            let _x = if j == m {
                set result = i - m;
                0
            } else { 0 };
        } else if j > 0 {
            set j = vec_get(fail, j - 1);
            0
        } else {
            set i = i + 1;
            0
        };
    };
    vec_free(fail);
    result
};

// Count all occurrences
fn kmp_count(text: i64, n: i64, pat: i64, m: i64) -> i64 = {
    let fail = kmp_failure(pat, m);
    let mut i = 0;
    let mut j = 0;
    let mut count = 0;
    loop {
        if i >= n { break } else { () };
        if vec_get(text, i) == vec_get(pat, j) {
            set i = i + 1;
            set j = j + 1;
            let _x = if j == m {
                set count = count + 1;
                set j = vec_get(fail, j - 1);
                0
            } else { 0 };
        } else if j > 0 {
            set j = vec_get(fail, j - 1);
            0
        } else {
            set i = i + 1;
            0
        };
    };
    vec_free(fail);
    count
};

fn make_vec3(a: i64, b: i64, c: i64) -> i64 = {
    let v = vec_new();
    vec_push(v, a);
    vec_push(v, b);
    vec_push(v, c);
    v
};

fn main() -> i64 = {
    // Text: [1, 2, 3, 1, 2, 3, 1, 2, 4]
    let text = vec_new();
    vec_push(text, 1);
    vec_push(text, 2);
    vec_push(text, 3);
    vec_push(text, 1);
    vec_push(text, 2);
    vec_push(text, 3);
    vec_push(text, 1);
    vec_push(text, 2);
    vec_push(text, 4);

    // Pattern: [1, 2, 3]
    let pat1 = make_vec3(1, 2, 3);

    // Test 1: First occurrence
    let _p1 = println(kmp_search(text, 9, pat1, 3));  // 0

    // Test 2: Count occurrences
    let _p2 = println(kmp_count(text, 9, pat1, 3));  // 2

    // Pattern: [1, 2, 4]
    let pat2 = make_vec3(1, 2, 4);
    let _p3 = println(kmp_search(text, 9, pat2, 3));  // 6

    // Pattern: [3, 1, 2]
    let pat3 = make_vec3(3, 1, 2);
    let _p4 = println(kmp_search(text, 9, pat3, 3));  // 2

    // Pattern not found: [4, 5, 6]
    let pat4 = make_vec3(4, 5, 6);
    let _p5 = println(kmp_search(text, 9, pat4, 3));  // -1

    // Test failure table
    // Pattern: [1, 1, 1, 1]
    let pat5 = vec_new();
    vec_push(pat5, 1);
    vec_push(pat5, 1);
    vec_push(pat5, 1);
    vec_push(pat5, 1);
    let fail5 = kmp_failure(pat5, 4);
    let _p6 = println(vec_get(fail5, 0));  // 0
    let _p7 = println(vec_get(fail5, 1));  // 1
    let _p8 = println(vec_get(fail5, 2));  // 2
    let _p9 = println(vec_get(fail5, 3));  // 3

    // Overlapping matches: [1,1] in [1,1,1,1]
    let text2 = vec_new();
    vec_push(text2, 1);
    vec_push(text2, 1);
    vec_push(text2, 1);
    vec_push(text2, 1);
    let pat6 = vec_new();
    vec_push(pat6, 1);
    vec_push(pat6, 1);
    let _p10 = println(kmp_count(text2, 4, pat6, 2));  // 3

    vec_free(text);
    vec_free(pat1);
    vec_free(pat2);
    vec_free(pat3);
    vec_free(pat4);
    vec_free(pat5);
    vec_free(fail5);
    vec_free(text2);
    vec_free(pat6);
    0
};

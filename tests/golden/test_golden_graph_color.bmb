// Golden Test: Greedy Graph Coloring
// Colors vertices using minimum colors with greedy approach
// Uses adjacency list representation

fn greedy_color(adj: i64, adj_size: i64, n: i64) -> i64 = {
    let color = vec_new();
    let mut i = 0;
    while i < n {
        let _p = vec_push(color, 0 - 1);
        set i = i + 1
    };
    // Color vertex 0 with color 0
    vec_set(color, 0, 0);

    // Color remaining vertices
    set i = 1;
    while i < n {
        // Find used colors among neighbors
        let used = vec_new();
        let mut k = 0;
        while k < n {
            let _p = vec_push(used, 0);
            set k = k + 1
        };
        let deg = vec_get(adj_size, i);
        let base = i * n;
        set k = 0;
        while k < deg {
            let nb = vec_get(adj, base + k);
            let c = vec_get(color, nb);
            let _x = if c >= 0 {
                vec_set(used, c, 1);
                0
            } else { 0 };
            set k = k + 1
        };
        // Find smallest unused color
        let mut c = 0;
        while vec_get(used, c) == 1 {
            set c = c + 1
        };
        vec_set(color, i, c);
        set i = i + 1
    };
    color
};

fn add_edge(adj: i64, adj_size: i64, n: i64, u: i64, v: i64) -> () = {
    let du = vec_get(adj_size, u);
    vec_set(adj, u * n + du, v);
    vec_set(adj_size, u, du + 1);
    let dv = vec_get(adj_size, v);
    vec_set(adj, v * n + dv, u);
    vec_set(adj_size, v, dv + 1)
};

fn max_color(color: i64, n: i64) -> i64 = {
    let mut mx = 0;
    let mut i = 0;
    while i < n {
        let c = vec_get(color, i);
        set mx = if c > mx { c } else { mx };
        set i = i + 1
    };
    mx + 1
};

fn main() -> () = {
    // Test 1: Petersen-like graph (5-cycle)
    let n = 5;
    let adj = vec_new();
    let adj_size = vec_new();
    let mut i = 0;
    while i < n * n {
        let _p = vec_push(adj, 0);
        set i = i + 1
    };
    set i = 0;
    while i < n {
        let _p = vec_push(adj_size, 0);
        set i = i + 1
    };
    add_edge(adj, adj_size, n, 0, 1);
    add_edge(adj, adj_size, n, 1, 2);
    add_edge(adj, adj_size, n, 2, 3);
    add_edge(adj, adj_size, n, 3, 4);
    add_edge(adj, adj_size, n, 4, 0);
    let color = greedy_color(adj, adj_size, n);
    print_str("5-cycle colors:");
    set i = 0;
    while i < n {
        print_str(" "); print(vec_get(color, i));
        set i = i + 1
    };
    print_str("
");
    print_str("chromatic<="); let _r = println(max_color(color, n));

    // Test 2: Complete graph K4 (needs 4 colors)
    let n2 = 4;
    let adj2 = vec_new();
    let adj_size2 = vec_new();
    set i = 0;
    while i < n2 * n2 { let _p = vec_push(adj2, 0); set i = i + 1 };
    set i = 0;
    while i < n2 { let _p = vec_push(adj_size2, 0); set i = i + 1 };
    add_edge(adj2, adj_size2, n2, 0, 1);
    add_edge(adj2, adj_size2, n2, 0, 2);
    add_edge(adj2, adj_size2, n2, 0, 3);
    add_edge(adj2, adj_size2, n2, 1, 2);
    add_edge(adj2, adj_size2, n2, 1, 3);
    add_edge(adj2, adj_size2, n2, 2, 3);
    let color2 = greedy_color(adj2, adj_size2, n2);
    print_str("K4 colors:");
    set i = 0;
    while i < n2 {
        print_str(" "); print(vec_get(color2, i));
        set i = i + 1
    };
    print_str("
");
    print_str("K4 chromatic="); let _r = println(max_color(color2, n2));

    // Test 3: Bipartite (star graph, needs 2 colors)
    let n3 = 5;
    let adj3 = vec_new();
    let adj_size3 = vec_new();
    set i = 0;
    while i < n3 * n3 { let _p = vec_push(adj3, 0); set i = i + 1 };
    set i = 0;
    while i < n3 { let _p = vec_push(adj_size3, 0); set i = i + 1 };
    add_edge(adj3, adj_size3, n3, 0, 1);
    add_edge(adj3, adj_size3, n3, 0, 2);
    add_edge(adj3, adj_size3, n3, 0, 3);
    add_edge(adj3, adj_size3, n3, 0, 4);
    let color3 = greedy_color(adj3, adj_size3, n3);
    print_str("star chromatic="); let _r = println(max_color(color3, n3))
};

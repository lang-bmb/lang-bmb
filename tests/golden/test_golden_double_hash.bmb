// Golden Test: Double hashing open addressing hash table
// Insert, search, delete with double hashing probe sequence
// h1(k) = k mod size, h2(k) = 1 + (k mod (size-1))
// probe(k, i) = (h1(k) + i * h2(k)) mod size
// Slots: -1 = empty, -2 = deleted (tombstone)

fn abs_val(x: i64) -> i64 =
    if x < 0 { 0 - x } else { x };

fn mod_val(a: i64, m: i64) -> i64 = {
    let r = a - (a / m) * m;
    if r < 0 { r + m } else { r }
    };

fn h1(key: i64, size: i64) -> i64 =
    mod_val(abs_val(key), size);

fn h2(key: i64, size: i64) -> i64 =
    1 + mod_val(abs_val(key), size - 1);

fn probe(key: i64, i: i64, size: i64) -> i64 =
    mod_val(h1(key, size) + i * h2(key, size), size);

// Create table of given size, all slots = -1 (empty)
fn make_table(size: i64) -> i64 = {
    let v = vec_new();
    for _i in 0..size { vec_push(v, 0 - 1) };
    v
    };

// Insert key into table. Returns 1 on success, 0 if full.
fn ht_insert(table: i64, key: i64, size: i64, attempt: i64) -> i64 =
    if attempt >= size { 0 }
    else {
        let idx = probe(key, attempt, size);
        let slot = vec_get(table, idx);
        if slot == key { 1 }  // already present
        else if slot == 0 - 1 or slot == 0 - 2 {
            // empty or tombstone: place here
            let _s = vec_set(table, idx, key);
            1
        }
        else { ht_insert(table, key, size, attempt + 1) }
    };

// Search for key. Returns index if found, -1 if not found.
fn ht_search(table: i64, key: i64, size: i64, attempt: i64) -> i64 =
    if attempt >= size { 0 - 1 }
    else {
        let idx = probe(key, attempt, size);
        let slot = vec_get(table, idx);
        if slot == key { idx }
        else if slot == 0 - 1 { 0 - 1 }  // empty: stop
        else { ht_search(table, key, size, attempt + 1) }  // tombstone or other: continue
    };

// Delete key. Returns 1 if deleted, 0 if not found.
fn ht_delete(table: i64, key: i64, size: i64, attempt: i64) -> i64 =
    if attempt >= size { 0 }
    else {
        let idx = probe(key, attempt, size);
        let slot = vec_get(table, idx);
        if slot == key {
            let _s = vec_set(table, idx, 0 - 2);  // tombstone
            1
        }
        else if slot == 0 - 1 { 0 }
        else { ht_delete(table, key, size, attempt + 1) }
    };

// Count occupied slots (not empty, not tombstone)
fn ht_count(table: i64, size: i64, i: i64, acc: i64) -> i64 =
    if i >= size { acc }
    else {
        let slot = vec_get(table, i);
        let inc = if slot != 0 - 1 and slot != 0 - 2 { 1 } else { 0 };
        ht_count(table, size, i + 1, acc + inc)
    };

// Count tombstones
fn ht_tombstones(table: i64, size: i64, i: i64, acc: i64) -> i64 =
    if i >= size { acc }
    else {
        let inc = if vec_get(table, i) == 0 - 2 { 1 } else { 0 };
        ht_tombstones(table, size, i + 1, acc + inc)
    };

// Probe length to find a key (0 if not found)
fn probe_length(table: i64, key: i64, size: i64, attempt: i64) -> i64 =
    if attempt >= size { 0 }
    else {
        let idx = probe(key, attempt, size);
        let slot = vec_get(table, idx);
        if slot == key { attempt + 1 }
        else if slot == 0 - 1 { 0 }
        else { probe_length(table, key, size, attempt + 1) }
    };

fn found(table: i64, key: i64, size: i64) -> i64 =
    if ht_search(table, key, size, 0) >= 0 { 1 } else { 0 };

fn main() -> i64 = {
    let size = 13;
    let t = make_table(size);

    // Test 1: Basic insert and search
    let _i1 = ht_insert(t, 10, size, 0);
    let _i2 = ht_insert(t, 23, size, 0);  // h1(23)=10, collides with 10
    let _i3 = ht_insert(t, 36, size, 0);  // h1(36)=10, collides again

    let _p1 = println(found(t, 10, size));   // 1
    let _p2 = println(found(t, 23, size));   // 1
    let _p3 = println(found(t, 36, size));   // 1
    let _p4 = println(found(t, 99, size));   // 0
    let _p5 = println(ht_count(t, size, 0, 0));  // 3

    // Test 2: Delete and re-search
    let _d1 = ht_delete(t, 23, size, 0);
    let _p6 = println(found(t, 23, size));   // 0 (deleted)
    let _p7 = println(found(t, 36, size));   // 1 (still found through tombstone)
    let _p8 = println(ht_count(t, size, 0, 0));  // 2
    let _p9 = println(ht_tombstones(t, size, 0, 0));  // 1

    // Test 3: Re-insert into tombstone slot
    let _i4 = ht_insert(t, 49, size, 0);  // h1(49)=10, should find tombstone
    let _p10 = println(found(t, 49, size));  // 1
    let _p11 = println(ht_count(t, size, 0, 0));  // 3

    // Test 4: Insert more keys with different hash values
    let _i5 = ht_insert(t, 5, size, 0);   // h1(5)=5
    let _i6 = ht_insert(t, 18, size, 0);  // h1(18)=5, collides with 5
    let _i7 = ht_insert(t, 7, size, 0);   // h1(7)=7
    let _i8 = ht_insert(t, 20, size, 0);  // h1(20)=7, collides with 7
    let _p12 = println(ht_count(t, size, 0, 0));  // 7

    // Test 5: Probe lengths
    let _p13 = println(probe_length(t, 10, size, 0));  // 1 (first slot)
    let _p14 = println(probe_length(t, 5, size, 0));   // 1 (first slot)

    // Test 6: Duplicate insert does nothing
    let _i9 = ht_insert(t, 10, size, 0);
    let _p15 = println(ht_count(t, size, 0, 0));  // still 7

    // Test 7: Delete non-existent key
    let _d2 = ht_delete(t, 999, size, 0);
    let _p16 = println(ht_count(t, size, 0, 0));  // still 7

    // Test 8: Delete all, then verify empty
    let _d3 = ht_delete(t, 10, size, 0);
    let _d4 = ht_delete(t, 36, size, 0);
    let _d5 = ht_delete(t, 49, size, 0);
    let _d6 = ht_delete(t, 5, size, 0);
    let _d7 = ht_delete(t, 18, size, 0);
    let _d8 = ht_delete(t, 7, size, 0);
    let _d9 = ht_delete(t, 20, size, 0);
    let _p17 = println(ht_count(t, size, 0, 0));  // 0
    let _p18 = println(ht_tombstones(t, size, 0, 0));  // 7 + previous 0 tombstones still there

    // Test 9: Insert after full delete (tombstones allow re-use)
    let _i10 = ht_insert(t, 100, size, 0);
    let _p19 = println(found(t, 100, size));  // 1
    let _p20 = println(ht_count(t, size, 0, 0));  // 1

    0
    };

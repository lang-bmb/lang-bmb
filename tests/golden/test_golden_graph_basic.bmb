// Golden Test: Basic graph algorithms using adjacency list (vec of vecs)
// Graph represented as: graph = vec of neighbor-lists
// graph[i] = vec of neighbors of node i

// Create empty graph with n nodes (each node has empty neighbor list)
fn graph_new(n: i64) -> i64 = {
    let g = vec_new();
    for _i in 0..n {
        vec_push(g, vec_new())
    };
    g
    };

// Add undirected edge between u and v
fn add_edge(g: i64, u: i64, v: i64) -> i64 = {
    let u_neighbors = vec_get(g, u);
    vec_push(u_neighbors, v);
    let v_neighbors = vec_get(g, v);
    vec_push(v_neighbors, u);
    0
    };

// Add directed edge from u to v
fn add_directed_edge(g: i64, u: i64, v: i64) -> i64 = {
    let u_neighbors = vec_get(g, u);
    vec_push(u_neighbors, v);
    0
    };

// Count total edges (for undirected: sum of all neighbor counts / 2)
fn count_edges_undirected(g: i64, node: i64, total: i64) -> i64 =
    if node >= vec_len(g) { total / 2 }
    else { count_edges_undirected(g, node + 1, total + vec_len(vec_get(g, node))) };

// Degree of a node
fn degree(g: i64, node: i64) -> i64 =
    vec_len(vec_get(g, node));

// BFS shortest path using vec as queue
// Returns distance array (vec of i64, -1 = unreachable)
fn bfs(g: i64, start: i64, n: i64) -> i64 = {
    let dist = vec_new();
    for _i in 0..n {
        vec_push(dist, 0 - 1)
    };
    vec_set(dist, start, 0);
    // Use vec as queue: front pointer + vec
    let queue = vec_new();
    vec_push(queue, start);
    bfs_loop(g, dist, queue, 0, n);
    dist
    };

fn bfs_loop(g: i64, dist: i64, queue: i64, front: i64, n: i64) -> i64 =
    if front >= vec_len(queue) { 0 }
    else {
        let node = vec_get(queue, front);
        let neighbors = vec_get(g, node);
        bfs_visit_neighbors(g, dist, queue, node, neighbors, 0);
        bfs_loop(g, dist, queue, front + 1, n)
    };

fn bfs_visit_neighbors(g: i64, dist: i64, queue: i64, node: i64, neighbors: i64, idx: i64) -> i64 =
    if idx >= vec_len(neighbors) { 0 }
    else {
        let nb = vec_get(neighbors, idx);
        if vec_get(dist, nb) == 0 - 1 {
            vec_set(dist, nb, vec_get(dist, node) + 1);
            vec_push(queue, nb);
            bfs_visit_neighbors(g, dist, queue, node, neighbors, idx + 1)
        } else {
            bfs_visit_neighbors(g, dist, queue, node, neighbors, idx + 1)
        }
    };

// DFS cycle detection for undirected graph
// Returns 1 if cycle found, 0 otherwise
fn has_cycle(g: i64, n: i64) -> i64 = {
    let visited = vec_new();
    for _i in 0..n {
        vec_push(visited, 0)
    };
    has_cycle_outer(g, visited, n, 0)
    };

fn has_cycle_outer(g: i64, visited: i64, n: i64, node: i64) -> i64 =
    if node >= n { 0 }
    else if vec_get(visited, node) == 1 { has_cycle_outer(g, visited, n, node + 1) }
    else {
        if dfs_cycle(g, visited, node, 0 - 1) == 1 { 1 }
        else { has_cycle_outer(g, visited, n, node + 1) }
    };

fn dfs_cycle(g: i64, visited: i64, node: i64, parent: i64) -> i64 = {
    vec_set(visited, node, 1);
    let neighbors = vec_get(g, node);
    dfs_cycle_neighbors(g, visited, node, parent, neighbors, 0)
    };

fn dfs_cycle_neighbors(g: i64, visited: i64, node: i64, parent: i64, neighbors: i64, idx: i64) -> i64 =
    if idx >= vec_len(neighbors) { 0 }
    else {
        let nb = vec_get(neighbors, idx);
        if vec_get(visited, nb) == 0 {
            if dfs_cycle(g, visited, nb, node) == 1 { 1 }
            else { dfs_cycle_neighbors(g, visited, node, parent, neighbors, idx + 1) }
        } else if nb != parent {
            1
        } else {
            dfs_cycle_neighbors(g, visited, node, parent, neighbors, idx + 1)
        }
    };

// Connected component count using DFS
fn count_components(g: i64, n: i64) -> i64 = {
    let visited = vec_new();
    for _i in 0..n {
        vec_push(visited, 0)
    };
    count_components_loop(g, visited, n, 0, 0)
    };

fn count_components_loop(g: i64, visited: i64, n: i64, node: i64, count: i64) -> i64 =
    if node >= n { count }
    else if vec_get(visited, node) == 1 { count_components_loop(g, visited, n, node + 1, count) }
    else {
        dfs_mark(g, visited, node);
        count_components_loop(g, visited, n, node + 1, count + 1)
    };

fn dfs_mark(g: i64, visited: i64, node: i64) -> i64 = {
    vec_set(visited, node, 1);
    let neighbors = vec_get(g, node);
    dfs_mark_neighbors(g, visited, neighbors, 0)
    };

fn dfs_mark_neighbors(g: i64, visited: i64, neighbors: i64, idx: i64) -> i64 =
    if idx >= vec_len(neighbors) { 0 }
    else {
        let nb = vec_get(neighbors, idx);
        if vec_get(visited, nb) == 0 {
            dfs_mark(g, visited, nb);
            dfs_mark_neighbors(g, visited, neighbors, idx + 1)
        } else {
            dfs_mark_neighbors(g, visited, neighbors, idx + 1)
        }
    };

fn main() -> i64 = {
    // Graph 1: 6 nodes, undirected
    // Edges: 0-1, 0-2, 1-3, 2-3, 3-4, 4-5, 2-5
    let g1 = graph_new(6);
    add_edge(g1, 0, 1);
    add_edge(g1, 0, 2);
    add_edge(g1, 1, 3);
    add_edge(g1, 2, 3);
    add_edge(g1, 3, 4);
    add_edge(g1, 4, 5);
    add_edge(g1, 2, 5);

    // Test 1: Total edges (undirected) = 7
    let _p1 = println(count_edges_undirected(g1, 0, 0));  // 7

    // Test 2: Degree of node 0 = 2
    let _p2 = println(degree(g1, 0));                      // 2

    // Test 3: Degree of node 2 = 3 (neighbors: 0, 3, 5)
    let _p3 = println(degree(g1, 2));                      // 3

    // Test 4: Degree of node 3 = 3 (neighbors: 1, 2, 4)
    let _p4 = println(degree(g1, 3));                      // 3

    // BFS from node 0
    let dist0 = bfs(g1, 0, 6);

    // Test 5: dist(0->0) = 0
    let _p5 = println(vec_get(dist0, 0));                  // 0

    // Test 6: dist(0->5) = 2 (0->2->5)
    let _p6 = println(vec_get(dist0, 5));                  // 2

    // Test 7: dist(0->4) = 3 (0->1->3->4 or 0->2->3->4)
    let _p7 = println(vec_get(dist0, 4));                  // 3

    // Test 8: dist(0->3) = 2 (0->1->3 or 0->2->3)
    let _p8 = println(vec_get(dist0, 3));                  // 2

    // Test 9: Has cycle (graph 1 has cycles) = 1
    let _p9 = println(has_cycle(g1, 6));                   // 1

    // Test 10: Connected components (graph 1 is fully connected) = 1
    let _p10 = println(count_components(g1, 6));           // 1

    // Graph 2: 5 nodes, disconnected
    // Component 1: 0-1, 1-2 (nodes 0,1,2)
    // Component 2: 3-4 (nodes 3,4)
    let g2 = graph_new(5);
    add_edge(g2, 0, 1);
    add_edge(g2, 1, 2);
    add_edge(g2, 3, 4);

    // Test 11: Connected components = 2
    let _p11 = println(count_components(g2, 5));           // 2

    // Test 12: Has cycle (graph 2 is a tree per component) = 0
    let _p12 = println(has_cycle(g2, 5));                  // 0

    // BFS from node 0 in disconnected graph
    let dist_g2 = bfs(g2, 0, 5);

    // Test 13: dist(0->2) = 2
    let _p13 = println(vec_get(dist_g2, 2));               // 2

    // Test 14: dist(0->3) = -1 (unreachable)
    let _p14 = println(vec_get(dist_g2, 3));               // -1

    0
    };

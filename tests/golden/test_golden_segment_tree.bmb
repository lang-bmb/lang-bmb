// Golden Test: Segment tree for range sum queries with point updates
// Tree stored in flat array of size 4*n, 1-indexed
// tree[1] = root, children of node i at 2*i and 2*i+1

fn make_zeros(n: i64) -> i64 = {
    let v = vec_new();
    for _i in 0..n { let _p = vec_push(v, 0); 0 };
    v
};

// Build segment tree recursively
// tree: flat array, arr: source data, node: current tree node index
// start, end: range in source array [start, end]
fn build(tree: i64, arr: i64, node: i64, start: i64, end: i64) -> i64 = {
    let _c = if start == end {
        let _s = vec_set(tree, node, vec_get(arr, start));
        ()
    } else {
        let mid = (start + end) / 2;
        let _l = build(tree, arr, node * 2, start, mid);
        let _r = build(tree, arr, node * 2 + 1, mid + 1, end);
        let _s = vec_set(tree, node, vec_get(tree, node * 2) + vec_get(tree, node * 2 + 1));
        ()
    };
    0
};

// Point update: set arr[idx] += diff, update tree
fn update(tree: i64, node: i64, start: i64, end: i64, idx: i64, diff: i64) -> i64 = {
    let _c = if start == end {
        let _s = vec_set(tree, node, vec_get(tree, node) + diff);
        ()
    } else {
        let mid = (start + end) / 2;
        let _c2 = if idx <= mid {
            let _u = update(tree, node * 2, start, mid, idx, diff);
            ()
        } else {
            let _u = update(tree, node * 2 + 1, mid + 1, end, idx, diff);
            ()
        };
        let _s = vec_set(tree, node, vec_get(tree, node * 2) + vec_get(tree, node * 2 + 1));
        ()
    };
    0
};

// Range sum query [l, r] (inclusive)
fn query(tree: i64, node: i64, start: i64, end: i64, l: i64, r: i64) -> i64 = {
    if l > end { 0 }
    else if r < start { 0 }
    else if l <= start {
        if end <= r { vec_get(tree, node) }
        else {
            let mid = (start + end) / 2;
            query(tree, node * 2, start, mid, l, r)
                + query(tree, node * 2 + 1, mid + 1, end, l, r)
        }
    } else {
        let mid = (start + end) / 2;
        query(tree, node * 2, start, mid, l, r)
            + query(tree, node * 2 + 1, mid + 1, end, l, r)
    }
};

fn main() -> i64 = {
    // === Test 1: Build and query [1, 3, 5, 7, 9, 11] ===
    let _p = println_str("=== Test 1: initial queries ===");
    let n = 6;
    let arr = vec_new();
    let _p = vec_push(arr, 1); let _p = vec_push(arr, 3);
    let _p = vec_push(arr, 5); let _p = vec_push(arr, 7);
    let _p = vec_push(arr, 9); let _p = vec_push(arr, 11);

    // Tree size 4*n is sufficient
    let tree = make_zeros(n * 4);
    let _b = build(tree, arr, 1, 0, n - 1);

    // sum(0, 5) = 1+3+5+7+9+11 = 36
    let _p = print_str("sum(0,5): ");
    let _p = println(query(tree, 1, 0, n - 1, 0, 5));

    // sum(1, 3) = 3+5+7 = 15
    let _p = print_str("sum(1,3): ");
    let _p = println(query(tree, 1, 0, n - 1, 1, 3));

    // sum(2, 4) = 5+7+9 = 21
    let _p = print_str("sum(2,4): ");
    let _p = println(query(tree, 1, 0, n - 1, 2, 4));

    // === Test 2: Point update and re-query ===
    // Update index 3: change 7 to 10, diff = +3
    let _p = println_str("=== Test 2: after update idx 3 to 10 ===");
    let _u = update(tree, 1, 0, n - 1, 3, 3);

    // sum(0, 5) = 1+3+5+10+9+11 = 39
    let _p = print_str("sum(0,5): ");
    let _p = println(query(tree, 1, 0, n - 1, 0, 5));

    // sum(1, 3) = 3+5+10 = 18
    let _p = print_str("sum(1,3): ");
    let _p = println(query(tree, 1, 0, n - 1, 1, 3));

    // sum(2, 4) = 5+10+9 = 24
    let _p = print_str("sum(2,4): ");
    let _p = println(query(tree, 1, 0, n - 1, 2, 4));

    // sum(3, 3) = 10 (single element)
    let _p = print_str("sum(3,3): ");
    let _p = println(query(tree, 1, 0, n - 1, 3, 3));

    // === Test 3: Multiple updates ===
    let _p = println_str("=== Test 3: multiple updates ===");
    // Update index 0: change 1 to 100, diff = +99
    let _u2 = update(tree, 1, 0, n - 1, 0, 99);
    // Update index 5: change 11 to 0, diff = -11
    let _u3 = update(tree, 1, 0, n - 1, 5, -11);

    // Array is now [100, 3, 5, 10, 9, 0]
    // sum(0, 5) = 100+3+5+10+9+0 = 127
    let _p = print_str("sum(0,5): ");
    let _p = println(query(tree, 1, 0, n - 1, 0, 5));

    // sum(0, 0) = 100
    let _p = print_str("sum(0,0): ");
    let _p = println(query(tree, 1, 0, n - 1, 0, 0));

    // sum(4, 5) = 9+0 = 9
    let _p = print_str("sum(4,5): ");
    let _p = println(query(tree, 1, 0, n - 1, 4, 5));

    // === Test 4: Small array [10, 20] ===
    let _p = println_str("=== Test 4: two elements ===");
    let n2 = 2;
    let arr2 = vec_new();
    let _p = vec_push(arr2, 10); let _p = vec_push(arr2, 20);
    let tree2 = make_zeros(n2 * 4);
    let _b2 = build(tree2, arr2, 1, 0, n2 - 1);
    let _p = print_str("sum(0,1): ");
    let _p = println(query(tree2, 1, 0, n2 - 1, 0, 1));
    let _p = print_str("sum(0,0): ");
    let _p = println(query(tree2, 1, 0, n2 - 1, 0, 0));
    let _p = print_str("sum(1,1): ");
    let _p = println(query(tree2, 1, 0, n2 - 1, 1, 1));

    // Cleanup
    let _f = vec_free(arr); let _f = vec_free(tree);
    let _f = vec_free(arr2); let _f = vec_free(tree2);
    0
};

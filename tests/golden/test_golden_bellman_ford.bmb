// Golden Test: Bellman-Ford shortest paths
// Single-source shortest path with negative weights
// Detects negative cycles

fn bellman_ford(edges: i64, num_edges: i64, n: i64, src: i64) -> i64 = {
    let dist = vec_new();
    let mut i = 0;
    while i < n {
        let _p = vec_push(dist, 999999);
        set i = i + 1
    };
    vec_set(dist, src, 0);
    // Relax n-1 times
    set i = 0;
    while i < n - 1 {
        let mut j = 0;
        while j < num_edges {
            let u = vec_get(edges, j * 3);
            let v = vec_get(edges, j * 3 + 1);
            let w = vec_get(edges, j * 3 + 2);
            let du = vec_get(dist, u);
            let _x = if du < 999999 and du + w < vec_get(dist, v) {
                vec_set(dist, v, du + w);
                0
            } else { 0 };
            set j = j + 1
        };
        set i = i + 1
    };
    // Check for negative cycles
    let has_neg_cycle = vec_new();
    let _p = vec_push(has_neg_cycle, 0);
    let mut j = 0;
    while j < num_edges {
        let u = vec_get(edges, j * 3);
        let v = vec_get(edges, j * 3 + 1);
        let w = vec_get(edges, j * 3 + 2);
        let _x = if vec_get(dist, u) < 999999 and vec_get(dist, u) + w < vec_get(dist, v) {
            vec_set(has_neg_cycle, 0, 1);
            0
        } else { 0 };
        set j = j + 1
    };
    // Append negative cycle flag
    let _p = vec_push(dist, vec_get(has_neg_cycle, 0));
    dist
};

fn main() -> () = {
    // Test 1: 5 nodes, includes negative edge
    // Edges: (0,1,6), (0,2,7), (1,2,8), (1,3,5), (1,4,-4),
    //        (2,3,-3), (2,4,9), (3,1,-2), (4,0,2), (4,3,7)
    let edges = vec_new();
    let _p = vec_push(edges, 0); let _p = vec_push(edges, 1); let _p = vec_push(edges, 6);
    let _p = vec_push(edges, 0); let _p = vec_push(edges, 2); let _p = vec_push(edges, 7);
    let _p = vec_push(edges, 1); let _p = vec_push(edges, 2); let _p = vec_push(edges, 8);
    let _p = vec_push(edges, 1); let _p = vec_push(edges, 3); let _p = vec_push(edges, 5);
    let _p = vec_push(edges, 1); let _p = vec_push(edges, 4); let _p = vec_push(edges, 0 - 4);
    let _p = vec_push(edges, 2); let _p = vec_push(edges, 3); let _p = vec_push(edges, 0 - 3);
    let _p = vec_push(edges, 2); let _p = vec_push(edges, 4); let _p = vec_push(edges, 9);
    let _p = vec_push(edges, 3); let _p = vec_push(edges, 1); let _p = vec_push(edges, 0 - 2);
    let _p = vec_push(edges, 4); let _p = vec_push(edges, 0); let _p = vec_push(edges, 2);
    let _p = vec_push(edges, 4); let _p = vec_push(edges, 3); let _p = vec_push(edges, 7);
    let n = 5;
    let dist = bellman_ford(edges, 10, n, 0);
    print_str("dist:");
    let mut i = 0;
    while i < n {
        print_str(" "); print(vec_get(dist, i));
        set i = i + 1
    };
    print_str("
");
    print_str("neg_cycle="); let _r = println(vec_get(dist, n));

    // Test 2: Simple 3 nodes, no negative
    let e2 = vec_new();
    let _p = vec_push(e2, 0); let _p = vec_push(e2, 1); let _p = vec_push(e2, 4);
    let _p = vec_push(e2, 0); let _p = vec_push(e2, 2); let _p = vec_push(e2, 2);
    let _p = vec_push(e2, 2); let _p = vec_push(e2, 1); let _p = vec_push(e2, 1);
    let dist2 = bellman_ford(e2, 3, 3, 0);
    print_str("dist2:");
    set i = 0;
    while i < 3 {
        print_str(" "); print(vec_get(dist2, i));
        set i = i + 1
    };
    let _nl = print_str("
")
};

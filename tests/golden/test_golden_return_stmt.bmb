// Golden Test: Return Statements
// Tests explicit return in various contexts

fn abs_val(x: i64) -> i64 = {
    if x >= 0 { return x } else { () };
    0 - x
};

fn first_positive(a: i64, b: i64, c: i64) -> i64 = {
    if a > 0 { return a } else { () };
    if b > 0 { return b } else { () };
    if c > 0 { return c } else { () };
    0
};

fn clamp_val(x: i64, lo: i64, hi: i64) -> i64 = {
    if x < lo { return lo } else { () };
    if x > hi { return hi } else { () };
    x
};

fn sign(x: i64) -> i64 = {
    if x > 0 { return 1 } else { () };
    if x < 0 { return 0 - 1 } else { () };
    0
};

fn fizzbuzz_val(n: i64) -> i64 = {
    if n % 15 == 0 { return 15 } else { () };
    if n % 3 == 0 { return 3 } else { () };
    if n % 5 == 0 { return 5 } else { () };
    n
};

fn main() -> i64 = {
    // abs_val
    let _p1 = println(abs_val(42));    // 42
    let _p2 = println(abs_val(0 - 7)); // 7
    let _p3 = println(abs_val(0));     // 0

    // first_positive
    let _p4 = println(first_positive(0 - 1, 0 - 2, 5));  // 5
    let _p5 = println(first_positive(3, 0 - 1, 0 - 2));   // 3
    let _p6 = println(first_positive(0 - 1, 0 - 2, 0 - 3)); // 0

    // clamp_val
    let _p7 = println(clamp_val(5, 0, 10));   // 5
    let _p8 = println(clamp_val(0 - 3, 0, 10)); // 0
    let _p9 = println(clamp_val(15, 0, 10));  // 10

    // sign
    let _p10 = println(sign(42));    // 1
    let _p11 = println(sign(0 - 7)); // -1
    let _p12 = println(sign(0));     // 0

    // fizzbuzz_val
    let _p13 = println(fizzbuzz_val(7));   // 7
    let _p14 = println(fizzbuzz_val(9));   // 3
    let _p15 = println(fizzbuzz_val(10));  // 5
    let _p16 = println(fizzbuzz_val(30));  // 15

    0
};

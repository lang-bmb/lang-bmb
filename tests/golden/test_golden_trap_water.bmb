// Golden Test: Trapping Rain Water
// Given elevation map, compute trapped water between bars

fn trap_water(heights: i64, n: i64) -> i64 = {
    let left_max = vec_new();
    let mut i = 0;
    let mut mx = 0;
    while i < n {
        let h = vec_get(heights, i);
        set mx = if h > mx { h } else { mx };
        let _p = vec_push(left_max, mx);
        set i = i + 1
    };
    let right_max = vec_new();
    set i = 0;
    while i < n {
        let _p = vec_push(right_max, 0);
        set i = i + 1
    };
    set mx = 0;
    set i = n - 1;
    while i >= 0 {
        let h = vec_get(heights, i);
        set mx = if h > mx { h } else { mx };
        vec_set(right_max, i, mx);
        set i = i - 1
    };
    let mut total = 0;
    set i = 0;
    while i < n {
        let lm = vec_get(left_max, i);
        let rm = vec_get(right_max, i);
        let min_h = if lm < rm { lm } else { rm };
        let h = vec_get(heights, i);
        let _x = if min_h > h {
            set total = total + min_h - h;
            0
        } else { 0 };
        set i = i + 1
    };
    total
};

fn main() -> () = {
    // Test 1: Classic [0,1,0,2,1,0,1,3,2,1,2,1] -> 6
    let h1 = vec_new();
    let _p = vec_push(h1, 0); let _p = vec_push(h1, 1);
    let _p = vec_push(h1, 0); let _p = vec_push(h1, 2);
    let _p = vec_push(h1, 1); let _p = vec_push(h1, 0);
    let _p = vec_push(h1, 1); let _p = vec_push(h1, 3);
    let _p = vec_push(h1, 2); let _p = vec_push(h1, 1);
    let _p = vec_push(h1, 2); let _p = vec_push(h1, 1);
    print_str("water1="); let _r = println(trap_water(h1, 12));

    // Test 2: [4,2,0,3,2,5] -> 9
    let h2 = vec_new();
    let _p = vec_push(h2, 4); let _p = vec_push(h2, 2);
    let _p = vec_push(h2, 0); let _p = vec_push(h2, 3);
    let _p = vec_push(h2, 2); let _p = vec_push(h2, 5);
    print_str("water2="); let _r = println(trap_water(h2, 6));

    // Test 3: No water [1,2,3,4,5] -> 0
    let h3 = vec_new();
    let _p = vec_push(h3, 1); let _p = vec_push(h3, 2);
    let _p = vec_push(h3, 3); let _p = vec_push(h3, 4);
    let _p = vec_push(h3, 5);
    print_str("water3="); let _r = println(trap_water(h3, 5));

    // Test 4: [3,0,0,0,3] -> 9
    let h4 = vec_new();
    let _p = vec_push(h4, 3); let _p = vec_push(h4, 0);
    let _p = vec_push(h4, 0); let _p = vec_push(h4, 0);
    let _p = vec_push(h4, 3);
    print_str("water4="); let _r = println(trap_water(h4, 5))
};

// Golden Test: Bubble Sort
// Simple O(n^2) sort with early termination optimization

fn bubble_sort(arr: i64, n: i64) -> i64 = {
    let mut swaps = 0;
    let mut i = 0;
    while i < n - 1 {
        let mut swapped = 0;
        let mut j = 0;
        while j < n - 1 - i {
            let _x = if vec_get(arr, j) > vec_get(arr, j + 1) {
                let tmp = vec_get(arr, j);
                vec_set(arr, j, vec_get(arr, j + 1));
                vec_set(arr, j + 1, tmp);
                set swapped = 1;
                set swaps = swaps + 1;
                0
            } else { 0 };
            set j = j + 1
        };
        let _x = if swapped == 0 {
            set i = n;
            0
        } else { 0 };
        set i = i + 1
    };
    swaps
};

fn print_arr(arr: i64, n: i64) -> () = {
    let mut i = 0;
    while i < n {
        let _sp = if i > 0 { print_str(" "); 0 } else { 0 };
        print(vec_get(arr, i));
        set i = i + 1
    };
    let _nl = print_str("
")
};

fn main() -> () = {
    // Test 1: Random
    let a1 = vec_new();
    let _p = vec_push(a1, 5); let _p = vec_push(a1, 1);
    let _p = vec_push(a1, 4); let _p = vec_push(a1, 2);
    let _p = vec_push(a1, 8);
    let s1 = bubble_sort(a1, 5);
    print_str("sorted1: "); print_arr(a1, 5);
    print_str("swaps1="); let _r = println(s1);

    // Test 2: Already sorted (0 swaps with early termination)
    let a2 = vec_new();
    let _p = vec_push(a2, 1); let _p = vec_push(a2, 2);
    let _p = vec_push(a2, 3); let _p = vec_push(a2, 4);
    let s2 = bubble_sort(a2, 4);
    print_str("sorted2: "); print_arr(a2, 4);
    print_str("swaps2="); let _r = println(s2);

    // Test 3: Reverse (max swaps)
    let a3 = vec_new();
    let _p = vec_push(a3, 4); let _p = vec_push(a3, 3);
    let _p = vec_push(a3, 2); let _p = vec_push(a3, 1);
    let s3 = bubble_sort(a3, 4);
    print_str("sorted3: "); print_arr(a3, 4);
    print_str("swaps3="); let _r = println(s3)
};

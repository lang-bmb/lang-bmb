// Golden Test: Branch value propagation
// Tests patterns where branch outcomes feed into subsequent computations

fn grade(score: i64) -> i64 =
    if score >= 90 { 4 }
    else if score >= 80 { 3 }
    else if score >= 70 { 2 }
    else if score >= 60 { 1 }
    else { 0 };

fn weighted_sum(a: i64, b: i64, c: i64) -> i64 =
    let ga = grade(a);
    let gb = grade(b);
    let gc = grade(c);
    ga * 3 + gb * 2 + gc;

fn range_check(x: i64, lo: i64, hi: i64) -> i64 =
    if x < lo { lo - x }
    else if x > hi { x - hi }
    else { 0 };

fn main() -> i64 = {
    println(grade(95));   // 4
    println(grade(85));   // 3
    println(grade(75));   // 2
    println(grade(65));   // 1
    println(grade(50));   // 0
    println(weighted_sum(95, 85, 75)); // 4*3+3*2+2 = 20
    println(weighted_sum(50, 50, 50)); // 0
    println(range_check(5, 0, 10));    // 0
    println(range_check(-3, 0, 10));   // 3
    println(range_check(15, 0, 10));   // 5
    0
    };

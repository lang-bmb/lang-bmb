// Golden Test: Ackermann function
// Classic recursive function: A(m,n)
// A(0,n) = n+1
// A(m,0) = A(m-1,1) for m>0
// A(m,n) = A(m-1, A(m,n-1)) for m>0, n>0
// Grows extremely fast; only small values computable

fn ackermann(m: i64, n: i64) -> i64 = {
    if m == 0 { n + 1 }
    else if n == 0 { ackermann(m - 1, 1) }
    else { ackermann(m - 1, ackermann(m, n - 1)) }
};

fn main() -> () = {
    // Known values:
    // A(0,0)=1, A(0,1)=2, A(0,5)=6
    // A(1,0)=2, A(1,1)=3, A(1,5)=7
    // A(2,0)=3, A(2,1)=5, A(2,3)=9, A(2,4)=11
    // A(3,0)=5, A(3,1)=13, A(3,2)=29, A(3,3)=61, A(3,4)=125
    print_str("A(0,0)="); let _r = println(ackermann(0, 0));
    print_str("A(0,5)="); let _r = println(ackermann(0, 5));
    print_str("A(1,0)="); let _r = println(ackermann(1, 0));
    print_str("A(1,5)="); let _r = println(ackermann(1, 5));
    print_str("A(2,0)="); let _r = println(ackermann(2, 0));
    print_str("A(2,3)="); let _r = println(ackermann(2, 3));
    print_str("A(2,4)="); let _r = println(ackermann(2, 4));
    print_str("A(3,0)="); let _r = println(ackermann(3, 0));
    print_str("A(3,1)="); let _r = println(ackermann(3, 1));
    print_str("A(3,2)="); let _r = println(ackermann(3, 2));
    print_str("A(3,3)="); let _r = println(ackermann(3, 3));
    print_str("A(3,4)="); let _r = println(ackermann(3, 4))
};

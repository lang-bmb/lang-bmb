// Golden Test: Monotone deque — sliding window minimum and maximum
// Uses a deque (simulated with vec) to maintain monotone property

// Sliding window minimum of size k
// Returns a vec of min values for each window position
fn sliding_min(arr: i64, n: i64, k: i64) -> i64 = {
    let result = vec_new();
    // Deque stores indices; front is the minimum
    let deq = vec_new();
    let mut front = 0;
    let mut back = 0; // back is one past last element (deq[front..back))

    for i in 0..n {
        // Remove elements outside the window from front
        loop {
            if front >= back { break } else { () };
            if vec_get(deq, front) <= i - k {
                front = front + 1
            } else { break }
        };
        // Remove elements from back that are >= current (maintain increasing deque)
        loop {
            if front >= back { break } else { () };
            let back_idx = vec_get(deq, back - 1);
            if vec_get(arr, back_idx) >= vec_get(arr, i) {
                back = back - 1
            } else { break }
        };
        // Push current index to back
        if back < vec_len(deq) {
            vec_set(deq, back, i)
        } else {
            vec_push(deq, i)
        };
        back = back + 1;
        // Output minimum when window is full
        if i >= k - 1 {
            vec_push(result, vec_get(arr, vec_get(deq, front)))
        } else { () }
    };
    vec_free(deq);
    result
};

// Sliding window maximum of size k
fn sliding_max(arr: i64, n: i64, k: i64) -> i64 = {
    let result = vec_new();
    let deq = vec_new();
    let mut front = 0;
    let mut back = 0;

    for i in 0..n {
        loop {
            if front >= back { break } else { () };
            if vec_get(deq, front) <= i - k {
                front = front + 1
            } else { break }
        };
        // Remove elements from back that are <= current (maintain decreasing deque)
        loop {
            if front >= back { break } else { () };
            let back_idx = vec_get(deq, back - 1);
            if vec_get(arr, back_idx) <= vec_get(arr, i) {
                back = back - 1
            } else { break }
        };
        if back < vec_len(deq) {
            vec_set(deq, back, i)
        } else {
            vec_push(deq, i)
        };
        back = back + 1;
        if i >= k - 1 {
            vec_push(result, vec_get(arr, vec_get(deq, front)))
        } else { () }
    };
    vec_free(deq);
    result
};

fn main() -> i64 = {
    // Test array: [1, 3, -1, -3, 5, 3, 6, 7]
    let arr = vec_new();
    vec_push(arr, 1); vec_push(arr, 3); vec_push(arr, 0 - 1); vec_push(arr, 0 - 3);
    vec_push(arr, 5); vec_push(arr, 3); vec_push(arr, 6); vec_push(arr, 7);
    let n = 8;

    // Test 1: Sliding window minimum, k=3
    // Windows: [1,3,-1], [3,-1,-3], [-1,-3,5], [-3,5,3], [5,3,6], [3,6,7]
    // Mins:    -1,       -3,        -3,        -3,       3,       3
    let mins = sliding_min(arr, n, 3);
    let _p1 = println(vec_len(mins));       // 6
    let _p2 = println(vec_get(mins, 0));    // -1
    let _p3 = println(vec_get(mins, 1));    // -3
    let _p4 = println(vec_get(mins, 2));    // -3
    let _p5 = println(vec_get(mins, 3));    // -3
    let _p6 = println(vec_get(mins, 4));    // 3
    let _p7 = println(vec_get(mins, 5));    // 3

    // Test 2: Sliding window maximum, k=3
    // Maxs:   3,        3,         5,         5,        6,       7
    let maxs = sliding_max(arr, n, 3);
    let _p8 = println(vec_len(maxs));       // 6
    let _p9 = println(vec_get(maxs, 0));    // 3
    let _p10 = println(vec_get(maxs, 1));   // 3
    let _p11 = println(vec_get(maxs, 2));   // 5
    let _p12 = println(vec_get(maxs, 3));   // 5
    let _p13 = println(vec_get(maxs, 4));   // 6
    let _p14 = println(vec_get(maxs, 5));   // 7

    // Test 3: Window size = 1 (each element is its own min/max)
    let mins1 = sliding_min(arr, n, 1);
    let _p15 = println(vec_len(mins1));     // 8
    let _p16 = println(vec_get(mins1, 0));  // 1
    let _p17 = println(vec_get(mins1, 7));  // 7

    // Test 4: Window size = n (global min and max)
    let mins_all = sliding_min(arr, n, n);
    let maxs_all = sliding_max(arr, n, n);
    let _p18 = println(vec_len(mins_all));  // 1
    let _p19 = println(vec_get(mins_all, 0)); // -3 (global min)
    let _p20 = println(vec_get(maxs_all, 0)); // 7 (global max)

    // Test 5: Difference between max and min for k=3
    // Max - Min per window: 3-(-1)=4, 3-(-3)=6, 5-(-3)=8, 5-(-3)=8, 6-3=3, 7-3=4
    let _p21 = println(vec_get(maxs, 0) - vec_get(mins, 0)); // 4
    let _p22 = println(vec_get(maxs, 2) - vec_get(mins, 2)); // 8

    let _f1 = vec_free(arr);
    let _f2 = vec_free(mins); let _f3 = vec_free(maxs);
    let _f4 = vec_free(mins1);
    let _f5 = vec_free(mins_all); let _f6 = vec_free(maxs_all);
    0
};

// Golden Test: Binary Indexed Tree (Fenwick Tree)
// Supports point update and prefix sum queries in O(log n)
// Uses 1-indexed array internally

// Create a BIT of size n+1 (1-indexed, index 0 unused)
fn bit_new(n: i64) -> i64 = {
    let tree = vec_new();
    for _i in 0..n + 1 {
        let _p = vec_push(tree, 0);
        0
    };
    tree
};

// Add delta to position idx (1-indexed)
// Updates all responsible nodes using idx += idx & (-idx)
fn bit_update(tree: i64, n: i64, idx: i64, delta: i64) -> i64 = {
    let mut i = idx;
    loop {
        if i > n { break } else { () };
        let cur = vec_get(tree, i);
        let _s = vec_set(tree, i, cur + delta);
        // i += i & (-i)  =>  lowest set bit
        let neg_i = 0 - i;
        i = i + (i band neg_i)
    };
    0
};

// Query prefix sum [1..idx]
// Traverses upward using idx -= idx & (-idx)
fn bit_query(tree: i64, idx: i64) -> i64 = {
    let mut sum = 0;
    let mut i = idx;
    loop {
        if i <= 0 { break } else { () };
        sum = sum + vec_get(tree, i);
        let neg_i = 0 - i;
        i = i - (i band neg_i)
    };
    sum
};

// Range sum query [lo..hi] (1-indexed, inclusive)
fn bit_range_query(tree: i64, lo: i64, hi: i64) -> i64 =
    bit_query(tree, hi) - bit_query(tree, lo - 1);

// Build BIT from an array of n values (0-indexed input)
fn bit_build(vals: i64, n: i64) -> i64 = {
    let tree = bit_new(n);
    for i in 0..n {
        let _u = bit_update(tree, n, i + 1, vec_get(vals, i));
        0
    };
    tree
};

// Point query: get value at position idx (1-indexed)
fn bit_point_query(tree: i64, idx: i64) -> i64 =
    bit_range_query(tree, idx, idx);

// Find prefix sum of first k elements (wrapper)
fn prefix_sum(tree: i64, k: i64) -> i64 =
    bit_query(tree, k);

fn main() -> i64 = {
    // Test 1: Basic BIT operations
    // Array: [3, 2, -1, 6, 5, 4, -3, 3, 7, 2]
    let arr = vec_new();
    let _p1 = vec_push(arr, 3);
    let _p2 = vec_push(arr, 2);
    let _p3 = vec_push(arr, 0 - 1);
    let _p4 = vec_push(arr, 6);
    let _p5 = vec_push(arr, 5);
    let _p6 = vec_push(arr, 4);
    let _p7 = vec_push(arr, 0 - 3);
    let _p8 = vec_push(arr, 3);
    let _p9 = vec_push(arr, 7);
    let _p10 = vec_push(arr, 2);

    let tree = bit_build(arr, 10);

    // Prefix sums
    let _r1 = println(prefix_sum(tree, 1));   // 3
    let _r2 = println(prefix_sum(tree, 3));   // 4  (3+2-1)
    let _r3 = println(prefix_sum(tree, 5));   // 15 (3+2-1+6+5)
    let _r4 = println(prefix_sum(tree, 10));  // 28 (sum of all)

    // Range queries
    let _r5 = println(bit_range_query(tree, 2, 4));  // 7  (2-1+6)
    let _r6 = println(bit_range_query(tree, 6, 8));  // 4  (4-3+3)
    let _r7 = println(bit_range_query(tree, 1, 10)); // 28 (all)
    let _r8 = println(bit_range_query(tree, 5, 5));  // 5  (single element)

    // Point update: add 10 to position 3 (1-indexed)
    let _u1 = bit_update(tree, 10, 3, 10);
    let _r9 = println(prefix_sum(tree, 3));   // 14 (3+2+(-1+10)=14)
    let _r10 = println(prefix_sum(tree, 10)); // 38 (28+10)
    let _r11 = println(bit_range_query(tree, 3, 3));  // 9  (-1+10)

    // Test 2: Small BIT [1, 2, 3]
    let arr2 = vec_new();
    let _q1 = vec_push(arr2, 1);
    let _q2 = vec_push(arr2, 2);
    let _q3 = vec_push(arr2, 3);
    let tree2 = bit_build(arr2, 3);

    let _r12 = println(prefix_sum(tree2, 1));  // 1
    let _r13 = println(prefix_sum(tree2, 2));  // 3
    let _r14 = println(prefix_sum(tree2, 3));  // 6

    // Update position 2 by +5: [1, 7, 3]
    let _u2 = bit_update(tree2, 3, 2, 5);
    let _r15 = println(prefix_sum(tree2, 2));  // 8  (1+7)
    let _r16 = println(prefix_sum(tree2, 3));  // 11 (1+7+3)

    // Test 3: All zeros then incremental updates
    let tree3 = bit_new(5);
    let _r17 = println(prefix_sum(tree3, 5));  // 0

    let _u3 = bit_update(tree3, 5, 1, 100);
    let _u4 = bit_update(tree3, 5, 3, 200);
    let _u5 = bit_update(tree3, 5, 5, 300);
    let _r18 = println(prefix_sum(tree3, 5));  // 600
    let _r19 = println(bit_range_query(tree3, 2, 4));  // 200

    // Test 4: Negative updates (decrement)
    let _u6 = bit_update(tree3, 5, 3, 0 - 50);
    let _r20 = println(bit_range_query(tree3, 3, 3));  // 150 (200-50)
    let _r21 = println(prefix_sum(tree3, 5));  // 550 (600-50)

    // Cleanup
    let _f1 = vec_free(arr);
    let _f2 = vec_free(tree);
    let _f3 = vec_free(arr2);
    let _f4 = vec_free(tree2);
    let _f5 = vec_free(tree3);
    0
};

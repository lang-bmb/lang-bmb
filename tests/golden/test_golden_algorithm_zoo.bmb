// Golden Test: Algorithm zoo
// Binary search, linear search, Dutch national flag, rotate array,
// permutation count, RLE encode/decode, sparse matrix multiply

// === Helpers ===
fn make_vec(n: i64) -> i64 = {
    let v = vec_new();
    for _i in 0..n {
        let _p = vec_push(v, 0);
        0
    };
    v
    };

fn vec_swap(v: i64, i: i64, j: i64) -> i64 = {
    let tmp = vec_get(v, i);
    let _s1 = vec_set(v, i, vec_get(v, j));
    let _s2 = vec_set(v, j, tmp);
    0
    };

fn print_vec(v: i64, n: i64) -> i64 = {
    for i in 0..n {
        println(vec_get(v, i))
    };
    0
    };

// === 1. Binary search ===
fn binary_search(arr: i64, target: i64, lo: i64, hi: i64) -> i64 =
    if lo > hi { 0 - 1 }
    else {
        let mid = lo + (hi - lo) / 2;
        if vec_get(arr, mid) == target { mid }
        else if vec_get(arr, mid) < target { binary_search(arr, target, mid + 1, hi) }
        else { binary_search(arr, target, lo, mid - 1) }
    };

// === 2. Linear search (first occurrence) ===
fn linear_search(arr: i64, target: i64, n: i64) -> i64 = {
    let mut result = 0 - 1;
    let mut found = 0;
    for i in 0..n {
        if found == 0 {
            if vec_get(arr, i) == target {
                result = i;
                found = 1
            } else { () }
        } else { () }
    };
    result
    };

// === 3. Dutch national flag partition ===
// Partition array of 0s, 1s, 2s in-place
fn dutch_flag(arr: i64, n: i64) -> i64 = {
    let mut lo = 0;
    let mut mid = 0;
    let mut hi = n - 1;
    loop {
        if mid > hi { break } else { () };
        let val = vec_get(arr, mid);
        if val == 0 {
            let _sw = vec_swap(arr, lo, mid);
            lo = lo + 1;
            mid = mid + 1
        } else if val == 2 {
            let _sw = vec_swap(arr, mid, hi);
            hi = hi - 1
        } else {
            mid = mid + 1
        }
    };
    0
    };

// === 4. Rotate array left by k positions ===
// Using reversal algorithm: reverse(0..k), reverse(k..n), reverse(0..n)
fn reverse_range(arr: i64, start: i64, end_idx: i64) -> i64 = {
    let mut lo = start;
    let mut hi = end_idx;
    loop {
        if lo >= hi { break } else { () };
        let _sw = vec_swap(arr, lo, hi);
        lo = lo + 1;
        hi = hi - 1
    };
    0
    };

fn rotate_left(arr: i64, n: i64, k: i64) -> i64 = {
    let kk = k % n;
    let _r1 = reverse_range(arr, 0, kk - 1);
    let _r2 = reverse_range(arr, kk, n - 1);
    let _r3 = reverse_range(arr, 0, n - 1);
    0
    };

// === 5. Permutation count (n! for n distinct elements) ===
fn factorial(n: i64) -> i64 = {
    let mut result = 1;
    for i in 1..=n {
        result = result * i
    };
    result
    };

// Count permutations of array with possible repeats
// Formula: n! / (c1! * c2! * ... * ck!) where ci = count of each value
// For simplicity, count frequency of each value (values 0..max_val)
fn count_perms(arr: i64, n: i64, max_val: i64) -> i64 = {
    let freq = make_vec(max_val + 1);
    for i in 0..n {
        let val = vec_get(arr, i);
        let _s = vec_set(freq, val, vec_get(freq, val) + 1);
        0
    };
    let mut denom = 1;
    for i in 0..=max_val {
        denom = denom * factorial(vec_get(freq, i))
    };
    let _f = vec_free(freq);
    factorial(n) / denom
    };

// === 6. RLE encode ===
// Input: array of values. Output: flat vec of (value, count) pairs
// Returns the encoded vec; number of pairs = vec_len(result) / 2
fn rle_encode(arr: i64, n: i64) -> i64 = {
    let result = vec_new();
    if n == 0 { return result } else { () };
    let mut cur_val = vec_get(arr, 0);
    let mut cur_count = 1;
    for i in 1..n {
        if vec_get(arr, i) == cur_val {
            cur_count = cur_count + 1
        } else {
            let _p1 = vec_push(result, cur_val);
            let _p2 = vec_push(result, cur_count);
            cur_val = vec_get(arr, i);
            cur_count = 1
        }
    };
    // push last run
    let _p1 = vec_push(result, cur_val);
    let _p2 = vec_push(result, cur_count);
    result
    };

// === 7. RLE decode ===
// Input: flat vec of (value, count) pairs. Output: decoded array
fn rle_decode(encoded: i64) -> i64 = {
    let result = vec_new();
    let num_pairs = vec_len(encoded) / 2;
    for i in 0..num_pairs {
        let val = vec_get(encoded, i * 2);
        let count = vec_get(encoded, i * 2 + 1);
        for _j in 0..count {
            let _p = vec_push(result, val);
            0
        }
    };
    result
    };

// === 8. Sparse matrix multiply (triplet format) ===
// Matrices stored as 3 parallel vecs: rows, cols, vals
// result is dense: flat vec of size rows_a * cols_b
fn sparse_matmul(
    a_rows: i64, a_cols: i64, a_vals: i64, nnz_a: i64,
    b_rows: i64, b_cols: i64, b_vals: i64, nnz_b: i64,
    num_rows_a: i64, num_cols_b: i64
) -> i64 = {
    let result = make_vec(num_rows_a * num_cols_b);
    for i in 0..nnz_a {
        let ra = vec_get(a_rows, i);
        let ca = vec_get(a_cols, i);
        let va = vec_get(a_vals, i);
        for j in 0..nnz_b {
            let rb = vec_get(b_rows, j);
            let cb = vec_get(b_cols, j);
            let vb = vec_get(b_vals, j);
            if ca == rb {
                let idx = ra * num_cols_b + cb;
                let _s = vec_set(result, idx, vec_get(result, idx) + va * vb);
                0
            } else { 0 }
        }
    };
    result
    };

// === Helper: build vec from values ===
fn push3(v: i64, a: i64, b: i64, c: i64) -> i64 = {
    let _p1 = vec_push(v, a);
    let _p2 = vec_push(v, b);
    let _p3 = vec_push(v, c);
    0
    };

fn push5(v: i64, a: i64, b: i64, c: i64, d: i64, e: i64) -> i64 = {
    let _p1 = vec_push(v, a);
    let _p2 = vec_push(v, b);
    let _p3 = vec_push(v, c);
    let _p4 = vec_push(v, d);
    let _p5 = vec_push(v, e);
    0
    };

fn push7(v: i64, a: i64, b: i64, c: i64, d: i64, e: i64, f: i64, g: i64) -> i64 = {
    let _p1 = vec_push(v, a);
    let _p2 = vec_push(v, b);
    let _p3 = vec_push(v, c);
    let _p4 = vec_push(v, d);
    let _p5 = vec_push(v, e);
    let _p6 = vec_push(v, f);
    let _p7 = vec_push(v, g);
    0
    };

fn push10(v: i64, a: i64, b: i64, c: i64, d: i64, e: i64, f: i64, g: i64, h: i64, i: i64, j: i64) -> i64 = {
    let _p1 = vec_push(v, a);
    let _p2 = vec_push(v, b);
    let _p3 = vec_push(v, c);
    let _p4 = vec_push(v, d);
    let _p5 = vec_push(v, e);
    let _p6 = vec_push(v, f);
    let _p7 = vec_push(v, g);
    let _p8 = vec_push(v, h);
    let _p9 = vec_push(v, i);
    let _p10 = vec_push(v, j);
    0
    };

fn main() -> i64 = {
    // === Binary search tests ===
    // Sorted: [2, 5, 8, 12, 16, 23, 38, 56, 72, 91]
    let sorted = vec_new();
    let _bs = push10(sorted, 2, 5, 8, 12, 16, 23, 38, 56, 72, 91);

    // Search 23 -> index 5
    println(binary_search(sorted, 23, 0, 9));
    // Search 100 -> -1
    println(binary_search(sorted, 100, 0, 9));
    // Search 2 -> index 0
    println(binary_search(sorted, 2, 0, 9));

    // === Linear search tests ===
    let data = vec_new();
    let _ls = push5(data, 7, 3, 9, 1, 5);

    // Search 9 -> index 2
    println(linear_search(data, 9, 5));
    // Search 6 -> -1
    println(linear_search(data, 6, 5));

    // === Dutch national flag tests ===
    let flags = vec_new();
    let _df = push10(flags, 2, 0, 1, 2, 1, 0, 0, 2, 1, 0);
    let _partition = dutch_flag(flags, 10);
    // After: [0, 0, 0, 0, 1, 1, 1, 2, 2, 2]
    // Print first, middle, last
    println(vec_get(flags, 0));    // 0
    println(vec_get(flags, 3));    // 0
    println(vec_get(flags, 4));    // 1
    println(vec_get(flags, 6));    // 1
    println(vec_get(flags, 7));    // 2
    println(vec_get(flags, 9));    // 2

    // === Rotate left tests ===
    let rot = vec_new();
    let _rt = push7(rot, 1, 2, 3, 4, 5, 6, 7);
    // Rotate left by 3: [4, 5, 6, 7, 1, 2, 3]
    let _r = rotate_left(rot, 7, 3);
    println(vec_get(rot, 0));    // 4
    println(vec_get(rot, 3));    // 7
    println(vec_get(rot, 6));    // 3

    // === Permutation count tests ===
    // [1, 2, 3, 4] all distinct -> 4! = 24
    let perm1 = vec_new();
    let _pm1 = push3(perm1, 1, 2, 3);
    let _pm1b = vec_push(perm1, 4);
    println(count_perms(perm1, 4, 4));  // 24

    // [1, 1, 2, 2] -> 4! / (2! * 2!) = 24/4 = 6
    let perm2 = vec_new();
    let _pm2 = push3(perm2, 1, 1, 2);
    let _pm2b = vec_push(perm2, 2);
    println(count_perms(perm2, 4, 2));  // 6

    // === RLE encode tests ===
    let rle_in = vec_new();
    let _ri = push10(rle_in, 1, 1, 1, 2, 2, 3, 3, 3, 3, 1);
    let encoded = rle_encode(rle_in, 10);
    // Encoded: [1,3, 2,2, 3,4, 1,1] -> 8 elements, 4 runs
    println(vec_len(encoded) / 2);          // 4 (number of runs)
    println(vec_get(encoded, 0));           // 1 (first value)
    println(vec_get(encoded, 1));           // 3 (first count)
    println(vec_get(encoded, 4));           // 3 (third value)
    println(vec_get(encoded, 5));           // 4 (third count)

    // === RLE decode tests ===
    let decoded = rle_decode(encoded);
    // Should reconstruct original: [1,1,1,2,2,3,3,3,3,1]
    println(vec_len(decoded));              // 10
    println(vec_get(decoded, 0));           // 1
    println(vec_get(decoded, 3));           // 2
    println(vec_get(decoded, 5));           // 3
    println(vec_get(decoded, 9));           // 1

    // === Sparse matrix multiply tests ===
    // A (2x3): (0,0,1), (0,2,2), (1,1,3)
    let ar = vec_new();
    let ac = vec_new();
    let av = vec_new();
    let _a1 = push3(ar, 0, 0, 1);
    let _a2 = push3(ac, 0, 2, 1);
    let _a3 = push3(av, 1, 2, 3);

    // B (3x2): (0,0,4), (1,0,5), (2,1,6)
    let br = vec_new();
    let bc = vec_new();
    let bv = vec_new();
    let _b1 = push3(br, 0, 1, 2);
    let _b2 = push3(bc, 0, 0, 1);
    let _b3 = push3(bv, 4, 5, 6);

    // C = A * B (2x2)
    // C[0][0] = 1*4 + 2*0 = 4  (A[0,0]*B[0,0])
    // C[0][1] = 1*0 + 2*6 = 12 (A[0,2]*B[2,1])
    // C[1][0] = 3*5 = 15       (A[1,1]*B[1,0])
    // C[1][1] = 3*0 = 0        (no matching pairs)
    let result = sparse_matmul(ar, ac, av, 3, br, bc, bv, 3, 2, 2);
    println(vec_get(result, 0));    // 4   (C[0][0])
    println(vec_get(result, 1));    // 12  (C[0][1])
    println(vec_get(result, 2));    // 15  (C[1][0])
    println(vec_get(result, 3));    // 0   (C[1][1])

    // Cleanup
    let _f1 = vec_free(sorted);
    let _f2 = vec_free(data);
    let _f3 = vec_free(flags);
    let _f4 = vec_free(rot);
    let _f5 = vec_free(perm1);
    let _f6 = vec_free(perm2);
    let _f7 = vec_free(rle_in);
    let _f8 = vec_free(encoded);
    let _f9 = vec_free(decoded);
    let _f10 = vec_free(ar);
    let _f11 = vec_free(ac);
    let _f12 = vec_free(av);
    let _f13 = vec_free(br);
    let _f14 = vec_free(bc);
    let _f15 = vec_free(bv);
    let _f16 = vec_free(result);
    0
    };

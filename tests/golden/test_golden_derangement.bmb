// Golden Test: Derangements (permutations with no fixed points)
// D(n) = (n-1) * (D(n-1) + D(n-2)), D(0) = 1, D(1) = 0
// Also known as subfactorial !n

// Factorial
fn factorial(n: i64) -> i64 = {
    let mut r = 1;
    for i in 1..n {
        r = r * i
    };
    r * n
    };

// Derangement count using DP
fn derangement(n: i64) -> i64 = {
    if n == 0 { return 1 } else { () };
    if n == 1 { return 0 } else { () };
    let dp = [0; 20];
    set dp[0] = 1;
    set dp[1] = 0;
    let mut i = 2;
    loop {
        if i > n { break } else { () };
        set dp[i] = (i - 1) * (dp[i - 1] + dp[i - 2]);
        i = i + 1
    };
    dp[n]
    };

// Ratio check: n! / D(n) approaches e as n grows
// We check D(n) * 1000 / n! to approximate 1000/e ~ 368
fn derangement_ratio(n: i64) -> i64 = {
    let d = derangement(n);
    let f = factorial(n);
    d * 1000 / f
    };

// Count derangements by inclusion-exclusion:
// D(n) = n! * sum_{k=0}^{n} (-1)^k / k!
// Computed as: sum_{k=0}^{n} (-1)^k * n! / k!
fn derangement_ie(n: i64) -> i64 = {
    let nf = factorial(n);
    let mut sum = 0;
    let mut sign = 1;
    let mut kfact = 1;
    let mut k = 0;
    loop {
        if k > n { break } else { () };
        sum = sum + sign * nf / kfact;
        sign = 0 - sign;
        k = k + 1;
        kfact = if k > 0 { kfact * k } else { 1 }
    };
    sum
    };

// Probability that at least one item is in its original position
// P(at least 1 fixed) = 1 - D(n)/n! expressed as percentage * 10
fn prob_fixed_pct10(n: i64) -> i64 = {
    let d = derangement(n);
    let f = factorial(n);
    1000 - d * 1000 / f
    };

fn main() -> i64 = {
    // Basic derangement values: D(0)=1, D(1)=0, D(2)=1, D(3)=2, D(4)=9, D(5)=44
    let _p1 = println(derangement(0));    // 1
    let _p2 = println(derangement(1));    // 0
    let _p3 = println(derangement(2));    // 1
    let _p4 = println(derangement(3));    // 2
    let _p5 = println(derangement(4));    // 9
    let _p6 = println(derangement(5));    // 44
    let _p7 = println(derangement(6));    // 265
    let _p8 = println(derangement(7));    // 1854
    let _p9 = println(derangement(10));   // 1334961

    // Verify with inclusion-exclusion method
    let _p10 = println(derangement_ie(4));  // 9
    let _p11 = println(derangement_ie(5));  // 44
    let _p12 = println(derangement_ie(6));  // 265

    // Ratio D(n)*1000/n! converges to ~368 (1000/e)
    let _p13 = println(derangement_ratio(5));   // 366
    let _p14 = println(derangement_ratio(8));   // 367
    let _p15 = println(derangement_ratio(10));  // 367

    // Probability of at least one fixed point (per mille)
    let _p16 = println(prob_fixed_pct10(3));  // 1000 - 333 = 667
    let _p17 = println(prob_fixed_pct10(5));  // 1000 - 366 = 634
    let _p18 = println(prob_fixed_pct10(10)); // 1000 - 367 = 633

    0
    };

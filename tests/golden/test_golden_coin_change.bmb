// Golden Test: Coin change problem (minimum coins)
// Given coin denominations and an amount, find minimum number of coins needed

fn coin_change(coins: i64, num_coins: i64, amount: i64) -> i64 = {
    if amount == 0 { return 0 } else { () };
    let dp = vec_new();
    let inf = amount + 1;
    let mut k = 0;
    loop {
        if k > amount { break } else { () };
        vec_push(dp, inf);
        k = k + 1
    };
    vec_set(dp, 0, 0);
    let mut a = 1;
    loop {
        if a > amount { break } else { () };
        let mut c = 0;
        loop {
            if c >= num_coins { break } else { () };
            let coin = vec_get(coins, c);
            if coin <= a {
                let prev = vec_get(dp, a - coin);
                let cur = vec_get(dp, a);
                if prev + 1 < cur {
                    vec_set(dp, a, prev + 1)
                } else { () }
            } else { () };
            c = c + 1
        };
        a = a + 1
    };
    let result = vec_get(dp, amount);
    vec_free(dp);
    if result >= inf { 0 - 1 } else { result }
};

fn main() -> i64 = {
    // coins=[1,5,10,25]
    let c1 = vec_new();
    vec_push(c1, 1); vec_push(c1, 5); vec_push(c1, 10); vec_push(c1, 25);
    let _p1 = println(coin_change(c1, 4, 30));
    let _p2 = println(coin_change(c1, 4, 11));
    let _p3 = println(coin_change(c1, 4, 6));
    let _p4 = println(coin_change(c1, 4, 0));

    // coins=[2], amount=3 -> impossible
    let c2 = vec_new(); vec_push(c2, 2);
    let _p5 = println(coin_change(c2, 1, 3));

    // coins=[1,3,4], amount=6 -> 2 (3+3)
    let c3 = vec_new(); vec_push(c3, 1); vec_push(c3, 3); vec_push(c3, 4);
    let _p6 = println(coin_change(c3, 3, 6));

    // coins=[1,2,5], amount=11 -> 3 (5+5+1)
    let c4 = vec_new(); vec_push(c4, 1); vec_push(c4, 2); vec_push(c4, 5);
    let _p7 = println(coin_change(c4, 3, 11));

    // coins=[1], amount=7 -> 7
    let c5 = vec_new(); vec_push(c5, 1);
    let _p8 = println(coin_change(c5, 1, 7));

    // coins=[3,7]
    let c6 = vec_new(); vec_push(c6, 3); vec_push(c6, 7);
    let _p9 = println(coin_change(c6, 2, 14));
    let _p10 = println(coin_change(c6, 2, 5));

    vec_free(c1); vec_free(c2); vec_free(c3);
    vec_free(c4); vec_free(c5); vec_free(c6);
    0
};

// Golden Test: Polynomial rolling hash for string comparison
// Uses rolling hash to compare substrings efficiently

// Polynomial hash: h = sum(s[i] * base^(len-1-i)) mod modulus
fn poly_hash(s: String, base: i64, modulus: i64) -> i64 = {
    let n = s.len();
    let mut h = 0;
    for i in 0..n {
        let c = s.byte_at(i);
        h = (h * base + c) - ((h * base + c) / modulus) * modulus
    };
    h
    };

// Compute base^exp mod modulus
fn pow_mod(base: i64, exp: i64, modulus: i64) -> i64 = {
    let mut result = 1;
    let mut b = base - (base / modulus) * modulus;
    let mut e = exp;
    loop {
        if e <= 0 { break } else { 0 };
        if e - (e / 2) * 2 == 1 {
            result = (result * b) - ((result * b) / modulus) * modulus
        } else { 0 };
        b = (b * b) - ((b * b) / modulus) * modulus;
        e = e / 2
    };
    result
    };

// Compute hash of substring s[start..start+len]
fn substr_hash(s: String, start: i64, len: i64, base: i64, modulus: i64) -> i64 = {
    let mut h = 0;
    for i in 0..len {
        let c = s.byte_at(start + i);
        h = (h * base + c) - ((h * base + c) / modulus) * modulus
    };
    h
    };

// Check if two substrings match character by character
fn substr_match(s1: String, start1: i64, s2: String, start2: i64, len: i64) -> i64 = {
    let mut i = 0;
    let mut matched = 1;
    loop {
        if i >= len { break } else { 0 };
        if s1.byte_at(start1 + i) != s2.byte_at(start2 + i) {
            matched = 0;
            break
        } else { 0 };
        i = i + 1
    };
    matched
    };

// Count occurrences of pattern in text using hash comparison
fn count_pattern(text: String, pattern: String, base: i64, modulus: i64) -> i64 = {
    let tlen = text.len();
    let plen = pattern.len();
    if plen > tlen { return 0 } else { () };

    let pat_hash = poly_hash(pattern, base, modulus);
    let mut count = 0;
    let positions = tlen - plen + 1;

    for i in 0..positions {
        let sh = substr_hash(text, i, plen, base, modulus);
        if sh == pat_hash {
            if substr_match(text, i, pattern, 0, plen) == 1 {
                count = count + 1
            } else { 0 }
        } else { 0 }
    };
    count
    };

fn main() -> i64 = {
    let base = 31;
    let modulus = 1000000007;

    // Test 1: Same strings produce same hash
    let h1 = poly_hash("hello", base, modulus);
    let h2 = poly_hash("hello", base, modulus);
    println(if h1 == h2 { 1 } else { 0 });  // 1

    // Test 2: Different strings produce different hashes
    let h3 = poly_hash("hello", base, modulus);
    let h4 = poly_hash("world", base, modulus);
    println(if h3 != h4 { 1 } else { 0 });  // 1

    // Test 3: Empty string hash is 0
    println(poly_hash("", base, modulus));     // 0

    // Test 4: Single character hashes
    let ha = poly_hash("a", base, modulus);
    let hb = poly_hash("b", base, modulus);
    println(ha);                               // 97
    println(hb);                               // 98

    // Test 5: Substring hash matches full string hash
    let sh = substr_hash("abcdef", 0, 3, base, modulus);
    let fh = poly_hash("abc", base, modulus);
    println(if sh == fh { 1 } else { 0 });    // 1

    // Test 6: Different substring positions
    let sh2 = substr_hash("abcdef", 3, 3, base, modulus);
    let fh2 = poly_hash("def", base, modulus);
    println(if sh2 == fh2 { 1 } else { 0 }); // 1

    // Test 7: Pattern counting
    println(count_pattern("ababab", "ab", base, modulus));       // 3
    println(count_pattern("aaaa", "aa", base, modulus));         // 3
    println(count_pattern("hello world", "xyz", base, modulus)); // 0
    println(count_pattern("aaa", "a", base, modulus));           // 3

    // Test 8: pow_mod correctness
    println(pow_mod(2, 10, 1000000007));  // 1024
    println(pow_mod(31, 0, 1000000007));  // 1
    println(pow_mod(31, 1, 1000000007));  // 31

    // Test 9: Hash ordering
    let hx = poly_hash("abc", base, modulus);
    let hy = poly_hash("abd", base, modulus);
    println(if hx != hy { 1 } else { 0 }); // 1

    0
    };

// Golden Test: Palindrome partitioning with DP (minimum cuts)
// Given a string, find the minimum number of cuts needed
// so that every substring in the partition is a palindrome.
// Uses O(n^2) DP: is_pal[i*n+j] = 1 if s[i..j] is palindrome
// cut[i] = min cuts for s[0..i]

// Check if substring s[lo..hi] is a palindrome using precomputed table
fn get_pal(is_pal: i64, n: i64, i: i64, j: i64) -> i64 =
    vec_get(is_pal, i * n + j);

fn set_pal(is_pal: i64, n: i64, i: i64, j: i64, val: i64) -> i64 = {
    vec_set(is_pal, i * n + j, val);
    0
};

// Build palindrome table: is_pal[i][j] = 1 if s[i..j] is palindrome
// Expand by length: len=1, then len=2, ..., then len=n
fn build_pal_table(s: String, is_pal: i64, n: i64) -> i64 = {
    // Length 1: every single char is a palindrome
    for i in 0..n {
        let _s1 = set_pal(is_pal, n, i, i, 1)
    };
    // Length 2: check if adjacent chars match
    let mut i2 = 0;
    loop {
        if i2 >= n - 1 { break } else { () };
        let eq = if s.byte_at(i2) == s.byte_at(i2 + 1) { 1 } else { 0 };
        let _s2 = set_pal(is_pal, n, i2, i2 + 1, eq);
        i2 = i2 + 1
    };
    // Length 3 to n
    let mut len = 3;
    loop {
        if len > n { break } else { () };
        let mut i3 = 0;
        loop {
            let j3 = i3 + len - 1;
            if j3 >= n { break } else { () };
            let outer_match = if s.byte_at(i3) == s.byte_at(j3) { 1 } else { 0 };
            let inner_pal = get_pal(is_pal, n, i3 + 1, j3 - 1);
            let val = if outer_match == 1 and inner_pal == 1 { 1 } else { 0 };
            let _s3 = set_pal(is_pal, n, i3, j3, val);
            i3 = i3 + 1
        };
        len = len + 1
    };
    0
};

// Compute minimum cuts for palindrome partitioning
// cut[i] = min cuts for s[0..i]
fn min_cuts(s: String, is_pal: i64, cut: i64, n: i64) -> i64 = {
    // If entire s[0..i] is a palindrome, cut[i] = 0
    // Otherwise cut[i] = min over j in [0..i-1] of (cut[j] + 1) where s[j+1..i] is palindrome
    for i in 0..n {
        let whole_pal = get_pal(is_pal, n, 0, i);
        if whole_pal == 1 {
            vec_set(cut, i, 0)
        } else {
            // Start with worst case: i cuts (each char separate)
            vec_set(cut, i, i);
            let mut j = 0;
            loop {
                if j >= i { break } else { () };
                let right_pal = get_pal(is_pal, n, j + 1, i);
                if right_pal == 1 {
                    let candidate = vec_get(cut, j) + 1;
                    let current = vec_get(cut, i);
                    if candidate < current {
                        vec_set(cut, i, candidate)
                    } else { () }
                } else { () };
                j = j + 1
            }
        }
    };
    vec_get(cut, n - 1)
};

// Allocate a vec of n zeros
fn make_zeros(n: i64) -> i64 = {
    let v = vec_new();
    for _i in 0..n {
        vec_push(v, 0)
    };
    v
};

fn solve(s: String) -> i64 = {
    let n = s.len();
    if n <= 1 { return 0 } else { () };
    let is_pal = make_zeros(n * n);
    let cut = make_zeros(n);
    let _b = build_pal_table(s, is_pal, n);
    let result = min_cuts(s, is_pal, cut, n);
    vec_free(is_pal);
    vec_free(cut);
    result
};

fn main() -> i64 = {
    // "aab" -> 1 cut: "aa" | "b"
    let _p1 = println(solve("aab"));         // 1

    // "a" -> 0 cuts (already palindrome)
    let _p2 = println(solve("a"));           // 0

    // "aba" -> 0 cuts (already palindrome)
    let _p3 = println(solve("aba"));         // 0

    // "abcba" -> 0 cuts (already palindrome)
    let _p4 = println(solve("abcba"));       // 0

    // "aabb" -> 1 cut: "aa" | "bb"
    let _p5 = println(solve("aabb"));        // 1

    // "abcd" -> 3 cuts: "a" | "b" | "c" | "d"
    let _p6 = println(solve("abcd"));        // 3

    // "abacaba" -> 0 cuts (entire string is palindrome)
    let _p7 = println(solve("abacaba"));     // 0

    // "abcbdd" -> 1 cut: "abcba" err.. let me think
    // "abcbdd" -> "a" | "bcb" | "dd" = 2 cuts, or "abcba" isn't there...
    // a|b|c|b|d|d = 5 cuts worst case
    // "abcb" not palindrome, "bcb" palindrome, "dd" palindrome
    // So: "a" | "bcb" | "dd" = 2 cuts
    let _p8 = println(solve("abcbdd"));      // 2

    // "racecar" -> 0 cuts (palindrome)
    let _p9 = println(solve("racecar"));     // 0

    // "abba" -> 0 cuts (palindrome)
    let _p10 = println(solve("abba"));       // 0

    // "aabaa" -> 0 cuts (palindrome)
    let _p11 = println(solve("aabaa"));      // 0

    // "abcde" -> 4 cuts
    let _p12 = println(solve("abcde"));      // 4

    0
};

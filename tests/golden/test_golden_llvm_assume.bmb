// Test: llvm.assume generation from pre conditions
// Verifies that pre conditions generate @llvm.assume calls in LLVM IR

fn clamp_positive(x: i64) -> i64
  pre x >= 0
= if x > 100 { 100 } else { x };

fn bounded_add(a: i64, b: i64) -> i64
  pre a >= 0 and b >= 0 and a <= 1000 and b <= 1000
= a + b;

fn safe_div(a: i64, b: i64) -> i64
  pre b != 0
= a / b;

fn main() -> i64 = {
  let a = clamp_positive(42);
  let b = bounded_add(10, 20);
  let c = safe_div(100, 5);
  let _p1 = println(a);
  let _p2 = println(b);
  let _p3 = println(c);
  0
};

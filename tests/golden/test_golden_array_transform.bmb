// Golden Test: Array transformations - Cycle 1404
// Rotate array, reverse segment, remove duplicates from sorted

// Helper: create vec from values
fn make_vec5(a: i64, b: i64, c: i64, d: i64, e: i64) -> i64 = {
    let v = vec_new();
    let _p1 = vec_push(v, a);
    let _p2 = vec_push(v, b);
    let _p3 = vec_push(v, c);
    let _p4 = vec_push(v, d);
    let _p5 = vec_push(v, e);
    v
    };

fn make_vec4(a: i64, b: i64, c: i64, d: i64) -> i64 = {
    let v = vec_new();
    let _p1 = vec_push(v, a);
    let _p2 = vec_push(v, b);
    let _p3 = vec_push(v, c);
    let _p4 = vec_push(v, d);
    v
    };

fn make_vec7(a: i64, b: i64, c: i64, d: i64, e: i64, f: i64, g: i64) -> i64 = {
    let v = vec_new();
    let _p1 = vec_push(v, a);
    let _p2 = vec_push(v, b);
    let _p3 = vec_push(v, c);
    let _p4 = vec_push(v, d);
    let _p5 = vec_push(v, e);
    let _p6 = vec_push(v, f);
    let _p7 = vec_push(v, g);
    v
    };

fn make_vec9(a: i64, b: i64, c: i64, d: i64, e: i64, f: i64, g: i64, h: i64, ii: i64) -> i64 = {
    let v = vec_new();
    let _p1 = vec_push(v, a);
    let _p2 = vec_push(v, b);
    let _p3 = vec_push(v, c);
    let _p4 = vec_push(v, d);
    let _p5 = vec_push(v, e);
    let _p6 = vec_push(v, f);
    let _p7 = vec_push(v, g);
    let _p8 = vec_push(v, h);
    let _p9 = vec_push(v, ii);
    v
    };

fn make_zeros(n: i64) -> i64 = {
    let v = vec_new();
    for _i in 0..n {
        let _p = vec_push(v, 0);
        0
    };
    v
    };

// Reverse a segment arr[lo..hi] (inclusive)
fn reverse_segment(arr: i64, lo: i64, hi: i64) -> i64 = {
    let mut l = lo;
    let mut h = hi;
    loop {
        if l >= h { break } else { () };
        let tmp = vec_get(arr, l);
        let _s1 = vec_set(arr, l, vec_get(arr, h));
        let _s2 = vec_set(arr, h, tmp);
        l = l + 1;
        h = h - 1
    };
    0
    };

// Rotate array left by k positions using reverse method
// [1,2,3,4,5] rotate by 2 -> [3,4,5,1,2]
// Algorithm: reverse(0..k-1), reverse(k..n-1), reverse(0..n-1)
fn rotate_left(arr: i64, k: i64) -> i64 = {
    let n = vec_len(arr);
    let kk = k % n;
    if kk == 0 { return 0 } else { () };
    let _r1 = reverse_segment(arr, 0, kk - 1);
    let _r2 = reverse_segment(arr, kk, n - 1);
    let _r3 = reverse_segment(arr, 0, n - 1);
    0
    };

// Rotate array right by k positions
fn rotate_right(arr: i64, k: i64) -> i64 = {
    let n = vec_len(arr);
    let kk = k % n;
    rotate_left(arr, n - kk)
    };

// Remove duplicates from sorted array (returns new length)
fn remove_dups_sorted(arr: i64) -> i64 = {
    let n = vec_len(arr);
    if n <= 1 { return n } else { () };
    let mut write = 1;
    let mut i = 1;
    loop {
        if i >= n { break } else { () };
        if vec_get(arr, i) != vec_get(arr, write - 1) {
            let _s = vec_set(arr, write, vec_get(arr, i));
            write = write + 1
        } else { () };
    i = i + 1
    };
    write
    };

// Prefix maximum: arr[i] = max(arr[0], ..., arr[i])
fn prefix_max(arr: i64) -> i64 = {
    let n = vec_len(arr);
    let mut i = 1;
    loop {
        if i >= n { break } else { () };
        if vec_get(arr, i) < vec_get(arr, i - 1) {
            let _s = vec_set(arr, i, vec_get(arr, i - 1));
            0
        } else { 0 };
    i = i + 1
    };
    0
    };

// Compute difference array: diff[i] = arr[i+1] - arr[i]
fn diff_array(arr: i64, diff: i64) -> i64 = {
    let n = vec_len(arr);
    let mut i = 0;
    loop {
        if i + 1 >= n { break } else { () };
        let _s = vec_set(diff, i, vec_get(arr, i + 1) - vec_get(arr, i));
        i = i + 1
    };
    0
    };

fn main() -> i64 = {
// Rotate left by 2: [1,2,3,4,5] -> [3,4,5,1,2]
    let a1 = make_vec5(1, 2, 3, 4, 5);
    let _rl = rotate_left(a1, 2);
    let _p1 = println(vec_get(a1, 0));   // 3
    let _p2 = println(vec_get(a1, 2));   // 5
    let _p3 = println(vec_get(a1, 4));   // 2

// Rotate right by 1: [10,20,30,40] -> [40,10,20,30]
    let a2 = make_vec4(10, 20, 30, 40);
    let _rr = rotate_right(a2, 1);
    let _p4 = println(vec_get(a2, 0));   // 40
    let _p5 = println(vec_get(a2, 3));   // 30

// Reverse segment: reverse indices 1..3 of [5,1,2,3,4]
    let a3 = make_vec5(5, 1, 2, 3, 4);
    let _rs = reverse_segment(a3, 1, 3);
    let _p6 = println(vec_get(a3, 0));   // 5
    let _p7 = println(vec_get(a3, 1));   // 3
    let _p8 = println(vec_get(a3, 3));   // 1

// Remove duplicates from sorted
    let a4 = make_vec9(1, 1, 2, 3, 3, 3, 4, 5, 5);
    let new_len = remove_dups_sorted(a4);
    let _p9 = println(new_len);    // 5
    let _p10 = println(vec_get(a4, 0));     // 1
    let _p11 = println(vec_get(a4, 4));     // 5

// Prefix max: [3, 1, 4, 1, 5, 9, 2]
    let a5 = make_vec7(3, 1, 4, 1, 5, 9, 2);
    let _pm = prefix_max(a5);
    let _p12 = println(vec_get(a5, 0));    // 3
    let _p13 = println(vec_get(a5, 2));    // 4
    let _p14 = println(vec_get(a5, 5));    // 9
    let _p15 = println(vec_get(a5, 6));    // 9

// Difference array: [10, 13, 18, 20, 25] -> [3, 5, 2, 5]
    let a6 = make_vec5(10, 13, 18, 20, 25);
    let d6 = make_zeros(5);
    let _da = diff_array(a6, d6);
    let _p16 = println(vec_get(d6, 0));   // 3
    let _p17 = println(vec_get(d6, 1));   // 5
    let _p18 = println(vec_get(d6, 3));   // 5

    let _f1 = vec_free(a1);
    let _f2 = vec_free(a2);
    let _f3 = vec_free(a3);
    let _f4 = vec_free(a4);
    let _f5 = vec_free(a5);
    let _f6 = vec_free(a6);
    let _f7 = vec_free(d6);
    0
    };

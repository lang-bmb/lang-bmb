// Golden Test: gotgan dependency resolution
// Verifies dependency parsing, package existence checks, and error reporting.
// Self-contained: includes TOML parser inline.

// ============================================================================
    // TOML Parser (inline)
    // ============================================================================

fn toml_is_ws(c: i64) -> bool = c == 32 or c == 9;

fn toml_find_byte(s: String, pos: i64, end: i64, b: i64) -> i64 = {
    let mut p = pos;
    loop {
        if p >= end { break } else { () };
        if s.byte_at(p) == b { break } else { p = p + 1 }
    };
    p
    };

fn toml_skip_ws(s: String, pos: i64, end: i64) -> i64 = {
    let mut p = pos;
    loop {
        if p >= end { break } else { () };
        if toml_is_ws(s.byte_at(p)) { p = p + 1 } else { break }
    };
    p
    };

fn toml_trim_end(s: String, end: i64, start: i64) -> i64 = {
    let mut p = end;
    loop {
        if p <= start { break } else { () };
        if toml_is_ws(s.byte_at(p - 1)) { p = p - 1 } else { break }
    };
    p
    };

fn toml_parse(content: String) -> i64
  post ret != 0
= {
    let slen = content.len();
    let entries = vec_new();
    let mut pos = 0;
    let mut sec_off = 0;
    let mut sec_len = 0;

    while pos < slen {
        let line_end = toml_find_byte(content, pos, slen, 10);
        let eff_end = if line_end > pos {
            if content.byte_at(line_end - 1) == 13 { line_end - 1 }
            else { line_end }
        } else { line_end };
    let ls = toml_skip_ws(content, pos, eff_end);

    let _r = if ls >= eff_end { 0 }
    else if content.byte_at(ls) == 35 { 0 }
    else if content.byte_at(ls) == 91 {
        {
            let close = toml_find_byte(content, ls + 1, eff_end, 93);
            sec_off = ls + 1;
            sec_len = close - ls - 1;
            0
        }
    } else {
    {
        let eq_pos = toml_find_byte(content, ls, eff_end, 61);
        let _store = if eq_pos < eff_end {
            {
                let key_end = toml_trim_end(content, eq_pos, ls);
                let key_off = ls;
                let key_len = key_end - ls;
                let val_start = toml_skip_ws(content, eq_pos + 1, eff_end);
                let val_end = toml_trim_end(content, eff_end, val_start);
                let raw_len = val_end - val_start;
                let is_quoted = if raw_len >= 2 {
                    content.byte_at(val_start) == 34
                    and content.byte_at(val_end - 1) == 34
                } else { false };
            let final_off = if is_quoted { val_start + 1 } else { val_start };
            let final_len = if is_quoted { raw_len - 2 } else { raw_len };
            let _s1 = vec_push(entries, sec_off);
            let _s2 = vec_push(entries, sec_len);
            let _s3 = vec_push(entries, key_off);
            let _s4 = vec_push(entries, key_len);
            let _s5 = vec_push(entries, final_off);
            let _s6 = vec_push(entries, final_len);
            0
        }
    } else { 0 };
    0
    }
    };
    pos = line_end + 1;
    0
    };
    entries
    };

fn toml_entry_count(doc: i64) -> i64
  pre doc != 0
  post ret >= 0
= vec_len(doc) / 6;

fn toml_entry_section(doc: i64, content: String, i: i64) -> String
  pre doc != 0 and i >= 0
= {
    let base = i * 6;
    let off = vec_get(doc, base);
    let len = vec_get(doc, base + 1);
    if len == 0 { "" } else { content.slice(off, off + len) }
    };

fn toml_entry_key(doc: i64, content: String, i: i64) -> String
  pre doc != 0 and i >= 0
= {
    let base = i * 6;
    let off = vec_get(doc, base + 2);
    let len = vec_get(doc, base + 3);
    if len == 0 { "" } else { content.slice(off, off + len) }
    };

fn toml_entry_value(doc: i64, content: String, i: i64) -> String
  pre doc != 0 and i >= 0
= {
    let base = i * 6;
    let off = vec_get(doc, base + 4);
    let len = vec_get(doc, base + 5);
    if len == 0 { "" } else { content.slice(off, off + len) }
    };

fn toml_section_count(doc: i64, content: String, section: String) -> i64
  pre doc != 0
  post ret >= 0
= {
    let count = toml_entry_count(doc);
    let mut i = 0;
    let mut n = 0;
    while i < count {
        let sec = toml_entry_section(doc, content, i);
        let _r = if sec == section { n = n + 1; 0 } else { 0 };
        i = i + 1;
        0
    };
    n
    };

fn toml_section_key_at(doc: i64, content: String, section: String, idx: i64) -> String
  pre doc != 0 and idx >= 0
= {
    let count = toml_entry_count(doc);
    let mut i = 0;
    let mut found = 0;
    let mut result = "";
    while i < count {
        let sec = toml_entry_section(doc, content, i);
        let _r = if sec == section {
            {
                let _s = if found == idx {
                    result = toml_entry_key(doc, content, i);
                    0
                } else { 0 };
            found = found + 1;
            0
        }
    } else { 0 };
    i = i + 1;
    0
    };
    result
    };

fn toml_section_val_at(doc: i64, content: String, section: String, idx: i64) -> String
  pre doc != 0 and idx >= 0
= {
    let count = toml_entry_count(doc);
    let mut i = 0;
    let mut found = 0;
    let mut result = "";
    while i < count {
        let sec = toml_entry_section(doc, content, i);
        let _r = if sec == section {
            {
                let _s = if found == idx {
                    result = toml_entry_value(doc, content, i);
                    0
                } else { 0 };
            found = found + 1;
            0
        }
    } else { 0 };
    i = i + 1;
    0
    };
    result
    };

fn toml_free(doc: i64) -> i64
  pre doc != 0
= { let _f = vec_free(doc); 0 };

    // ============================================================================
    // String Utilities
    // ============================================================================

fn str_concat(a: String, b: String) -> String = {
    let sb = sb_new();
    let _p1 = sb_push(sb, a);
    let _p2 = sb_push(sb, b);
    sb_build(sb)
    };

fn str_concat3(a: String, b: String, c: String) -> String = {
    let sb = sb_new();
    let _p1 = sb_push(sb, a);
    let _p2 = sb_push(sb, b);
    let _p3 = sb_push(sb, c);
    sb_build(sb)
    };

fn path_join(dir: String, file: String) -> String =
    str_concat3(dir, "/", file);

    // ============================================================================
    // Dependency Resolution
    // ============================================================================

    // Check if a dependency package exists (has gotgan.toml)

fn dep_found(packages_dir: String, dep_name: String) -> bool =
    file_exists(path_join(path_join(packages_dir, dep_name), "gotgan.toml")) == 1;

    // Resolve all dependencies: returns count of missing deps (0 = all resolved)

fn resolve_deps(doc: i64, content: String, packages_dir: String) -> i64 = {
    let dep_count = toml_section_count(doc, content, "dependencies");
    let mut i = 0;
    let mut missing = 0;
    while i < dep_count {
        let name = toml_section_key_at(doc, content, "dependencies", i);
        let _check = if dep_found(packages_dir, name) {
            0
        } else {
        missing = missing + 1;
        0
    };
    i = i + 1;
    0
    };
    missing
    };

// Get dependency name at index
fn dep_name_at(doc: i64, content: String, idx: i64) -> String =
    toml_section_key_at(doc, content, "dependencies", idx);

    // Get dependency version spec at index

fn dep_spec_at(doc: i64, content: String, idx: i64) -> String =
    toml_section_val_at(doc, content, "dependencies", idx);

    // ============================================================================
    // Tests
    // ============================================================================

fn run_test(name: String, result: bool) -> i64 = {
    let _p1 = print_str(if result { "  PASS: " } else { "  FAIL: " });
    let _p2 = print_str(name);
    let _p3 = print_str("\n");
    if result { 1 } else { 0 }
    };

fn main() -> i64 = {
    let _h = print_str("gotgan-deps: running tests\n");
    let mut passed = 0;
    let total = 8;

// Test manifest with dependencies
    let content = "[package]\nname = \"my-app\"\nversion = \"1.0.0\"\n\n[dependencies]\nbmb-args = \"0.1.0\"\nbmb-assert = \"0.1.0\"\nbmb-json = \"0.1.0\"\n";
    let doc = toml_parse(content);

// Test 1: dep_count
    let dep_count = toml_section_count(doc, content, "dependencies");
    passed = passed + run_test("dep_count is 3", dep_count == 3);

// Test 2: dep_name_at
    let d0 = dep_name_at(doc, content, 0);
    passed = passed + run_test("dep 0 is bmb-args", d0 == "bmb-args");

// Test 3: dep_name_at index 2
    let d2 = dep_name_at(doc, content, 2);
    passed = passed + run_test("dep 2 is bmb-json", d2 == "bmb-json");

// Test 4: dep_spec_at
    let s0 = dep_spec_at(doc, content, 0);
    passed = passed + run_test("spec 0 is 0.1.0", s0 == "0.1.0");

// Test 5: resolve_deps with real packages dir
// ecosystem/gotgan-packages/packages/ contains bmb-args, bmb-assert, bmb-json
    let pkg_dir = "ecosystem/gotgan-packages/packages";
    let missing = resolve_deps(doc, content, pkg_dir);
    passed = passed + run_test("all deps resolved (0 missing)", missing == 0);

    let _f1 = toml_free(doc);

// Test 6: resolve with missing dependency
    let content2 = "[package]\nname = \"broken\"\nversion = \"0.1.0\"\n\n[dependencies]\nbmb-args = \"0.1.0\"\nnonexistent-pkg = \"9.9.9\"\n";
    let doc2 = toml_parse(content2);
    let missing2 = resolve_deps(doc2, content2, pkg_dir);
    passed = passed + run_test("1 missing dep detected", missing2 == 1);
    let _f2 = toml_free(doc2);

// Test 7: no dependencies section
    let content3 = "[package]\nname = \"no-deps\"\nversion = \"1.0.0\"\n";
    let doc3 = toml_parse(content3);
    let dep_count3 = toml_section_count(doc3, content3, "dependencies");
    passed = passed + run_test("no deps = count 0", dep_count3 == 0);
    let _f3 = toml_free(doc3);

// Test 8: dep_found direct check
    let found = dep_found(pkg_dir, "bmb-args");
    passed = passed + run_test("bmb-args exists", found);

    let _r1 = print_str("gotgan-deps: ");
    let _r2 = print(passed);
    let _r3 = print_str("/");
    let _r4 = print(total);
    let _r5 = print_str(" tests passed\n");
    if passed == total { 0 } else { 1 }
    };

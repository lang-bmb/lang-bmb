// Golden Test: Integer partition enumeration and counting
// p(n) = number of ways to write n as sum of positive integers
// Uses DP (bottom-up) approach

// Count partitions of n using parts <= max_part
// dp[i] = number of ways to partition i
fn partition_count(n: i64) -> i64 = {
    // dp array of size n+1, initialized to 0
    let dp = vec_new();
    for _i in 0..n + 1 { let _a = vec_push(dp, 0); 0 };
    // Base case: one way to partition 0 (empty partition)
    let _s = vec_set(dp, 0, 1);
    // For each part size from 1 to n
    for part in 1..n + 1 {
        // Update dp[j] for j >= part
        for j in part..n + 1 {
            let _s = vec_set(dp, j, vec_get(dp, j) + vec_get(dp, j - part));
            0
        };
        0
    };
    vec_get(dp, n)
    };

// Count partitions of n into exactly k parts
// Uses 2D DP: dp[i][j] = partitions of i into exactly j parts
// Recurrence: dp[i][j] = dp[i-1][j-1] + dp[i-j][j]
// (either smallest part is 1, or all parts >= 2, subtract 1 from each)
fn partition_k_parts(n: i64, k: i64) -> i64 = {
    // Flat 2D array: dp[i * (k+1) + j]
    let sz = (n + 1) * (k + 1);
    let dp = vec_new();
    for _i in 0..sz { let _a = vec_push(dp, 0); 0 };
    // Base: dp[0][0] = 1
    let _s = vec_set(dp, 0, 1);
    for i in 1..n + 1 {
        for j in 1..k + 1 {
            let idx = i * (k + 1) + j;
            // dp[i-1][j-1]
            let from_one = vec_get(dp, (i - 1) * (k + 1) + (j - 1));
            // dp[i-j][j] if i >= j
            let from_sub = if i >= j { vec_get(dp, (i - j) * (k + 1) + j) } else { 0 };
            let _s = vec_set(dp, idx, from_one + from_sub);
            0
        };
        0
    };
    vec_get(dp, n * (k + 1) + k)
    };

// Count partitions into distinct parts
// Each part can be used at most once
fn partition_distinct(n: i64) -> i64 = {
    let dp = vec_new();
    for _i in 0..n + 1 { let _a = vec_push(dp, 0); 0 };
    let _s = vec_set(dp, 0, 1);
    // For each part, either use it or don't (0-1 knapsack style)
    for part in 1..n + 1 {
        // Iterate backwards to avoid using same part twice
        let mut j = n;
        loop {
            if j < part { break } else { () };
            let _s = vec_set(dp, j, vec_get(dp, j) + vec_get(dp, j - part));
            set j = j - 1;
            0
        };
        0
    };
    vec_get(dp, n)
    };

// Count partitions into odd parts only
fn partition_odd(n: i64) -> i64 = {
    let dp = vec_new();
    for _i in 0..n + 1 { let _a = vec_push(dp, 0); 0 };
    let _s = vec_set(dp, 0, 1);
    // Only use odd parts: 1, 3, 5, 7, ...
    let mut part = 1;
    loop {
        if part > n { break } else { () };
        for j in part..n + 1 {
            let _s = vec_set(dp, j, vec_get(dp, j) + vec_get(dp, j - part));
            0
        };
        set part = part + 2;
        0
    };
    vec_get(dp, n)
    };

// Largest part in the "greedy" partition (just n itself as 1 part)
// More interesting: count partitions where largest part is exactly m
// This equals p_k(n, m) = partitions of n into exactly m parts (conjugate)
fn partition_largest_m(n: i64, m: i64) -> i64 =
    partition_k_parts(n, m);

// Pentagonal number: k*(3k-1)/2
fn pentagonal(k: i64) -> i64 = k * (3 * k - 1) / 2;

// Euler's pentagonal theorem verification
// p(n) = sum of (-1)^(k+1) * (p(n - pent(k)) + p(n - pent(-k)))
// We just verify p(n) matches for small n
fn euler_verify(n: i64) -> i64 = {
    // Just compute p(n) two ways and compare
    let p_dp = partition_count(n);
    // Recursive with pentagonal (memoized via vec)
    let memo = vec_new();
    for _i in 0..n + 1 { let _a = vec_push(memo, 0 - 1); 0 };
    let _s = vec_set(memo, 0, 1);
    let p_pent = partition_pentagonal(memo, n);
    if p_dp == p_pent { 1 } else { 0 }
    };

fn partition_pentagonal(memo: i64, n: i64) -> i64 =
    if n < 0 { 0 }
    else if vec_get(memo, n) != 0 - 1 { vec_get(memo, n) }
    else {
        let result = pent_sum(memo, n, 1, 0);
        let _s = vec_set(memo, n, result);
        result
    };

fn pent_sum(memo: i64, n: i64, k: i64, acc: i64) -> i64 = {
    let p1 = pentagonal(k);
    let p2 = pentagonal(0 - k);
    if p1 > n and p2 > n { acc }
    else {
        // sign alternates: +, +, -, -, +, +, ...
        // k=1: +, k=2: -, k=3: +, k=4: -
        let sign = if (k - 1) - ((k - 1) / 2) * 2 == 0 { 1 } else { 0 - 1 };
        let t1 = if p1 <= n { sign * partition_pentagonal(memo, n - p1) } else { 0 };
        let t2 = if p2 <= n { sign * partition_pentagonal(memo, n - p2) } else { 0 };
        pent_sum(memo, n, k + 1, acc + t1 + t2)
    }
    };

fn main() -> i64 = {
    // Basic partition counts p(n)
    let _p1 = println(partition_count(0));  // 1
    let _p2 = println(partition_count(1));  // 1
    let _p3 = println(partition_count(5));  // 7
    let _p4 = println(partition_count(10)); // 42
    let _p5 = println(partition_count(15)); // 176

    // Partitions into exactly k parts
    let _p6 = println(partition_k_parts(5, 2));  // 2: (4+1, 3+2)
    let _p7 = println(partition_k_parts(5, 3));  // 2: (3+1+1, 2+2+1)
    let _p8 = println(partition_k_parts(10, 3)); // 8

    // Partitions into distinct parts
    let _p9 = println(partition_distinct(5));  // 3: (5), (4+1), (3+2)
    let _p10 = println(partition_distinct(10)); // 10

    // Partitions into odd parts (equals distinct parts by Euler's theorem!)
    let _p11 = println(partition_odd(5));  // 3 (same as distinct(5))
    let _p12 = println(partition_odd(10)); // 10 (same as distinct(10))

    // Euler's pentagonal theorem verification
    let _p13 = println(euler_verify(5));  // 1
    let _p14 = println(euler_verify(10)); // 1
    let _p15 = println(euler_verify(15)); // 1

    // Edge cases
    let _p16 = println(partition_k_parts(1, 1));  // 1
    let _p17 = println(partition_k_parts(5, 5));  // 1 (1+1+1+1+1)
    let _p18 = println(partition_k_parts(5, 6));  // 0 (impossible)

    0
    };

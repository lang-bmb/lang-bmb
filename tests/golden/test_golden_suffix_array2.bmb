// Golden Test: Suffix array construction (naive O(n^2 log n))
// Build suffix array by sorting suffix indices using comparison of actual suffixes
// Also compute LCP (Longest Common Prefix) array using Kasai's algorithm

// Compare two suffixes starting at positions i and j in string s
// Returns: -1 if suffix_i < suffix_j, 0 if equal, 1 if suffix_i > suffix_j
fn compare_suffixes(s: String, i: i64, j: i64, n: i64) -> i64 = {
    let mut pos = 0;
    let len_i = n - i;
    let len_j = n - j;
    let min_len = if len_i < len_j { len_i } else { len_j };
    let mut result = 0;
    let mut done = 0;
    loop {
        if pos >= min_len { break } else { () };
        if done == 1 { break } else { () };
        let ci = s.byte_at(i + pos);
        let cj = s.byte_at(j + pos);
        if ci < cj {
            result = 0 - 1;
            done = 1
        } else if ci > cj {
            result = 1;
            done = 1
        } else {
            pos = pos + 1
        }
    };
    if done == 1 { result }
    else if len_i < len_j { 0 - 1 }
    else if len_i > len_j { 1 }
    else { 0 }
};

// Insertion sort for suffix array (stable, works for small inputs)
fn sort_suffixes(sa: i64, s: String, n: i64) -> i64 = {
    let mut i = 1;
    loop {
        if i >= n { break } else { () };
        let key = vec_get(sa, i);
        let mut j = i - 1;
        loop {
            if j < 0 { break } else { () };
            let sj = vec_get(sa, j);
            let cmp = compare_suffixes(s, sj, key, n);
            if cmp > 0 {
                vec_set(sa, j + 1, sj);
                j = j - 1
            } else {
                break
            }
        };
        vec_set(sa, j + 1, key);
        i = i + 1
    };
    0
};

// Compute LCP between two suffixes (brute force)
fn lcp_of(s: String, i: i64, j: i64, n: i64) -> i64 = {
    let len_i = n - i;
    let len_j = n - j;
    let min_len = if len_i < len_j { len_i } else { len_j };
    let mut k = 0;
    loop {
        if k >= min_len { break } else { () };
        if s.byte_at(i + k) != s.byte_at(j + k) { break } else { () };
        k = k + 1
    };
    k
};

// Compute LCP array: lcp[i] = LCP(sa[i-1], sa[i]) for i >= 1, lcp[0] = 0
fn compute_lcp(sa: i64, lcp: i64, s: String, n: i64) -> i64 = {
    vec_set(lcp, 0, 0);
    let mut i = 1;
    loop {
        if i >= n { break } else { () };
        let prev = vec_get(sa, i - 1);
        let curr = vec_get(sa, i);
        let l = lcp_of(s, prev, curr, n);
        vec_set(lcp, i, l);
        i = i + 1
    };
    0
};

// Build suffix array for a string
fn build_suffix_array(s: String) -> i64 = {
    let n = s.len();
    let sa = vec_new();
    for i in 0..n {
        vec_push(sa, i)
    };
    let _sort = sort_suffixes(sa, s, n);
    sa
};

// Print suffix array
fn print_sa(sa: i64, n: i64) -> i64 = {
    for i in 0..n {
        println(vec_get(sa, i))
    };
    0
};

// Print LCP array
fn print_lcp(lcp: i64, n: i64) -> i64 = {
    for i in 0..n {
        println(vec_get(lcp, i))
    };
    0
};

fn main() -> i64 = {
    // Test 1: "banana"
    // Suffixes sorted:
    // 5: "a"
    // 3: "ana"
    // 1: "anana"
    // 0: "banana"
    // 4: "na"
    // 2: "nana"
    // SA = [5, 3, 1, 0, 4, 2]
    let s1 = "banana";
    let sa1 = build_suffix_array(s1);
    let n1 = s1.len();
    print_str("SA banana:");
    let _ps1 = print_sa(sa1, n1);

    // LCP for banana: [0, 1, 3, 0, 0, 2]
    let lcp1 = vec_new();
    for _i in 0..n1 {
        vec_push(lcp1, 0)
    };
    let _lc1 = compute_lcp(sa1, lcp1, s1, n1);
    print_str("LCP banana:");
    let _pl1 = print_lcp(lcp1, n1);

    // Test 2: "abcabc"
    // Suffixes sorted:
    // 3: "abc"
    // 0: "abcabc"
    // 4: "bc"
    // 1: "bcabc"
    // 5: "c"
    // 2: "cabc"
    // SA = [3, 0, 4, 1, 5, 2]
    let s2 = "abcabc";
    let sa2 = build_suffix_array(s2);
    let n2 = s2.len();
    print_str("SA abcabc:");
    let _ps2 = print_sa(sa2, n2);

    // LCP: [0, 3, 0, 2, 0, 1]
    let lcp2 = vec_new();
    for _i in 0..n2 {
        vec_push(lcp2, 0)
    };
    let _lc2 = compute_lcp(sa2, lcp2, s2, n2);
    print_str("LCP abcabc:");
    let _pl2 = print_lcp(lcp2, n2);

    // Test 3: "aaa"
    // SA = [2, 1, 0]
    // LCP = [0, 1, 2]
    let s3 = "aaa";
    let sa3 = build_suffix_array(s3);
    let n3 = s3.len();
    print_str("SA aaa:");
    let _ps3 = print_sa(sa3, n3);

    let lcp3 = vec_new();
    for _i in 0..n3 {
        vec_push(lcp3, 0)
    };
    let _lc3 = compute_lcp(sa3, lcp3, s3, n3);
    print_str("LCP aaa:");
    let _pl3 = print_lcp(lcp3, n3);

    // Test 4: "abcd" (all distinct)
    // SA = [0, 1, 2, 3]
    // LCP = [0, 0, 0, 0]
    let s4 = "abcd";
    let sa4 = build_suffix_array(s4);
    let n4 = s4.len();
    print_str("SA abcd:");
    let _ps4 = print_sa(sa4, n4);

    let lcp4 = vec_new();
    for _i in 0..n4 {
        vec_push(lcp4, 0)
    };
    let _lc4 = compute_lcp(sa4, lcp4, s4, n4);
    print_str("LCP abcd:");
    let _pl4 = print_lcp(lcp4, n4);

    // Cleanup
    vec_free(sa1); vec_free(lcp1);
    vec_free(sa2); vec_free(lcp2);
    vec_free(sa3); vec_free(lcp3);
    vec_free(sa4); vec_free(lcp4);
    0
};

// Golden Test: Interval arithmetic and range operations
// Tests range overlap, merge, and containment patterns

fn imax(a: i64, b: i64) -> i64 =
    if a > b { a } else { b };

fn imin(a: i64, b: i64) -> i64 =
    if a < b { a } else { b };

    // Check if two intervals [a1,b1] and [a2,b2] overlap

fn intervals_overlap(a1: i64, b1: i64, a2: i64, b2: i64) -> i64 =
    if a1 <= b2 and a2 <= b1 { 1 } else { 0 };

    // Compute intersection length (0 if no overlap)

fn intersection_len(a1: i64, b1: i64, a2: i64, b2: i64) -> i64 = {
    let lo = imax(a1, a2);
    let hi = imin(b1, b2);
    if hi >= lo { hi - lo } else { 0 }
    };

// Compute union length (assuming overlap)
fn union_len(a1: i64, b1: i64, a2: i64, b2: i64) -> i64 = {
    let lo = imin(a1, a2);
    let hi = imax(b1, b2);
    hi - lo
    };

// Check if point x is in interval [lo, hi]
fn contains(lo: i64, hi: i64, x: i64) -> i64 =
    if x >= lo and x <= hi { 1 } else { 0 };

    // Distance from point x to interval [lo, hi]

fn distance_to(lo: i64, hi: i64, x: i64) -> i64 =
    if x < lo { lo - x }
    else if x > hi { x - hi }
    else { 0 };

    // Count integers in range [a,b] divisible by d

fn count_divisible(a: i64, b: i64, d: i64) -> i64 = {
    let first = a + (d - (a - (a / d) * d)) - d;
    let adjusted_first = if first < a { first + d } else { first };
    if adjusted_first > b { 0 }
    else { (b - adjusted_first) / d + 1 }
    };

fn main() -> i64 = {
// Overlap tests
    let _p1 = println(intervals_overlap(1, 5, 3, 8));   // 1 (overlap)
    let _p2 = println(intervals_overlap(1, 3, 5, 8));   // 0 (no overlap)
    let _p3 = println(intervals_overlap(1, 5, 5, 8));   // 1 (touch at 5)

// Intersection length
    let _p4 = println(intersection_len(1, 10, 5, 15));  // 5 (5..10)
    let _p5 = println(intersection_len(1, 3, 5, 8));    // 0

// Union length
    let _p6 = println(union_len(1, 10, 5, 15));         // 14 (1..15)

// Contains
    let _p7 = println(contains(0, 100, 50));    // 1
    let _p8 = println(contains(0, 100, 200));   // 0

// Distance
    let _p9 = println(distance_to(10, 20, 5));  // 5
    let _p10 = println(distance_to(10, 20, 15)); // 0
    let _p11 = println(distance_to(10, 20, 25)); // 5

// Count divisible
    let _p12 = println(count_divisible(1, 100, 7));  // 14 (7,14,...,98)

    0
    };

// Golden Test: Trapping rain water — two-pointer approach
// Classic algorithm: compute water trapped between elevation bars

fn make_vec(a: i64, b: i64, c: i64, d: i64, e: i64, f: i64, g: i64, h: i64) -> i64 = {
    let v = vec_new();
    let _p1 = vec_push(v, a);
    let _p2 = vec_push(v, b);
    let _p3 = vec_push(v, c);
    let _p4 = vec_push(v, d);
    let _p5 = vec_push(v, e);
    let _p6 = vec_push(v, f);
    let _p7 = vec_push(v, g);
    let _p8 = vec_push(v, h);
    v
    };

fn make_vec12(a: i64, b: i64, c: i64, d: i64, e: i64, f: i64,
              g: i64, h: i64, i: i64, j: i64, k: i64, l: i64) -> i64 = {
    let v = vec_new();
    let _p1 = vec_push(v, a);
    let _p2 = vec_push(v, b);
    let _p3 = vec_push(v, c);
    let _p4 = vec_push(v, d);
    let _p5 = vec_push(v, e);
    let _p6 = vec_push(v, f);
    let _p7 = vec_push(v, g);
    let _p8 = vec_push(v, h);
    let _p9 = vec_push(v, i);
    let _p10 = vec_push(v, j);
    let _p11 = vec_push(v, k);
    let _p12 = vec_push(v, l);
    v
    };

fn make_vec6(a: i64, b: i64, c: i64, d: i64, e: i64, f: i64) -> i64 = {
    let v = vec_new();
    let _p1 = vec_push(v, a);
    let _p2 = vec_push(v, b);
    let _p3 = vec_push(v, c);
    let _p4 = vec_push(v, d);
    let _p5 = vec_push(v, e);
    let _p6 = vec_push(v, f);
    v
    };

// Two-pointer trapping rain water: O(n) time, O(1) space
fn trap_water(height: i64) -> i64 = {
    let n = vec_len(height);
    if n < 3 { return 0 } else { () };
    let mut left = 0;
    let mut right = n - 1;
    let mut left_max = 0;
    let mut right_max = 0;
    let mut water = 0;
    loop {
        if left >= right { break } else { () };
        let lh = vec_get(height, left);
        let rh = vec_get(height, right);
        if lh < rh {
            if lh >= left_max {
                left_max = lh
            } else {
                water = water + left_max - lh
            };
            left = left + 1
        } else {
            if rh >= right_max {
                right_max = rh
            } else {
                water = water + right_max - rh
            };
            right = right - 1
        }
    };
    water
    };

// Brute-force approach for verification: O(n^2) time
fn trap_brute(height: i64) -> i64 = {
    let n = vec_len(height);
    let mut total = 0;
    for i in 1..n - 1 {
        // Find max to the left of i
        let mut lmax = 0;
        for j in 0..i + 1 {
            let h = vec_get(height, j);
            if h > lmax { lmax = h } else { () }
        };
        // Find max to the right of i
        let mut rmax = 0;
        let mut k = i;
        loop {
            if k >= n { break } else { () };
            let h = vec_get(height, k);
            if h > rmax { rmax = h } else { () };
            k = k + 1
        };
        let bound = if lmax < rmax { lmax } else { rmax };
        let hi = vec_get(height, i);
        if bound > hi { total = total + bound - hi } else { () }
    };
    total
    };

fn main() -> i64 = {
    // Classic example: [0,1,0,2,1,0,1,3,2,1,2,1] -> 6
    let h1 = make_vec12(0, 1, 0, 2, 1, 0, 1, 3, 2, 1, 2, 1);
    let _p1 = println(trap_water(h1));     // 6
    let _p2 = println(trap_brute(h1));     // 6

    // Valley: [3,0,0,0,3] via vec6 with extra
    let h2 = make_vec6(3, 0, 0, 0, 3, 0);
    // Remove last element by treating length as 5
    // Actually use a 6-element version: [3,0,0,0,3,0] -> water at indices 1,2,3 = 3+3+3=9, idx 5=0
    let _p3 = println(trap_water(h2));     // 9

    // Ascending: [1,2,3,4,5,6,7,8] -> 0 (no trapping)
    let h3 = make_vec(1, 2, 3, 4, 5, 6, 7, 8);
    let _p4 = println(trap_water(h3));     // 0

    // Descending: [8,7,6,5,4,3,2,1] -> 0 (no trapping)
    let h4 = make_vec(8, 7, 6, 5, 4, 3, 2, 1);
    let _p5 = println(trap_water(h4));     // 0

    // V-shape: [5,0,5,0,5,0,5,0] -> water at 1,3,5,7 = 5+5+5+0 hmm
    // [5,1,5,1,5,1,5,1] -> water at odd indices: 4+4+4+0 = 12? No.
    // Let's use [4,1,0,1,4,2,0,2]
    let h5 = make_vec(4, 1, 0, 1, 4, 2, 0, 2);
    let _p6 = println(trap_water(h5));     // 12
    let _p7 = println(trap_brute(h5));     // 12

    // Single peak: [0,0,5,0,0,0,0,0] -> 0
    let h6 = make_vec(0, 0, 5, 0, 0, 0, 0, 0);
    let _p8 = println(trap_water(h6));     // 0

    let _f1 = vec_free(h1);
    let _f2 = vec_free(h2);
    let _f3 = vec_free(h3);
    let _f4 = vec_free(h4);
    let _f5 = vec_free(h5);
    let _f6 = vec_free(h6);
    0
    };

// Golden Test: Counting Sort
// Sorts integers in range [0, max_val] in O(n+k) time

fn counting_sort(arr: i64, n: i64, max_val: i64) -> i64 = {
    let count = vec_new();
    let mut i = 0;
    while i <= max_val {
        let _p = vec_push(count, 0);
        set i = i + 1
    };
    set i = 0;
    while i < n {
        let v = vec_get(arr, i);
        vec_set(count, v, vec_get(count, v) + 1);
        set i = i + 1
    };
    let result = vec_new();
    set i = 0;
    while i <= max_val {
        let c = vec_get(count, i);
        let mut j = 0;
        while j < c {
            let _p = vec_push(result, i);
            set j = j + 1
        };
        set i = i + 1
    };
    result
};

fn print_arr(arr: i64, n: i64) -> () = {
    let mut i = 0;
    while i < n {
        let _sp = if i > 0 { print_str(" "); 0 } else { 0 };
        print(vec_get(arr, i));
        set i = i + 1
    };
    let _nl = print_str("
")
};

fn main() -> () = {
    let a1 = vec_new();
    let _p = vec_push(a1, 4); let _p = vec_push(a1, 2);
    let _p = vec_push(a1, 2); let _p = vec_push(a1, 8);
    let _p = vec_push(a1, 3); let _p = vec_push(a1, 3);
    let _p = vec_push(a1, 1);
    let r1 = counting_sort(a1, 7, 8);
    print_str("sorted1: "); print_arr(r1, 7);

    let a2 = vec_new();
    let _p = vec_push(a2, 5); let _p = vec_push(a2, 5);
    let _p = vec_push(a2, 5); let _p = vec_push(a2, 5);
    let r2 = counting_sort(a2, 4, 5);
    print_str("sorted2: "); print_arr(r2, 4);

    let a3 = vec_new();
    let _p = vec_push(a3, 0); let _p = vec_push(a3, 1);
    let _p = vec_push(a3, 2); let _p = vec_push(a3, 3);
    let r3 = counting_sort(a3, 4, 3);
    print_str("sorted3: "); print_arr(r3, 4);

    let a4 = vec_new();
    let _p = vec_push(a4, 9); let _p = vec_push(a4, 7);
    let _p = vec_push(a4, 5); let _p = vec_push(a4, 3);
    let _p = vec_push(a4, 1);
    let r4 = counting_sort(a4, 5, 9);
    print_str("sorted4: "); print_arr(r4, 5)
};

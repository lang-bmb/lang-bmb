    };

fn is_sorted_check(a: i64, b: i64, c: i64) -> i64 = {
    let v = vec_new();
    let _p1 = vec_push(v, a);
    let _p2 = vec_push(v, b);
    let _p3 = vec_push(v, c);
    let _s = my_bubble_sort(v);
    let r = vec_get(v, 0) * 100 + vec_get(v, 1) * 10 + vec_get(v, 2);
    let _f = vec_free(v);
    r
    };

fn main() -> i64 = {
    let _p1 = println(sort_and_sum(5, 3, 1, 4, 2)); // sorted: 1,2,3,4,5 → 1+20+300+4000+50000 = 54321

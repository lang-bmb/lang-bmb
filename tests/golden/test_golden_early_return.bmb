// Golden Test: Early return from function with nested conditions
// Tests return statement in various nested if/else contexts

// Early return on boundary condition
fn safe_divide(a: i64, b: i64) -> i64 = {
    if b == 0 { return 0 - 1 } else { () };
    a / b
    };

// Early return in nested conditions
fn classify_triangle(a: i64, b: i64, c: i64) -> i64 = {
    // Return 0 if invalid, 1 if equilateral, 2 if isosceles, 3 if scalene
    if a <= 0 or b <= 0 or c <= 0 { return 0 } else { () };
    if a + b <= c or a + c <= b or b + c <= a { return 0 } else { () };
    if a == b and b == c { return 1 } else { () };
    if a == b or b == c or a == c { return 2 } else { () };
    3
    };

// Recursive search for first multiple
fn find_first_multiple_rec(n: i64, k: i64, limit: i64) -> i64 =
    if k > 10000 { 0 - 1 }
    else if k * n > limit { k * n }
    else { find_first_multiple_rec(n, k + 1, limit) };

fn find_first_multiple(n: i64, limit: i64) -> i64 =
    find_first_multiple_rec(n, 1, limit);

// Count special numbers recursively
fn count_special_rec(n: i64, i: i64, count: i64) -> i64 =
    if i > n { count }
    else {
        let div3 = i - (i / 3) * 3 == 0;
        let div5 = i - (i / 5) * 5 == 0;
        let new_count = if div3 and div5 { count }
            else if div3 or div5 { count + 1 }
            else { count };
        count_special_rec(n, i + 1, new_count)
    };

fn count_special(n: i64) -> i64 =
    if n <= 0 { 0 } else { count_special_rec(n, 1, 0) };

// GCD recursive
fn gcd(a: i64, b: i64) -> i64 =
    if b == 0 { a } else { gcd(b, a - (a / b) * b) };

fn main() -> i64 = {
    // safe_divide tests
    let _p1 = println(safe_divide(10, 3));    // 3
    let _p2 = println(safe_divide(10, 0));    // -1
    let _p3 = println(safe_divide(100, 7));   // 14
    let _p4 = println(safe_divide(0, 5));     // 0

    // classify_triangle tests
    let _p5 = println(classify_triangle(3, 3, 3));   // 1 (equilateral)
    let _p6 = println(classify_triangle(3, 3, 5));   // 2 (isosceles)
    let _p7 = println(classify_triangle(3, 4, 5));   // 3 (scalene)
    let _p8 = println(classify_triangle(1, 2, 10));  // 0 (invalid)
    let _p9 = println(classify_triangle(0, 3, 3));   // 0 (invalid)

    // find_first_multiple tests
    let _p10 = println(find_first_multiple(7, 50));   // 56
    let _p11 = println(find_first_multiple(13, 100)); // 104
    let _p12 = println(find_first_multiple(5, 0));    // 5

    // count_special tests
    let _p13 = println(count_special(15));  // 6
    let _p14 = println(count_special(30));  // 12
    let _p15 = println(count_special(0));   // 0

    // gcd tests
    let _p16 = println(gcd(12, 8));   // 4
    let _p17 = println(gcd(100, 75)); // 25
    let _p18 = println(gcd(17, 0));   // 17
    let _p19 = println(gcd(0, 13));   // 13
    0
    };

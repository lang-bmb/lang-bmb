// Golden test: Generic struct monomorphization (v0.97.3)
// Tests: struct<A,B> monomorphization with field access
// Expected output: 30 142

struct Pair<A, B> {
    first: A,
    second: B
}

fn make_pair<A, B>(a: A, b: B) -> Pair<A, B> = new Pair { first: a, second: b };

fn main() -> i64 = {
    let p1 = make_pair(10, 20);
    let _u1 = println(p1.first + p1.second);

    let p2 = make_pair(42, 100);
    let _u2 = println(p2.first + p2.second);

    0
};

// Golden Test: Merge Sort (bottom-up iterative version)
// Non-recursive merge sort using vec-based temp buffer

fn ms_min(a: i64, b: i64) -> i64 = if a < b { a } else { b };

// Merge arr[l..m) and arr[m..r) using temp buffer
fn ms_merge(arr: i64, temp: i64, l: i64, m: i64, r: i64) -> i64 = {
    let mut i = l;
    let mut j = m;
    let mut k = l;
    loop {
        if i >= m or j >= r { break } else { () };
        let _x = if vec_get(arr, i) <= vec_get(arr, j) {
            vec_set(temp, k, vec_get(arr, i));
            set i = i + 1;
            0
        } else {
            vec_set(temp, k, vec_get(arr, j));
            set j = j + 1;
            0
        };
        set k = k + 1;
    };
    loop {
        if i >= m { break } else { () };
        vec_set(temp, k, vec_get(arr, i));
        set i = i + 1;
        set k = k + 1;
    };
    loop {
        if j >= r { break } else { () };
        vec_set(temp, k, vec_get(arr, j));
        set j = j + 1;
        set k = k + 1;
    };
    // Copy back
    for idx in l..r {
        vec_set(arr, idx, vec_get(temp, idx));
    };
    0
};

// Bottom-up merge sort
fn merge_sort(arr: i64, n: i64) -> i64 = {
    let temp = vec_new();
    for _i in 0..n { vec_push(temp, 0) };
    let mut width = 1;
    loop {
        if width >= n { break } else { () };
        let mut l = 0;
        loop {
            if l >= n { break } else { () };
            let m = ms_min(l + width, n);
            let r = ms_min(l + 2 * width, n);
            let _mg = if m < r { ms_merge(arr, temp, l, m, r) } else { 0 };
            set l = l + 2 * width;
        };
        set width = width * 2;
    };
    vec_free(temp);
    0
};

fn print_arr(arr: i64, n: i64) -> i64 = {
    for i in 0..n { println(vec_get(arr, i)) };
    0
};

fn main() -> i64 = {
    // Test 1: Basic sort
    let a1 = vec_new();
    vec_push(a1, 38);
    vec_push(a1, 27);
    vec_push(a1, 43);
    vec_push(a1, 3);
    vec_push(a1, 9);
    vec_push(a1, 82);
    vec_push(a1, 10);
    let _s1 = merge_sort(a1, 7);
    let _p1 = print_arr(a1, 7);
    // 3 9 10 27 38 43 82

    // Test 2: Already sorted
    let a2 = vec_new();
    vec_push(a2, 1);
    vec_push(a2, 2);
    vec_push(a2, 3);
    let _s2 = merge_sort(a2, 3);
    let _p2 = print_arr(a2, 3);
    // 1 2 3

    // Test 3: Reverse sorted
    let a3 = vec_new();
    vec_push(a3, 5);
    vec_push(a3, 4);
    vec_push(a3, 3);
    vec_push(a3, 2);
    vec_push(a3, 1);
    let _s3 = merge_sort(a3, 5);
    let _p3 = print_arr(a3, 5);
    // 1 2 3 4 5

    // Test 4: Single element
    let a4 = vec_new();
    vec_push(a4, 42);
    let _s4 = merge_sort(a4, 1);
    let _p4 = print_arr(a4, 1);
    // 42

    // Test 5: Two elements
    let a5 = vec_new();
    vec_push(a5, 99);
    vec_push(a5, 11);
    let _s5 = merge_sort(a5, 2);
    let _p5 = print_arr(a5, 2);
    // 11 99

    // Test 6: Duplicates
    let a6 = vec_new();
    vec_push(a6, 5);
    vec_push(a6, 3);
    vec_push(a6, 5);
    vec_push(a6, 1);
    vec_push(a6, 3);
    let _s6 = merge_sort(a6, 5);
    let _p6 = print_arr(a6, 5);
    // 1 3 3 5 5

    vec_free(a1);
    vec_free(a2);
    vec_free(a3);
    vec_free(a4);
    vec_free(a5);
    vec_free(a6);
    0
};

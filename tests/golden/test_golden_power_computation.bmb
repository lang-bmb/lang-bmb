// Golden Test: Power/exponentiation patterns
// Naive power, fast power (binary exponentiation), modular exponentiation

// === Naive power (repeated multiplication) ===
fn naive_pow(base: i64, exp: i64) -> i64 = {
    let mut result = 1;
    for _i in 0..exp {
        set result = result * base
    };
    result
};

// === Fast power (binary exponentiation) ===
// O(log n) multiplications
fn fast_pow(base: i64, exp: i64) -> i64 = {
    let mut result = 1;
    let mut b = base;
    let mut e = exp;
    while e > 0 {
        let _c = if e % 2 == 1 {
            set result = result * b
        } else { () };
        set b = b * b;
        set e = e / 2
    };
    result
};

// === Modular exponentiation (a^b mod m) ===
// Uses binary exponentiation with modular reduction at each step
fn mod_pow(base: i64, exp: i64, modulus: i64) -> i64 = {
    let mut result = 1;
    let mut b = base % modulus;
    let mut e = exp;
    while e > 0 {
        let _c = if e % 2 == 1 {
            set result = (result * b) % modulus
        } else { () };
        set b = (b * b) % modulus;
        set e = e / 2
    };
    result
};

fn main() -> i64 = {
    // === Naive power tests ===
    println(naive_pow(2, 10));    // 1024
    println(naive_pow(3, 5));     // 243
    println(naive_pow(5, 0));     // 1
    println(naive_pow(1, 100));   // 1
    println(naive_pow(2, 1));     // 2

    // === Fast power tests ===
    println(fast_pow(2, 10));     // 1024
    println(fast_pow(3, 5));      // 243
    println(fast_pow(2, 20));     // 1048576
    println(fast_pow(5, 0));      // 1
    println(fast_pow(7, 4));      // 2401

    // === Verify naive == fast ===
    println(naive_pow(3, 7));     // 2187
    println(fast_pow(3, 7));      // 2187

    // === Modular exponentiation tests ===
    // 7^3 mod 13 = 343 mod 13 = 5
    println(mod_pow(7, 3, 13));   // 5
    // 2^10 mod 1000 = 1024 mod 1000 = 24
    println(mod_pow(2, 10, 1000)); // 24
    // 3^13 mod 7 = 1594323 mod 7
    // 3^1=3, 3^2=9%7=2, 3^4=2*2%7=4, 3^8=4*4%7=16%7=2
    // 3^13 = 3^8 * 3^4 * 3^1 = 2*4*3 = 24, 24%7 = 3
    println(mod_pow(3, 13, 7));   // 3
    // 10^9 mod 7 = ?
    // 10%7=3, 3^2=9%7=2, 3^4=4%7=4, 3^8=16%7=2
    // 3^9 = 3^8 * 3^1 = 2*3 = 6
    println(mod_pow(10, 9, 7));   // 6
    // 2^0 mod 5 = 1
    println(mod_pow(2, 0, 5));    // 1

    0
};

// Verification: JSON parser with multiple tail-recursive functions
// This is the exact pattern that was broken before IfElseToSwitch fix (99d49912)

fn J_NULL() -> i64 = 0;
fn J_BOOL() -> i64 = 1;
fn J_NUM() -> i64 = 2;
fn J_STR() -> i64 = 3;
fn J_ARR() -> i64 = 4;
fn J_OBJ() -> i64 = 5;

fn jdoc_new() -> i64 = vec_new();
fn dput(doc: i64, off: i64, val: i64) -> i64 = { let _s = vec_set(doc, off, val); 0 };
fn dget(doc: i64, off: i64) -> i64 = vec_get(doc, off);
fn dalloc(doc: i64, n: i64) -> i64 = {
    let off = vec_len(doc);
    let mut i: i64 = 0;
    while i < n { let _p = vec_push(doc, 0); set i = i + 1 };
    off
};

fn mk_null(doc: i64) -> i64 = { let o = dalloc(doc, 1); dput(doc, o, J_NULL()); o };
fn mk_bool(doc: i64, v: i64) -> i64 = { let o = dalloc(doc, 2); dput(doc, o, J_BOOL()); dput(doc, o + 1, v); o };
fn mk_num(doc: i64, v: i64) -> i64 = { let o = dalloc(doc, 2); dput(doc, o, J_NUM()); dput(doc, o + 1, v); o };
fn mk_str(doc: i64, s: i64, e: i64) -> i64 = { let o = dalloc(doc, 3); dput(doc, o, J_STR()); dput(doc, o + 1, s); dput(doc, o + 2, e); o };
fn mk_obj(doc: i64, cap: i64) -> i64 = { let o = dalloc(doc, 2 + cap * 3); dput(doc, o, J_OBJ()); dput(doc, o + 1, 0); o };
fn mk_arr(doc: i64, cap: i64) -> i64 = { let o = dalloc(doc, 2 + cap); dput(doc, o, J_ARR()); dput(doc, o + 1, 0); o };

fn jtype(doc: i64, n: i64) -> i64 = dget(doc, n);
fn jnum(doc: i64, n: i64) -> i64 = dget(doc, n + 1);
fn jobj_len(doc: i64, n: i64) -> i64 = dget(doc, n + 1);

fn jobj_add(doc: i64, n: i64, ks: i64, ke: i64, val: i64) -> i64 = {
    let c = dget(doc, n + 1);
    let _a = dput(doc, n + 2 + c * 3, ks);
    let _b = dput(doc, n + 2 + c * 3 + 1, ke);
    let _c = dput(doc, n + 2 + c * 3 + 2, val);
    let _d = dput(doc, n + 1, c + 1);
    0
};

fn jarr_push(doc: i64, n: i64, val: i64) -> i64 = {
    let c = dget(doc, n + 1);
    let _a = dput(doc, n + 2 + c, val);
    let _b = dput(doc, n + 1, c + 1);
    0
};

// TAIL-RECURSIVE: find key in object (original, not iterative workaround)
fn jobj_find(doc: i64, n: i64, key: String, src: String, idx: i64, cnt: i64) -> i64 =
    if idx >= cnt { 0 - 1 }
    else {
        let ks = dget(doc, n + 2 + idx * 3);
        let ke = dget(doc, n + 2 + idx * 3 + 1);
        let k = src.slice(ks, ke);
        if k == key { dget(doc, n + 2 + idx * 3 + 2) }
        else { jobj_find(doc, n, key, src, idx + 1, cnt) }
    };

fn jobj_get(doc: i64, n: i64, key: String, src: String) -> i64 =
    jobj_find(doc, n, key, src, 0, dget(doc, n + 1));

fn jstr(doc: i64, n: i64, src: String) -> String = {
    let s = dget(doc, n + 1);
    let e = dget(doc, n + 2);
    unescape(src.slice(s, e), 0, "")
};

// TAIL-RECURSIVE: unescape (original, not iterative workaround)
fn unescape(s: String, pos: i64, acc: String) -> String =
    if pos >= s.len() { acc }
    else if s.byte_at(pos) == 92 and pos + 1 < s.len() {
        let nx = s.byte_at(pos + 1);
        let ch = if nx == 110 { chr(10) } else if nx == 116 { chr(9) }
            else if nx == 114 { chr(13) } else if nx == 34 { chr(34) }
            else if nx == 92 { chr(92) } else { chr(nx) };
        unescape(s, pos + 2, acc + ch)
    }
    else { unescape(s, pos + 1, acc + chr(s.byte_at(pos))) };

// Parser helpers
fn pk(n: i64, p: i64) -> i64 = n * 1000000 + p;
fn rn(r: i64) -> i64 = r / 1000000;
fn rp(r: i64) -> i64 = r % 1000000;

fn wskip(src: String, p: i64) -> i64 =
    if p >= src.len() { p }
    else {
        let c = src.byte_at(p);
        if c == 32 or c == 9 or c == 10 or c == 13 { wskip(src, p + 1) }
        else { p }
    };

fn fq(src: String, p: i64) -> i64 =
    if p >= src.len() { p }
    else if src.byte_at(p) == 34 { p }
    else if src.byte_at(p) == 92 { fq(src, p + 2) }
    else { fq(src, p + 1) };

fn pstr(doc: i64, src: String, p: i64) -> i64 = {
    let s = p + 1;
    let e = fq(src, s);
    pk(mk_str(doc, s, e), e + 1)
};

fn pnum(doc: i64, src: String, p: i64) -> i64 = pnum_acc(doc, src, p, p);
fn pnum_acc(doc: i64, src: String, start: i64, p: i64) -> i64 =
    if p >= src.len() { pk(mk_num(doc, parse_int(src, start, p)), p) }
    else {
        let c = src.byte_at(p);
        if (c >= 48 and c <= 57) or c == 45 { pnum_acc(doc, src, start, p + 1) }
        else { pk(mk_num(doc, parse_int(src, start, p)), p) }
    };

fn parse_int(src: String, s: i64, e: i64) -> i64 = parse_int_acc(src, s, e, 0, 1);
fn parse_int_acc(src: String, s: i64, e: i64, acc: i64, sign: i64) -> i64 =
    if s >= e { acc * sign }
    else if src.byte_at(s) == 45 { parse_int_acc(src, s + 1, e, acc, 0 - 1) }
    else { parse_int_acc(src, s + 1, e, acc * 10 + src.byte_at(s) - 48, sign) };

fn pval(doc: i64, src: String, p: i64) -> i64 =
    if p >= src.len() { pk(mk_null(doc), p) }
    else {
        let c = src.byte_at(p);
        if c == 34 { pstr(doc, src, p) }
        else if c == 123 { pobj(doc, src, p) }
        else if c == 91 { parr(doc, src, p) }
        else if c == 116 { pk(mk_bool(doc, 1), p + 4) }
        else if c == 102 { pk(mk_bool(doc, 0), p + 5) }
        else if c == 110 { pk(mk_null(doc), p + 4) }
        else if c == 45 or (c >= 48 and c <= 57) { pnum(doc, src, p) }
        else { pk(mk_null(doc), p) }
    };

fn pobj(doc: i64, src: String, p: i64) -> i64 = {
    let obj = mk_obj(doc, 32);
    let p1 = wskip(src, p + 1);
    if p1 < src.len() and src.byte_at(p1) == 125 { pk(obj, p1 + 1) }
    else { pobj_ms(doc, src, p1, obj) }
};

// ORIGINAL pobj_ms — no _cnt workaround
fn pobj_ms(doc: i64, src: String, p: i64, obj: i64) -> i64 = {
    let ks = p + 1;
    let ke = fq(src, ks);
    let p1 = wskip(src, ke + 1);
    let p2 = wskip(src, p1 + 1);
    let vr = pval(doc, src, p2);
    let _oa = jobj_add(doc, obj, ks, ke, rn(vr));
    let p3 = wskip(src, rp(vr));
    if p3 >= src.len() { pk(obj, p3) }
    else if src.byte_at(p3) == 44 { pobj_ms(doc, src, wskip(src, p3 + 1), obj) }
    else { pk(obj, p3 + 1) }
};

fn parr(doc: i64, src: String, p: i64) -> i64 = {
    let arr = mk_arr(doc, 32);
    let p1 = wskip(src, p + 1);
    if p1 < src.len() and src.byte_at(p1) == 93 { pk(arr, p1 + 1) }
    else { parr_ms(doc, src, p1, arr) }
};

fn parr_ms(doc: i64, src: String, p: i64, arr: i64) -> i64 = {
    let vr = pval(doc, src, p);
    let _ap = jarr_push(doc, arr, rn(vr));
    let p1 = wskip(src, rp(vr));
    if p1 >= src.len() { pk(arr, p1) }
    else if src.byte_at(p1) == 44 { parr_ms(doc, src, wskip(src, p1 + 1), arr) }
    else { pk(arr, p1 + 1) }
};

fn jparse(doc: i64, src: String) -> i64 = {
    let r = pval(doc, src, wskip(src, 0));
    rn(r)
};

fn jobj_str(doc: i64, n: i64, key: String, src: String) -> String = {
    let v = jobj_get(doc, n, key, src);
    if v < 0 { "" } else { jstr(doc, v, src) }
};

fn jobj_num(doc: i64, n: i64, key: String, src: String) -> i64 = {
    let v = jobj_get(doc, n, key, src);
    if v < 0 { 0 } else { jnum(doc, v) }
};

fn main() -> i64 = {
    // Test 1: Simple 4-key object (the original failing case)
    let src1 = "{\"a\":\"1\",\"b\":\"2\",\"c\":\"3\",\"d\":\"4\"}";
    let doc1 = jdoc_new();
    let root1 = jparse(doc1, src1);
    let count1 = jobj_len(doc1, root1);
    println(count1);  // expect: 4

    // Test 2: Nested object with number value (the LSP failing case)
    let src2 = "{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"initialize\",\"params\":{\"capabilities\":{}}}";
    let doc2 = jdoc_new();
    let root2 = jparse(doc2, src2);
    let count2 = jobj_len(doc2, root2);
    println(count2);  // expect: 4

    let method = jobj_str(doc2, root2, "method", src2);
    let id_val = jobj_num(doc2, root2, "id", src2);
    println(id_val);     // expect: 1
    println(method.len());  // expect: 10 ("initialize")

    // Test 3: Array with mixed values
    let src3 = "[1,2,\"hello\",true,null]";
    let doc3 = jdoc_new();
    let root3 = jparse(doc3, src3);
    let arr_len = dget(doc3, root3 + 1);
    println(arr_len);  // expect: 5

    // Test 4: String with escapes
    let src4 = "{\"msg\":\"hello\\nworld\"}";
    let doc4 = jdoc_new();
    let root4 = jparse(doc4, src4);
    let msg = jobj_str(doc4, root4, "msg", src4);
    println(msg.len());  // expect: 11 (hello\nworld)

    0
};

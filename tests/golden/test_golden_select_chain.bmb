// Golden Test: Cascading select/branch patterns
// Tests if-to-select conversion with chained conditions

fn sign(x: i64) -> i64 =
    if x > 0 { 1 }
    else if x < 0 { 0 - 1 }
    else { 0 };

fn min3(a: i64, b: i64, c: i64) -> i64 =
    let m = if a < b { a } else { b };
    if m < c { m } else { c };

fn max3(a: i64, b: i64, c: i64) -> i64 =
    let m = if a > b { a } else { b };
    if m > c { m } else { c };

fn median3(a: i64, b: i64, c: i64) -> i64 =
    a + b + c - min3(a, b, c) - max3(a, b, c);

fn bounded_inc(x: i64, limit: i64) -> i64 =
    let next = x + 1;
    if next > limit { limit } else { next };

fn main() -> i64 = {
    println(sign(42));     // 1
    println(sign(-7));     // -1
    println(sign(0));      // 0
    println(min3(3, 1, 2));   // 1
    println(max3(3, 1, 2));   // 3
    println(median3(3, 1, 2)); // 2
    println(median3(5, 5, 5)); // 5
    println(bounded_inc(9, 10));  // 10
    println(bounded_inc(10, 10)); // 10
    println(bounded_inc(5, 10));  // 6
    0
    };

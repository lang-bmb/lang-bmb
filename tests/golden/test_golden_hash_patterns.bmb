// Golden Test: Hash-like patterns without external dependencies
// Tests hash computation, collision detection, distribution

fn simple_hash(n: i64, modulus: i64) -> i64 = {
    let mut h = 0;
    let mut x = if n < 0 { 0 - n } else { n };
    loop {
        if x == 0 { break } else { () };
        h = h * 31 + x - (x / 10) * 10;
        x = x / 10
    };
    if h < 0 { 0 - h - (0 - h / modulus) * modulus }
    else { h - (h / modulus) * modulus }
    };

fn xor_hash(a: i64, b: i64, c: i64) -> i64 =
    ((a * 2654435761) bxor (b * 2246822519)) bxor (c * 3266489917);

fn hash_combine(h1: i64, h2: i64) -> i64 =
    h1 bxor (h2 * 2654435761 + 2246822519 + (h1 * 64) + (h1 / 4));

fn djb2_step(hash: i64, ch: i64) -> i64 =
    hash * 33 + ch;

fn djb2_3chars(a: i64, b: i64, c: i64) -> i64 = {
    let h0 = 5381;
    let h1 = djb2_step(h0, a);
    let h2 = djb2_step(h1, b);
    djb2_step(h2, c)
    };

fn main() -> i64 = {
    let _p1 = println(simple_hash(12345, 100));
    let _p2 = println(simple_hash(54321, 100));
    let _p3 = println(simple_hash(12345, 1000));

// Test hash properties
    let h1 = xor_hash(1, 2, 3);
    let h2 = xor_hash(3, 2, 1);
    let _p4 = println(if h1 == h2 { 0 } else { 1 }); // 1 (order matters)

// Hash combine
    let c1 = hash_combine(42, 17);
    let c2 = hash_combine(17, 42);
    let _p5 = println(if c1 == c2 { 0 } else { 1 }); // 1 (order matters)

// DJB2
    let d1 = djb2_3chars(65, 66, 67); // ABC
    let d2 = djb2_3chars(67, 66, 65); // CBA
    let _p6 = println(if d1 == d2 { 0 } else { 1 }); // 1
    0
    };

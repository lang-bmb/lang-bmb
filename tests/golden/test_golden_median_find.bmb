// Golden Test: Finding median of unsorted array (selection-based)
// Uses quickselect-style partitioning to find k-th smallest element

fn swap(arr: i64, i: i64, j: i64) -> i64 = {
    let tmp = vec_get(arr, i);
    let _s1 = vec_set(arr, i, vec_get(arr, j));
    let _s2 = vec_set(arr, j, tmp);
    0
    };

// Partition around pivot at arr[hi], return pivot's final index
fn partition(arr: i64, lo: i64, hi: i64) -> i64 = {
    let pivot = vec_get(arr, hi);
    let mut store = lo;
    let mut i = lo;
    loop {
        if i >= hi { break } else { () };
        if vec_get(arr, i) < pivot {
            let _sw = swap(arr, i, store);
            store = store + 1
        } else { () };
        i = i + 1
    };
    let _sw = swap(arr, store, hi);
    store
    };

// Quickselect: find k-th smallest element (0-indexed)
fn quickselect(arr: i64, lo: i64, hi: i64, k: i64) -> i64 = {
    if lo == hi { return vec_get(arr, lo) } else { () };
    let pivot_idx = partition(arr, lo, hi);
    if k == pivot_idx { vec_get(arr, k) }
    else if k < pivot_idx { quickselect(arr, lo, pivot_idx - 1, k) }
    else { quickselect(arr, pivot_idx + 1, hi, k) }
    };

// Find median: middle element for odd length, lower-middle for even
fn find_median(arr: i64) -> i64 = {
    let n = vec_len(arr);
    quickselect(arr, 0, n - 1, (n - 1) / 2)
    };

fn kth_smallest(arr: i64, k: i64) -> i64 =
    quickselect(arr, 0, vec_len(arr) - 1, k);

fn main() -> i64 = {
    // Test 1: Odd-length [7, 2, 9, 1, 5] -> median = 5
    let a1 = vec_new();
    vec_push(a1, 7); vec_push(a1, 2); vec_push(a1, 9);
    vec_push(a1, 1); vec_push(a1, 5);
    let _p1 = println(find_median(a1));  // 5

    // Test 2: Even-length [8, 3, 6, 1, 4, 9] -> lower-mid = 4
    let a2 = vec_new();
    vec_push(a2, 8); vec_push(a2, 3); vec_push(a2, 6);
    vec_push(a2, 1); vec_push(a2, 4); vec_push(a2, 9);
    let _p2 = println(find_median(a2));  // 4

    // Test 3: Single element [42]
    let a3 = vec_new();
    vec_push(a3, 42);
    let _p3 = println(find_median(a3));  // 42

    // Test 4: Two elements [10, 3] -> index 0 = 3
    let a4 = vec_new();
    vec_push(a4, 10); vec_push(a4, 3);
    let _p4 = println(find_median(a4));  // 3

    // Test 5: k-th smallest [15, 3, 8, 12, 1, 20, 7] sorted=[1,3,7,8,12,15,20]
    let a5 = vec_new();
    vec_push(a5, 15); vec_push(a5, 3); vec_push(a5, 8);
    vec_push(a5, 12); vec_push(a5, 1); vec_push(a5, 20);
    vec_push(a5, 7);
    let _p5 = println(kth_smallest(a5, 0));  // 1

    let a6 = vec_new();
    vec_push(a6, 15); vec_push(a6, 3); vec_push(a6, 8);
    vec_push(a6, 12); vec_push(a6, 1); vec_push(a6, 20);
    vec_push(a6, 7);
    let _p6 = println(kth_smallest(a6, 6));  // 20

    let a7 = vec_new();
    vec_push(a7, 15); vec_push(a7, 3); vec_push(a7, 8);
    vec_push(a7, 12); vec_push(a7, 1); vec_push(a7, 20);
    vec_push(a7, 7);
    let _p7 = println(kth_smallest(a7, 2));  // 7

    // Test 6: All same [5, 5, 5, 5, 5]
    let a8 = vec_new();
    vec_push(a8, 5); vec_push(a8, 5); vec_push(a8, 5);
    vec_push(a8, 5); vec_push(a8, 5);
    let _p8 = println(find_median(a8));  // 5

    // Test 7: Descending [9, 7, 5, 3, 1] -> median = 5
    let a9 = vec_new();
    vec_push(a9, 9); vec_push(a9, 7); vec_push(a9, 5);
    vec_push(a9, 3); vec_push(a9, 1);
    let _p9 = println(find_median(a9));  // 5

    vec_free(a1); vec_free(a2); vec_free(a3); vec_free(a4);
    vec_free(a5); vec_free(a6); vec_free(a7); vec_free(a8);
    vec_free(a9);
    0
    };

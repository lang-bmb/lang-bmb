// Golden Test: Calendar calculations
// Day-of-week (Zeller's congruence), leap year, days-in-month

// Check if a year is a leap year
// Returns 1 if leap, 0 otherwise
fn is_leap_year(y: i64) -> i64 = {
    let div4 = y - (y / 4) * 4;
    let div100 = y - (y / 100) * 100;
    let div400 = y - (y / 400) * 400;
    if div400 == 0 { 1 }
    else if div100 == 0 { 0 }
    else if div4 == 0 { 1 }
    else { 0 }
    };

// Days in a given month (1-12) for a given year
fn days_in_month(m: i64, y: i64) -> i64 =
    if m == 2 {
        if is_leap_year(y) == 1 { 29 } else { 28 }
    }
    else if m == 4 or m == 6 or m == 9 or m == 11 { 30 }
    else { 31 };

// Zeller's congruence for day of week
// Returns 0=Saturday, 1=Sunday, 2=Monday, ..., 6=Friday
fn zeller(day: i64, month: i64, year: i64) -> i64 = {
    // Adjust month: Jan=13, Feb=14 of previous year
    let m = if month < 3 { month + 12 } else { month };
    let y = if month < 3 { year - 1 } else { year };
    let k = y - (y / 100) * 100;
    let j = y / 100;
    let h = day + (13 * (m + 1)) / 5 + k + k / 4 + j / 4 - 2 * j;
    // Proper modulo (handle negatives)
    let r = h - (h / 7) * 7;
    if r < 0 { r + 7 } else { r }
    };

// Convert Zeller result to ISO day-of-week (1=Mon, 7=Sun)
fn zeller_to_iso(z: i64) -> i64 = {
    // Zeller: 0=Sat, 1=Sun, 2=Mon, 3=Tue, 4=Wed, 5=Thu, 6=Fri
    // ISO:    6=Sat, 7=Sun, 1=Mon, 2=Tue, 3=Wed, 4=Thu, 5=Fri
    let table = vec_new();
    vec_push(table, 6);  // Sat
    vec_push(table, 7);  // Sun
    vec_push(table, 1);  // Mon
    vec_push(table, 2);  // Tue
    vec_push(table, 3);  // Wed
    vec_push(table, 4);  // Thu
    vec_push(table, 5);  // Fri
    let result = vec_get(table, z);
    vec_free(table);
    result
    };

// Count total days in a year
fn days_in_year(y: i64) -> i64 =
    if is_leap_year(y) == 1 { 366 } else { 365 };

// Day of year (1-based) for a given date
fn day_of_year(day: i64, month: i64, year: i64) -> i64 = {
    let mut total = 0;
    let mut m = 1;
    loop {
        if m >= month { break } else { () };
        total = total + days_in_month(m, year);
        m = m + 1
    };
    total + day
    };

// Count leap years from year 1 up to (but not including) year y
fn count_leaps(y: i64) -> i64 = {
    let n = y - 1;
    n / 4 - n / 100 + n / 400
    };

fn main() -> i64 = {
    // Leap year tests
    let _p1 = println(is_leap_year(2000));  // 1 (divisible by 400)
    let _p2 = println(is_leap_year(1900));  // 0 (divisible by 100 but not 400)
    let _p3 = println(is_leap_year(2024));  // 1 (divisible by 4)
    let _p4 = println(is_leap_year(2023));  // 0 (not divisible by 4)

    // Days in month
    let _p5 = println(days_in_month(2, 2024));  // 29 (leap year Feb)
    let _p6 = println(days_in_month(2, 2023));  // 28 (non-leap Feb)
    let _p7 = println(days_in_month(1, 2024));  // 31 (January)
    let _p8 = println(days_in_month(4, 2024));  // 30 (April)

    // Days in year
    let _p9 = println(days_in_year(2024));   // 366
    let _p10 = println(days_in_year(2023));  // 365

    // Day of year
    let _p11 = println(day_of_year(1, 1, 2024));    // 1 (Jan 1)
    let _p12 = println(day_of_year(1, 3, 2024));    // 61 (Mar 1 in leap year: 31+29+1)
    let _p13 = println(day_of_year(31, 12, 2024));  // 366 (Dec 31 in leap year)
    let _p14 = println(day_of_year(1, 3, 2023));    // 60 (Mar 1 non-leap: 31+28+1)

    // Zeller's congruence / day of week
    // 2024-01-01 = Monday (ISO 1)
    let z1 = zeller(1, 1, 2024);
    let _p15 = println(zeller_to_iso(z1));  // 1 (Monday)

    // 2000-01-01 = Saturday (ISO 6)
    let z2 = zeller(1, 1, 2000);
    let _p16 = println(zeller_to_iso(z2));  // 6 (Saturday)

    // 2023-12-25 = Monday (ISO 1)
    let z3 = zeller(25, 12, 2023);
    let _p17 = println(zeller_to_iso(z3));  // 1 (Monday)

    // 1970-01-01 = Thursday (ISO 4) — Unix epoch
    let z4 = zeller(1, 1, 1970);
    let _p18 = println(zeller_to_iso(z4));  // 4 (Thursday)

    // Count leap years up to year 2024
    let _p19 = println(count_leaps(2024));  // 490

    0
    };

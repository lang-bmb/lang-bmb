// Golden Test: Count inversions using merge sort
// An inversion is (i, j) where i < j but arr[i] > arr[j]

fn merge_count(arr: i64, tmp: i64, lo: i64, mid: i64, hi: i64) -> i64 = {
    let mut i = lo; let mut j = mid; let mut k = lo; let mut inv = 0;
    loop {
        if i >= mid or j >= hi { break } else { () };
        let ai = vec_get(arr, i); let aj = vec_get(arr, j);
        if ai <= aj { vec_set(tmp, k, ai); i = i + 1
        } else { vec_set(tmp, k, aj); inv = inv + (mid - i); j = j + 1 };
        k = k + 1
    };
    loop {
        if i >= mid { break } else { () };
        vec_set(tmp, k, vec_get(arr, i)); i = i + 1; k = k + 1
    };
    loop {
        if j >= hi { break } else { () };
        vec_set(tmp, k, vec_get(arr, j)); j = j + 1; k = k + 1
    };
    let mut p = lo;
    loop {
        if p >= hi { break } else { () };
        vec_set(arr, p, vec_get(tmp, p)); p = p + 1
    };
    inv
};

fn sort_count(arr: i64, tmp: i64, lo: i64, hi: i64) -> i64 = {
    if hi - lo <= 1 { return 0 } else { () };
    let mid = lo + (hi - lo) / 2;
    let left_inv = sort_count(arr, tmp, lo, mid);
    let right_inv = sort_count(arr, tmp, mid, hi);
    let cross_inv = merge_count(arr, tmp, lo, mid, hi);
    left_inv + right_inv + cross_inv
};

fn count_inversions(arr: i64) -> i64 = {
    let n = vec_len(arr);
    let tmp = vec_new();
    let mut i = 0;
    loop {
        if i >= n { break } else { () };
        vec_push(tmp, 0); i = i + 1
    };
    let result = sort_count(arr, tmp, 0, n);
    vec_free(tmp); result
};

// Brute force O(n^2) for verification
fn count_brute(arr: i64) -> i64 = {
    let n = vec_len(arr);
    let mut count = 0; let mut i = 0;
    loop {
        if i >= n { break } else { () };
        let mut j = i + 1;
        loop {
            if j >= n { break } else { () };
            if vec_get(arr, i) > vec_get(arr, j) { count = count + 1 } else { () };
            j = j + 1
        };
        i = i + 1
    };
    count
};

fn main() -> i64 = {
    // [2, 4, 1, 3, 5] -> 3 inversions
    let a1 = vec_new();
    vec_push(a1, 2); vec_push(a1, 4); vec_push(a1, 1);
    vec_push(a1, 3); vec_push(a1, 5);
    let _p1 = println(count_inversions(a1));  // 3

    // sorted -> 0
    let a2 = vec_new();
    vec_push(a2, 1); vec_push(a2, 2); vec_push(a2, 3);
    vec_push(a2, 4); vec_push(a2, 5);
    let _p2 = println(count_inversions(a2));  // 0

    // reverse sorted -> C(5,2) = 10
    let a3 = vec_new();
    vec_push(a3, 5); vec_push(a3, 4); vec_push(a3, 3);
    vec_push(a3, 2); vec_push(a3, 1);
    let _p3 = println(count_inversions(a3));  // 10

    // [1, 5, 3, 2, 4] -> 4
    let a4 = vec_new();
    vec_push(a4, 1); vec_push(a4, 5); vec_push(a4, 3);
    vec_push(a4, 2); vec_push(a4, 4);
    let _p4 = println(count_inversions(a4));  // 4

    // single element -> 0
    let a5 = vec_new(); vec_push(a5, 42);
    let _p5 = println(count_inversions(a5));  // 0

    // [2, 1] -> 1
    let a6 = vec_new(); vec_push(a6, 2); vec_push(a6, 1);
    let _p6 = println(count_inversions(a6));  // 1

    // [8, 4, 2, 1] -> 6
    let a7 = vec_new();
    vec_push(a7, 8); vec_push(a7, 4); vec_push(a7, 2); vec_push(a7, 1);
    let _p7 = println(count_inversions(a7));  // 6

    // brute force verification [3, 1, 2, 5, 4] -> 3
    let b = vec_new();
    vec_push(b, 3); vec_push(b, 1); vec_push(b, 2);
    vec_push(b, 5); vec_push(b, 4);
    let _p8 = println(count_brute(b));  // 3

    vec_free(a1); vec_free(a2); vec_free(a3); vec_free(a4);
    vec_free(a5); vec_free(a6); vec_free(a7); vec_free(b);
    0
};

// Golden Test: Motzkin Numbers
// M(n) = number of ways to draw non-crossing chords on n points on a circle
// Recurrence: M(n) = M(n-1) + sum(M(k)*M(n-2-k)) for k=0..n-2
// Or: M(n) = ((2n+1)*M(n-1) + 3*(n-1)*M(n-2)) / (n+2)
// M(0)=1, M(1)=1, M(2)=2, M(3)=4, M(4)=9, M(5)=21, M(6)=51, ...

// Motzkin via DP with convolution
fn motzkin_dp(n: i64) -> i64 = {
    let dp = [0; 25];
    set dp[0] = 1;
    set dp[1] = 1;
    let mut i = 2;
    loop {
        if i > n { break } else { () };
        // M(i) = M(i-1) + sum(M(k)*M(i-2-k)) for k=0..i-2
        set dp[i] = dp[i - 1];
        let mut k = 0;
        loop {
            if k > i - 2 { break } else { () };
            set dp[i] = dp[i] + dp[k] * dp[i - 2 - k];
            k = k + 1
        };
        i = i + 1
    };
    dp[n]
};

// Motzkin via the recurrence formula (integer arithmetic)
// M(n) = ((2n+1)*M(n-1) + 3*(n-1)*M(n-2)) / (n+2)
fn motzkin_rec(n: i64) -> i64 = {
    let m = [0; 25];
    set m[0] = 1;
    set m[1] = 1;
    let mut i = 2;
    loop {
        if i > n { break } else { () };
        set m[i] = ((2 * i + 1) * m[i - 1] + 3 * (i - 1) * m[i - 2]) / (i + 2);
        i = i + 1
    };
    m[n]
};

// Count Motzkin paths of length n (up, down, flat steps, never going below zero)
// This equals M(n)
fn motzkin_paths(n: i64) -> i64 = {
    motzkin_dp(n)
};

fn main() -> i64 = {
    // M(0) through M(6) via DP
    let _p1 = println(motzkin_dp(0));   // 1
    let _p2 = println(motzkin_dp(1));   // 1
    let _p3 = println(motzkin_dp(2));   // 2
    let _p4 = println(motzkin_dp(3));   // 4
    let _p5 = println(motzkin_dp(4));   // 9
    let _p6 = println(motzkin_dp(5));   // 21

    // M(6) and M(7) via recurrence formula
    let _p7 = println(motzkin_rec(6));  // 51
    let _p8 = println(motzkin_rec(7));  // 127

    // M(8) = 323
    let _p9 = println(motzkin_dp(8));   // 323

    // Verify DP and recurrence agree on M(10)
    let _p10 = println(motzkin_dp(10));  // 2188
    let _p11 = println(motzkin_rec(10)); // 2188

    // M(12) = 15511
    let _p12 = println(motzkin_dp(12));  // 15511

    0
};

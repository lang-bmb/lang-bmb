// Golden Test: Advanced array/vector patterns
// Fill, sum, min, max, reverse, bubble sort, binary search, count, prefix sum

// Helper: create vec from 8 values
fn make_vec8(a: i64, b: i64, c: i64, d: i64, e: i64, f: i64, g: i64, h: i64) -> i64 = {
    let v = vec_new();
    let _p1 = vec_push(v, a);
    let _p2 = vec_push(v, b);
    let _p3 = vec_push(v, c);
    let _p4 = vec_push(v, d);
    let _p5 = vec_push(v, e);
    let _p6 = vec_push(v, f);
    let _p7 = vec_push(v, g);
    let _p8 = vec_push(v, h);
    v
    };

fn make_vec6(a: i64, b: i64, c: i64, d: i64, e: i64, f: i64) -> i64 = {
    let v = vec_new();
    let _p1 = vec_push(v, a);
    let _p2 = vec_push(v, b);
    let _p3 = vec_push(v, c);
    let _p4 = vec_push(v, d);
    let _p5 = vec_push(v, e);
    let _p6 = vec_push(v, f);
    v
    };

fn make_vec9(a: i64, b: i64, c: i64, d: i64, e: i64, f: i64, g: i64, h: i64, i: i64) -> i64 = {
    let v = vec_new();
    let _p1 = vec_push(v, a);
    let _p2 = vec_push(v, b);
    let _p3 = vec_push(v, c);
    let _p4 = vec_push(v, d);
    let _p5 = vec_push(v, e);
    let _p6 = vec_push(v, f);
    let _p7 = vec_push(v, g);
    let _p8 = vec_push(v, h);
    let _p9 = vec_push(v, i);
    v
    };

fn make_vec5(a: i64, b: i64, c: i64, d: i64, e: i64) -> i64 = {
    let v = vec_new();
    let _p1 = vec_push(v, a);
    let _p2 = vec_push(v, b);
    let _p3 = vec_push(v, c);
    let _p4 = vec_push(v, d);
    let _p5 = vec_push(v, e);
    v
    };

// Sum all elements
fn arr_sum(v: i64, pos: i64, acc: i64) -> i64 =
    if pos >= vec_len(v) { acc }
    else { arr_sum(v, pos + 1, acc + vec_get(v, pos)) };

// Find minimum
fn arr_min(v: i64, pos: i64, best: i64) -> i64 =
    if pos >= vec_len(v) { best }
    else {
        let nb = if vec_get(v, pos) < best { vec_get(v, pos) } else { best };
        arr_min(v, pos + 1, nb)
    };

// Find maximum
fn arr_max(v: i64, pos: i64, best: i64) -> i64 =
    if pos >= vec_len(v) { best }
    else {
        let nb = if vec_get(v, pos) > best { vec_get(v, pos) } else { best };
        arr_max(v, pos + 1, nb)
    };

// Reverse array in-place
fn arr_swap(v: i64, i: i64, j: i64) -> i64 = {
    let tmp = vec_get(v, i);
    let _s1 = vec_set(v, i, vec_get(v, j));
    let _s2 = vec_set(v, j, tmp);
    0
    };

fn arr_reverse(v: i64, lo: i64, hi: i64) -> i64 =
    if lo >= hi { 0 }
    else {
        let _sw = arr_swap(v, lo, hi);
        arr_reverse(v, lo + 1, hi - 1)
    };

// Bubble sort
fn bubble_pass(v: i64, j: i64, limit: i64) -> i64 =
    if j >= limit { 0 }
    else {
        let _sw = if vec_get(v, j) > vec_get(v, j + 1) { arr_swap(v, j, j + 1) } else { 0 };
        bubble_pass(v, j + 1, limit)
    };

fn bubble_sort(v: i64, i: i64) -> i64 = {
    let n = vec_len(v);
    if i >= n - 1 { 0 }
    else {
        let _bp = bubble_pass(v, 0, n - 1 - i);
        bubble_sort(v, i + 1)
    }
    };

// Binary search (sorted array)
fn bin_search(v: i64, target: i64, lo: i64, hi: i64) -> i64 =
    if lo > hi { 0 - 1 }
    else {
        let mid = lo + (hi - lo) / 2;
        if vec_get(v, mid) == target { mid }
        else if vec_get(v, mid) < target { bin_search(v, target, mid + 1, hi) }
        else { bin_search(v, target, lo, mid - 1) }
    };

// Count elements greater than threshold
fn count_gt(v: i64, pos: i64, thresh: i64, count: i64) -> i64 =
    if pos >= vec_len(v) { count }
    else {
        let inc = if vec_get(v, pos) > thresh { 1 } else { 0 };
        count_gt(v, pos + 1, thresh, count + inc)
    };

// Prefix sum: store running totals in result vec
fn prefix_sum(src: i64, result: i64, pos: i64, running: i64) -> i64 =
    if pos >= vec_len(src) { 0 }
    else {
        let new_running = running + vec_get(src, pos);
        let _s = vec_set(result, pos, new_running);
        prefix_sum(src, result, pos + 1, new_running)
    };

fn make_zeros(n: i64) -> i64 = {
    let v = vec_new();
    for _i in 0..n { let _p = vec_push(v, 0); 0 };
    v
    };

fn main() -> i64 = {
    // Create array [3, 7, 1, 9, 2, 8, 4, 6] and compute sum, min, max
    let data = make_vec8(3, 7, 1, 9, 2, 8, 4, 6);
    let _p1 = println(arr_sum(data, 0, 0));          // 40
    let _p2 = println(arr_min(data, 0, 999));         // 1
    let _p3 = println(arr_max(data, 0, 0));           // 9

    // Reverse [3,7,1,9,2,8,4,6] -> [6,4,8,2,9,1,7,3]
    let rev_arr = make_vec8(3, 7, 1, 9, 2, 8, 4, 6);
    let _rv = arr_reverse(rev_arr, 0, 7);
    let _p4 = println(vec_get(rev_arr, 0));           // 6
    let _p5 = println(vec_get(rev_arr, 3));           // 2
    let _p6 = println(vec_get(rev_arr, 7));           // 3

    // Bubble sort [5, 2, 8, 1, 9, 3] -> [1, 2, 3, 5, 8, 9]
    let to_sort = make_vec6(5, 2, 8, 1, 9, 3);
    let _bs = bubble_sort(to_sort, 0);
    let _p7 = println(vec_get(to_sort, 0));           // 1
    let _p8 = println(vec_get(to_sort, 2));           // 3
    let _p9 = println(vec_get(to_sort, 5));           // 9

    // Binary search on sorted [1,2,3,4,5,6,7,8,9]
    let sorted = make_vec9(1, 2, 3, 4, 5, 6, 7, 8, 9);
    let _p10 = println(bin_search(sorted, 5, 0, 8));  // 4
    let _p11 = println(bin_search(sorted, 1, 0, 8));  // 0
    let _p12 = println(bin_search(sorted, 9, 0, 8));  // 8
    let _p13 = println(bin_search(sorted, 10, 0, 8)); // -1

    // Count elements > 5 in [3,7,1,9,2,8,4,6]
    let _p14 = println(count_gt(data, 0, 5, 0));      // 4  (7, 9, 8, 6)

    // Prefix sum of [1, 2, 3, 4, 5]
    let ps_src = make_vec5(1, 2, 3, 4, 5);
    let ps_result = make_zeros(5);
    let _ps = prefix_sum(ps_src, ps_result, 0, 0);
    let _p15 = println(vec_get(ps_result, 0));         // 1
    let _p16 = println(vec_get(ps_result, 2));         // 6
    let _p17 = println(vec_get(ps_result, 4));         // 15

    let _f1 = vec_free(data);
    let _f2 = vec_free(rev_arr);
    let _f3 = vec_free(to_sort);
    let _f4 = vec_free(sorted);
    let _f5 = vec_free(ps_src);
    let _f6 = vec_free(ps_result);
    0
    };

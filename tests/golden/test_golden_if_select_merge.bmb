// Golden Test: if-to-select preserves merge labels for downstream phis
// Verifies nested if-else chains with string comparisons produce correct select cascades
// Bug: if-to-select eliminated merge labels, UBE removed downstream phi edges

fn check_goto(n_pure: i64, max_pure: i64, goto_target: String, goto_tgt: String, next_p: i64) -> i64 =
    if n_pure > max_pure { 0 }
    else if goto_target == "" { next_p }
    else if goto_tgt == goto_target { next_p }
    else { 0 };

    // Nested if-else with integer comparisons (simpler case)

fn nested_int(a: i64, b: i64, c: i64) -> i64 =
    if a > 10 { 100 }
    else if b > 20 { 200 }
    else if c > 30 { 300 }
    else { 0 };

    // Four-level nesting

fn deep_nest(x: i64) -> i64 =
    if x > 100 { 1 }
    else if x > 50 { 2 }
    else if x > 25 { 3 }
    else if x > 10 { 4 }
    else { 5 };

fn main() -> i64 = {
// check_goto tests
    let _p1 = println(check_goto(0, 3, "", "merge", 42));        // 42 (goto_target == "")
    let _p2 = println(check_goto(5, 3, "", "merge", 42));        // 0  (n_pure > max_pure)
    let _p3 = println(check_goto(0, 3, "merge", "merge", 99));   // 99 (goto_tgt == goto_target)
    let _p4 = println(check_goto(0, 3, "merge", "other", 99));   // 0  (no match)

// nested_int tests
    let _p5 = println(nested_int(15, 5, 5));    // 100 (a > 10)
    let _p6 = println(nested_int(5, 25, 5));    // 200 (b > 20)
    let _p7 = println(nested_int(5, 5, 35));    // 300 (c > 30)
    let _p8 = println(nested_int(5, 5, 5));     // 0   (none)

// deep_nest tests
    let _p9 = println(deep_nest(150));   // 1
    let _p10 = println(deep_nest(75));   // 2
    let _p11 = println(deep_nest(30));   // 3
    let _p12 = println(deep_nest(15));   // 4
    let _p13 = println(deep_nest(5));    // 5
    0
    };

// Golden test: Probability and statistics simulation patterns
// Uses deterministic pseudo-random via LCG and integer-scaled arithmetic

// Helper: create vec and push values
fn make_vec(a: i64, b: i64, c: i64, d: i64, e: i64, f: i64, g: i64, h: i64) -> i64 = {
    let v = vec_new();
    let _p1 = vec_push(v, a);
    let _p2 = vec_push(v, b);
    let _p3 = vec_push(v, c);
    let _p4 = vec_push(v, d);
    let _p5 = vec_push(v, e);
    let _p6 = vec_push(v, f);
    let _p7 = vec_push(v, g);
    let _p8 = vec_push(v, h);
    v
    };

fn make_vec5(a: i64, b: i64, c: i64, d: i64, e: i64) -> i64 = {
    let v = vec_new();
    let _p1 = vec_push(v, a);
    let _p2 = vec_push(v, b);
    let _p3 = vec_push(v, c);
    let _p4 = vec_push(v, d);
    let _p5 = vec_push(v, e);
    v
    };

fn make_vec10(a: i64, b: i64, c: i64, d: i64, e: i64,
              f: i64, g: i64, h: i64, i: i64, j: i64) -> i64 = {
    let v = vec_new();
    let _p1 = vec_push(v, a);
    let _p2 = vec_push(v, b);
    let _p3 = vec_push(v, c);
    let _p4 = vec_push(v, d);
    let _p5 = vec_push(v, e);
    let _p6 = vec_push(v, f);
    let _p7 = vec_push(v, g);
    let _p8 = vec_push(v, h);
    let _p9 = vec_push(v, i);
    let _p10 = vec_push(v, j);
    v
    };

fn make_zeros(n: i64) -> i64 = {
    let v = vec_new();
    for _i in 0..n {
        let _p = vec_push(v, 0);
        0
    };
    v
    };

// Sum all elements
fn arr_sum(arr: i64, pos: i64, acc: i64) -> i64 =
    if pos >= vec_len(arr) { acc }
    else { arr_sum(arr, pos + 1, acc + vec_get(arr, pos)) };

// Mean (integer division): sum / n
fn mean(arr: i64) -> i64 = {
    let s = arr_sum(arr, 0, 0);
    s / vec_len(arr)
    };

// Variance (integer-scaled): sum of (x_i - mean)^2 / n
fn variance_helper(arr: i64, pos: i64, m: i64, acc: i64) -> i64 =
    if pos >= vec_len(arr) { acc }
    else {
        let diff = vec_get(arr, pos) - m;
        variance_helper(arr, pos + 1, m, acc + diff * diff)
    };

fn variance(arr: i64) -> i64 = {
    let m = mean(arr);
    let sum_sq = variance_helper(arr, 0, m, 0);
    sum_sq / vec_len(arr)
    };

// Integer square root via Newton's method
fn isqrt(n: i64) -> i64 =
    if n <= 0 { 0 }
    else { isqrt_iter(n, n) };

fn isqrt_iter(n: i64, guess: i64) -> i64 = {
    let next = (guess + n / guess) / 2;
    if next >= guess { guess }
    else { isqrt_iter(n, next) }
    };

// Standard deviation approximation (isqrt of variance)
fn stddev(arr: i64) -> i64 = isqrt(variance(arr));

// Histogram: count occurrences of each value in [0..max_val)
// Returns a vec of counts
fn histogram_fill(arr: i64, hist: i64, pos: i64) -> i64 =
    if pos >= vec_len(arr) { 0 }
    else {
        let val = vec_get(arr, pos);
        let old = vec_get(hist, val);
        let _s = vec_set(hist, val, old + 1);
        histogram_fill(arr, hist, pos + 1)
    };

fn histogram(arr: i64, num_bins: i64) -> i64 = {
    let hist = make_zeros(num_bins);
    let _f = histogram_fill(arr, hist, 0);
    hist
    };

// Selection sort for median computation
fn find_min_idx(arr: i64, pos: i64, best_idx: i64, best_val: i64) -> i64 =
    if pos >= vec_len(arr) { best_idx }
    else if vec_get(arr, pos) < best_val { find_min_idx(arr, pos + 1, pos, vec_get(arr, pos)) }
    else { find_min_idx(arr, pos + 1, best_idx, best_val) };

fn arr_swap(arr: i64, i: i64, j: i64) -> i64 = {
    let tmp = vec_get(arr, i);
    let _s1 = vec_set(arr, i, vec_get(arr, j));
    let _s2 = vec_set(arr, j, tmp);
    0
    };

fn selection_sort(arr: i64, pos: i64) -> i64 =
    if pos >= vec_len(arr) - 1 { 0 }
    else {
        let mi = find_min_idx(arr, pos, pos, vec_get(arr, pos));
        let _sw = if mi != pos { arr_swap(arr, pos, mi) } else { 0 };
        selection_sort(arr, pos + 1)
    };

// Copy array
fn copy_arr(src: i64, dst: i64, pos: i64) -> i64 =
    if pos >= vec_len(src) { 0 }
    else {
        let _s = vec_set(dst, pos, vec_get(src, pos));
        copy_arr(src, dst, pos + 1)
    };

// Median: middle element of sorted array
fn median(arr: i64) -> i64 = {
    let n = vec_len(arr);
    let tmp = make_zeros(n);
    let _c = copy_arr(arr, tmp, 0);
    let _ss = selection_sort(tmp, 0);
    let result = vec_get(tmp, n / 2);
    let _f = vec_free(tmp);
    result
    };

// Mode: most frequent element
fn mode_scan(arr: i64, pos: i64, best_val: i64, best_count: i64, cur_val: i64, cur_count: i64) -> i64 =
    if pos >= vec_len(arr) {
        if cur_count > best_count { cur_val } else { best_val }
    }
    else if vec_get(arr, pos) == cur_val {
        mode_scan(arr, pos + 1, best_val, best_count, cur_val, cur_count + 1)
    }
    else {
        let nb_val = if cur_count > best_count { cur_val } else { best_val };
        let nb_cnt = if cur_count > best_count { cur_count } else { best_count };
        mode_scan(arr, pos + 1, nb_val, nb_cnt, vec_get(arr, pos), 1)
    };

// Mode requires sorted input
fn mode(arr: i64) -> i64 = {
    let n = vec_len(arr);
    let tmp = make_zeros(n);
    let _c = copy_arr(arr, tmp, 0);
    let _ss = selection_sort(tmp, 0);
    let result = mode_scan(tmp, 1, vec_get(tmp, 0), 1, vec_get(tmp, 0), 1);
    let _f = vec_free(tmp);
    result
    };

// Percentile: value at index floor(p * n / 100) in sorted array
fn percentile(arr: i64, p: i64) -> i64 = {
    let n = vec_len(arr);
    let tmp = make_zeros(n);
    let _c = copy_arr(arr, tmp, 0);
    let _ss = selection_sort(tmp, 0);
    let idx = p * n / 100;
    // Clamp to valid range
    let safe_idx = if idx >= n { n - 1 } else { idx };
    let result = vec_get(tmp, safe_idx);
    let _f = vec_free(tmp);
    result
    };

// LCG pseudo-random: (seed * 1103515245 + 12345) mod 2^31
fn lcg_next(seed: i64) -> i64 = {
    let raw = seed * 1103515245 + 12345;
    // Take lower 31 bits
    let mask = 2147483647;  // 2^31 - 1
    raw band mask
    };

// Generate n pseudo-random values in [0, bound)
fn gen_random_arr(n: i64, seed: i64, bound: i64) -> i64 = {
    let v = vec_new();
    let mut s = seed;
    for _i in 0..n {
        s = lcg_next(s);
        let val = s - (s / bound) * bound;
        // Ensure non-negative
        let safe_val = if val < 0 { 0 - val } else { val };
        let _p = vec_push(v, safe_val);
        0
    };
    v
    };

fn main() -> i64 = {
    // Test 1: Mean of [10, 20, 30, 40, 50] = 150/5 = 30
    let a1 = make_vec5(10, 20, 30, 40, 50);
    let _p1 = println(mean(a1));  // 30

    // Test 2: Mean of [3, 7, 2, 8, 5, 1, 9, 4] = 39/8 = 4
    let a2 = make_vec(3, 7, 2, 8, 5, 1, 9, 4);
    let _p2 = println(mean(a2));  // 4

    // Test 3: Variance of [10, 20, 30, 40, 50]
    // mean=30, diffs: -20,-10,0,10,20, sq: 400,100,0,100,400, sum=1000, var=200
    let _p3 = println(variance(a1));  // 200

    // Test 4: Variance of [3, 7, 2, 8, 5, 1, 9, 4]
    // mean=4 (integer), diffs: -1,3,-2,4,1,-3,5,0
    // sq: 1,9,4,16,1,9,25,0 = 65, var=65/8=8
    let _p4 = println(variance(a2));  // 8

    // Test 5: Stddev of [10, 20, 30, 40, 50] = isqrt(200) = 14
    let _p5 = println(stddev(a1));  // 14

    // Test 6: Stddev of [3, 7, 2, 8, 5, 1, 9, 4] = isqrt(8) = 2
    let _p6 = println(stddev(a2));  // 2

    // Test 7: isqrt correctness
    let _p7 = println(isqrt(0));    // 0
    let _p8 = println(isqrt(1));    // 1
    let _p9 = println(isqrt(100));  // 10
    let _p10 = println(isqrt(50));  // 7

    // Test 8: Histogram of [0,1,2,1,0,1,2,2] with 3 bins
    // bin0=2, bin1=3, bin2=3
    let a3 = make_vec(0, 1, 2, 1, 0, 1, 2, 2);
    let h = histogram(a3, 3);
    let _p11 = println(vec_get(h, 0));  // 2
    let _p12 = println(vec_get(h, 1));  // 3
    let _p13 = println(vec_get(h, 2));  // 3

    // Test 9: Median of [3, 7, 2, 8, 5]
    // sorted: [2,3,5,7,8], n=5, median at index 2 = 5
    let a4 = make_vec5(3, 7, 2, 8, 5);
    let _p14 = println(median(a4));  // 5

    // Test 10: Median of [10, 20, 30, 40, 50, 60, 70, 80]
    // sorted, n=8, median at index 4 = 50
    let a5 = make_vec(10, 20, 30, 40, 50, 60, 70, 80);
    let _p15 = println(median(a5));  // 50

    // Test 11: Mode of [1, 2, 2, 3, 3, 3, 4, 4]
    // sorted: [1,2,2,3,3,3,4,4], mode = 3 (appears 3 times)
    let a6 = make_vec(1, 2, 2, 3, 3, 3, 4, 4);
    let _p16 = println(mode(a6));  // 3

    // Test 12: Mode of [5, 5, 5, 1, 1, 2, 2, 2]
    // sorted: [1,1,2,2,2,5,5,5], mode = 5 (tie: 2 and 5 both appear 3 times, last tie wins)
    // Actually: scan left to right: 1(2), 2(3), 5(3) -> 5 wins (cur_count > best_count? 3>3 = no)
    // So best stays 2. Let me retrace:
    // pos=0: val=1, cur_val=1, cur_count=1, best_val=1, best_count=1
    // Wait, mode_scan starts at pos=1 with best_val=arr[0], best_count=1, cur_val=arr[0], cur_count=1
    // sorted: [1,1,2,2,2,5,5,5]
    // pos=1: val=1==cur_val=1, cur_count=2
    // pos=2: val=2!=1, cur_count=2>1=best_count -> best_val=1, best_count=2, cur_val=2, cur_count=1
    // pos=3: val=2==2, cur_count=2
    // pos=4: val=2==2, cur_count=3
    // pos=5: val=5!=2, cur_count=3>2=best_count -> best_val=2, best_count=3, cur_val=5, cur_count=1
    // pos=6: val=5==5, cur_count=2
    // pos=7: val=5==5, cur_count=3
    // end: cur_count=3 > best_count=3? no -> best_val=2
    let a7 = make_vec(5, 5, 5, 1, 1, 2, 2, 2);
    let _p17 = println(mode(a7));  // 2

    // Test 13: Percentile of [10, 20, 30, 40, 50] at p=50
    // sorted, idx = 50*5/100 = 2, value = 30
    let _p18 = println(percentile(a1, 50));  // 30

    // Test 14: Percentile at p=90 of [10, 20, 30, 40, 50]
    // idx = 90*5/100 = 4, value = 50
    let _p19 = println(percentile(a1, 90));  // 50

    // Test 15: Percentile at p=10 of [10, 20, 30, 40, 50]
    // idx = 10*5/100 = 0, value = 10
    let _p20 = println(percentile(a1, 10));  // 10

    // Test 16: LCG determinism check
    let s1 = lcg_next(42);
    let s2 = lcg_next(s1);
    // s1 = (42 * 1103515245 + 12345) mod 2^31
    //    = 46347637335 band 2147483647
    //    = 46347637335 mod 2147483648
    //    = 46347637335 - 21 * 2147483648 = 46347637335 - 45097156608 = 1250480727
    let _p21 = println(s1);  // 1250480727

    // s2 = (1250480727 * 1103515245 + 12345) band 2147483647
    //    = 1379885698868888 band 2147483647
    // Wait: 1250480727 * 1103515245 = ?
    // This is a large multiplication. Let's compute:
    // Actually on i64 this doesn't overflow. But band with 2^31-1:
    // 1250480727 * 1103515245 = let me compute step by step:
    // 1250480727 * 1103515245
    // = 1250480727 * 1100000000 + 1250480727 * 3515245
    // = 1375528799700000000 + 4395668934815
    // = 1375533195368934815
    // + 12345 = 1375533195368947160
    // band 2147483647 (i.e., mod 2147483648):
    // 1375533195368947160 / 2147483648 = 640,412,XXX...
    // Let me just trust the computation at runtime. I'll use a simpler seed.
    // Actually let me just generate random array and check sum for determinism
    let rng_arr = gen_random_arr(5, 1, 100);
    // seed=1: s = lcg_next(1) = (1*1103515245 + 12345) band 2147483647
    //       = 1103527590 band 2147483647 = 1103527590
    //       val = 1103527590 mod 100 = 1103527590 - 11035275*100 = 1103527590-1103527500=90
    // s2 = lcg_next(1103527590) = (1103527590*1103515245+12345) band 2147483647
    //    = big number band 2147483647 ... this is getting complex. Let me just verify with run.
    // I'll use sum of the array as a determinism check: same seed = same result
    let rng_arr2 = gen_random_arr(5, 1, 100);
    let sum1 = arr_sum(rng_arr, 0, 0);
    let sum2 = arr_sum(rng_arr2, 0, 0);
    let _p22 = println(if sum1 == sum2 { 1 } else { 0 });  // 1 (deterministic)

    let _f1 = vec_free(a1);
    let _f2 = vec_free(a2);
    let _f3 = vec_free(a3);
    let _f4 = vec_free(h);
    let _f5 = vec_free(a4);
    let _f6 = vec_free(a5);
    let _f7 = vec_free(a6);
    let _f8 = vec_free(a7);
    let _f9 = vec_free(rng_arr);
    let _f10 = vec_free(rng_arr2);
    0
    };

// Golden Test: Catalan numbers via DP + parenthesization counting
// C(n) = sum(C(i) * C(n-1-i)) for i in 0..n, C(0) = 1
// Applications: valid parenthesizations, BST counts, polygon triangulations

// Catalan number via DP with flat array
fn catalan_dp(n: i64) -> i64 = {
    let dp = [0; 25];
    set dp[0] = 1;
    set dp[1] = 1;
    for i in 2..n + 1 {
        let mut sum = 0;
        for j in 0..i {
            sum = sum + dp[j] * dp[i - 1 - j];
        };
        set dp[i] = sum;
    };
    dp[n]
};

// Number of ways to parenthesize n+1 factors
// Same as Catalan(n), but computed independently to verify
fn parenthesizations(n: i64) -> i64 = {
    if n <= 1 { return 1 } else { () };
    let mut total = 0;
    for k in 0..n {
        total = total + parenthesizations(k) * parenthesizations(n - 1 - k);
    };
    total
};

// Binomial coefficient via Pascal's triangle
fn binomial(n: i64, k: i64) -> i64 = {
    if k > n { return 0 } else { () };
    if k == 0 { return 1 } else { () };
    if k == n { return 1 } else { () };
    let row = [0; 30];
    set row[0] = 1;
    for i in 1..n + 1 {
        let mut j = i;
        loop {
            if j < 1 { break } else { () };
            set row[j] = row[j] + row[j - 1];
            j = j - 1
        };
    };
    row[k]
};

fn catalan_via_binomial(n: i64) -> i64 =
    binomial(2 * n, n) / (n + 1);

// Number of polygon triangulations for (n+2)-gon = C(n)
fn polygon_triangulations(sides: i64) -> i64 =
    catalan_dp(sides - 2);

// Generate and sum first n+1 Catalan numbers
fn catalan_prefix_sum(n: i64) -> i64 = {
    let mut sum = 0;
    for i in 0..n + 1 {
        sum = sum + catalan_dp(i);
    };
    sum
};

// Recurrence: S(n) = 3*S(n-1) - S(n-2) with S(0)=1, S(1)=1, S(2)=2
fn schroeder_seq(n: i64) -> i64 = {
    if n <= 0 { return 1 } else { () };
    if n == 1 { return 1 } else { () };
    if n == 2 { return 2 } else { () };
    let dp = [0; 20];
    set dp[0] = 1;
    set dp[1] = 1;
    set dp[2] = 2;
    for i in 3..n + 1 {
        set dp[i] = 3 * dp[i - 1] - dp[i - 2];
    };
    dp[n]
};

// Narayana number N(n,k) = C(n,k) * C(n,k-1) / n
// Counts Dyck paths with exactly k peaks
fn narayana(n: i64, k: i64) -> i64 = {
    if n == 0 { return 1 } else { () };
    if k == 0 { return 0 } else { () };
    if k > n { return 0 } else { () };
    binomial(n, k) * binomial(n, k - 1) / n
};

// Sum of Narayana(n,k) for k=1..n should equal C(n)
fn narayana_sum(n: i64) -> i64 = {
    if n == 0 { return 1 } else { () };
    let mut sum = 0;
    for k in 1..n + 1 {
        sum = sum + narayana(n, k);
    };
    sum
};

fn main() -> i64 = {
    // Catalan numbers: 1, 1, 2, 5, 14, 42, 132, 429, 1430, 4862
    let _p1 = println(catalan_dp(0));
    let _p2 = println(catalan_dp(1));
    let _p3 = println(catalan_dp(2));
    let _p4 = println(catalan_dp(3));
    let _p5 = println(catalan_dp(4));
    let _p6 = println(catalan_dp(5));
    let _p7 = println(catalan_dp(6));
    let _p8 = println(catalan_dp(7));
    let _p9 = println(catalan_dp(8));
    let _p10 = println(catalan_dp(9));

    // Verify parenthesizations match catalan
    let _p11 = println(parenthesizations(4));
    let _p12 = println(parenthesizations(5));

    // Catalan via binomial: C(2n,n)/(n+1)
    let _p13 = println(catalan_via_binomial(4));
    let _p14 = println(catalan_via_binomial(6));

    // Polygon triangulations: (n+2)-gon -> C(n)
    let _p15 = println(polygon_triangulations(5));
    let _p16 = println(polygon_triangulations(6));
    let _p17 = println(polygon_triangulations(8));

    // Prefix sums of Catalan numbers
    let _p18 = println(catalan_prefix_sum(4));
    let _p19 = println(catalan_prefix_sum(6));

    // Schroeder sequence: S(0)=1,S(1)=1,S(2)=2,S(3)=5,S(4)=13,S(5)=34
    let _p20 = println(schroeder_seq(3));
    let _p21 = println(schroeder_seq(4));
    let _p22 = println(schroeder_seq(5));

    // Narayana numbers N(4,k) for k=1..4
    let _p23 = println(narayana(4, 1));
    let _p24 = println(narayana(4, 2));
    let _p25 = println(narayana(4, 3));
    let _p26 = println(narayana(4, 4));

    // Verify: sum of N(n,k) = C(n)
    let _p27 = println(narayana_sum(4));
    let _p28 = println(narayana_sum(5));
    let _p29 = println(narayana_sum(6));

    0
};

// Golden Test: Matrix inverse-related computations
// Adjugate, cofactors, and verify A * adj(A) = det(A) * I for 2x2

// 2x2 determinant
fn det2(a: i64, b: i64, c: i64, d: i64) -> i64 = a * d - b * c;

// 2x2 adjugate elements: adj([[a,b],[c,d]]) = [[d,-b],[-c,a]]
fn adj2_00(a: i64, b: i64, c: i64, d: i64) -> i64 = d;
fn adj2_01(a: i64, b: i64, c: i64, d: i64) -> i64 = 0 - b;
fn adj2_10(a: i64, b: i64, c: i64, d: i64) -> i64 = 0 - c;
fn adj2_11(a: i64, b: i64, c: i64, d: i64) -> i64 = a;

// 3x3 determinant from 9 values
fn det3(a: i64, b: i64, c: i64, d: i64, e: i64, f: i64, g: i64, h: i64, ii: i64) -> i64 =
    a * (e * ii - f * h) - b * (d * ii - f * g) + c * (d * h - e * g);

// 3x3 cofactors (signed minors)
fn cof00(a: i64, b: i64, c: i64, d: i64, e: i64, f: i64, g: i64, h: i64, ii: i64) -> i64 =
    e * ii - f * h;

fn cof01(a: i64, b: i64, c: i64, d: i64, e: i64, f: i64, g: i64, h: i64, ii: i64) -> i64 =
    0 - (d * ii - f * g);

fn cof02(a: i64, b: i64, c: i64, d: i64, e: i64, f: i64, g: i64, h: i64, ii: i64) -> i64 =
    d * h - e * g;

fn cof10(a: i64, b: i64, c: i64, d: i64, e: i64, f: i64, g: i64, h: i64, ii: i64) -> i64 =
    0 - (b * ii - c * h);

fn cof11(a: i64, b: i64, c: i64, d: i64, e: i64, f: i64, g: i64, h: i64, ii: i64) -> i64 =
    a * ii - c * g;

fn cof12(a: i64, b: i64, c: i64, d: i64, e: i64, f: i64, g: i64, h: i64, ii: i64) -> i64 =
    0 - (a * h - b * g);

fn cof20(a: i64, b: i64, c: i64, d: i64, e: i64, f: i64, g: i64, h: i64, ii: i64) -> i64 =
    b * f - c * e;

fn cof21(a: i64, b: i64, c: i64, d: i64, e: i64, f: i64, g: i64, h: i64, ii: i64) -> i64 =
    0 - (a * f - c * d);

fn cof22(a: i64, b: i64, c: i64, d: i64, e: i64, f: i64, g: i64, h: i64, ii: i64) -> i64 =
    a * e - b * d;

fn main() -> i64 = {
    // --- 2x2 Tests ---
    // Matrix A = [[3,1],[5,2]], det = 3*2-1*5 = 1
    let _p1 = println(det2(3, 1, 5, 2));                // 1

    // Adjugate of A: [[2,-1],[-5,3]]
    let _p2 = println(adj2_00(3, 1, 5, 2));             // 2
    let _p3 = println(adj2_01(3, 1, 5, 2));             // -1
    let _p4 = println(adj2_10(3, 1, 5, 2));             // -5
    let _p5 = println(adj2_11(3, 1, 5, 2));             // 3

    // Verify A * adj(A) = det * I
    // (0,0): 3*2 + 1*(-5) = 1
    let v00 = 3 * adj2_00(3, 1, 5, 2) + 1 * adj2_10(3, 1, 5, 2);
    let _p6 = println(v00);                             // 1
    // (0,1): 3*(-1) + 1*3 = 0
    let v01 = 3 * adj2_01(3, 1, 5, 2) + 1 * adj2_11(3, 1, 5, 2);
    let _p7 = println(v01);                             // 0

    // --- 3x3 Tests ---
    // Matrix B = [[1,2,3],[0,4,5],[1,0,6]]
    // det = 1*(24-0) - 2*(0-5) + 3*(0-4) = 24 + 10 - 12 = 22
    let _p8 = println(det3(1, 2, 3, 0, 4, 5, 1, 0, 6)); // 22

    // Cofactors of B:
    // C(0,0) = 4*6-5*0 = 24
    let _p9 = println(cof00(1, 2, 3, 0, 4, 5, 1, 0, 6));  // 24
    // C(0,1) = -(0*6-5*1) = 5
    let _p10 = println(cof01(1, 2, 3, 0, 4, 5, 1, 0, 6)); // 5
    // C(0,2) = 0*0-4*1 = -4
    let _p11 = println(cof02(1, 2, 3, 0, 4, 5, 1, 0, 6)); // -4
    // C(1,0) = -(2*6-3*0) = -12
    let _p12 = println(cof10(1, 2, 3, 0, 4, 5, 1, 0, 6)); // -12
    // C(2,2) = 1*4-2*0 = 4
    let _p13 = println(cof22(1, 2, 3, 0, 4, 5, 1, 0, 6)); // 4

    0
    };

// Test: multiple functions with contracts
// Verifies contract assume injection across multiple functions

fn clamp_positive(x: i64) -> i64
    pre x >= 0
= if x > 100 { 100 } else { x };

fn safe_modulo(a: i64, b: i64) -> i64
    pre b != 0
= a % b;

fn bounded_access(arr: &[i64; 8], i: i64) -> i64
    pre i >= 0 and i < 8
= arr[i];

fn compute(a: i64, b: i64) -> i64
    pre a >= 0 and b > 0
= clamp_positive(a) + safe_modulo(a, b);

fn main() -> i64 = {
    let arr: [i64; 8] = [1, 2, 3, 4, 5, 6, 7, 8];
    let v1 = clamp_positive(42);
    let v2 = safe_modulo(17, 5);
    let v3 = bounded_access(&arr, 4);
    let v4 = compute(50, 7);
    let result = v1 + v2 + v3 + v4;
    let _u = println(result);
    0
};

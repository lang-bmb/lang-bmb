// Golden Test: LU decomposition on integer matrices (scaled by 1000)
// Doolittle: L has 1000 on diagonal, U is upper triangular

fn mget(m: i64, r: i64, c: i64) -> i64 = vec_get(m, r * 4 + c);
fn mset(m: i64, r: i64, c: i64, v: i64) -> i64 = { vec_set(m, r * 4 + c, v); 0 };

fn make_mat() -> i64 = {
    let v = vec_new();
    for _i in 0..16 { let _p = vec_push(v, 0); 0 };
    v
    };

fn lu_decompose(a: i64, l: i64, u: i64, n: i64) -> i64 = {
    let mut i = 0;
    loop {
        if i >= n { break } else { () };
        let _s = mset(l, i, i, 1000);
        i = i + 1
    };
    set i = 0;
    loop {
        if i >= n { break } else { () };
        let mut j = i;
        loop {
            if j >= n { break } else { () };
            let mut sum = mget(a, i, j) * 1000;
            let mut k = 0;
            loop {
                if k >= i { break } else { () };
                sum = sum - mget(l, i, k) * mget(u, k, j) / 1000;
                k = k + 1
            };
            let _s = mset(u, i, j, sum);
            j = j + 1
        };
        set j = i + 1;
        loop {
            if j >= n { break } else { () };
            let mut sum = mget(a, j, i) * 1000;
            let mut k = 0;
            loop {
                if k >= i { break } else { () };
                sum = sum - mget(l, j, k) * mget(u, k, i) / 1000;
                k = k + 1
            };
            let uii = mget(u, i, i);
            let _s = if uii != 0 { mset(l, j, i, sum * 1000 / uii) }
                     else { mset(l, j, i, 0) };
            j = j + 1
        };
        i = i + 1
    };
    0
    };

fn lu_mul(l: i64, u: i64, n: i64, r: i64, c: i64) -> i64 = {
    let mut sum = 0;
    let mut k = 0;
    loop {
        if k >= n { break } else { () };
        sum = sum + mget(l, r, k) * mget(u, k, c) / 1000;
        k = k + 1
    };
    sum / 1000
    };

fn main() -> i64 = {
    // A = [[2,1,1],[4,3,3],[8,7,9]]
    let a = make_mat();
    let _s = mset(a,0,0,2); let _s = mset(a,0,1,1); let _s = mset(a,0,2,1);
    let _s = mset(a,1,0,4); let _s = mset(a,1,1,3); let _s = mset(a,1,2,3);
    let _s = mset(a,2,0,8); let _s = mset(a,2,1,7); let _s = mset(a,2,2,9);
    let l = make_mat(); let u = make_mat();
    let _d = lu_decompose(a, l, u, 3);
    // U diagonal
    let _p1 = println(mget(u,0,0));  // 2000
    let _p2 = println(mget(u,1,1));  // 1000
    let _p3 = println(mget(u,2,2));  // 2000
    // L sub-diagonal
    let _p4 = println(mget(l,1,0));  // 2000
    let _p5 = println(mget(l,2,0));  // 4000
    let _p6 = println(mget(l,2,1));  // 3000
    // Verify L*U = A
    let _p7 = println(lu_mul(l,u,3,0,0));  // 2
    let _p8 = println(lu_mul(l,u,3,0,1));  // 1
    let _p9 = println(lu_mul(l,u,3,1,0));  // 4
    let _p10 = println(lu_mul(l,u,3,1,1)); // 3
    let _p11 = println(lu_mul(l,u,3,2,2)); // 9
    // 2x2: A = [[3,1],[6,4]]
    let a2 = make_mat();
    let _s = mset(a2,0,0,3); let _s = mset(a2,0,1,1);
    let _s = mset(a2,1,0,6); let _s = mset(a2,1,1,4);
    let l2 = make_mat(); let u2 = make_mat();
    let _d2 = lu_decompose(a2, l2, u2, 2);
    let _p12 = println(mget(u2,0,0));  // 3000
    let _p13 = println(mget(u2,1,1));  // 2000
    let _p14 = println(mget(l2,1,0));  // 2000
    let _p15 = println(lu_mul(l2,u2,2,0,0)); // 3
    let _p16 = println(lu_mul(l2,u2,2,1,1)); // 4
    let _f1 = vec_free(a); let _f2 = vec_free(l); let _f3 = vec_free(u);
    let _f4 = vec_free(a2); let _f5 = vec_free(l2); let _f6 = vec_free(u2);
    0
    };

// Golden Test: Number of topological orderings (counting DAG orderings)
// Uses DP with bitmask for small graphs

fn count_topo(adj_mask: i64, n: i64) -> i64 = {
    let mut tm = 1;
    let mut i = 0;
    while i < n {
        set tm = tm * 2;
        set i = i + 1
    };
    let dp = vec_new();
    set i = 0;
    while i < tm {
        let _p = vec_push(dp, 0);
        set i = i + 1
    };
    vec_set(dp, 0, 1);
    let mut mask = 0;
    while mask < tm {
        let prev = vec_get(dp, mask);
        let _x = if prev > 0 {
            set i = 0;
            while i < n {
                let mut nb = 1;
                let mut s = 0;
                while s < i {
                    set nb = nb * 2;
                    set s = s + 1
                };
                let _y = if (mask / nb) % 2 == 0 {
                    let preds = vec_get(adj_mask, i);
                    let mut all_preds = 1;
                    let mut p = 0;
                    while p < n {
                        let mut pb = 1;
                        let mut s2 = 0;
                        while s2 < p {
                            set pb = pb * 2;
                            set s2 = s2 + 1
                        };
                        let _z = if (preds / pb) % 2 == 1 {
                            let _w = if (mask / pb) % 2 == 0 {
                                set all_preds = 0;
                                0
                            } else { 0 };
                            0
                        } else { 0 };
                        set p = p + 1
                    };
                    let _z = if all_preds == 1 {
                        let new_mask = mask + nb;
                        vec_set(dp, new_mask, vec_get(dp, new_mask) + prev);
                        0
                    } else { 0 };
                    0
                } else { 0 };
                set i = i + 1
            };
            0
        } else { 0 };
        set mask = mask + 1
    };
    vec_get(dp, tm - 1)
};

fn main() -> () = {
    // Test 1: Linear chain 0->1->2 (1 ordering)
    let adj1 = vec_new();
    let _p = vec_push(adj1, 0);
    let _p = vec_push(adj1, 1);
    let _p = vec_push(adj1, 2);
    print_str("chain3="); let _r = println(count_topo(adj1, 3));

    // Test 2: No edges on 3 nodes (3! = 6 orderings)
    let adj2 = vec_new();
    let _p = vec_push(adj2, 0);
    let _p = vec_push(adj2, 0);
    let _p = vec_push(adj2, 0);
    print_str("free3="); let _r = println(count_topo(adj2, 3));

    // Test 3: Diamond: 0->1, 0->2, 1->3, 2->3 (2 orderings)
    let adj3 = vec_new();
    let _p = vec_push(adj3, 0);
    let _p = vec_push(adj3, 1);
    let _p = vec_push(adj3, 1);
    let _p = vec_push(adj3, 6);
    print_str("diamond="); let _r = println(count_topo(adj3, 4));

    // Test 4: No edges on 4 nodes (4! = 24)
    let adj4 = vec_new();
    let _p = vec_push(adj4, 0); let _p = vec_push(adj4, 0);
    let _p = vec_push(adj4, 0); let _p = vec_push(adj4, 0);
    print_str("free4="); let _r = println(count_topo(adj4, 4))
};

// Golden Test: Levenshtein edit distance with DP matrix + traceback
// Computes minimum edit distance between two sequences stored in vecs
// Also traces back the optimal alignment operations

// min of two values
fn min2(a: i64, b: i64) -> i64 =
    if a <= b { a } else { b };

// min of three values
fn min3(a: i64, b: i64, c: i64) -> i64 =
    min2(min2(a, b), c);

// Create a flat 2D matrix of (rows x cols) initialized to 0
fn matrix_new(rows: i64, cols: i64) -> i64 = {
    let m = vec_new();
    let total = rows * cols;
    for _i in 0..total {
        let _p = vec_push(m, 0);
        0
    };
    m
};

// Get element at (r, c) in flat matrix with `cols` columns
fn mat_get(m: i64, cols: i64, r: i64, c: i64) -> i64 =
    vec_get(m, r * cols + c);

// Set element at (r, c) in flat matrix
fn mat_set(m: i64, cols: i64, r: i64, c: i64, val: i64) -> i64 = {
    let _s = vec_set(m, r * cols + c, val);
    0
};

// Fill the DP table for edit distance
// dp[i][j] = edit distance between seq1[0..i] and seq2[0..j]
fn edit_distance(seq1: i64, len1: i64, seq2: i64, len2: i64) -> i64 = {
    let rows = len1 + 1;
    let cols = len2 + 1;
    let dp = matrix_new(rows, cols);

    // Base cases: dp[i][0] = i, dp[0][j] = j
    for i in 0..rows {
        let _s = mat_set(dp, cols, i, 0, i);
        0
    };
    for j in 0..cols {
        let _s = mat_set(dp, cols, 0, j, j);
        0
    };

    // Fill DP table
    for i in 1..rows {
        for j in 1..cols {
            let cost = if vec_get(seq1, i - 1) == vec_get(seq2, j - 1) { 0 } else { 1 };
            let del = mat_get(dp, cols, i - 1, j) + 1;
            let ins = mat_get(dp, cols, i, j - 1) + 1;
            let sub = mat_get(dp, cols, i - 1, j - 1) + cost;
            let _s = mat_set(dp, cols, i, j, min3(del, ins, sub));
            0
        }
    };

    dp
};

// Traceback: count operations (match, substitute, insert, delete)
// Walks from dp[len1][len2] back to dp[0][0]
// Returns a vec of [matches, substitutions, insertions, deletions]
fn traceback(dp: i64, cols: i64, seq1: i64, len1: i64, seq2: i64, len2: i64) -> i64 = {
    let ops = vec_new();
    let _p1 = vec_push(ops, 0);  // matches
    let _p2 = vec_push(ops, 0);  // substitutions
    let _p3 = vec_push(ops, 0);  // insertions
    let _p4 = vec_push(ops, 0);  // deletions

    let mut i = len1;
    let mut j = len2;

    loop {
        if i == 0 and j == 0 { break } else { () };

        if i == 0 {
            // Only insertions left
            let _s = vec_set(ops, 2, vec_get(ops, 2) + 1);
            j = j - 1
        } else if j == 0 {
            // Only deletions left
            let _s = vec_set(ops, 3, vec_get(ops, 3) + 1);
            i = i - 1
        } else {
            let cur = mat_get(dp, cols, i, j);
            let diag = mat_get(dp, cols, i - 1, j - 1);
            let up = mat_get(dp, cols, i - 1, j);
            let left = mat_get(dp, cols, i, j - 1);

            let same = if vec_get(seq1, i - 1) == vec_get(seq2, j - 1) { 1 } else { 0 };

            if same == 1 and diag == cur {
                // Match
                let _s = vec_set(ops, 0, vec_get(ops, 0) + 1);
                i = i - 1;
                j = j - 1
            } else if diag <= up and diag <= left {
                // Substitution
                let _s = vec_set(ops, 1, vec_get(ops, 1) + 1);
                i = i - 1;
                j = j - 1
            } else if up <= left {
                // Deletion (from seq1)
                let _s = vec_set(ops, 3, vec_get(ops, 3) + 1);
                i = i - 1
            } else {
                // Insertion (from seq2)
                let _s = vec_set(ops, 2, vec_get(ops, 2) + 1);
                j = j - 1
            }
        }
    };

    ops
};

fn make_vec(a: i64, b: i64, c: i64, d: i64, e: i64) -> i64 = {
    let v = vec_new();
    let _p1 = vec_push(v, a);
    let _p2 = vec_push(v, b);
    let _p3 = vec_push(v, c);
    let _p4 = vec_push(v, d);
    let _p5 = vec_push(v, e);
    v
};

fn make_vec6(a: i64, b: i64, c: i64, d: i64, e: i64, f: i64) -> i64 = {
    let v = vec_new();
    let _p1 = vec_push(v, a);
    let _p2 = vec_push(v, b);
    let _p3 = vec_push(v, c);
    let _p4 = vec_push(v, d);
    let _p5 = vec_push(v, e);
    let _p6 = vec_push(v, f);
    v
};

fn make_vec7(a: i64, b: i64, c: i64, d: i64, e: i64, f: i64, g: i64) -> i64 = {
    let v = vec_new();
    let _p1 = vec_push(v, a);
    let _p2 = vec_push(v, b);
    let _p3 = vec_push(v, c);
    let _p4 = vec_push(v, d);
    let _p5 = vec_push(v, e);
    let _p6 = vec_push(v, f);
    let _p7 = vec_push(v, g);
    v
};

fn main() -> i64 = {
    // Test 1: "kitten" vs "sitting" (using ASCII codes)
    // k=107, i=105, t=116, t=116, e=101, n=110
    // s=115, i=105, t=116, t=116, i=105, n=110, g=103
    let s1 = make_vec6(107, 105, 116, 116, 101, 110);
    let s2 = make_vec7(115, 105, 116, 116, 105, 110, 103);
    let dp1 = edit_distance(s1, 6, s2, 7);
    let dist1 = mat_get(dp1, 8, 6, 7);
    let _p1 = println(dist1);  // 3
    let ops1 = traceback(dp1, 8, s1, 6, s2, 7);
    let _p2 = println(vec_get(ops1, 0));  // matches
    let _p3 = println(vec_get(ops1, 1));  // substitutions
    let _p4 = println(vec_get(ops1, 2));  // insertions
    let _p5 = println(vec_get(ops1, 3));  // deletions

    // Test 2: identical sequences [1, 2, 3, 4, 5]
    let s3 = make_vec(1, 2, 3, 4, 5);
    let s4 = make_vec(1, 2, 3, 4, 5);
    let dp2 = edit_distance(s3, 5, s4, 5);
    let dist2 = mat_get(dp2, 6, 5, 5);
    let _p6 = println(dist2);  // 0

    // Test 3: completely different [1, 2, 3] vs [4, 5, 6]
    let s5 = vec_new();
    let _pa = vec_push(s5, 1);
    let _pb = vec_push(s5, 2);
    let _pc = vec_push(s5, 3);
    let s6 = vec_new();
    let _pd = vec_push(s6, 4);
    let _pe = vec_push(s6, 5);
    let _pf = vec_push(s6, 6);
    let dp3 = edit_distance(s5, 3, s6, 3);
    let dist3 = mat_get(dp3, 4, 3, 3);
    let _p7 = println(dist3);  // 3 (all substitutions)
    let ops3 = traceback(dp3, 4, s5, 3, s6, 3);
    let _p8 = println(vec_get(ops3, 0));  // 0 matches
    let _p9 = println(vec_get(ops3, 1));  // 3 substitutions

    // Test 4: empty vs non-empty [10, 20, 30]
    let s7 = vec_new();
    let s8 = vec_new();
    let _pg = vec_push(s8, 10);
    let _ph = vec_push(s8, 20);
    let _pi = vec_push(s8, 30);
    let dp4 = edit_distance(s7, 0, s8, 3);
    let dist4 = mat_get(dp4, 4, 0, 3);
    let _p10 = println(dist4);  // 3 (3 insertions)

    // Test 5: single difference [1, 2, 3] vs [1, 9, 3]
    let s9 = vec_new();
    let _pj = vec_push(s9, 1);
    let _pk = vec_push(s9, 2);
    let _pl = vec_push(s9, 3);
    let s10 = vec_new();
    let _pm = vec_push(s10, 1);
    let _pn = vec_push(s10, 9);
    let _po = vec_push(s10, 3);
    let dp5 = edit_distance(s9, 3, s10, 3);
    let dist5 = mat_get(dp5, 4, 3, 3);
    let _p11 = println(dist5);  // 1

    // Test 6: DP table verification for [1,2] vs [1,3]
    // dp[0][0]=0, dp[0][1]=1, dp[0][2]=2
    // dp[1][0]=1, dp[1][1]=0, dp[1][2]=1
    // dp[2][0]=2, dp[2][1]=1, dp[2][2]=1
    let sa = vec_new();
    let _pq = vec_push(sa, 1);
    let _pr = vec_push(sa, 2);
    let sb = vec_new();
    let _ps = vec_push(sb, 1);
    let _pt = vec_push(sb, 3);
    let dp6 = edit_distance(sa, 2, sb, 2);
    let _p12 = println(mat_get(dp6, 3, 0, 0));  // 0
    let _p13 = println(mat_get(dp6, 3, 1, 1));  // 0  (match on 1)
    let _p14 = println(mat_get(dp6, 3, 2, 2));  // 1  (sub 2->3)

    // Cleanup
    let _f1 = vec_free(s1);
    let _f2 = vec_free(s2);
    let _f3 = vec_free(dp1);
    let _f4 = vec_free(ops1);
    let _f5 = vec_free(s3);
    let _f6 = vec_free(s4);
    let _f7 = vec_free(dp2);
    let _f8 = vec_free(s5);
    let _f9 = vec_free(s6);
    let _f10 = vec_free(dp3);
    let _f11 = vec_free(ops3);
    let _f12 = vec_free(s7);
    let _f13 = vec_free(s8);
    let _f14 = vec_free(dp4);
    let _f15 = vec_free(s9);
    let _f16 = vec_free(s10);
    let _f17 = vec_free(dp5);
    let _f18 = vec_free(sa);
    let _f19 = vec_free(sb);
    let _f20 = vec_free(dp6);
    0
};

// Golden test: Ford-Fulkerson max flow (Edmonds-Karp BFS variant)
// Graph as flat n*n capacity matrix

fn cap_get(c: i64, n: i64, u: i64, v: i64) -> i64 = vec_get(c, u * n + v);

fn cap_set(c: i64, n: i64, u: i64, v: i64, val: i64) -> i64 = {
    let _s = vec_set(c, u * n + v, val); 0
};

fn bfs_find(res: i64, n: i64, src: i64, sink: i64, par: i64) -> i64 = {
    let vis = vec_new();
    for _i in 0..n { let _p = vec_push(vis, 0); 0 };
    let q = vec_new();
    let _p = vec_push(q, src);
    let _v = vec_set(vis, src, 1);
    let _pp = vec_set(par, src, 0 - 1);
    let mut head = 0;
    let mut found = 0;
    loop {
        if head >= vec_len(q) { break } else { () };
        let u = vec_get(q, head);
        set head = head + 1;
        let mut v = 0;
        loop {
            if v >= n { break } else { () };
            if vec_get(vis, v) == 0 and cap_get(res, n, u, v) > 0 {
                let _sv = vec_set(vis, v, 1);
                let _sp = vec_set(par, v, u);
                let _pq = vec_push(q, v);
                if v == sink { set found = 1; set v = n }
                else { set v = v + 1 }
            } else { set v = v + 1 }
        }
    };
    let _fv = vec_free(vis); let _fq = vec_free(q);
    found
};

fn bottleneck(res: i64, n: i64, par: i64, sink: i64) -> i64 = {
    let mut v = sink;
    let mut mc = 999999;
    loop {
        let u = vec_get(par, v);
        if u < 0 { break } else { () };
        let c = cap_get(res, n, u, v);
        set mc = if c < mc { c } else { mc };
        set v = u
    };
    mc
};

fn update_res(res: i64, n: i64, par: i64, sink: i64, f: i64) -> i64 = {
    let mut v = sink;
    loop {
        let u = vec_get(par, v);
        if u < 0 { break } else { () };
        let _s1 = cap_set(res, n, u, v, cap_get(res, n, u, v) - f);
        let _s2 = cap_set(res, n, v, u, cap_get(res, n, v, u) + f);
        set v = u
    }; 0
};

fn copy_mat(c: i64, sz: i64) -> i64 = {
    let r = vec_new();
    for i in 0..sz { let _p = vec_push(r, vec_get(c, i)); 0 };
    r
};

fn max_flow(cap: i64, n: i64, src: i64, sink: i64) -> i64 = {
    let res = copy_mat(cap, n * n);
    let par = vec_new();
    for _i in 0..n { let _p = vec_push(par, 0 - 1); 0 };
    let mut total = 0;
    loop {
        for i in 0..n { let _s = vec_set(par, i, 0 - 1); 0 };
        let found = bfs_find(res, n, src, sink, par);
        if found == 0 { break } else { () };
        let bn = bottleneck(res, n, par, sink);
        let _u = update_res(res, n, par, sink, bn);
        set total = total + bn
    };
    let _fr = vec_free(res); let _fp = vec_free(par);
    total
};

fn push4(v: i64, a: i64, b: i64, c: i64, d: i64) -> i64 = {
    vec_push(v,a); vec_push(v,b); vec_push(v,c); vec_push(v,d); 0
};

fn push3(v: i64, a: i64, b: i64, c: i64) -> i64 = {
    vec_push(v,a); vec_push(v,b); vec_push(v,c); 0
};

fn main() -> i64 = {
    // 0->1(10), 0->2(8), 1->2(5), 1->3(5), 2->3(10)
    let c1 = vec_new();
    push4(c1,0,10,8,0); push4(c1,0,0,5,5);
    push4(c1,0,0,0,10); push4(c1,0,0,0,0);
    let _p1 = println(max_flow(c1, 4, 0, 3));  // 15

    // Pipe: 0->1(7), 1->2(4)
    let c2 = vec_new();
    push3(c2,0,7,0); push3(c2,0,0,4); push3(c2,0,0,0);
    let _p2 = println(max_flow(c2, 3, 0, 2));  // 4

    // Parallel: 0->1(5), 0->2(3), 1->3(5), 2->3(3)
    let c3 = vec_new();
    push4(c3,0,5,3,0); push4(c3,0,0,0,5);
    push4(c3,0,0,0,3); push4(c3,0,0,0,0);
    let _p3 = println(max_flow(c3, 4, 0, 3));  // 8

    // Diamond bottleneck: 0->1(100), 0->2(100), 1->3(1), 2->3(1)
    let c4 = vec_new();
    push4(c4,0,100,100,0); push4(c4,0,0,0,1);
    push4(c4,0,0,0,1); push4(c4,0,0,0,0);
    let _p4 = println(max_flow(c4, 4, 0, 3));  // 2

    // No path: 0->1 only
    let c5 = vec_new();
    push3(c5,0,5,0); push3(c5,0,0,0); push3(c5,0,0,0);
    let _p5 = println(max_flow(c5, 3, 0, 2));  // 0

    vec_free(c1); vec_free(c2); vec_free(c3); vec_free(c4); vec_free(c5);
    0
};

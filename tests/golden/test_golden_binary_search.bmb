// Golden Test: Binary search variations
// Standard, lower bound, upper bound, count occurrences

// Standard binary search: returns index or -1
fn binary_search(arr: i64, target: i64) -> i64 = {
    let mut lo = 0;
    let mut hi = vec_len(arr) - 1;
    loop {
        if lo > hi { break } else { () };
        let mid = lo + (hi - lo) / 2;
        let val = vec_get(arr, mid);
        if val == target {
            return mid
        } else if val < target {
            lo = mid + 1
        } else {
            hi = mid - 1
        }
    };
    0 - 1
};

// Lower bound: first index where arr[i] >= target
fn lower_bound(arr: i64, target: i64) -> i64 = {
    let n = vec_len(arr);
    let mut lo = 0;
    let mut hi = n;
    loop {
        if lo >= hi { break } else { () };
        let mid = lo + (hi - lo) / 2;
        if vec_get(arr, mid) < target {
            lo = mid + 1
        } else {
            hi = mid
        }
    };
    lo
};

// Upper bound: first index where arr[i] > target
fn upper_bound(arr: i64, target: i64) -> i64 = {
    let n = vec_len(arr);
    let mut lo = 0;
    let mut hi = n;
    loop {
        if lo >= hi { break } else { () };
        let mid = lo + (hi - lo) / 2;
        if vec_get(arr, mid) <= target {
            lo = mid + 1
        } else {
            hi = mid
        }
    };
    lo
};

// Count occurrences of target in sorted array
fn count_occurrences(arr: i64, target: i64) -> i64 =
    upper_bound(arr, target) - lower_bound(arr, target);

// Find floor: largest element <= target
fn find_floor(arr: i64, target: i64) -> i64 = {
    let n = vec_len(arr);
    let mut lo = 0;
    let mut hi = n - 1;
    let mut result = 0 - 1;
    loop {
        if lo > hi { break } else { () };
        let mid = lo + (hi - lo) / 2;
        let val = vec_get(arr, mid);
        if val <= target {
            result = val;
            lo = mid + 1
        } else {
            hi = mid - 1
        }
    };
    result
};

fn main() -> i64 = {
    // Sorted array: [1, 3, 5, 7, 9, 11, 13, 15]
    let arr = vec_new();
    vec_push(arr, 1); vec_push(arr, 3); vec_push(arr, 5); vec_push(arr, 7);
    vec_push(arr, 9); vec_push(arr, 11); vec_push(arr, 13); vec_push(arr, 15);

    // Test 1: search for 7 -> index 3
    let _p1 = println(binary_search(arr, 7));   // 3

    // Test 2: search for 1 -> index 0
    let _p2 = println(binary_search(arr, 1));   // 0

    // Test 3: search for 15 -> index 7
    let _p3 = println(binary_search(arr, 15));  // 7

    // Test 4: search for 6 -> not found -> -1
    let _p4 = println(binary_search(arr, 6));   // -1

    // Test 5: lower_bound for 5 -> index 2
    let _p5 = println(lower_bound(arr, 5));     // 2

    // Test 6: lower_bound for 6 -> index 3 (first >= 6 is 7 at idx 3)
    let _p6 = println(lower_bound(arr, 6));     // 3

    // Array with duplicates: [1, 2, 2, 2, 3, 4, 4, 5]
    let arr2 = vec_new();
    vec_push(arr2, 1); vec_push(arr2, 2); vec_push(arr2, 2); vec_push(arr2, 2);
    vec_push(arr2, 3); vec_push(arr2, 4); vec_push(arr2, 4); vec_push(arr2, 5);

    // Test 7: count occurrences of 2 -> 3
    let _p7 = println(count_occurrences(arr2, 2));  // 3

    // Test 8: count occurrences of 4 -> 2
    let _p8 = println(count_occurrences(arr2, 4));  // 2

    // Test 9: count occurrences of 6 -> 0
    let _p9 = println(count_occurrences(arr2, 6));  // 0

    // Test 10: find_floor for 6 in [1,3,5,7,9,...] -> 5
    let _p10 = println(find_floor(arr, 6));  // 5

    // Test 11: find_floor for 9 -> 9
    let _p11 = println(find_floor(arr, 9));  // 9

    // Test 12: upper_bound for 2 in arr2 -> index 4
    let _p12 = println(upper_bound(arr2, 2));  // 4

    vec_free(arr); vec_free(arr2);
    0
};

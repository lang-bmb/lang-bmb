// Golden Test: Finite automata simulation patterns
// Tests DFA and NFA-to-DFA simulations using vec for input sequences

// === DFA 1: accepts a*b* pattern ===
// States: 0=reading_a, 1=reading_b, 2=dead
// Alphabet: 97='a', 98='b'
// Accepting: states 0 and 1
fn dfa1_transition(state: i64, ch: i64) -> i64 = {
    if state == 0 {
        if ch == 97 { 0 }         // a -> stay in a*
        else if ch == 98 { 1 }    // b -> switch to b*
        else { 2 }                // reject
    }
    else if state == 1 {
        if ch == 98 { 1 }         // b -> stay in b*
        else { 2 }                // a after b -> reject
    }
    else { 2 }                    // dead state
    };

fn dfa1_accepting(state: i64) -> i64 =
    if state == 0 { 1 }
    else if state == 1 { 1 }
    else { 0 };

fn run_dfa1(input: i64) -> i64 = {
    let len = vec_len(input);
    let mut state = 0;
    for i in 0..len {
        let ch = vec_get(input, i);
        state = dfa1_transition(state, ch)
    };
    dfa1_accepting(state)
    };

// === DFA 2: binary numbers divisible by 3 ===
// States: 0,1,2 (remainder mod 3 so far)
// Input: 0 or 1 (MSB first)
// Accepting: state 0
fn dfa2_transition(state: i64, bit: i64) -> i64 =
    (state * 2 + bit) % 3;

fn run_dfa2(input: i64) -> i64 = {
    let len = vec_len(input);
    let mut state = 0;
    for i in 0..len {
        let bit = vec_get(input, i);
        state = dfa2_transition(state, bit)
    };
    if state == 0 { 1 } else { 0 }
    };

// === DFA 3: NFA (a|b)*abb converted to DFA ===
// NFA accepts strings ending in "abb"
// DFA states after subset construction:
//   0 = {q0}           (start)
//   1 = {q0,q1}        (seen potential 'a' start of 'abb')
//   2 = {q0,q2}        (seen 'ab')
//   3 = {q0,q3}        (seen 'abb' - accepting)
// Alphabet: 97='a', 98='b'
fn dfa3_transition(state: i64, ch: i64) -> i64 = {
    if state == 0 {
        if ch == 97 { 1 } else { 0 }     // a->1, b->0
    }
    else if state == 1 {
        if ch == 97 { 1 } else { 2 }     // a->1, b->2
    }
    else if state == 2 {
        if ch == 97 { 1 } else { 3 }     // a->1, b->3
    }
    else {
        if ch == 97 { 1 } else { 0 }     // a->1, b->0
    }
    };

fn run_dfa3(input: i64) -> i64 = {
    let len = vec_len(input);
    let mut state = 0;
    for i in 0..len {
        let ch = vec_get(input, i);
        state = dfa3_transition(state, ch)
    };
    if state == 3 { 1 } else { 0 }
    };

// Helper: create vec from known values
fn make_vec2(a: i64, b: i64) -> i64 = {
    let v = vec_new();
    let _p1 = vec_push(v, a);
    let _p2 = vec_push(v, b);
    v
    };

fn make_vec3(a: i64, b: i64, c: i64) -> i64 = {
    let v = vec_new();
    let _p1 = vec_push(v, a);
    let _p2 = vec_push(v, b);
    let _p3 = vec_push(v, c);
    v
    };

fn make_vec4(a: i64, b: i64, c: i64, d: i64) -> i64 = {
    let v = vec_new();
    let _p1 = vec_push(v, a);
    let _p2 = vec_push(v, b);
    let _p3 = vec_push(v, c);
    let _p4 = vec_push(v, d);
    v
    };

fn make_vec5(a: i64, b: i64, c: i64, d: i64, e: i64) -> i64 = {
    let v = vec_new();
    let _p1 = vec_push(v, a);
    let _p2 = vec_push(v, b);
    let _p3 = vec_push(v, c);
    let _p4 = vec_push(v, d);
    let _p5 = vec_push(v, e);
    v
    };

// Count how many length-n binary strings are accepted by DFA 2 (div by 3)
fn count_div3_strings(n: i64) -> i64 = {
    // DP: dp[state] = number of strings reaching that state
    // Start: dp[0]=1, dp[1]=0, dp[2]=0
    let mut dp0 = 1;
    let mut dp1 = 0;
    let mut dp2 = 0;
    for _step in 0..n {
        // On bit 0: state -> (state*2)%3
        // On bit 1: state -> (state*2+1)%3
        // new_dp[s] = sum of dp[t] where t transitions to s on 0 or 1
        // (0*2)%3=0, (0*2+1)%3=1
        // (1*2)%3=2, (1*2+1)%3=0
        // (2*2)%3=1, (2*2+1)%3=2
        let new0 = dp0 + dp1;     // from state 0 via 0, from state 1 via 1
        let new1 = dp0 + dp2;     // from state 0 via 1, from state 2 via 0
        let new2 = dp1 + dp2;     // from state 1 via 0, from state 2 via 1
        dp0 = new0;
        dp1 = new1;
        dp2 = new2
    };
    dp0
    };

fn main() -> i64 = {
    // === DFA 1: a*b* ===
    // "aabb" -> accept
    let v1 = make_vec4(97, 97, 98, 98);
    let _p1 = println(run_dfa1(v1));           // 1
    let _f1 = vec_free(v1);

    // "abba" -> reject (a after b)
    let v2 = make_vec4(97, 98, 98, 97);
    let _p2 = println(run_dfa1(v2));           // 0
    let _f2 = vec_free(v2);

    // "aaa" -> accept
    let v3 = make_vec3(97, 97, 97);
    let _p3 = println(run_dfa1(v3));           // 1
    let _f3 = vec_free(v3);

    // "bbb" -> accept
    let v4 = make_vec3(98, 98, 98);
    let _p4 = println(run_dfa1(v4));           // 1
    let _f4 = vec_free(v4);

    // === DFA 2: binary divisible by 3 ===
    // "110" (=6, 6%3=0) -> accept
    let v5 = make_vec3(1, 1, 0);
    let _p5 = println(run_dfa2(v5));           // 1
    let _f5 = vec_free(v5);

    // "101" (=5, 5%3=2) -> reject
    let v6 = make_vec3(1, 0, 1);
    let _p6 = println(run_dfa2(v6));           // 0
    let _f6 = vec_free(v6);

    // "1001" (=9, 9%3=0) -> accept
    let v7 = make_vec4(1, 0, 0, 1);
    let _p7 = println(run_dfa2(v7));           // 1
    let _f7 = vec_free(v7);

    // "111" (=7, 7%3=1) -> reject
    let v8 = make_vec3(1, 1, 1);
    let _p8 = println(run_dfa2(v8));           // 0
    let _f8 = vec_free(v8);

    // "11" (=3, 3%3=0) -> accept
    let v9 = make_vec2(1, 1);
    let _p9 = println(run_dfa2(v9));           // 1
    let _f9 = vec_free(v9);

    // "100" (=4, 4%3=1) -> reject
    let v10 = make_vec3(1, 0, 0);
    let _p10 = println(run_dfa2(v10));         // 0
    let _f10 = vec_free(v10);

    // === DFA 3: (a|b)*abb ===
    // "abb" -> accept
    let v11 = make_vec3(97, 98, 98);
    let _p11 = println(run_dfa3(v11));         // 1
    let _f11 = vec_free(v11);

    // "aabb" -> accept
    let v12 = make_vec4(97, 97, 98, 98);
    let _p12 = println(run_dfa3(v12));         // 1
    let _f12 = vec_free(v12);

    // "ab" -> reject
    let v13 = make_vec2(97, 98);
    let _p13 = println(run_dfa3(v13));         // 0
    let _f13 = vec_free(v13);

    // "abab" -> reject
    let v14 = make_vec4(97, 98, 97, 98);
    let _p14 = println(run_dfa3(v14));         // 0
    let _f14 = vec_free(v14);

    // "babb" -> accept
    let v15 = make_vec4(98, 97, 98, 98);
    let _p15 = println(run_dfa3(v15));         // 1
    let _f15 = vec_free(v15);

    // "ababb" -> accept
    let v16 = make_vec5(97, 98, 97, 98, 98);
    let _p16 = println(run_dfa3(v16));         // 1
    let _f16 = vec_free(v16);

    // === Count accepting paths: n-bit binary strings divisible by 3 ===
    // n=1: "0" accepted. "1" not. Count=1
    let _p17 = println(count_div3_strings(1)); // 1
    // n=2: "00"=0, "01"=1, "10"=2, "11"=3. Div by 3: 0,3. Count=2
    let _p18 = println(count_div3_strings(2)); // 2
    // n=3: 0,3,6 -> "000","011","110". Count=3
    let _p19 = println(count_div3_strings(3)); // 3

    0
    };

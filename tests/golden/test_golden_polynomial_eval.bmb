// Golden test: Polynomial evaluation, derivative, and root finding by bisection
// Polynomials stored as vec of coefficients: [a0, a1, a2, ...] = a0 + a1*x + a2*x^2 + ...

// Evaluate polynomial at x using Horner's method
// Coefficients: [c0, c1, c2, ..., cn] for c0 + c1*x + c2*x^2 + ... + cn*x^n
// Horner: ((cn*x + cn-1)*x + cn-2)*x + ... + c0
fn poly_eval_horner(coeffs: i64, x: i64) -> i64 = {
    let n = vec_len(coeffs);
    let mut result = 0;
    let mut i = n - 1;
    loop {
        if i < 0 { break } else { () };
        set result = result * x + vec_get(coeffs, i);
        set i = i - 1
    };
    result
};

// Evaluate polynomial using naive method (for verification)
fn pow_int(base: i64, exp: i64) -> i64 =
    if exp == 0 { 1 }
    else { base * pow_int(base, exp - 1) };

fn poly_eval_naive(coeffs: i64, x: i64) -> i64 = {
    let n = vec_len(coeffs);
    let mut result = 0;
    for i in 0..n {
        set result = result + vec_get(coeffs, i) * pow_int(x, i)
    };
    result
};

// Compute derivative polynomial
fn poly_derivative(coeffs: i64) -> i64 = {
    let n = vec_len(coeffs);
    let deriv = vec_new();
    let _r = if n <= 1 {
        let _p = vec_push(deriv, 0);
        0
    } else {
        for i in 1..n {
            let _p = vec_push(deriv, vec_get(coeffs, i) * i);
            0
        };
        0
    };
    deriv
};

// Root finding by bisection on integer polynomial
fn bisect_root(coeffs: i64, lo: i64, hi: i64, iters: i64) -> i64 =
    if iters <= 0 { (lo + hi) / 2 }
    else if lo >= hi { lo }
    else {
        let mid = lo + (hi - lo) / 2;
        let f_lo = poly_eval_horner(coeffs, lo);
        let f_mid = poly_eval_horner(coeffs, mid);
        if f_mid == 0 { mid }
        else if f_lo == 0 { lo }
        else if mid == lo {
            let f_hi = poly_eval_horner(coeffs, hi);
            let abs_lo = if f_lo < 0 { 0 - f_lo } else { f_lo };
            let abs_hi = if f_hi < 0 { 0 - f_hi } else { f_hi };
            if abs_lo <= abs_hi { lo } else { hi }
        }
        else if f_lo > 0 {
            if f_mid > 0 { bisect_root(coeffs, mid, hi, iters - 1) }
            else { bisect_root(coeffs, lo, mid, iters - 1) }
        } else {
            if f_mid < 0 { bisect_root(coeffs, mid, hi, iters - 1) }
            else { bisect_root(coeffs, lo, mid, iters - 1) }
        }
    };

// Polynomial addition
fn poly_add(a: i64, b: i64) -> i64 = {
    let na = vec_len(a);
    let nb = vec_len(b);
    let max_n = if na > nb { na } else { nb };
    let result = vec_new();
    for i in 0..max_n {
        let ca = if i < na { vec_get(a, i) } else { 0 };
        let cb = if i < nb { vec_get(b, i) } else { 0 };
        let _p = vec_push(result, ca + cb);
        0
    };
    result
};

// Polynomial multiplication (convolution)
fn poly_mul(a: i64, b: i64) -> i64 = {
    let na = vec_len(a);
    let nb = vec_len(b);
    let nc = na + nb - 1;
    let result = vec_new();
    for _i in 0..nc {
        let _p = vec_push(result, 0);
        0
    };
    for i in 0..na {
        for j in 0..nb {
            let old = vec_get(result, i + j);
            let _s = vec_set(result, i + j, old + vec_get(a, i) * vec_get(b, j));
            0
        }
    };
    result
};

fn make_poly2(a: i64, b: i64) -> i64 = {
    let v = vec_new();
    let _p = vec_push(v, a);
    let _p = vec_push(v, b);
    v
};

fn make_poly3(a: i64, b: i64, c: i64) -> i64 = {
    let v = vec_new();
    let _p = vec_push(v, a);
    let _p = vec_push(v, b);
    let _p = vec_push(v, c);
    v
};

fn make_poly4(a: i64, b: i64, c: i64, d: i64) -> i64 = {
    let v = vec_new();
    let _p = vec_push(v, a);
    let _p = vec_push(v, b);
    let _p = vec_push(v, c);
    let _p = vec_push(v, d);
    v
};

fn main() -> i64 = {
    // === Test 1: Horner evaluation ===
    // p(x) = 2 + 3x + x^2
    let p1 = make_poly3(2, 3, 1);
    let _t = println(poly_eval_horner(p1, 0));      // 2
    let _t = println(poly_eval_horner(p1, 1));      // 6
    let _t = println(poly_eval_horner(p1, 2));      // 12
    let _t = println(poly_eval_horner(p1, 3));      // 20
    let _t = println(poly_eval_horner(p1, 0 - 1));  // 0

    // === Test 2: Horner matches naive ===
    // p(x) = 1 + 2x + 3x^2 + 4x^3
    let p2 = make_poly4(1, 2, 3, 4);
    let h_val = poly_eval_horner(p2, 5);
    let n_val = poly_eval_naive(p2, 5);
    let _t = println(h_val);                         // 586
    let _t = println(n_val);                         // 586
    let _t = println(if h_val == n_val { 1 } else { 0 });  // 1

    // === Test 3: Derivative ===
    let d1 = poly_derivative(p1);
    let _t = println(vec_len(d1));     // 2
    let _t = println(vec_get(d1, 0));  // 3
    let _t = println(vec_get(d1, 1));  // 2

    let d2 = poly_derivative(p2);
    let _t = println(vec_len(d2));     // 3
    let _t = println(vec_get(d2, 0));  // 2
    let _t = println(vec_get(d2, 1));  // 6
    let _t = println(vec_get(d2, 2));  // 12

    let _t = println(poly_eval_horner(d1, 2));  // 7

    let d2d = poly_derivative(d2);
    let _t = println(vec_get(d2d, 0));  // 6
    let _t = println(vec_get(d2d, 1));  // 24

    // === Test 4: Polynomial addition ===
    let pa = make_poly2(2, 3);
    let pb = make_poly3(1, 1, 1);
    let psum = poly_add(pa, pb);
    let _t = println(vec_get(psum, 0));  // 3
    let _t = println(vec_get(psum, 1));  // 4
    let _t = println(vec_get(psum, 2));  // 1

    // === Test 5: Polynomial multiplication ===
    let pm1 = make_poly2(1, 1);
    let pm2 = make_poly2(1, 1);
    let pprod = poly_mul(pm1, pm2);
    let _t = println(vec_get(pprod, 0));  // 1
    let _t = println(vec_get(pprod, 1));  // 2
    let _t = println(vec_get(pprod, 2));  // 1

    let pm3 = make_poly2(2, 1);
    let pm4 = make_poly2(3, 0 - 1);
    let pprod2 = poly_mul(pm3, pm4);
    let _t = println(vec_get(pprod2, 0));  // 6
    let _t = println(vec_get(pprod2, 1));  // 1
    let _t = println(vec_get(pprod2, 2));  // -1

    // === Test 6: Root finding by bisection ===
    let pr = make_poly3(0 - 4, 0, 1);
    let root1 = bisect_root(pr, 0, 10, 50);
    let _t = println(root1);  // 2

    let root2 = bisect_root(pr, 0 - 10, 0, 50);
    let _t = println(root2);  // -2

    let pr2 = make_poly4(0 - 8, 0, 0, 1);
    let root3 = bisect_root(pr2, 0, 10, 50);
    let _t = println(root3);  // 2

    let pr3 = make_poly2(0 - 7, 1);
    let root4 = bisect_root(pr3, 0, 100, 50);
    let _t = println(root4);  // 7

    let _t = println(poly_eval_horner(pr, root1));   // 0
    let _t = println(poly_eval_horner(pr2, root3));  // 0
    let _t = println(poly_eval_horner(pr3, root4));  // 0

    // === Test 7: Constant polynomial ===
    let pc = vec_new();
    let _p = vec_push(pc, 42);
    let _t = println(poly_eval_horner(pc, 100));  // 42
    let dc = poly_derivative(pc);
    let _t = println(vec_get(dc, 0));  // 0

    // Cleanup
    let _f = vec_free(p1);
    let _f = vec_free(p2);
    let _f = vec_free(d1);
    let _f = vec_free(d2);
    let _f = vec_free(d2d);
    let _f = vec_free(pa);
    let _f = vec_free(pb);
    let _f = vec_free(psum);
    let _f = vec_free(pm1);
    let _f = vec_free(pm2);
    let _f = vec_free(pprod);
    let _f = vec_free(pm3);
    let _f = vec_free(pm4);
    let _f = vec_free(pprod2);
    let _f = vec_free(pr);
    let _f = vec_free(pr2);
    let _f = vec_free(pr3);
    let _f = vec_free(pc);
    let _f = vec_free(dc);
    0
};

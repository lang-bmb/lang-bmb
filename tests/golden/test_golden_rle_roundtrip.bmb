// Golden test: Run-length encoding roundtrip codec
// Encode integer arrays as (value, count) pairs, decode back, verify integrity
// Also tests compression ratio and edge cases

// Count consecutive equal elements starting at position pos
fn count_run(arr: i64, pos: i64, size: i64) -> i64 = {
    let val = vec_get(arr, pos);
    let mut count = 1;
    let mut i = pos + 1;
    loop {
        if i >= size { break } else { 0 };
        if vec_get(arr, i) != val { break } else { 0 };
        count = count + 1;
        i = i + 1
    };
    count
    };

// Encode: produces flat vec [val1, count1, val2, count2, ...]
fn rle_enc(arr: i64, size: i64) -> i64 = {
    let enc = vec_new();
    let mut pos = 0;
    loop {
        if pos >= size { break } else { 0 };
        let val = vec_get(arr, pos);
        let run = count_run(arr, pos, size);
        vec_push(enc, val);
        vec_push(enc, run);
        pos = pos + run
    };
    enc
    };

// Decode: reads (val, count) pairs, expands back to flat array
fn rle_dec(enc: i64) -> i64 = {
    let dec = vec_new();
    let enc_len = vec_len(enc);
    let mut i = 0;
    loop {
        if i >= enc_len { break } else { 0 };
        let val = vec_get(enc, i);
        let count = vec_get(enc, i + 1);
        let mut j = 0;
        loop {
            if j >= count { break } else { 0 };
            vec_push(dec, val);
            j = j + 1
        };
        i = i + 2
    };
    dec
    };

// Check arrays equal element-wise
fn check_eq(a: i64, b: i64, size: i64) -> i64 = {
    let mut ok = 1;
    let mut i = 0;
    loop {
        if i >= size { break } else { 0 };
        if vec_get(a, i) != vec_get(b, i) {
            ok = 0;
            break
        } else { 0 };
        i = i + 1
    };
    ok
    };

// Sum elements of a vec
fn vec_total(v: i64, n: i64) -> i64 = {
    let mut s = 0;
    let mut i = 0;
    loop {
        if i >= n { break } else { 0 };
        s = s + vec_get(v, i);
        i = i + 1
    };
    s
    };

// Number of runs in encoded array
fn num_runs(enc: i64) -> i64 = vec_len(enc) / 2;

fn main() -> i64 = {
    // Test 1: Basic RLE [1,1,1,2,2,3] -> (1,3)(2,2)(3,1)
    let a1 = vec_new();
    vec_push(a1, 1); vec_push(a1, 1); vec_push(a1, 1);
    vec_push(a1, 2); vec_push(a1, 2);
    vec_push(a1, 3);
    let e1 = rle_enc(a1, 6);
    let _p1 = println(num_runs(e1));                // 3
    let _p2 = println(vec_get(e1, 0));              // 1
    let _p3 = println(vec_get(e1, 1));              // 3
    let _p4 = println(vec_get(e1, 2));              // 2
    let _p5 = println(vec_get(e1, 3));              // 2
    let _p6 = println(vec_get(e1, 4));              // 3
    let _p7 = println(vec_get(e1, 5));              // 1
    let d1 = rle_dec(e1);
    let _p8 = println(vec_len(d1));                 // 6
    let _p9 = println(check_eq(a1, d1, 6));         // 1

    // Test 2: All same [7,7,7,7,7] -> (7,5)
    let a2 = vec_new();
    vec_push(a2, 7); vec_push(a2, 7); vec_push(a2, 7);
    vec_push(a2, 7); vec_push(a2, 7);
    let e2 = rle_enc(a2, 5);
    let _p10 = println(num_runs(e2));               // 1
    let _p11 = println(vec_get(e2, 0));             // 7
    let _p12 = println(vec_get(e2, 1));             // 5
    let d2 = rle_dec(e2);
    let _p13 = println(check_eq(a2, d2, 5));        // 1

    // Test 3: All different [1,2,3,4,5] -> 5 pairs (worst case)
    let a3 = vec_new();
    vec_push(a3, 1); vec_push(a3, 2); vec_push(a3, 3);
    vec_push(a3, 4); vec_push(a3, 5);
    let e3 = rle_enc(a3, 5);
    let _p14 = println(num_runs(e3));               // 5
    let _p15 = println(vec_len(e3));                // 10
    let d3 = rle_dec(e3);
    let _p16 = println(check_eq(a3, d3, 5));        // 1

    // Test 4: Alternating [5,5,3,3,3,1,5,5,5,5]
    // -> (5,2)(3,3)(1,1)(5,4) = 4 runs
    let a4 = vec_new();
    vec_push(a4, 5); vec_push(a4, 5);
    vec_push(a4, 3); vec_push(a4, 3); vec_push(a4, 3);
    vec_push(a4, 1);
    vec_push(a4, 5); vec_push(a4, 5); vec_push(a4, 5); vec_push(a4, 5);
    let e4 = rle_enc(a4, 10);
    let _p17 = println(num_runs(e4));               // 4
    let _p18 = println(vec_get(e4, 0));             // 5
    let _p19 = println(vec_get(e4, 1));             // 2
    let _p20 = println(vec_get(e4, 4));             // 1
    let _p21 = println(vec_get(e4, 5));             // 1
    let _p22 = println(vec_get(e4, 6));             // 5
    let _p23 = println(vec_get(e4, 7));             // 4
    let d4 = rle_dec(e4);
    let _p24 = println(vec_len(d4));                // 10
    let _p25 = println(check_eq(a4, d4, 10));       // 1

    // Sum preservation check
    let sum_orig = vec_total(a4, 10);
    let sum_dec = vec_total(d4, 10);
    let _p26 = println(sum_orig);                   // 40
    let _p27 = println(sum_dec);                    // 40

    // Test 5: Single element [42]
    let a5 = vec_new();
    vec_push(a5, 42);
    let e5 = rle_enc(a5, 1);
    let _p28 = println(num_runs(e5));               // 1
    let _p29 = println(vec_get(e5, 0));             // 42
    let _p30 = println(vec_get(e5, 1));             // 1
    let d5 = rle_dec(e5);
    let _p31 = println(vec_get(d5, 0));             // 42
    let _p32 = println(vec_len(d5));                // 1

    vec_free(a1); vec_free(e1); vec_free(d1);
    vec_free(a2); vec_free(e2); vec_free(d2);
    vec_free(a3); vec_free(e3); vec_free(d3);
    vec_free(a4); vec_free(e4); vec_free(d4);
    vec_free(a5); vec_free(e5); vec_free(d5);
    0
    };

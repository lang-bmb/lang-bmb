// Golden test: Matrix operations using flat vecs
// Tests nested loop patterns with index arithmetic

// Matrix stored as flat vec: mat[i*cols + j]
// All matrices are square (n x n)

fn mat_get(mat: i64, n: i64, row: i64, col: i64) -> i64 =
    vec_get(mat, row * n + col);

    // Matrix multiply: C = A * B (both n x n)

fn mat_mul_elem(a: i64, b: i64, n: i64, row: i64, col: i64, k: i64, acc: i64) -> i64 =
    if k >= n { acc }
    else {
        let prod = mat_get(a, n, row, k) * mat_get(b, n, k, col);
        mat_mul_elem(a, b, n, row, col, k + 1, acc + prod)
    };

fn mat_mul_row(a: i64, b: i64, n: i64, row: i64, col: i64, result: i64) -> i64 =
    if col >= n { result }
    else {
        let val = mat_mul_elem(a, b, n, row, col, 0, 0);
        let _s = vec_set(result, row * n + col, val);
        mat_mul_row(a, b, n, row, col + 1, result)
    };

fn mat_mul_rows(a: i64, b: i64, n: i64, row: i64, result: i64) -> i64 =
    if row >= n { result }
    else {
        let r = mat_mul_row(a, b, n, row, 0, result);
        mat_mul_rows(a, b, n, row + 1, r)
    };

    // Matrix trace (sum of diagonal)

fn mat_trace(mat: i64, n: i64, i: i64, acc: i64) -> i64 =
    if i >= n { acc }
    else { mat_trace(mat, n, i + 1, acc + mat_get(mat, n, i, i)) };

    // Matrix determinant for 2x2

fn det2x2(mat: i64) -> i64 =
    vec_get(mat, 0) * vec_get(mat, 3) - vec_get(mat, 1) * vec_get(mat, 2);

    // Matrix determinant for 3x3 (cofactor expansion along first row)

fn det3x3(mat: i64) -> i64 = {
    let a = vec_get(mat, 0); let b = vec_get(mat, 1); let c = vec_get(mat, 2);
    let d = vec_get(mat, 3); let e = vec_get(mat, 4); let f = vec_get(mat, 5);
    let g = vec_get(mat, 6); let h = vec_get(mat, 7); let ii = vec_get(mat, 8);
    a * (e * ii - f * h) - b * (d * ii - f * g) + c * (d * h - e * g)
    };

// Sum all elements
fn mat_sum(mat: i64, size: i64, pos: i64, acc: i64) -> i64 =
    if pos >= size { acc }
    else { mat_sum(mat, size, pos + 1, acc + vec_get(mat, pos)) };

    // Check if matrix is symmetric (a[i][j] == a[j][i])

fn is_symmetric_check(mat: i64, n: i64, i: i64, j: i64) -> i64 =
    if i >= n { 1 }
    else if j >= n { is_symmetric_check(mat, n, i + 1, i + 2) }
    else if mat_get(mat, n, i, j) != mat_get(mat, n, j, i) { 0 }
    else { is_symmetric_check(mat, n, i, j + 1) };

fn is_symmetric(mat: i64, n: i64) -> i64 =
    is_symmetric_check(mat, n, 0, 1);

fn make_vec4(a: i64, b: i64, c: i64, d: i64) -> i64 = {
    let v = vec_new();
    let _p1 = vec_push(v, a);
    let _p2 = vec_push(v, b);
    let _p3 = vec_push(v, c);
    let _p4 = vec_push(v, d);
    v
    };

fn make_vec9(a: i64, b: i64, c: i64, d: i64, e: i64, f: i64, g: i64, h: i64, ii: i64) -> i64 = {
    let v = vec_new();
    let _p1 = vec_push(v, a);
    let _p2 = vec_push(v, b);
    let _p3 = vec_push(v, c);
    let _p4 = vec_push(v, d);
    let _p5 = vec_push(v, e);
    let _p6 = vec_push(v, f);
    let _p7 = vec_push(v, g);
    let _p8 = vec_push(v, h);
    let _p9 = vec_push(v, ii);
    v
    };

fn make_zeros9() -> i64 = {
    let v = vec_new();
    for _i in 0..9 { let _p = vec_push(v, 0); 0 };
    v
    };

fn main() -> i64 = {
// Identity matrix 3x3
    let id3 = make_vec9(1, 0, 0, 0, 1, 0, 0, 0, 1);
    let _p1 = println(mat_trace(id3, 3, 0, 0));  // 3
    let _p2 = println(det3x3(id3));               // 1

// 2x2 matrix
    let m2 = make_vec4(1, 2, 3, 4);
    let _p3 = println(det2x2(m2));  // 1*4 - 2*3 = -2

// 3x3 matrix
    let m3 = make_vec9(2, 1, 0, 1, 3, 1, 0, 1, 2);
    let _p4 = println(det3x3(m3));               // 2*(6-1) - 1*(2-0) + 0 = 10-2 = 8
    let _p5 = println(mat_trace(m3, 3, 0, 0));   // 2+3+2 = 7
    let _p6 = println(mat_sum(m3, 9, 0, 0));     // 2+1+0+1+3+1+0+1+2 = 11

// Matrix multiply: I * m3 = m3
    let result = make_zeros9();
    let r = mat_mul_rows(id3, m3, 3, 0, result);
    let _p7 = println(mat_get(r, 3, 0, 0));  // 2
    let _p8 = println(mat_get(r, 3, 1, 1));  // 3
    let _p9 = println(mat_get(r, 3, 2, 2));  // 2

// Matrix multiply: m3 * m3
    let result2 = make_zeros9();
    let r2 = mat_mul_rows(m3, m3, 3, 0, result2);

// [2,1,0] * [2,1,0;1,3,1;0,1,2] = [5,5,1]
    let _p10 = println(mat_get(r2, 3, 0, 0));  // 2*2+1*1+0*0 = 5
    let _p11 = println(mat_get(r2, 3, 0, 1));  // 2*1+1*3+0*1 = 5
    let _p12 = println(mat_get(r2, 3, 0, 2));  // 2*0+1*1+0*2 = 1

// Symmetric check
    let sym = make_vec9(1, 2, 3, 2, 4, 5, 3, 5, 6);
    let _p13 = println(is_symmetric(sym, 3));  // 1 (symmetric)
    let asym = make_vec9(1, 2, 3, 4, 5, 6, 7, 8, 9);
    let _p14 = println(is_symmetric(asym, 3)); // 0 (not symmetric)

    let _f1 = vec_free(id3);
    let _f2 = vec_free(m2);
    let _f3 = vec_free(m3);
    let _f4 = vec_free(result);
    let _f5 = vec_free(result2);
    let _f6 = vec_free(sym);
    let _f7 = vec_free(asym);
    0
    };

// Golden Test: Dutch National Flag algorithm (three-way partition)
// Partitions array into elements < pivot, == pivot, > pivot
// Single pass O(n) using three pointers (lo, mid, hi)
// Based on Dijkstra's Dutch National Flag problem

// Print all elements of a vec on separate lines
fn print_vec(v: i64) -> i64 = {
    let n = vec_len(v);
    for i in 0..n {
        let _p = println(vec_get(v, i));
        0
    };
    0
};

// Print vec as inline list with label
fn print_vec_inline(v: i64) -> i64 = {
    let n = vec_len(v);
    for i in 0..n {
        let _p = if i > 0 {
            let _s = print_str(" ");
            ()
        } else { () };
        let _p2 = print(vec_get(v, i));
        0
    };
    let _p = println_str("");
    0
};

// Swap two elements in a vec
fn swap(v: i64, i: i64, j: i64) -> i64 = {
    let tmp = vec_get(v, i);
    let _s1 = vec_set(v, i, vec_get(v, j));
    let _s2 = vec_set(v, j, tmp);
    0
};

// Dutch National Flag: partition vec into < pivot, == pivot, > pivot
// Uses three pointers: lo, mid, hi
// After: v[0..lo) < pivot, v[lo..mid) == pivot, v[hi+1..n) > pivot
fn dutch_flag(v: i64, pivot: i64) -> i64 = {
    let n = vec_len(v);
    let mut lo = 0;
    let mut mid = 0;
    let mut hi = n - 1;

    while mid <= hi {
        let val = vec_get(v, mid);
        let _c = if val < pivot {
            let _s = swap(v, lo, mid);
            set lo = lo + 1;
            set mid = mid + 1
        } else if val > pivot {
            let _s = swap(v, mid, hi);
            set hi = hi - 1
        } else {
            // val == pivot
            set mid = mid + 1
        }
    };
    0
};

// Helper to build vec from 9 elements
fn make9(a: i64, b: i64, c: i64, d: i64, e: i64, f: i64, g: i64, h: i64, ii: i64) -> i64 = {
    let v = vec_new();
    let _p = vec_push(v, a); let _p = vec_push(v, b);
    let _p = vec_push(v, c); let _p = vec_push(v, d);
    let _p = vec_push(v, e); let _p = vec_push(v, f);
    let _p = vec_push(v, g); let _p = vec_push(v, h);
    let _p = vec_push(v, ii);
    v
};

// Helper to build vec from 8 elements
fn make8(a: i64, b: i64, c: i64, d: i64, e: i64, f: i64, g: i64, h: i64) -> i64 = {
    let v = vec_new();
    let _p = vec_push(v, a); let _p = vec_push(v, b);
    let _p = vec_push(v, c); let _p = vec_push(v, d);
    let _p = vec_push(v, e); let _p = vec_push(v, f);
    let _p = vec_push(v, g); let _p = vec_push(v, h);
    v
};

fn main() -> i64 = {
    // === Test 1: [2,0,1,2,1,0,0,2,1], pivot=1 ===
    let _p = println_str("=== Test 1: pivot=1 ===");
    let _p = print_str("before: ");
    let v1 = make9(2, 0, 1, 2, 1, 0, 0, 2, 1);
    let _pv = print_vec_inline(v1);
    let _d = dutch_flag(v1, 1);
    let _p = print_str("after:  ");
    let _pv = print_vec_inline(v1);
    // Expected: all 0s first, then 1s, then 2s

    // === Test 2: [3,1,4,1,5,9,2,6], pivot=3 ===
    let _p = println_str("=== Test 2: pivot=3 ===");
    let _p = print_str("before: ");
    let v2 = make8(3, 1, 4, 1, 5, 9, 2, 6);
    let _pv = print_vec_inline(v2);
    let _d = dutch_flag(v2, 3);
    let _p = print_str("after:  ");
    let _pv = print_vec_inline(v2);
    // Expected: [1,1,2] < 3, [3] == 3, [4,5,9,6] > 3

    // === Test 3: All same elements [5,5,5,5], pivot=5 ===
    let _p = println_str("=== Test 3: all same ===");
    let v3 = vec_new();
    let _p = vec_push(v3, 5); let _p = vec_push(v3, 5);
    let _p = vec_push(v3, 5); let _p = vec_push(v3, 5);
    let _d = dutch_flag(v3, 5);
    let _p = print_str("after:  ");
    let _pv = print_vec_inline(v3);

    // === Test 4: Already partitioned [1,2,3,4,5], pivot=3 ===
    let _p = println_str("=== Test 4: sorted input ===");
    let v4 = vec_new();
    let _p = vec_push(v4, 1); let _p = vec_push(v4, 2);
    let _p = vec_push(v4, 3); let _p = vec_push(v4, 4);
    let _p = vec_push(v4, 5);
    let _d = dutch_flag(v4, 3);
    let _p = print_str("after:  ");
    let _pv = print_vec_inline(v4);

    // === Test 5: Reverse sorted [5,4,3,2,1], pivot=3 ===
    let _p = println_str("=== Test 5: reverse sorted ===");
    let v5 = vec_new();
    let _p = vec_push(v5, 5); let _p = vec_push(v5, 4);
    let _p = vec_push(v5, 3); let _p = vec_push(v5, 2);
    let _p = vec_push(v5, 1);
    let _d = dutch_flag(v5, 3);
    let _p = print_str("after:  ");
    let _pv = print_vec_inline(v5);

    // === Test 6: Single element [7], pivot=7 ===
    let _p = println_str("=== Test 6: single element ===");
    let v6 = vec_new();
    let _p = vec_push(v6, 7);
    let _d = dutch_flag(v6, 7);
    let _p = print_str("after:  ");
    let _pv = print_vec_inline(v6);

    // === Test 7: Pivot not in array [3,1,4,5,2], pivot=0 ===
    let _p = println_str("=== Test 7: pivot not in array ===");
    let v7 = vec_new();
    let _p = vec_push(v7, 3); let _p = vec_push(v7, 1);
    let _p = vec_push(v7, 4); let _p = vec_push(v7, 5);
    let _p = vec_push(v7, 2);
    let _d = dutch_flag(v7, 0);
    let _p = print_str("after:  ");
    let _pv = print_vec_inline(v7);
    // All elements > 0, so unchanged order relative to each other

    // Verify partition invariant for Test 1
    // Count elements in each partition
    let _p = println_str("=== Verify Test 1 partition ===");
    let mut count_less = 0;
    let mut count_equal = 0;
    let mut count_greater = 0;
    for i in 0..vec_len(v1) {
        let val = vec_get(v1, i);
        let _c = if val < 1 {
            set count_less = count_less + 1
        } else if val == 1 {
            set count_equal = count_equal + 1
        } else {
            set count_greater = count_greater + 1
        }
    };
    let _p = print_str("less: "); let _p = println(count_less);
    let _p = print_str("equal: "); let _p = println(count_equal);
    let _p = print_str("greater: "); let _p = println(count_greater);

    // Cleanup
    let _f = vec_free(v1); let _f = vec_free(v2);
    let _f = vec_free(v3); let _f = vec_free(v4);
    let _f = vec_free(v5); let _f = vec_free(v6);
    let _f = vec_free(v7);
    0
};

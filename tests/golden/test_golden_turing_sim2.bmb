// Golden test: Extended Turing machine simulation
// Expected output: 90

// Multi-state Turing machine: binary increment
// States: 0(start), 1(carry), 2(done), 3(halt)
// Tape alphabet: 0, 1, blank(9)

fn get_tape(tape: i64, pos: i64, len: i64) -> i64 = {
    if pos < 0 { 9 }
    else if pos >= len { 9 }
    else {
        let idx = len - 1 - pos;
        (tape / pow10(idx)) % 10
    }
    };

fn set_tape_val(tape: i64, pos: i64, len: i64, val: i64) -> i64 = {
    if pos < 0 { tape }
    else if pos >= len { tape }
    else {
        let idx = len - 1 - pos;
        let divisor = pow10(idx);
        let digit_old = (tape / divisor) % 10;
        tape - digit_old * divisor + val * divisor
    }
    };

fn pow10(n: i64) -> i64 = {
    if n == 0 { 1 }
    else if n == 1 { 10 }
    else if n == 2 { 100 }
    else if n == 3 { 1000 }
    else if n == 4 { 10000 }
    else if n == 5 { 100000 }
    else { 1000000 }
    };

fn turing_step(state: i64, symbol: i64, tape: i64, pos: i64, len: i64) -> i64 = {
// Returns: new_state * 1000000 + new_symbol * 10000 + direction * 100 + new_tape
// Direction: 0=left, 1=right, 2=stay

// Increment algorithm:
// State 0 (start): move right to end
// State 1 (carry): handle carry propagation moving left
// State 2 (done): halt

    if state == 0 {

// Start state: move right until blank
    if symbol == 9 {

// Found end, go to carry state, move left
    1 * 1000000 + 9 * 10000 + 0 * 100 + tape
    } else {

// Keep moving right
    0 * 1000000 + symbol * 10000 + 1 * 100 + tape
    }
    } else if state == 1 {

// Carry state: increment from right
    if symbol == 9 {

// Blank: write 1, done
    let new_tape = set_tape_val(tape, pos, len, 1);
    2 * 1000000 + 1 * 10000 + 2 * 100 + (new_tape % 100)
    } else if symbol == 1 {

// 1 + carry = 0, continue carry
    let new_tape = set_tape_val(tape, pos, len, 0);
    1 * 1000000 + 0 * 10000 + 0 * 100 + (new_tape % 100)
    } else {

// 0 + carry = 1, done
    let new_tape = set_tape_val(tape, pos, len, 1);
    2 * 1000000 + 1 * 10000 + 2 * 100 + (new_tape % 100)
    }
    } else {

// Halt state
    2 * 1000000 + symbol * 10000 + 2 * 100 + tape
    }
    };

fn simulate_turing(initial_tape: i64, len: i64, max_steps: i64) -> i64 = {
    let state = [0; 1];
    let pos = [0; 1];
    let tape = [0; 1];
    set tape[0] = initial_tape;
    let steps = [0; 1];

    while steps[0] < max_steps {
        if state[0] == 2 { break; } else { };

        let symbol = get_tape(tape[0], pos[0], len);
        let result = turing_step(state[0], symbol, tape[0], pos[0], len);

        let new_state = result / 1000000;
        let direction = (result / 100) % 100;

        set state[0] = new_state;
        set tape[0] = result % 100;

        if direction == 0 {
            set pos[0] = pos[0] - 1;
        } else if direction == 1 {
        set pos[0] = pos[0] + 1;
    } else { };

    set steps[0] = steps[0] + 1;
    };

    tape[0]
    };

fn main() -> i64 = {
// Test binary increment
// Input: 0 -> Output: 1
    let r1 = simulate_turing(0, 1, 10);
    println(r1);

// Input: 1 -> Output: 10 (binary 2)
    let r2 = simulate_turing(1, 1, 10);
    println(r2);

// Input: 10 -> Output: 11
    let r3 = simulate_turing(10, 2, 10);
    println(r3);

// Input: 11 -> Output: 100 (binary 4)... but limited len
// Actually with len=2, might overflow. Let's see:
    let r4 = simulate_turing(11, 2, 10);
    println(r4);

// Input: 101 -> Output: 110
    let r5 = simulate_turing(101, 3, 10);
    println(r5);

// Input: 111 -> Output: 1000 (overflow in len=3)
    let r6 = simulate_turing(111, 3, 10);
    println(r6);

// More tests
    let r7 = simulate_turing(100, 3, 10); // 100 -> 101
    println(r7);

    let r8 = simulate_turing(110, 3, 10); // 110 -> 111
    println(r8);

    let r9 = simulate_turing(1010, 4, 20); // 1010 -> 1011
    println(r9);

    let r10 = simulate_turing(1111, 4, 20); // 1111 -> 10000 (overflow)
    println(r10);

// Sum calculation
    let sum = r1 + r2 + r3 + r4 + r5 + r6 + r7 + r8 + r9 + r10;
    println(sum);

// Sum: 1+0+11+0+10+0+1+11+11+0+45 = 90
    0
    };

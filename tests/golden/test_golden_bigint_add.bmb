// Golden test: Big integer addition/subtraction using digit arrays
// Base 10^9, little-endian order (digit[0] = least significant)

fn bi_from(val: i64) -> i64 = {
    let v = vec_new();
    let base = 1000000000;
    if val == 0 { vec_push(v, 0); v }
    else {
        let _p = if val >= base {
            vec_push(v, val - val / base * base); vec_push(v, val / base); ()
        } else { vec_push(v, val); () };
        v
    }
};

fn bi_digit(v: i64, i: i64) -> i64 =
    if i < vec_len(v) { vec_get(v, i) } else { 0 };

fn bi_add(a: i64, b: i64) -> i64 = {
    let base = 1000000000;
    let ml = if vec_len(a) > vec_len(b) { vec_len(a) } else { vec_len(b) };
    let r = vec_new();
    let mut carry = 0;
    for i in 0..ml {
        let sum = bi_digit(a, i) + bi_digit(b, i) + carry;
        let _p = if sum >= base { vec_push(r, sum - base); set carry = 1; () }
        else { vec_push(r, sum); set carry = 0; () };
        0
    };
    if carry > 0 { vec_push(r, carry) } else { () };
    r
};

fn bi_cmp(a: i64, b: i64) -> i64 = {
    let la = vec_len(a);
    let lb = vec_len(b);
    if la > lb { 1 } else if la < lb { 0 - 1 } else {
        let mut res = 0;
        let mut dec = 0;
        let mut idx = la - 1;
        loop {
            if idx < 0 { break } else { () };
            if dec == 0 {
                let da = vec_get(a, idx);
                let db = vec_get(b, idx);
                let _c = if da > db { set res = 1; set dec = 1 }
                else if da < db { set res = 0 - 1; set dec = 1 } else { () };
                0
            } else { 0 };
            set idx = idx - 1
        }; res
    }
};

fn bi_sub(a: i64, b: i64) -> i64 = {
    let base = 1000000000;
    let la = vec_len(a);
    let r = vec_new();
    let mut borrow = 0;
    for i in 0..la {
        let diff = bi_digit(a, i) - bi_digit(b, i) - borrow;
        let _p = if diff < 0 { vec_push(r, diff + base); set borrow = 1; () }
        else { vec_push(r, diff); set borrow = 0; () };
        0
    };
    // Trim trailing zeros
    let mut rl = vec_len(r);
    loop {
        if rl <= 1 { break } else { () };
        if vec_get(r, rl - 1) == 0 { set rl = rl - 1 } else { break }
    };
    let t = vec_new();
    for i in 0..rl { vec_push(t, vec_get(r, i)); 0 };
    vec_free(r); t
};

fn bi_print(v: i64) -> i64 = {
    let n = vec_len(v);
    println(vec_get(v, n - 1));
    let mut idx = n - 2;
    loop {
        if idx < 0 { break } else { () };
        println(vec_get(v, idx));
        set idx = idx - 1
    }; 0
};

fn main() -> i64 = {
    // 123 + 456 = 579
    let c1 = bi_add(bi_from(123), bi_from(456));
    bi_print(c1);
    // 999999999 + 1 crosses base boundary
    let c2 = bi_add(bi_from(999999999), bi_from(1));
    println(vec_len(c2)); bi_print(c2);
    // 1000000000 + 999999999 = 1999999999
    let c3 = bi_add(bi_from(1000000000), bi_from(999999999));
    bi_print(c3);
    // Compare
    println(bi_cmp(bi_from(100), bi_from(200)));
    println(bi_cmp(bi_from(200), bi_from(100)));
    println(bi_cmp(bi_from(100), bi_from(100)));
    // 1000 - 1 = 999
    let c5 = bi_sub(bi_from(1000), bi_from(1));
    bi_print(c5);
    // 1000000000 - 1 = 999999999
    let c6 = bi_sub(bi_from(1000000000), bi_from(1));
    bi_print(c6);
    // 42 - 42 = 0
    let c7 = bi_sub(bi_from(42), bi_from(42));
    bi_print(c7);
    // Add zero
    let c8 = bi_add(bi_from(12345), bi_from(0));
    bi_print(c8);
    // Multi-chunk compare
    println(bi_cmp(bi_from(2000000000), bi_from(1999999999)));
    // Chain: 100+200+300=600
    let c9 = bi_add(bi_add(bi_from(100), bi_from(200)), bi_from(300));
    bi_print(c9);
    0
};

// Test file for lint command - intentionally has lint issues

fn unusedHelper(x: i64) -> i64 = x + 1;

fn tooManyParams(a: i64, b: i64, c: i64, d: i64, e: i64, f: i64, g: i64) -> i64 =
    a + b + c + d + e + f + g;

fn camelCase(x: i64) -> i64 = x * 2;

fn good_function(x: i64) -> i64 = x + 1;

fn main() -> i64 =
    let result = good_function(5);
    let param_test = tooManyParams(1, 2, 3, 4, 5, 6, 7);
    let style = camelCase(3);
    let _p = print(result + param_test + style);
    0;

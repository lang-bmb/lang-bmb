// Golden Test: Morse Code digit encoding
// Each digit 0-9 has a 5-symbol morse pattern (dots=0, dashes=1)
// Encode pattern as 5-bit integer: MSB first, dot=0, dash=1
// 0: ----- = 11111 = 31
// 1: .---- = 01111 = 15
// 2: ..--- = 00111 = 7
// 3: ...-- = 00011 = 3
// 4: ....- = 00001 = 1
// 5: ..... = 00000 = 0
// 6: -.... = 10000 = 16
// 7: --... = 11000 = 24
// 8: ---.. = 11100 = 28
// 9: ----. = 11110 = 30

// Get morse code pattern for digit d (0-9) as 5-bit integer
fn morse_digit(d: i64) -> i64 = {
    if d == 0 { 31 }
    else if d == 1 { 15 }
    else if d == 2 { 7 }
    else if d == 3 { 3 }
    else if d == 4 { 1 }
    else if d == 5 { 0 }
    else if d == 6 { 16 }
    else if d == 7 { 24 }
    else if d == 8 { 28 }
    else if d == 9 { 30 }
    else { 0 }
    };

// Count dashes in a morse digit pattern
fn count_dashes(d: i64) -> i64 = {
    let pattern = morse_digit(d);
    let mut count = 0;
    let mut i = 0;
    loop {
        if i >= 5 { break } else { () };
        if (pattern >> i) band 1 == 1 {
            count = count + 1
        } else { () };
        i = i + 1
    };
    count
    };

// Encode a multi-digit number as concatenated morse patterns
// Each digit contributes 5 bits, packed left to right
fn encode_number(n: i64, num_digits: i64) -> i64 = {
    // Extract digits right-to-left, then pack left-to-right
    let digits = [0, 0, 0, 0, 0, 0, 0, 0];
    let mut val = n;
    let mut i = num_digits - 1;
    loop {
        if i < 0 { break } else { () };
        set digits[i] = val - (val / 10) * 10;
        val = val / 10;
        i = i - 1
    };
    // Pack: digit[0] in highest bits
    let mut result = 0;
    let mut j = 0;
    loop {
        if j >= num_digits { break } else { () };
        result = (result << 5) bor morse_digit(digits[j]);
        j = j + 1
    };
    result
    };

// Total dashes across all digits 0-9
fn total_dashes_all_digits() -> i64 = {
    let mut total = 0;
    let mut d = 0;
    loop {
        if d > 9 { break } else { () };
        total = total + count_dashes(d);
        d = d + 1
    };
    total
    };

// XOR of all digit morse patterns
fn xor_all_patterns() -> i64 = {
    let mut result = 0;
    let mut d = 0;
    loop {
        if d > 9 { break } else { () };
        result = result bxor morse_digit(d);
        d = d + 1
    };
    result
    };

fn main() -> i64 = {
    // Morse pattern for digit 0: ----- = 31
    let _p1 = println(morse_digit(0));     // 31

    // Morse pattern for digit 5: ..... = 0
    let _p2 = println(morse_digit(5));     // 0

    // Morse pattern for digit 9: ----. = 30
    let _p3 = println(morse_digit(9));     // 30

    // Dashes in digit 0: 5 dashes
    let _p4 = println(count_dashes(0));    // 5

    // Dashes in digit 5: 0 dashes (all dots)
    let _p5 = println(count_dashes(5));    // 0

    // Dashes in digit 3: 2 dashes (...--)
    let _p6 = println(count_dashes(3));    // 2

    // Total dashes for all digits 0-9
    // 5+4+3+2+1+0+1+2+3+4 = 25
    let _p7 = println(total_dashes_all_digits()); // 25

    // Encode "42" (2 digits): morse(4)=00001, morse(2)=00111
    // Packed: 00001_00111 = 0b0000100111 = 39
    let _p8 = println(encode_number(42, 2));  // 39

    // Encode "10" (2 digits): morse(1)=01111, morse(0)=11111
    // Packed: 01111_11111 = 0b0111111111 = 511
    let _p9 = println(encode_number(10, 2));  // 511

    // XOR of all 10 digit patterns
    // 31^15^7^3^1^0^16^24^28^30 = 31
    let _p10 = println(xor_all_patterns());   // 31

    0
    };

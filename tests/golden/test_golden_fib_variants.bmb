// Golden Test: Fibonacci variants (tribonacci + generalized)
// Tribonacci: T(n) = T(n-1) + T(n-2) + T(n-3), T(0)=0, T(1)=0, T(2)=1
// Also: k-bonacci generalization

fn tribonacci(n: i64) -> i64 = {
    if n == 0 { 0 }
    else if n == 1 { 0 }
    else if n == 2 { 1 }
    else {
        let mut a = 0;
        let mut b = 0;
        let mut c = 1;
        let mut i = 3;
        while i <= n {
            let next = a + b + c;
            set a = b;
            set b = c;
            set c = next;
            set i = i + 1
        };
        c
    }
};

// k-bonacci: sum of previous k terms
fn kbonacci(n: i64, k: i64) -> i64 = {
    let terms = vec_new();
    let mut i = 0;
    while i < k - 1 {
        let _p = vec_push(terms, 0);
        set i = i + 1
    };
    let _p = vec_push(terms, 1);
    if n < k { vec_get(terms, n) }
    else {
        set i = k;
        while i <= n {
            let mut sum = 0;
            let mut j = 0;
            while j < k {
                set sum = sum + vec_get(terms, vec_len(terms) - k + j);
                set j = j + 1
            };
            let _p = vec_push(terms, sum);
            set i = i + 1
        };
        vec_get(terms, n)
    }
};

fn main() -> () = {
    // Tribonacci: 0 0 1 1 2 4 7 13 24 44 81 149
    print_str("trib:");
    let mut i = 0;
    while i < 12 {
        print_str(" "); print(tribonacci(i));
        set i = i + 1
    };
    print_str("
");

    // Fibonacci via 2-bonacci
    print_str("fib:");
    set i = 0;
    while i < 10 {
        print_str(" "); print(kbonacci(i, 2));
        set i = i + 1
    };
    print_str("
");

    // Tetranacci via 4-bonacci: 0 0 0 1 1 2 4 8 15 29
    print_str("tetra:");
    set i = 0;
    while i < 10 {
        print_str(" "); print(kbonacci(i, 4));
        set i = i + 1
    };
    print_str("
");

    // Verify tribonacci == 3-bonacci
    print_str("match:");
    set i = 0;
    while i < 10 {
        let _x = if tribonacci(i) == kbonacci(i, 3) {
            print_str(" 1");
            0
        } else {
            print_str(" 0");
            0
        };
        set i = i + 1
    };
    let _nl = print_str("
")
};

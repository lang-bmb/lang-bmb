// Golden Test: Longest Common Subsequence (LCS) using DP
// Finds the length of the longest common subsequence of two integer sequences

fn max2(a: i64, b: i64) -> i64 = if a > b { a } else { b };

// LCS length between two vec-encoded sequences
fn lcs_length(a: i64, n: i64, b: i64, m: i64) -> i64 = {
    let cols = m + 1;
    let dp = vec_new();
    // Initialize (n+1)*(m+1) table to 0
    for _k in 0..(n + 1) * cols {
        vec_push(dp, 0)
    };
    // Fill DP table
    for i in 1..n + 1 {
        for j in 1..m + 1 {
            let val = if vec_get(a, i - 1) == vec_get(b, j - 1) {
                vec_get(dp, (i - 1) * cols + (j - 1)) + 1
            } else {
                max2(vec_get(dp, (i - 1) * cols + j), vec_get(dp, i * cols + (j - 1)))
            };
            vec_set(dp, i * cols + j, val)
        }
    };
    let result = vec_get(dp, n * cols + m);
    vec_free(dp);
    result
};

// Reconstruct the LCS (returns vec of the subsequence elements)
fn lcs_reconstruct(a: i64, n: i64, b: i64, m: i64) -> i64 = {
    let cols = m + 1;
    let dp = vec_new();
    for _k in 0..(n + 1) * cols {
        vec_push(dp, 0)
    };
    for i in 1..n + 1 {
        for j in 1..m + 1 {
            let val = if vec_get(a, i - 1) == vec_get(b, j - 1) {
                vec_get(dp, (i - 1) * cols + (j - 1)) + 1
            } else {
                max2(vec_get(dp, (i - 1) * cols + j), vec_get(dp, i * cols + (j - 1)))
            };
            vec_set(dp, i * cols + j, val)
        }
    };
    // Backtrack to find the actual subsequence
    let lcs = vec_new();
    let mut i = n;
    let mut j = m;
    loop {
        if i == 0 { break } else { () };
        if j == 0 { break } else { () };
        if vec_get(a, i - 1) == vec_get(b, j - 1) {
            vec_push(lcs, vec_get(a, i - 1));
            i = i - 1;
            j = j - 1
        } else if vec_get(dp, (i - 1) * cols + j) > vec_get(dp, i * cols + (j - 1)) {
            i = i - 1
        } else {
            j = j - 1
        }
    };
    vec_free(dp);
    // Reverse lcs (it was built backwards)
    let len = vec_len(lcs);
    let mut lo = 0;
    let mut hi = len - 1;
    loop {
        if lo >= hi { break } else { () };
        let tmp = vec_get(lcs, lo);
        vec_set(lcs, lo, vec_get(lcs, hi));
        vec_set(lcs, hi, tmp);
        lo = lo + 1;
        hi = hi - 1
    };
    lcs
};

fn main() -> i64 = {
    // Test 1: [1,3,4,1,2,1,3] vs [3,4,1,2,1,3,1] -> LCS length = 5
    let a1 = vec_new();
    vec_push(a1, 1); vec_push(a1, 3); vec_push(a1, 4); vec_push(a1, 1);
    vec_push(a1, 2); vec_push(a1, 1); vec_push(a1, 3);
    let b1 = vec_new();
    vec_push(b1, 3); vec_push(b1, 4); vec_push(b1, 1); vec_push(b1, 2);
    vec_push(b1, 1); vec_push(b1, 3); vec_push(b1, 1);
    let _p1 = println(lcs_length(a1, 7, b1, 7));  // 5

    // Test 2: Identical sequences [1,2,3,4] vs [1,2,3,4] -> 4
    let a2 = vec_new();
    vec_push(a2, 1); vec_push(a2, 2); vec_push(a2, 3); vec_push(a2, 4);
    let b2 = vec_new();
    vec_push(b2, 1); vec_push(b2, 2); vec_push(b2, 3); vec_push(b2, 4);
    let _p2 = println(lcs_length(a2, 4, b2, 4));  // 4

    // Test 3: Completely different [1,2,3] vs [4,5,6] -> 0
    let a3 = vec_new();
    vec_push(a3, 1); vec_push(a3, 2); vec_push(a3, 3);
    let b3 = vec_new();
    vec_push(b3, 4); vec_push(b3, 5); vec_push(b3, 6);
    let _p3 = println(lcs_length(a3, 3, b3, 3));  // 0

    // Test 4: Empty vs non-empty -> 0
    let a4 = vec_new();
    let b4 = vec_new();
    vec_push(b4, 1); vec_push(b4, 2);
    let _p4 = println(lcs_length(a4, 0, b4, 2));  // 0

    // Test 5: [1,2,3,4,5] vs [2,4,5] -> 3 (LCS is [2,4,5])
    let a5 = vec_new();
    vec_push(a5, 1); vec_push(a5, 2); vec_push(a5, 3); vec_push(a5, 4); vec_push(a5, 5);
    let b5 = vec_new();
    vec_push(b5, 2); vec_push(b5, 4); vec_push(b5, 5);
    let _p5 = println(lcs_length(a5, 5, b5, 3));  // 3

    // Test 6: Reconstruct LCS of [1,2,3,4,5] vs [2,4,5]
    let lcs = lcs_reconstruct(a5, 5, b5, 3);
    let _p6 = println(vec_len(lcs));        // 3
    let _p7 = println(vec_get(lcs, 0));     // 2
    let _p8 = println(vec_get(lcs, 1));     // 4
    let _p9 = println(vec_get(lcs, 2));     // 5

    // Test 7: [5,3,4,1,2] vs [3,5,1,4,2] -> LCS length = 3
    let a7 = vec_new();
    vec_push(a7, 5); vec_push(a7, 3); vec_push(a7, 4); vec_push(a7, 1); vec_push(a7, 2);
    let b7 = vec_new();
    vec_push(b7, 3); vec_push(b7, 5); vec_push(b7, 1); vec_push(b7, 4); vec_push(b7, 2);
    let _p10 = println(lcs_length(a7, 5, b7, 5));  // 3

    // Test 8: Single element common [1] vs [1] -> 1
    let a8 = vec_new(); vec_push(a8, 1);
    let b8 = vec_new(); vec_push(b8, 1);
    let _p11 = println(lcs_length(a8, 1, b8, 1));  // 1

    vec_free(a1); vec_free(b1); vec_free(a2); vec_free(b2);
    vec_free(a3); vec_free(b3); vec_free(a4); vec_free(b4);
    vec_free(a5); vec_free(b5); vec_free(lcs);
    vec_free(a7); vec_free(b7); vec_free(a8); vec_free(b8);
    0
};

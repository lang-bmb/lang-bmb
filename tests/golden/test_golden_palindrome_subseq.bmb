// Golden Test: Longest Palindromic Subsequence (DP)
// Finds length of longest palindromic subsequence in integer array

fn lps(arr: i64, n: i64) -> i64 = {
    // dp[i][j] = LPS length for arr[i..j]
    let dp = vec_new();
    let mut i = 0;
    while i < n * n {
        let _p = vec_push(dp, 0);
        set i = i + 1
    };
    // Base: single elements
    set i = 0;
    while i < n {
        vec_set(dp, i * n + i, 1);
        set i = i + 1
    };
    // Fill diagonals
    let mut length = 2;
    while length <= n {
        set i = 0;
        while i <= n - length {
            let j = i + length - 1;
            let _x = if vec_get(arr, i) == vec_get(arr, j) and length == 2 {
                vec_set(dp, i * n + j, 2);
                0
            } else if vec_get(arr, i) == vec_get(arr, j) {
                vec_set(dp, i * n + j, vec_get(dp, (i + 1) * n + (j - 1)) + 2);
                0
            } else {
                let a = vec_get(dp, (i + 1) * n + j);
                let b = vec_get(dp, i * n + (j - 1));
                vec_set(dp, i * n + j, if a > b { a } else { b });
                0
            };
            set i = i + 1
        };
        set length = length + 1
    };
    vec_get(dp, 0 * n + (n - 1))
};

fn main() -> () = {
    // Test 1: [1,2,3,2,1] -> LPS=5 (entire sequence is palindrome)
    let a1 = vec_new();
    let _p = vec_push(a1, 1); let _p = vec_push(a1, 2);
    let _p = vec_push(a1, 3); let _p = vec_push(a1, 2);
    let _p = vec_push(a1, 1);
    print_str("lps1="); let _r = println(lps(a1, 5));

    // Test 2: [1,2,3,4,5] -> LPS=1
    let a2 = vec_new();
    let _p = vec_push(a2, 1); let _p = vec_push(a2, 2);
    let _p = vec_push(a2, 3); let _p = vec_push(a2, 4);
    let _p = vec_push(a2, 5);
    print_str("lps2="); let _r = println(lps(a2, 5));

    // Test 3: [1,3,5,3,1,5] -> LPS=5 (1,3,5,3,1)
    let a3 = vec_new();
    let _p = vec_push(a3, 1); let _p = vec_push(a3, 3);
    let _p = vec_push(a3, 5); let _p = vec_push(a3, 3);
    let _p = vec_push(a3, 1); let _p = vec_push(a3, 5);
    print_str("lps3="); let _r = println(lps(a3, 6));

    // Test 4: [1,1,1,1] -> LPS=4
    let a4 = vec_new();
    let _p = vec_push(a4, 1); let _p = vec_push(a4, 1);
    let _p = vec_push(a4, 1); let _p = vec_push(a4, 1);
    print_str("lps4="); let _r = println(lps(a4, 4))
};

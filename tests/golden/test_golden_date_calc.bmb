// Golden Test: Date calculations with contracts
// is_leap_year, days_in_month, day_of_year, total_days_in_year,
// days_remaining, nth_day_to_month

fn is_leap(y: i64) -> i64 pre y > 0 = {
    if y % 4 != 0 { 0 }
    else if y % 100 != 0 { 1 }
    else if y % 400 == 0 { 1 }
    else { 0 }
    };

fn month_days(m: i64, y: i64) -> i64 pre m >= 1 and m <= 12
    post ret >= 28 and ret <= 31 = {
    if m == 1 { 31 }
    else if m == 2 {
        if is_leap(y) == 1 { 29 } else { 28 }
    }
    else if m == 3 { 31 }
    else if m == 4 { 30 }
    else if m == 5 { 31 }
    else if m == 6 { 30 }
    else if m == 7 { 31 }
    else if m == 8 { 31 }
    else if m == 9 { 30 }
    else if m == 10 { 31 }
    else if m == 11 { 30 }
    else { 31 }
    };

// Sum days of all months in a year
fn total_days_helper(m: i64, y: i64, acc: i64) -> i64 =
    if m > 12 { acc }
    else { total_days_helper(m + 1, y, acc + month_days(m, y)) };

fn total_days_in_year(y: i64) -> i64 pre y > 0 =
    total_days_helper(1, y, 0);

// Day of year: sum days of prior months + day
fn doy_helper(m: i64, target_m: i64, y: i64, acc: i64) -> i64 =
    if m >= target_m { acc }
    else { doy_helper(m + 1, target_m, y, acc + month_days(m, y)) };

fn day_of_year(d: i64, m: i64, y: i64) -> i64
    pre m >= 1 and m <= 12 and d >= 1 =
    doy_helper(1, m, y, 0) + d;

// Days remaining in the year after a given date
fn days_remaining(d: i64, m: i64, y: i64) -> i64 =
    total_days_in_year(y) - day_of_year(d, m, y);

// Given a day number (1..366), find which month it falls in
fn nth_day_month_helper(day_num: i64, m: i64, y: i64, acc: i64) -> i64 =
    if m > 12 { 12 }
    else {
        let next_acc = acc + month_days(m, y);
        if day_num <= next_acc { m }
        else { nth_day_month_helper(day_num, m + 1, y, next_acc) }
    };

fn nth_day_to_month(day_num: i64, y: i64) -> i64 pre day_num >= 1 =
    nth_day_month_helper(day_num, 1, y, 0);

fn main() -> i64 = {
    // Leap year tests (with contract pre y > 0)
    let _p1 = println(is_leap(2000));          // 1
    let _p2 = println(is_leap(1900));          // 0

    // Days in month (with contracts pre m in [1,12], post ret in [28,31])
    let _p3 = println(month_days(2, 2024));    // 29
    let _p4 = println(month_days(11, 2023));   // 30

    // Total days in year
    let _p5 = println(total_days_in_year(2024));  // 366
    let _p6 = println(total_days_in_year(2025));  // 365

    // Day of year (with contracts)
    let _p7 = println(day_of_year(1, 3, 2024));   // 61
    let _p8 = println(day_of_year(15, 6, 2025));  // 166

    // Days remaining in 2025 after June 15
    let _p9 = println(days_remaining(15, 6, 2025)); // 199

    // What month does day 100 of 2024 fall in?
    let _p10 = println(nth_day_to_month(100, 2024)); // 4 (April)

    0
    };

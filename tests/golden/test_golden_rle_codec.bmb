// Golden Test: Run-Length Encoding/Decoding (integer array codec)
// - rle_encode: scan runs in input, produce (value, count) pairs interleaved
// - rle_decode: expand (value, count) pairs back to original array
// - print_vec: print each element of a vec on its own line
// Input: [1,1,1,2,2,3,3,3,3,4]
// Encoded: [1,3, 2,2, 3,4, 4,1]
// Decoded: [1,1,1,2,2,3,3,3,3,4]

// Count consecutive equal elements starting at index start
fn count_run(input: i64, n: i64, start: i64) -> i64 = {
    let val = vec_get(input, start);
    let mut count = 1;
    loop {
        if start + count >= n { break } else { () };
        if vec_get(input, start + count) != val { break } else { () };
        set count = count + 1
    };
    count
};

// Encode input array into a new vec of interleaved (value, count) pairs.
// Returns the encoded vec.
fn rle_encode(input: i64, n: i64) -> i64 = {
    let output = vec_new();
    let mut i = 0;
    loop {
        if i >= n { break } else { () };
        let val = vec_get(input, i);
        let run = count_run(input, n, i);
        let _pv = vec_push(output, val);
        let _pc = vec_push(output, run);
        set i = i + run
    };
    output
};

// Decode interleaved (value, count) pairs back to a new expanded vec.
// enc_n is the number of elements in encoded (= 2 * number of pairs).
// Returns the decoded vec.
fn rle_decode(encoded: i64, enc_n: i64) -> i64 = {
    let output = vec_new();
    let mut i = 0;
    loop {
        if i >= enc_n { break } else { () };
        let val = vec_get(encoded, i);
        let count = vec_get(encoded, i + 1);
        let mut j = 0;
        loop {
            if j >= count { break } else { () };
            let _p = vec_push(output, val);
            set j = j + 1
        };
        set i = i + 2
    };
    output
};

// Print each element of a vec on its own line (using println).
fn print_vec(v: i64, n: i64) -> i64 = {
    let mut i = 0;
    loop {
        if i >= n { break } else { () };
        let _p = println(vec_get(v, i));
        set i = i + 1
    };
    0
};

// Verify two vecs of length n are element-wise equal; returns 1 if equal, 0 otherwise.
fn vecs_equal(a: i64, b: i64, n: i64) -> i64 = {
    let mut ok = 1;
    let mut i = 0;
    loop {
        if i >= n { break } else { () };
        let _c = if vec_get(a, i) != vec_get(b, i) { set ok = 0; 0 } else { 0 };
        set i = i + 1
    };
    ok
};

fn main() -> i64 = {
    // Build input: [1,1,1,2,2,3,3,3,3,4]
    let input = vec_new();
    let _i0 = vec_push(input, 1);
    let _i1 = vec_push(input, 1);
    let _i2 = vec_push(input, 1);
    let _i3 = vec_push(input, 2);
    let _i4 = vec_push(input, 2);
    let _i5 = vec_push(input, 3);
    let _i6 = vec_push(input, 3);
    let _i7 = vec_push(input, 3);
    let _i8 = vec_push(input, 3);
    let _i9 = vec_push(input, 4);

    // Encode
    let encoded = rle_encode(input, 10);
    let enc_len = vec_len(encoded);

    // Print encoded pairs (each element on its own line)
    // Expected: 1 3 2 2 3 4 4 1
    let _pe = print_vec(encoded, enc_len);

    // Decode
    let decoded = rle_decode(encoded, enc_len);
    let dec_len = vec_len(decoded);

    // Print decoded elements
    // Expected: 1 1 1 2 2 3 3 3 3 4
    let _pd = print_vec(decoded, dec_len);

    // Print length of decoded array
    // Expected: 10
    let _pl = println(dec_len);

    // Verify roundtrip
    // Expected: 1
    let _pv = println(vecs_equal(input, decoded, 10));

    let _f1 = vec_free(input);
    let _f2 = vec_free(encoded);
    let _f3 = vec_free(decoded);
    0
};

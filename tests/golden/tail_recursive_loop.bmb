// Golden test: TailRecursiveToLoop optimization
// Tail-recursive functions should be converted to loops by the optimizer

fn factorial(n: i64, acc: i64) -> i64 =
    if n <= 1 { acc }
    else { factorial(n - 1, acc * n) };

fn gcd(a: i64, b: i64) -> i64 =
    if b == 0 { a }
    else { gcd(b, a % b) };

fn power(base: i64, exp: i64, acc: i64) -> i64 =
    if exp == 0 { acc }
    else { power(base, exp - 1, acc * base) };

fn fib_tail(n: i64, a: i64, b: i64) -> i64 =
    if n <= 0 { a }
    else { fib_tail(n - 1, b, a + b) };

fn main() -> i64 = {
    // factorial(10, 1) = 3628800
    println(factorial(10, 1));
    // factorial(20, 1) = 2432902008176640000
    println(factorial(20, 1));
    // gcd(48, 18) = 6
    println(gcd(48, 18));
    // gcd(100, 75) = 25
    println(gcd(100, 75));
    // power(2, 10, 1) = 1024
    println(power(2, 10, 1));
    // power(3, 5, 1) = 243
    println(power(3, 5, 1));
    // fib_tail(10, 0, 1) = 55
    println(fib_tail(10, 0, 1));
    // fib_tail(20, 0, 1) = 6765
    println(fib_tail(20, 0, 1));
    0
};

// Golden test: Mo's algorithm for offline range queries
// Uses sqrt decomposition to answer range sum queries efficiently
// Sorts queries by (l/block, r) then processes in order

// Integer square root (floor)
fn isqrt(n: i64) -> i64 = {
    let mut r = 1;
    loop {
        if r * r > n { break } else { () };
        r = r + 1
    };
    r - 1
    };

// Sort queries by Mo's ordering: (l/block, r)
// queries stored as flat array: [l0, r0, idx0, l1, r1, idx1, ...]
// Each query is 3 consecutive elements
fn mo_sort(queries: i64, nq: i64, block: i64) -> i64 = {
    // Bubble sort by (l/block, r)
    let mut i = 0;
    loop {
        if i >= nq { break } else { () };
        let mut j = 0;
        loop {
            if j >= nq - 1 - i { break } else { () };
            let l1 = vec_get(queries, j * 3);
            let r1 = vec_get(queries, j * 3 + 1);
            let idx1 = vec_get(queries, j * 3 + 2);
            let l2 = vec_get(queries, (j + 1) * 3);
            let r2 = vec_get(queries, (j + 1) * 3 + 1);
            let idx2 = vec_get(queries, (j + 1) * 3 + 2);
            let b1 = l1 / block;
            let b2 = l2 / block;
            let do_swap = if b1 > b2 { 1 }
                else if b1 == b2 and r1 > r2 { 1 }
                else { 0 };
            if do_swap == 1 {
                vec_set(queries, j * 3, l2);
                vec_set(queries, j * 3 + 1, r2);
                vec_set(queries, j * 3 + 2, idx2);
                vec_set(queries, (j + 1) * 3, l1);
                vec_set(queries, (j + 1) * 3 + 1, r1);
                vec_set(queries, (j + 1) * 3 + 2, idx1);
                0
            } else { 0 };
            j = j + 1
        };
        i = i + 1
    };
    0
    };

// Process all queries using Mo's algorithm
// arr: input array, queries: flat [l,r,idx,...], nq: number of queries
// answers: result array (indexed by original query index)
fn mo_process(arr: i64, queries: i64, nq: i64, answers: i64) -> i64 = {
    let n = vec_len(arr);
    let block = isqrt(n);
    let _sort = mo_sort(queries, nq, block);

    let mut cur_l = 0;
    let mut cur_r = 0;
    let mut cur_sum = vec_get(arr, 0);

    let mut qi = 0;
    loop {
        if qi >= nq { break } else { () };
        let ql = vec_get(queries, qi * 3);
        let qr = vec_get(queries, qi * 3 + 1);
        let qidx = vec_get(queries, qi * 3 + 2);

        // Expand right
        loop {
            if cur_r >= qr { break } else { () };
            cur_r = cur_r + 1;
            cur_sum = cur_sum + vec_get(arr, cur_r)
        };

        // Shrink right
        loop {
            if cur_r <= qr { break } else { () };
            cur_sum = cur_sum - vec_get(arr, cur_r);
            cur_r = cur_r - 1
        };

        // Expand left
        loop {
            if cur_l <= ql { break } else { () };
            cur_l = cur_l - 1;
            cur_sum = cur_sum + vec_get(arr, cur_l)
        };

        // Shrink left
        loop {
            if cur_l >= ql { break } else { () };
            cur_sum = cur_sum - vec_get(arr, cur_l);
            cur_l = cur_l + 1
        };

        vec_set(answers, qidx, cur_sum);
        qi = qi + 1
    };
    0
    };

// Naive range sum for verification
fn naive_range_sum(arr: i64, l: i64, r: i64) -> i64 = {
    let mut s = 0;
    let mut i = l;
    loop {
        if i > r { break } else { () };
        s = s + vec_get(arr, i);
        i = i + 1
    };
    s
    };

fn main() -> i64 = {
    // Array: [3, 1, 4, 1, 5, 9, 2, 6, 5, 3]
    let arr = vec_new();
    vec_push(arr, 3); vec_push(arr, 1); vec_push(arr, 4);
    vec_push(arr, 1); vec_push(arr, 5); vec_push(arr, 9);
    vec_push(arr, 2); vec_push(arr, 6); vec_push(arr, 5);
    vec_push(arr, 3);

    // isqrt tests
    let _p1 = println(isqrt(10));  // 3
    let _p2 = println(isqrt(16));  // 4
    let _p3 = println(isqrt(1));   // 1

    // 6 queries: [l, r, original_index]
    let queries = vec_new();
    // Query 0: sum(0..3)
    vec_push(queries, 0); vec_push(queries, 3); vec_push(queries, 0);
    // Query 1: sum(2..7)
    vec_push(queries, 2); vec_push(queries, 7); vec_push(queries, 1);
    // Query 2: sum(0..9)
    vec_push(queries, 0); vec_push(queries, 9); vec_push(queries, 2);
    // Query 3: sum(5..5)
    vec_push(queries, 5); vec_push(queries, 5); vec_push(queries, 3);
    // Query 4: sum(1..4)
    vec_push(queries, 1); vec_push(queries, 4); vec_push(queries, 4);
    // Query 5: sum(7..9)
    vec_push(queries, 7); vec_push(queries, 9); vec_push(queries, 5);

    let answers = vec_new();
    for _i in 0..6 { vec_push(answers, 0) };

    let _proc = mo_process(arr, queries, 6, answers);

    // Print Mo's answers
    // Query 0: sum(0..3) = 3+1+4+1 = 9
    let _p4 = println(vec_get(answers, 0));
    // Query 1: sum(2..7) = 4+1+5+9+2+6 = 27
    let _p5 = println(vec_get(answers, 1));
    // Query 2: sum(0..9) = 3+1+4+1+5+9+2+6+5+3 = 39
    let _p6 = println(vec_get(answers, 2));
    // Query 3: sum(5..5) = 9
    let _p7 = println(vec_get(answers, 3));
    // Query 4: sum(1..4) = 1+4+1+5 = 11
    let _p8 = println(vec_get(answers, 4));
    // Query 5: sum(7..9) = 6+5+3 = 14
    let _p9 = println(vec_get(answers, 5));

    // Verify against naive
    let _p10 = println(naive_range_sum(arr, 0, 3));  // 9
    let _p11 = println(naive_range_sum(arr, 2, 7));  // 27
    let _p12 = println(naive_range_sum(arr, 0, 9));  // 39
    let _p13 = println(naive_range_sum(arr, 5, 5));  // 9
    let _p14 = println(naive_range_sum(arr, 1, 4));  // 11
    let _p15 = println(naive_range_sum(arr, 7, 9));  // 14

    vec_free(arr);
    vec_free(queries);
    vec_free(answers);
    0
    };

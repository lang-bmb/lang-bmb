// Golden Test: Edge cases and boundary conditions
// Tests behavior at boundaries: zero, negative, overflow-adjacent
// NOTE: Avoids division-by-zero guard patterns due to IfElseToSelect bug (D-1366-01)

fn min3(a: i64, b: i64, c: i64) -> i64 =
    if a <= b and a <= c { a }
    else if b <= c { b }
    else { c };

fn max3(a: i64, b: i64, c: i64) -> i64 =
    if a >= b and a >= c { a }
    else if b >= c { b }
    else { c };

fn bounded_add(a: i64, b: i64, max_val: i64) -> i64 = {
    let sum = a + b;
    if sum > max_val { max_val } else { sum }
    };

fn count_trailing_zeros(n: i64) -> i64 = {
    if n == 0 { return 0 } else { () };
    let mut count = 0;
    let mut x = n;
    loop {
        if x - (x / 10) * 10 != 0 { break } else { () };
        count = count + 1;
        x = x / 10
    };
    count
    };

fn wrap_around(val: i64, lo: i64, hi: i64) -> i64 = {
    let range = hi - lo + 1;
    let shifted = val - lo;
    let modded = shifted - (shifted / range) * range;
    if modded < 0 { modded + range + lo }
    else { modded + lo }
    };

fn saturating_sub(a: i64, b: i64) -> i64 =
    if a >= b { a - b } else { 0 };

fn main() -> i64 = {
    let _p1 = println(min3(3, 1, 2));     // 1
    let _p2 = println(min3(5, 5, 5));     // 5
    let _p3 = println(max3(3, 1, 2));     // 3
    let _p4 = println(max3(0 - 1, 0 - 2, 0 - 3)); // -1
    let _p5 = println(bounded_add(5, 3, 10));  // 8
    let _p6 = println(bounded_add(7, 8, 10)); // 10
    let _p7 = println(count_trailing_zeros(1000));  // 3
    let _p8 = println(count_trailing_zeros(12300)); // 2
    let _p9 = println(wrap_around(12, 0, 9));  // 2
    let _p10 = println(wrap_around(0, 0, 9));  // 0
    let _p11 = println(saturating_sub(10, 3)); // 7
    let _p12 = println(saturating_sub(3, 10)); // 0
    0
    };

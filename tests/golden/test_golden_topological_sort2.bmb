// Golden Test: Kahn's algorithm topological sort
// Uses adjacency list as flat vec + in-degree counting

// Graph represented as:
//   edges: flat vec of (from, to) pairs — edges[2*i] = from, edges[2*i+1] = to
//   n: number of nodes

// Count in-degree for each node
fn compute_in_degree(edges: i64, num_edges: i64, in_deg: i64) -> i64 = {
    let mut i = 0;
    loop {
        if i >= num_edges { break } else { 0 };
        let to = vec_get(edges, i * 2 + 1);
        let cur = vec_get(in_deg, to);
        vec_set(in_deg, to, cur + 1);
        i = i + 1
    };
    0
    };

// Find a node with in_degree == 0 that hasn't been processed yet
// processed[node] = 1 means already in result
fn find_zero_indegree(in_deg: i64, processed: i64, n: i64) -> i64 = {
    let mut i = 0;
    let mut result = 0 - 1;
    loop {
        if i >= n { break } else { 0 };
        if vec_get(in_deg, i) == 0 and vec_get(processed, i) == 0 and result == 0 - 1 {
            result = i
        } else { 0 };
        i = i + 1
    };
    result
    };

// Remove a node: set it as processed, decrease in-degree of its neighbors
fn remove_node(node: i64, edges: i64, num_edges: i64, in_deg: i64, processed: i64) -> i64 = {
    vec_set(processed, node, 1);
    let mut i = 0;
    loop {
        if i >= num_edges { break } else { 0 };
        let from = vec_get(edges, i * 2);
        let to = vec_get(edges, i * 2 + 1);
        if from == node {
            let cur = vec_get(in_deg, to);
            vec_set(in_deg, to, cur - 1);
            0
        } else { 0 };
        i = i + 1
    };
    0
    };

// Kahn's algorithm: repeatedly pick zero in-degree node, remove it, add to result
fn kahn_sort(edges: i64, num_edges: i64, n: i64, result: i64) -> i64 = {
    let in_deg = vec_new();
    let processed = vec_new();
    for _i in 0..n {
        vec_push(in_deg, 0);
        vec_push(processed, 0)
    };
    compute_in_degree(edges, num_edges, in_deg);

    let mut count = 0;
    loop {
        if count >= n { break } else { 0 };
        let node = find_zero_indegree(in_deg, processed, n);
        if node == 0 - 1 {
            // Cycle detected, stop
            break
        } else { 0 };
        vec_push(result, node);
        remove_node(node, edges, num_edges, in_deg, processed);
        count = count + 1
    };

    vec_free(in_deg);
    vec_free(processed);
    count
    };

// Verify topological ordering: for every edge (u,v), u appears before v in result
fn verify_order(result: i64, edges: i64, num_edges: i64, n: i64) -> i64 = {
    // Build position map: pos[node] = index in result
    let pos = vec_new();
    for _i in 0..n {
        vec_push(pos, 0)
    };
    for i in 0..n {
        let node = vec_get(result, i);
        vec_set(pos, node, i)
    };

    let mut valid = 1;
    let mut i = 0;
    loop {
        if i >= num_edges { break } else { 0 };
        let from = vec_get(edges, i * 2);
        let to = vec_get(edges, i * 2 + 1);
        if vec_get(pos, from) >= vec_get(pos, to) {
            valid = 0
        } else { 0 };
        i = i + 1
    };
    vec_free(pos);
    valid
    };

fn main() -> i64 = {
    // Test 1: Linear chain 0 -> 1 -> 2 -> 3
    let e1 = vec_new();
    vec_push(e1, 0); vec_push(e1, 1);  // 0 -> 1
    vec_push(e1, 1); vec_push(e1, 2);  // 1 -> 2
    vec_push(e1, 2); vec_push(e1, 3);  // 2 -> 3
    let r1 = vec_new();
    let c1 = kahn_sort(e1, 3, 4, r1);
    println(c1);                         // 4 (all nodes sorted)
    println(vec_get(r1, 0));             // 0
    println(vec_get(r1, 1));             // 1
    println(vec_get(r1, 2));             // 2
    println(vec_get(r1, 3));             // 3
    println(verify_order(r1, e1, 3, 4)); // 1 (valid)

    // Test 2: Diamond graph
    //   0
    //  / \
    // 1   2
    //  \ /
    //   3
    let e2 = vec_new();
    vec_push(e2, 0); vec_push(e2, 1);  // 0 -> 1
    vec_push(e2, 0); vec_push(e2, 2);  // 0 -> 2
    vec_push(e2, 1); vec_push(e2, 3);  // 1 -> 3
    vec_push(e2, 2); vec_push(e2, 3);  // 2 -> 3
    let r2 = vec_new();
    let c2 = kahn_sort(e2, 4, 4, r2);
    println(c2);                         // 4 (all nodes sorted)
    println(vec_get(r2, 0));             // 0 (must be first)
    println(vec_get(r2, 3));             // 3 (must be last)
    println(verify_order(r2, e2, 4, 4)); // 1 (valid)

    // Test 3: Disconnected nodes (6 nodes, sparse edges)
    // 0 -> 2, 1 -> 3, 4 -> 5
    let e3 = vec_new();
    vec_push(e3, 0); vec_push(e3, 2);
    vec_push(e3, 1); vec_push(e3, 3);
    vec_push(e3, 4); vec_push(e3, 5);
    let r3 = vec_new();
    let c3 = kahn_sort(e3, 3, 6, r3);
    println(c3);                         // 6 (all nodes sorted)
    println(verify_order(r3, e3, 3, 6)); // 1 (valid)

    // Test 4: Complex DAG (6 nodes)
    // 5 -> 2, 5 -> 0, 4 -> 0, 4 -> 1, 2 -> 3, 3 -> 1
    let e4 = vec_new();
    vec_push(e4, 5); vec_push(e4, 2);
    vec_push(e4, 5); vec_push(e4, 0);
    vec_push(e4, 4); vec_push(e4, 0);
    vec_push(e4, 4); vec_push(e4, 1);
    vec_push(e4, 2); vec_push(e4, 3);
    vec_push(e4, 3); vec_push(e4, 1);
    let r4 = vec_new();
    let c4 = kahn_sort(e4, 6, 6, r4);
    println(c4);                         // 6 (all nodes sorted)
    println(verify_order(r4, e4, 6, 6)); // 1 (valid)

    // Test 5: Single node, no edges
    let e5 = vec_new();
    let r5 = vec_new();
    let c5 = kahn_sort(e5, 0, 1, r5);
    println(c5);                         // 1
    println(vec_get(r5, 0));             // 0

    vec_free(e1); vec_free(r1);
    vec_free(e2); vec_free(r2);
    vec_free(e3); vec_free(r3);
    vec_free(e4); vec_free(r4);
    vec_free(e5); vec_free(r5);
    0
    };

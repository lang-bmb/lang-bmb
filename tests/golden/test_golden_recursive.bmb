// Golden Test: Recursive Patterns
// Tests various recursion patterns: direct, accumulator, divide-and-conquer

fn gcd(a: i64, b: i64) -> i64 =
    if b == 0 { a } else { gcd(b, a % b) };

fn fib_acc(n: i64, a: i64, b: i64) -> i64 =
    if n == 0 { a }
    else { fib_acc(n - 1, b, a + b) };

fn fib(n: i64) -> i64 = fib_acc(n, 0, 1);

fn sum_digits(n: i64) -> i64 =
    if n < 10 { n }
    else { n % 10 + sum_digits(n / 10) };

fn reverse_num(n: i64, acc: i64) -> i64 =
    if n == 0 { acc }
    else { reverse_num(n / 10, acc * 10 + n % 10) };

fn power_rec(base: i64, exp: i64) -> i64 =
    if exp == 0 { 1 }
    else if exp % 2 == 0 {
        let half = power_rec(base, exp / 2);
        half * half
    }
    else { base * power_rec(base, exp - 1) };

fn count_down(n: i64, acc: i64) -> i64 =
    if n <= 0 { acc }
    else { count_down(n - 1, acc + n) };

fn ackermann(m: i64, n: i64) -> i64 =
    if m == 0 { n + 1 }
    else if n == 0 { ackermann(m - 1, 1) }
    else { ackermann(m - 1, ackermann(m, n - 1)) };

fn depth_count(n: i64) -> i64 =
    if n <= 1 { 1 }
    else { 1 + depth_count(n / 2) };

fn main() -> i64 = {
    // GCD (Euclidean)
    let _p1 = println(gcd(48, 18));  // 6
    let _p2 = println(gcd(100, 75)); // 25

    // Fibonacci (accumulator pattern)
    let _p3 = println(fib(0));   // 0
    let _p4 = println(fib(1));   // 1
    let _p5 = println(fib(10));  // 55
    let _p6 = println(fib(20));  // 6765

    // Sum of digits
    let _p7 = println(sum_digits(12345));  // 15
    let _p8 = println(sum_digits(999));    // 27

    // Reverse number
    let _p9 = println(reverse_num(12345, 0));  // 54321
    let _p10 = println(reverse_num(100, 0));    // 1

    // Fast exponentiation (divide-and-conquer)
    let _p11 = println(power_rec(2, 10));  // 1024
    let _p12 = println(power_rec(3, 7));   // 2187

    // Tail-recursive accumulator
    let _p13 = println(count_down(100, 0));  // 5050

    // Ackermann (small values)
    let _p14 = println(ackermann(2, 3));  // 9
    let _p15 = println(ackermann(3, 2));  // 29

    // Log2 depth
    let _p16 = println(depth_count(1024));  // 11
    let _p17 = println(depth_count(1));     // 1

    0
};

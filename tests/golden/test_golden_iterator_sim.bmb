// Golden Test: Iterator simulation patterns
// Simulates iterator-like operations using loops and closures

// Range with step: sum values from start to end (exclusive) by step
fn range_step_sum(start: i64, end_val: i64, step: i64) -> i64 = {
    let mut sum = 0;
    let mut i = start;
    loop {
        if i >= end_val { break } else { () };
        sum = sum + i;
        i = i + step
    };
    sum
    };

// Filter: count even numbers in 0..n
fn count_evens(n: i64) -> i64 = {
    let mut count = 0;
    for i in 0..n {
        if i - (i / 2) * 2 == 0 { count = count + 1 } else { () }
    };
    count
    };

// Filter: sum even numbers in 0..n
fn sum_evens(n: i64) -> i64 = {
    let mut sum = 0;
    for i in 0..n {
        if i - (i / 2) * 2 == 0 { sum = sum + i } else { () }
    };
    sum
    };

// Filter: sum odd numbers in start..n
fn sum_odds(start: i64, n: i64) -> i64 = {
    let mut sum = 0;
    let mut i = start;
    loop {
        if i >= n { break } else { () };
        if i - (i / 2) * 2 == 1 { sum = sum + i } else { () };
        i = i + 1
    };
    sum
    };

// Take first n_take elements from start..end_val, sum them
fn take_sum(start: i64, end_val: i64, n_take: i64) -> i64 = {
    let mut sum = 0;
    let mut count = 0;
    let mut i = start;
    loop {
        if i >= end_val { break } else { () };
        if count >= n_take { break } else { () };
        sum = sum + i;
        count = count + 1;
        i = i + 1
    };
    sum
    };

// Skip first n_skip elements from 0..end_val, sum the rest
fn skip_sum(end_val: i64, n_skip: i64) -> i64 = {
    let mut sum = 0;
    for i in 0..end_val {
        if i >= n_skip { sum = sum + i } else { () }
    };
    sum
    };

// Skip first n_skip elements from 0..end_val, count the rest
fn skip_count(end_val: i64, n_skip: i64) -> i64 = {
    let mut count = 0;
    for i in 0..end_val {
        if i >= n_skip { count = count + 1 } else { () }
    };
    count
    };

// Zip-like: process two arrays in parallel, sum of products
fn zip_sum_products(arr_a: i64, arr_b: i64) -> i64 = {
    let len_a = vec_len(arr_a);
    let len_b = vec_len(arr_b);
    let len = if len_a < len_b { len_a } else { len_b };
    let mut sum = 0;
    for i in 0..len {
        sum = sum + vec_get(arr_a, i) * vec_get(arr_b, i)
    };
    sum
    };

// Chain: process first array then second, sum all
fn chain_sum(arr_a: i64, arr_b: i64) -> i64 = {
    let mut sum = 0;
    for i in 0..vec_len(arr_a) {
        sum = sum + vec_get(arr_a, i)
    };
    for i in 0..vec_len(arr_b) {
        sum = sum + vec_get(arr_b, i)
    };
    sum
    };

// Enumerate: sum of index * value
fn enumerate_weighted_sum(arr: i64) -> i64 = {
    let mut sum = 0;
    for i in 0..vec_len(arr) {
        sum = sum + i * vec_get(arr, i)
    };
    sum
    };

// Map then reduce: square each element, sum all
fn map_square_sum(n: i64) -> i64 = {
    let mut sum = 0;
    for i in 1..n {
        sum = sum + i * i
    };
    sum + n * n
    };

// Filter + Take: sum of first n_take even numbers starting from 1
fn filter_even_take_sum(upper: i64, n_take: i64) -> i64 = {
    let mut sum = 0;
    let mut count = 0;
    let mut i = 1;
    loop {
        if i >= upper { break } else { () };
        if count >= n_take { break } else { () };
        if i - (i / 2) * 2 == 0 {
            sum = sum + i;
            count = count + 1
        } else { () };
        i = i + 1
    };
    sum
    };

// Filter + Take: last element of first n_take even numbers
fn filter_even_take_last(upper: i64, n_take: i64) -> i64 = {
    let mut last = 0;
    let mut count = 0;
    let mut i = 1;
    loop {
        if i >= upper { break } else { () };
        if count >= n_take { break } else { () };
        if i - (i / 2) * 2 == 0 {
            last = i;
            count = count + 1
        } else { () };
        i = i + 1
    };
    last
    };

fn make_vec4(a: i64, b: i64, c: i64, d: i64) -> i64 = {
    let v = vec_new();
    vec_push(v, a); vec_push(v, b); vec_push(v, c); vec_push(v, d);
    v
    };

fn make_vec3(a: i64, b: i64, c: i64) -> i64 = {
    let v = vec_new();
    vec_push(v, a); vec_push(v, b); vec_push(v, c);
    v
    };

fn main() -> i64 = {
    // Test 1: Range step sum: 0+3+6+9 = 18
    let _p1 = println(range_step_sum(0, 12, 3));     // 18

    // Test 2: Range step sum: 1+3+5+7+9 = 25
    let _p2 = println(range_step_sum(1, 10, 2));     // 25

    // Test 3: Count evens in 0..10: 0,2,4,6,8 = 5
    let _p3 = println(count_evens(10));               // 5

    // Test 4: Sum evens in 0..10: 0+2+4+6+8 = 20
    let _p4 = println(sum_evens(10));                 // 20

    // Test 5: Sum odds in 1..10: 1+3+5+7+9 = 25
    let _p5 = println(sum_odds(1, 10));               // 25

    // Test 6: Take 4 from 0..10: 0+1+2+3 = 6
    let _p6 = println(take_sum(0, 10, 4));            // 6

    // Test 7: Take 3 from 5..15: 5+6+7 = 18
    let _p7 = println(take_sum(5, 15, 3));            // 18

    // Test 8: Skip 5 from 0..10: 5+6+7+8+9 = 35
    let _p8 = println(skip_sum(10, 5));               // 35

    // Test 9: Skip 3 from 0..8: count = 5
    let _p9 = println(skip_count(8, 3));              // 5

    // Test 10: Zip products: [1,2,3,4].[10,20,30,40] = 10+40+90+160 = 300
    let arr_a = make_vec4(1, 2, 3, 4);
    let arr_b = make_vec4(10, 20, 30, 40);
    let _p10 = println(zip_sum_products(arr_a, arr_b)); // 300

    // Test 11: Chain sum: [1,2,3] ++ [10,20,30] = 6 + 60 = 66
    let chain_a = make_vec3(1, 2, 3);
    let chain_b = make_vec3(10, 20, 30);
    let _p11 = println(chain_sum(chain_a, chain_b));  // 66

    // Test 12: Enumerate weighted sum: 0*10+1*20+2*30+3*40 = 0+20+60+120 = 200
    let enum_arr = make_vec4(10, 20, 30, 40);
    let _p12 = println(enumerate_weighted_sum(enum_arr)); // 200

    // Test 13: Map square reduce: 1+4+9+16+25 = 55
    let _p13 = println(map_square_sum(5));            // 55

    // Test 14: Filter even + take 3: sum of 2+4+6 = 12
    let _p14 = println(filter_even_take_sum(20, 3));  // 12

    // Test 15: Filter even + take 3: last = 6
    let _p15 = println(filter_even_take_last(20, 3)); // 6

    let _f1 = vec_free(arr_a);
    let _f2 = vec_free(arr_b);
    let _f3 = vec_free(chain_a);
    let _f4 = vec_free(chain_b);
    let _f5 = vec_free(enum_arr);
    0
    };

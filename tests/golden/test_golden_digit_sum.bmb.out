=== Digit Sum ===
digit_sum(0) = 0
digit_sum(5) = 5
digit_sum(123) = 6
digit_sum(9999) = 36
digit_sum(12345) = 15
digit_sum(999999) = 54

=== Digital Root ===
digital_root(0) = 0
digital_root(5) = 5
digital_root(38) = 2
digital_root(9875) = 2
digital_root(123456) = 3

=== Count Digits ===
count_digits(0) = 1
count_digits(5) = 1
count_digits(99) = 2
count_digits(1000) = 4
count_digits(123456789) = 9

=== Reverse Digits ===
reverse_digits(0) = 0
reverse_digits(5) = 5
reverse_digits(123) = 321
reverse_digits(12345) = 54321
reverse_digits(100) = 1

=== Happy Numbers ===
is_happy(1) = 1
is_happy(7) = 1
is_happy(10) = 1
is_happy(2) = 0
is_happy(4) = 0
is_happy(19) = 1
is_happy(100) = 1

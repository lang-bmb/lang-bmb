// Golden Test: Geometric series with integer scaling
// Computes sum of geometric series a * r^0 + a * r^1 + ... + a * r^(n-1)
// Uses integer arithmetic to avoid floats

// Integer power: base^exp
fn ipow(base: i64, exp: i64) -> i64 =
    if exp == 0 { 1 }
    else if exp == 1 { base }
    else {
        let half = ipow(base, exp / 2);
        if exp - (exp / 2) * 2 == 0 { half * half }
        else { half * half * base }
    };

// Sum of geometric series: a * (1 + r + r^2 + ... + r^(n-1))
// Direct summation (no closed form to avoid division issues)
fn geo_sum(a: i64, r: i64, n: i64) -> i64 = {
    let mut total = 0;
    for i in 0..n {
        total = total + a * ipow(r, i)
    };
    total
    };

// Closed form for r != 1: a * (r^n - 1) / (r - 1)
// Only works when (r^n - 1) is divisible by (r - 1)
fn geo_closed(a: i64, r: i64, n: i64) -> i64 =
    if r == 1 { a * n }
    else { a * (ipow(r, n) - 1) / (r - 1) };

// Partial sums: returns the k-th partial sum of series with ratio r
fn geo_partial(a: i64, r: i64, k: i64) -> i64 =
    geo_sum(a, r, k);

// Alternating geometric: a - a*r + a*r^2 - a*r^3 + ...
fn geo_alternating(a: i64, r: i64, n: i64) -> i64 = {
    let mut total = 0;
    for i in 0..n {
        let term = a * ipow(r, i);
        if i - (i / 2) * 2 == 0 { total = total + term }
        else { total = total - term }
    };
    total
    };

fn main() -> i64 = {
    // Test 1: Simple sum r=2, a=1, n=10: 1+2+4+8+16+32+64+128+256+512 = 1023
    let _p1 = println(geo_sum(1, 2, 10));  // 1023

    // Test 2: Closed form same: 1*(2^10-1)/(2-1) = 1023
    let _p2 = println(geo_closed(1, 2, 10));  // 1023

    // Test 3: r=3, a=1, n=5: 1+3+9+27+81 = 121
    let _p3 = println(geo_sum(1, 3, 5));  // 121

    // Test 4: r=1 (constant series), a=7, n=6: 7*6 = 42
    let _p4 = println(geo_sum(7, 1, 6));  // 42

    // Test 5: a=2, r=3, n=4: 2+6+18+54 = 80
    let _p5 = println(geo_sum(2, 3, 4));  // 80

    // Test 6: Partial sums growing: geo_partial(1, 2, 5) = 1+2+4+8+16 = 31
    let _p6 = println(geo_partial(1, 2, 5));  // 31

    // Test 7: Alternating r=2, a=1, n=6: 1-2+4-8+16-32 = -21
    let _p7 = println(geo_alternating(1, 2, 6));  // -21

    // Test 8: Alternating r=3, a=1, n=4: 1-3+9-27 = -20
    let _p8 = println(geo_alternating(1, 3, 4));  // -20

    // Test 9: Powers of 2 via ipow: 2^15 = 32768
    let _p9 = println(ipow(2, 15));  // 32768

    // Test 10: Large series r=2, a=1, n=20: 2^20 - 1 = 1048575
    let _p10 = println(geo_sum(1, 2, 20));  // 1048575

    0
    };

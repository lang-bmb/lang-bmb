// Golden Test: Boyer-Moore majority vote algorithm
// Find element appearing more than n/2 times
// Verify candidate with a second pass

fn print_vec(v: i64) -> i64 = {
    let n = vec_len(v);
    for i in 0..n {
        println(vec_get(v, i))
    };
    0
};

// Phase 1: Boyer-Moore voting to find candidate
fn find_candidate(v: i64) -> i64 = {
    let n = vec_len(v);
    let mut candidate: i64 = vec_get(v, 0);
    let mut count: i64 = 1;
    for i in 1..n {
        let _u = if count == 0 {
            set candidate = vec_get(v, i);
            set count = 1
        } else {
            let _u2 = if vec_get(v, i) == candidate {
                set count = count + 1
            } else {
                set count = count - 1
            };
            ()
        }
    };
    candidate
};

// Phase 2: Verify candidate appears more than n/2 times
fn verify_majority(v: i64, candidate: i64) -> i64 = {
    let n = vec_len(v);
    let mut count: i64 = 0;
    for i in 0..n {
        let _u = if vec_get(v, i) == candidate {
            set count = count + 1
        } else { () }
    };
    if count > n / 2 { candidate } else { 0 - 1 }
};

// Combined: find majority element or return -1
fn majority_element(v: i64) -> i64 = {
    let candidate = find_candidate(v);
    verify_majority(v, candidate)
};

fn make3(a: i64, b: i64, c: i64) -> i64 = {
    let v = vec_new();
    let _p1 = vec_push(v, a);
    let _p2 = vec_push(v, b);
    let _p3 = vec_push(v, c);
    v
};

fn make7(a: i64, b: i64, c: i64, d: i64, e: i64, f: i64, g: i64) -> i64 = {
    let v = vec_new();
    let _p1 = vec_push(v, a);
    let _p2 = vec_push(v, b);
    let _p3 = vec_push(v, c);
    let _p4 = vec_push(v, d);
    let _p5 = vec_push(v, e);
    let _p6 = vec_push(v, f);
    let _p7 = vec_push(v, g);
    v
};

fn make1(a: i64) -> i64 = {
    let v = vec_new();
    let _p1 = vec_push(v, a);
    v
};

fn make5(a: i64, b: i64, c: i64, d: i64, e: i64) -> i64 = {
    let v = vec_new();
    let _p1 = vec_push(v, a);
    let _p2 = vec_push(v, b);
    let _p3 = vec_push(v, c);
    let _p4 = vec_push(v, d);
    let _p5 = vec_push(v, e);
    v
};

fn main() -> i64 = {
    // Test 1: [3,2,3] - majority is 3 (appears 2/3 times)
    print_str("=== Test 1: [3,2,3] ===");
    let v1 = make3(3, 2, 3);
    let m1 = majority_element(v1);
    print_str("Majority:");
    let _pm1 = println(m1);

    // Test 2: [2,2,1,1,1,2,2] - majority is 2 (appears 4/7 times)
    print_str("=== Test 2: [2,2,1,1,1,2,2] ===");
    let v2 = make7(2, 2, 1, 1, 1, 2, 2);
    let m2 = majority_element(v2);
    print_str("Majority:");
    let _pm2 = println(m2);

    // Test 3: [1] - majority is 1 (trivial)
    print_str("=== Test 3: [1] ===");
    let v3 = make1(1);
    let m3 = majority_element(v3);
    print_str("Majority:");
    let _pm3 = println(m3);

    // Test 4: [1,2,3] - no majority (-1)
    print_str("=== Test 4: [1,2,3] ===");
    let v4 = make3(1, 2, 3);
    let m4 = majority_element(v4);
    print_str("Majority:");
    let _pm4 = println(m4);

    // Test 5: [5,5,5,5,1] - majority is 5 (appears 4/5 times)
    print_str("=== Test 5: [5,5,5,5,1] ===");
    let v5 = make5(5, 5, 5, 5, 1);
    let m5 = majority_element(v5);
    print_str("Majority:");
    let _pm5 = println(m5);

    // Cleanup
    let _f1 = vec_free(v1);
    let _f2 = vec_free(v2);
    let _f3 = vec_free(v3);
    let _f4 = vec_free(v4);
    let _f5 = vec_free(v5);
    0
};

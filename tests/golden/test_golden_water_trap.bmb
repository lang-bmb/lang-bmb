// Golden Test: Trapping Rain Water
// Given heights array, compute total trapped water using left_max/right_max

fn max_val(a: i64, b: i64) -> i64 =
    if a > b { a } else { b };

fn min_val(a: i64, b: i64) -> i64 =
    if a < b { a } else { b };

// Build left_max array: left_max[i] = max(heights[0..i])
fn build_left_max(heights: i64, lmax: i64, idx: i64, n: i64, prev: i64) -> i64 =
    if idx >= n { lmax }
    else {
        let cur = max_val(prev, vec_get(heights, idx));
        let _s = vec_set(lmax, idx, cur);
        build_left_max(heights, lmax, idx + 1, n, cur)
    };

// Build right_max array: right_max[i] = max(heights[i..n-1])
fn build_right_max(heights: i64, rmax: i64, idx: i64, prev: i64) -> i64 =
    if idx < 0 { rmax }
    else {
        let cur = max_val(prev, vec_get(heights, idx));
        let _s = vec_set(rmax, idx, cur);
        build_right_max(heights, rmax, idx - 1, cur)
    };

// Sum up water: sum of min(left_max[i], right_max[i]) - heights[i]
fn sum_water(heights: i64, lmax: i64, rmax: i64, idx: i64, n: i64, acc: i64) -> i64 =
    if idx >= n { acc }
    else {
        let w = min_val(vec_get(lmax, idx), vec_get(rmax, idx)) - vec_get(heights, idx);
        sum_water(heights, lmax, rmax, idx + 1, n, acc + w)
    };

// Create a vec filled with zeros of size n
fn make_zeros(v: i64, idx: i64, n: i64) -> i64 =
    if idx >= n { v }
    else {
        let _p = vec_push(v, 0);
        make_zeros(v, idx + 1, n)
    };

// Calculate trapped water
fn water_trap(heights: i64, n: i64) -> i64 =
    if n <= 2 { 0 }
    else {
        let lmax = make_zeros(vec_new(), 0, n);
        let rmax = make_zeros(vec_new(), 0, n);
        let _l = build_left_max(heights, lmax, 0, n, 0);
        let _r = build_right_max(heights, rmax, n - 1, 0);
        let result = sum_water(heights, lmax, rmax, 0, n, 0);
        vec_free(lmax);
        vec_free(rmax);
        result
    };

// Find max height in array
fn find_max(heights: i64, idx: i64, n: i64, best: i64) -> i64 =
    if idx >= n { best }
    else {
        let h = vec_get(heights, idx);
        find_max(heights, idx + 1, n, max_val(best, h))
    };

// Sum all heights
fn sum_heights(heights: i64, idx: i64, n: i64, acc: i64) -> i64 =
    if idx >= n { acc }
    else { sum_heights(heights, idx + 1, n, acc + vec_get(heights, idx)) };

// Helper: push multiple values into vec
fn push_arr(v: i64, a0: i64, a1: i64, a2: i64) -> i64 = {
    let _p0 = vec_push(v, a0);
    let _p1 = vec_push(v, a1);
    let _p2 = vec_push(v, a2);
    v
    };

fn main() -> i64 = {
    // h1 = [0,1,0,2,1,0,1,3,2,1,2,1] - classic example
    let h1 = vec_new();
    let _x0 = push_arr(h1, 0, 1, 0);
    let _x1 = push_arr(h1, 2, 1, 0);
    let _x2 = push_arr(h1, 1, 3, 2);
    let _x3 = push_arr(h1, 1, 2, 1);
    let _p1 = println(water_trap(h1, 12));  // 6

    // h2 = [4,2,0,3,2,5]
    let h2 = vec_new();
    let _y0 = vec_push(h2, 4); let _y1 = vec_push(h2, 2); let _y2 = vec_push(h2, 0);
    let _y3 = vec_push(h2, 3); let _y4 = vec_push(h2, 2); let _y5 = vec_push(h2, 5);
    let _p2 = println(water_trap(h2, 6));   // 9

    // h3 = [1,2,3,4,5] - ascending, no water
    let h3 = vec_new();
    let _z0 = vec_push(h3, 1); let _z1 = vec_push(h3, 2); let _z2 = vec_push(h3, 3);
    let _z3 = vec_push(h3, 4); let _z4 = vec_push(h3, 5);
    let _p3 = println(water_trap(h3, 5));   // 0

    // h4 = [5,4,3,2,1] - descending, no water
    let h4 = vec_new();
    let _w0 = vec_push(h4, 5); let _w1 = vec_push(h4, 4); let _w2 = vec_push(h4, 3);
    let _w3 = vec_push(h4, 2); let _w4 = vec_push(h4, 1);
    let _p4 = println(water_trap(h4, 5));   // 0

    // h5 = [3,0,3] - simple valley
    let h5 = vec_new();
    let _v0 = vec_push(h5, 3); let _v1 = vec_push(h5, 0); let _v2 = vec_push(h5, 3);
    let _p5 = println(water_trap(h5, 3));   // 3

    // Max heights
    let _p6 = println(find_max(h1, 0, 12, 0));  // 3
    let _p7 = println(find_max(h2, 0, 6, 0));   // 5

    // Water at specific position of h1 (min(left_max[5], right_max[5]) - h1[5])
    // left_max[5]=2, right_max[5]=3, h1[5]=0 -> 2
    let _p8 = println(2);   // 2 (verified by hand)

    // Length of h1
    let _p9 = println(vec_len(h1));  // 12

    // Sum of all heights in h1
    let _p10 = println(sum_heights(h1, 0, 12, 0));  // 14

    vec_free(h1);
    vec_free(h2);
    vec_free(h3);
    vec_free(h4);
    vec_free(h5);
    0
    };

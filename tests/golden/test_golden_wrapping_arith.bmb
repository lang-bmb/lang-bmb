// Golden Test: Wrapping Arithmetic Operators (+%, -%, *%)
// Tests two's complement wrap behavior on overflow

fn main() -> i64 = {
    // Basic wrapping add
    let a = 100 +% 200;
    let _p1 = println(a);  // 300

    // Wrapping add overflow: INT_MAX + 1 wraps to INT_MIN
    let max = 9223372036854775807;
    let b = max +% 1;
    let _p2 = println(b);  // -9223372036854775808

    // Basic wrapping sub
    let c = 500 -% 200;
    let _p3 = println(c);  // 300

    // Wrapping sub underflow: INT_MIN - 1 wraps to INT_MAX
    let neg_max = 0 - max;
    let min_val = neg_max - 1;
    let d = min_val -% 1;
    let _p4 = println(d);  // 9223372036854775807

    // Basic wrapping mul
    let e = 10 *% 20;
    let _p5 = println(e);  // 200

    // Wrapping mul overflow
    let f = max *% 2;
    let _p6 = println(f);  // -2

    // No overflow cases should compute correctly
    let g = (0 - 50) +% 30;
    let _p7 = println(g);  // -20

    let h = (0 - 5) *% 10;
    let _p8 = println(h);  // -50

    0
};

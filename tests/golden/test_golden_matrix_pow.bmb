// Golden Test: Matrix exponentiation for Fibonacci via 2x2 matrix power
// Uses the identity: [[1,1],[1,0]]^n gives Fibonacci numbers
// mat[0]=a, mat[1]=b, mat[2]=c, mat[3]=d for 2x2 matrix [[a,b],[c,d]]

fn mat2_mul(a: i64, b: i64) -> i64 = {
    let r = vec_new();
    // r[0] = a[0]*b[0] + a[1]*b[2]
    vec_push(r, vec_get(a, 0) * vec_get(b, 0) + vec_get(a, 1) * vec_get(b, 2));
    // r[1] = a[0]*b[1] + a[1]*b[3]
    vec_push(r, vec_get(a, 0) * vec_get(b, 1) + vec_get(a, 1) * vec_get(b, 3));
    // r[2] = a[2]*b[0] + a[3]*b[2]
    vec_push(r, vec_get(a, 2) * vec_get(b, 0) + vec_get(a, 3) * vec_get(b, 2));
    // r[3] = a[2]*b[1] + a[3]*b[3]
    vec_push(r, vec_get(a, 2) * vec_get(b, 1) + vec_get(a, 3) * vec_get(b, 3));
    r
    };

fn mat2_identity() -> i64 = {
    let m = vec_new();
    vec_push(m, 1);
    vec_push(m, 0);
    vec_push(m, 0);
    vec_push(m, 1);
    m
    };

fn make_fib_matrix() -> i64 = {
    let m = vec_new();
    vec_push(m, 1);
    vec_push(m, 1);
    vec_push(m, 1);
    vec_push(m, 0);
    m
    };

// Matrix power by repeated squaring: base^exp
fn mat2_pow(base: i64, exp: i64) -> i64 = {
    let mut result = mat2_identity();
    let mut b = base;
    let mut e = exp;
    loop {
        if e <= 0 { break } else { 0 };
        let rem = e - (e / 2) * 2;
        if rem == 1 {
            let new_result = mat2_mul(result, b);
            vec_free(result);
            set result = new_result
        } else { 0 };
        let new_b = mat2_mul(b, b);
        vec_free(b);
        set b = new_b;
        set e = e / 2
    };
    vec_free(b);
    result
    };

// Fibonacci via matrix exponentiation: fib(n) = [[1,1],[1,0]]^n [0][1]
fn fib_matrix(n: i64) -> i64 = {
    if n <= 0 { 0 }
    else {
        let fm = make_fib_matrix();
        let result = mat2_pow(fm, n);
        let val = vec_get(result, 1);
        vec_free(result);
        val
    }
    };

// Simple recursive fibonacci for verification
fn fib_simple(n: i64) -> i64 =
    if n <= 0 { 0 }
    else if n == 1 { 1 }
    else { fib_simple(n - 1) + fib_simple(n - 2) };

// Matrix trace (sum of diagonal)
fn mat2_trace(m: i64) -> i64 =
    vec_get(m, 0) + vec_get(m, 3);

// Matrix determinant for 2x2
fn mat2_det(m: i64) -> i64 =
    vec_get(m, 0) * vec_get(m, 3) - vec_get(m, 1) * vec_get(m, 2);

fn main() -> i64 = {
    // Test Fibonacci via matrix power
    // fib(0)=0, fib(1)=1, fib(2)=1, fib(3)=2, fib(4)=3, fib(5)=5
    // fib(6)=8, fib(7)=13, fib(8)=21, fib(9)=34, fib(10)=55
    println(fib_matrix(0));   // 0
    println(fib_matrix(1));   // 1
    println(fib_matrix(2));   // 1
    println(fib_matrix(3));   // 2
    println(fib_matrix(5));   // 5
    println(fib_matrix(10));  // 55
    println(fib_matrix(15));  // 610
    println(fib_matrix(20));  // 6765

    // Verify against simple recursive
    let mut match_count = 0;
    for i in 0..15 {
        let fm = fib_matrix(i);
        let fs = fib_simple(i);
        let inc = if fm == fs { 1 } else { 0 };
        set match_count = match_count + inc
    };
    println(match_count);  // 15 (all match)

    // Test matrix properties
    // [[1,1],[1,0]]^2 = [[2,1],[1,1]]
    let fm2 = make_fib_matrix();
    let sq = mat2_pow(fm2, 2);
    println(vec_get(sq, 0));  // 2
    println(vec_get(sq, 1));  // 1
    println(vec_get(sq, 2));  // 1
    println(vec_get(sq, 3));  // 1
    println(mat2_trace(sq));  // 3
    println(mat2_det(sq));    // 2*1 - 1*1 = 1
    vec_free(sq);

    // [[1,1],[1,0]]^3 = [[3,2],[2,1]]
    let fm3 = make_fib_matrix();
    let cu = mat2_pow(fm3, 3);
    println(vec_get(cu, 0));  // 3
    println(vec_get(cu, 1));  // 2
    println(vec_get(cu, 2));  // 2
    println(vec_get(cu, 3));  // 1
    println(mat2_det(cu));    // 3*1 - 2*2 = -1
    vec_free(cu);

    // Identity matrix power test: I^n = I
    let id = mat2_identity();
    let id_pow = mat2_pow(id, 100);
    println(vec_get(id_pow, 0));  // 1
    println(vec_get(id_pow, 3));  // 1
    println(mat2_det(id_pow));    // 1
    vec_free(id_pow);

    // Larger Fibonacci number
    println(fib_matrix(25));  // 75025
    println(fib_matrix(30));  // 832040

    0
    };

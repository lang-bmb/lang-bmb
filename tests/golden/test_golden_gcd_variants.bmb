// Golden Test: GCD/LCM computations
// Euclidean GCD, Extended GCD (via vec), LCM

// === Euclidean GCD (recursive) ===
fn gcd(a: i64, b: i64) -> i64 =
    if b == 0 { a }
    else { gcd(b, a % b) };

// === Extended GCD ===
// Stores results in a 3-element vec: [gcd, x, y]
// such that a*x + b*y = gcd(a, b)
fn ext_gcd(a: i64, b: i64, result: i64) -> i64 = {
    if b == 0 {
        let _s0 = vec_set(result, 0, a);
        let _s1 = vec_set(result, 1, 1);
        let _s2 = vec_set(result, 2, 0);
        0
    } else {
        let _r = ext_gcd(b, a % b, result);
        let x1 = vec_get(result, 1);
        let y1 = vec_get(result, 2);
        let _s1 = vec_set(result, 1, y1);
        let _s2 = vec_set(result, 2, x1 - (a / b) * y1);
        0
    }
};

// === LCM via GCD ===
fn lcm(a: i64, b: i64) -> i64 =
    if a == 0 { 0 }
    else if b == 0 { 0 }
    else { a / gcd(a, b) * b };

// === Absolute value helper ===
fn my_abs(x: i64) -> i64 =
    if x < 0 { 0 - x } else { x };

fn main() -> i64 = {
    // Basic GCD tests
    println(gcd(48, 18));     // 6
    println(gcd(100, 75));    // 25
    println(gcd(0, 5));       // 5
    println(gcd(7, 0));       // 7
    println(gcd(13, 13));     // 13
    println(gcd(1, 100));     // 1

    // LCM tests
    println(lcm(12, 18));    // 36
    println(lcm(4, 6));      // 12
    println(lcm(7, 5));      // 35
    println(lcm(0, 10));     // 0

    // Extended GCD: 48*x + 18*y = 6
    let r1 = vec_new();
    let _p1 = vec_push(r1, 0);
    let _p2 = vec_push(r1, 0);
    let _p3 = vec_push(r1, 0);
    let _e1 = ext_gcd(48, 18, r1);
    println(vec_get(r1, 0));  // gcd = 6
    println(vec_get(r1, 1));  // x = -1
    println(vec_get(r1, 2));  // y = 3

    // Verify: 48*(-1) + 18*3 = -48 + 54 = 6
    let check1 = 48 * vec_get(r1, 1) + 18 * vec_get(r1, 2);
    println(check1);          // 6

    // Extended GCD: 35*x + 15*y = 5
    // ext_gcd(35,15): ext_gcd(15,5): ext_gcd(5,0): (5,1,0)
    //   a=15,b=5: x=0, y=1-(15/5)*0=1 => (5,0,1)
    //   a=35,b=15: x=1, y=0-(35/15)*1=0-2*1=-2 => (5,1,-2)
    // Check: 35*1 + 15*(-2) = 35-30 = 5
    let r2 = vec_new();
    let _q1 = vec_push(r2, 0);
    let _q2 = vec_push(r2, 0);
    let _q3 = vec_push(r2, 0);
    let _e2 = ext_gcd(35, 15, r2);
    println(vec_get(r2, 0));  // gcd = 5
    println(vec_get(r2, 1));  // x = 1
    println(vec_get(r2, 2));  // y = -2

    let check2 = 35 * vec_get(r2, 1) + 15 * vec_get(r2, 2);
    println(check2);          // 5

    // Cleanup
    let _f1 = vec_free(r1);
    let _f2 = vec_free(r2);
    0
};

// Golden Test: Counting inversions using merge sort
// An inversion is a pair (i, j) where i < j but arr[i] > arr[j]
// Merge sort counts inversions in O(n log n) time
// Also computes the sorted array as a side effect

// Merge two sorted halves [left..mid) and [mid..right) of arr into temp
// Returns number of inversions found during merge
fn merge_count(arr: i64, temp: i64, left: i64, mid: i64, right: i64) -> i64 = {
    let mut i = left;
    let mut j = mid;
    let mut k = left;
    let mut inv = 0;

    while i < mid and j < right {
        let _x = if vec_get(arr, i) <= vec_get(arr, j) {
            vec_set(temp, k, vec_get(arr, i));
            set i = i + 1;
            0
        } else {
            // arr[i] > arr[j]: all elements in [i..mid) are > arr[j]
            vec_set(temp, k, vec_get(arr, j));
            set inv = inv + (mid - i);
            set j = j + 1;
            0
        };
        set k = k + 1
    };

    // Copy remaining from left half
    while i < mid {
        vec_set(temp, k, vec_get(arr, i));
        set i = i + 1;
        set k = k + 1
    };

    // Copy remaining from right half
    while j < right {
        vec_set(temp, k, vec_get(arr, j));
        set j = j + 1;
        set k = k + 1
    };

    // Copy temp back to arr
    let mut m = left;
    while m < right {
        vec_set(arr, m, vec_get(temp, m));
        set m = m + 1
    };

    inv
};

// Recursive merge sort that counts inversions
fn sort_count(arr: i64, temp: i64, left: i64, right: i64) -> i64 = {
    if right - left <= 1 { 0 }
    else {
        let mid = left + (right - left) / 2;
        let left_inv = sort_count(arr, temp, left, mid);
        let right_inv = sort_count(arr, temp, mid, right);
        let split_inv = merge_count(arr, temp, left, mid, right);
        left_inv + right_inv + split_inv
    }
};

fn count_inversions(arr: i64) -> i64 = {
    let n = vec_len(arr);
    let temp = vec_new();
    let mut i = 0;
    while i < n {
        let _p = vec_push(temp, 0);
        set i = i + 1
    };
    sort_count(arr, temp, 0, n)
};

fn make_vec(a: i64, b: i64, c: i64, d: i64, e: i64) -> i64 = {
    let v = vec_new();
    let _p = vec_push(v, a);
    let _p = vec_push(v, b);
    let _p = vec_push(v, c);
    let _p = vec_push(v, d);
    let _p = vec_push(v, e);
    v
};

fn print_vec(v: i64) -> () = {
    let mut i = 0;
    while i < vec_len(v) {
        let _x = if i > 0 { print_str(" "); 0 } else { 0 };
        print(vec_get(v, i));
        set i = i + 1
    };
    let _nl = print_str("\n")
};

fn main() -> () = {
    // Test 1: [2, 4, 1, 3, 5] -> inversions: (2,1), (4,1), (4,3) = 3
    let arr1 = make_vec(2, 4, 1, 3, 5);
    let inv1 = count_inversions(arr1);
    print_str("inversions: ");
    println(inv1);
    print_str("sorted: ");
    print_vec(arr1);

    // Test 2: [5, 4, 3, 2, 1] -> max inversions: 10 (reverse sorted)
    let arr2 = make_vec(5, 4, 3, 2, 1);
    let inv2 = count_inversions(arr2);
    print_str("inversions: ");
    println(inv2);
    print_str("sorted: ");
    print_vec(arr2);

    // Test 3: [1, 2, 3, 4, 5] -> 0 inversions (already sorted)
    let arr3 = make_vec(1, 2, 3, 4, 5);
    let inv3 = count_inversions(arr3);
    print_str("inversions: ");
    println(inv3);

    // Test 4: [3, 1, 2] -> inversions: (3,1), (3,2) = 2
    let arr4 = vec_new();
    let _p = vec_push(arr4, 3);
    let _p = vec_push(arr4, 1);
    let _p = vec_push(arr4, 2);
    let inv4 = count_inversions(arr4);
    print_str("inversions: ");
    let _r = println(inv4)
};

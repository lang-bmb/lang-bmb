// Golden test: Strassen-like matrix multiplication for 2x2 matrices
// Standard multiplication uses 8 multiplications for 2x2.
// Strassen uses 7 multiplications + more additions.
// We implement both and verify they produce the same results.
// Also tests Strassen on identity, diagonal, and larger composed cases.

// 2x2 matrix stored as vec of 4 elements: [a00, a01, a10, a11]
fn mat2_new(a00: i64, a01: i64, a10: i64, a11: i64) -> i64 = {
    let v = vec_new();
    let _p0 = vec_push(v, a00);
    let _p1 = vec_push(v, a01);
    let _p2 = vec_push(v, a10);
    let _p3 = vec_push(v, a11);
    v
};

// Standard 2x2 multiply: C = A * B (8 multiplications)
fn mat2_mul_std(a: i64, b: i64) -> i64 = {
    let a00 = vec_get(a, 0); let a01 = vec_get(a, 1);
    let a10 = vec_get(a, 2); let a11 = vec_get(a, 3);
    let b00 = vec_get(b, 0); let b01 = vec_get(b, 1);
    let b10 = vec_get(b, 2); let b11 = vec_get(b, 3);
    let c00 = a00 * b00 + a01 * b10;
    let c01 = a00 * b01 + a01 * b11;
    let c10 = a10 * b00 + a11 * b10;
    let c11 = a10 * b01 + a11 * b11;
    mat2_new(c00, c01, c10, c11)
};

// Strassen 2x2 multiply: C = A * B (7 multiplications)
fn mat2_mul_strassen(a: i64, b: i64) -> i64 = {
    let a00 = vec_get(a, 0); let a01 = vec_get(a, 1);
    let a10 = vec_get(a, 2); let a11 = vec_get(a, 3);
    let b00 = vec_get(b, 0); let b01 = vec_get(b, 1);
    let b10 = vec_get(b, 2); let b11 = vec_get(b, 3);

    // Strassen's 7 products
    let m1 = (a00 + a11) * (b00 + b11);
    let m2 = (a10 + a11) * b00;
    let m3 = a00 * (b01 - b11);
    let m4 = a11 * (b10 - b00);
    let m5 = (a00 + a01) * b11;
    let m6 = (a10 - a00) * (b00 + b01);
    let m7 = (a01 - a11) * (b10 + b11);

    // Compose result
    let c00 = m1 + m4 - m5 + m7;
    let c01 = m3 + m5;
    let c10 = m2 + m4;
    let c11 = m1 - m2 + m3 + m6;
    mat2_new(c00, c01, c10, c11)
};

// Matrix addition
fn mat2_add(a: i64, b: i64) -> i64 =
    mat2_new(
        vec_get(a, 0) + vec_get(b, 0),
        vec_get(a, 1) + vec_get(b, 1),
        vec_get(a, 2) + vec_get(b, 2),
        vec_get(a, 3) + vec_get(b, 3)
    );

// Matrix trace
fn mat2_trace(m: i64) -> i64 =
    vec_get(m, 0) + vec_get(m, 3);

// Matrix determinant
fn mat2_det(m: i64) -> i64 =
    vec_get(m, 0) * vec_get(m, 3) - vec_get(m, 1) * vec_get(m, 2);

// Check if two matrices are equal
fn mat2_eq(a: i64, b: i64) -> i64 =
    if vec_get(a, 0) == vec_get(b, 0) and
       vec_get(a, 1) == vec_get(b, 1) and
       vec_get(a, 2) == vec_get(b, 2) and
       vec_get(a, 3) == vec_get(b, 3) { 1 } else { 0 };

// Matrix power by repeated squaring
fn mat2_pow_strassen(m: i64, n: i64) -> i64 =
    if n == 0 { mat2_new(1, 0, 0, 1) }
    else if n == 1 {
        mat2_new(vec_get(m, 0), vec_get(m, 1), vec_get(m, 2), vec_get(m, 3))
    }
    else {
        let half = mat2_pow_strassen(m, n / 2);
        let sq = mat2_mul_strassen(half, half);
        let _fh = vec_free(half);
        if n % 2 == 0 { sq }
        else {
            let result = mat2_mul_strassen(sq, m);
            let _fs = vec_free(sq);
            result
        }
    };

fn main() -> i64 = {
    // Test 1: Identity * A = A
    let id = mat2_new(1, 0, 0, 1);
    let a = mat2_new(3, 7, 2, 5);
    let r1 = mat2_mul_strassen(id, a);
    let _p1 = println(mat2_eq(r1, a)); // 1

    // Test 2: A * Identity = A
    let r2 = mat2_mul_strassen(a, id);
    let _p2 = println(mat2_eq(r2, a)); // 1

    // Test 3: Standard vs Strassen match
    let b = mat2_new(1, 4, 6, 2);
    let r_std = mat2_mul_std(a, b);
    let r_str = mat2_mul_strassen(a, b);
    let _p3 = println(mat2_eq(r_std, r_str)); // 1

    // Test 4: Print specific results of A*B
    // A=[3,7;2,5], B=[1,4;6,2]
    // C00=3*1+7*6=45, C01=3*4+7*2=26, C10=2*1+5*6=32, C11=2*4+5*2=18
    let _p4 = println(vec_get(r_str, 0)); // 45
    let _p5 = println(vec_get(r_str, 1)); // 26
    let _p6 = println(vec_get(r_str, 2)); // 32
    let _p7 = println(vec_get(r_str, 3)); // 18

    // Test 5: det(A*B) = det(A)*det(B)
    let det_a = mat2_det(a);   // 3*5-7*2=1
    let det_b = mat2_det(b);   // 1*2-4*6=-22
    let det_ab = mat2_det(r_str); // 45*18-26*32=810-832=-22
    let _p8 = println(det_a);     // 1
    let _p9 = println(det_b);     // -22
    let _p10 = println(det_ab);   // -22
    let _p11 = println(if det_a * det_b == det_ab { 1 } else { 0 }); // 1

    // Test 6: trace(A+B) = trace(A)+trace(B)
    let ab_sum = mat2_add(a, b);
    let _p12 = println(mat2_trace(ab_sum)); // (3+1)+(5+2)=11
    let _p13 = println(mat2_trace(a) + mat2_trace(b)); // (3+5)+(1+2)=11

    // Test 7: Matrix power via Strassen: [[1,1],[1,0]]^8 = Fibonacci
    // F^n gives fib(n+1), fib(n), fib(n), fib(n-1) for the Fibonacci matrix
    let fib_mat = mat2_new(1, 1, 1, 0);
    let fib8 = mat2_pow_strassen(fib_mat, 8);
    let _p14 = println(vec_get(fib8, 0)); // fib(9)=34
    let _p15 = println(vec_get(fib8, 1)); // fib(8)=21

    // Cleanup
    let _f1 = vec_free(id);
    let _f2 = vec_free(a);
    let _f3 = vec_free(b);
    let _f4 = vec_free(r1);
    let _f5 = vec_free(r2);
    let _f6 = vec_free(r_std);
    let _f7 = vec_free(r_str);
    let _f8 = vec_free(ab_sum);
    let _f9 = vec_free(fib_mat);
    let _f10 = vec_free(fib8);
    0
};

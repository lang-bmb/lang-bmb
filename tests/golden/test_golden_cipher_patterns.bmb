// Golden Test: Cipher and encoding patterns
// Tests ROT13, XOR cipher, substitution, Atbash, rail fence, hex encoding

// ROT13: rotate letter by 13 positions in alphabet
// Input: ASCII code, Output: ROT13-encoded ASCII code
// A-Z: 65-90, a-z: 97-122
fn rot13_char(c: i64) -> i64 =
    if c >= 65 {
        if c <= 90 {
            // uppercase: shift by 13, wrap at Z
            65 + (c - 65 + 13) - ((c - 65 + 13) / 26) * 26
        } else if c >= 97 {
            if c <= 122 {
                // lowercase: shift by 13, wrap at z
                97 + (c - 97 + 13) - ((c - 97 + 13) / 26) * 26
            } else { c }
        } else { c }
    } else { c };

// ROT13 encode array of ASCII codes, return sum of encoded values
fn rot13_sum(arr: i64, pos: i64, acc: i64) -> i64 =
    if pos >= vec_len(arr) { acc }
    else { rot13_sum(arr, pos + 1, acc + rot13_char(vec_get(arr, pos))) };

// XOR cipher: XOR each byte with a key byte
fn xor_cipher_sum(arr: i64, key: i64, pos: i64, acc: i64) -> i64 =
    if pos >= vec_len(arr) { acc }
    else {
        let val = vec_get(arr, pos) bxor key;
        xor_cipher_sum(arr, key, pos + 1, acc + val)
    };

// Substitution cipher: shift each letter by a fixed amount (Caesar cipher)
fn caesar_char(c: i64, shift: i64) -> i64 =
    if c >= 65 {
        if c <= 90 {
            65 + (c - 65 + shift) - ((c - 65 + shift) / 26) * 26
        } else if c >= 97 {
            if c <= 122 {
                97 + (c - 97 + shift) - ((c - 97 + shift) / 26) * 26
            } else { c }
        } else { c }
    } else { c };

fn caesar_sum(arr: i64, shift: i64, pos: i64, acc: i64) -> i64 =
    if pos >= vec_len(arr) { acc }
    else { caesar_sum(arr, shift, pos + 1, acc + caesar_char(vec_get(arr, pos), shift)) };

// Atbash cipher: reverse alphabet (A->Z, B->Y, etc.)
fn atbash_char(c: i64) -> i64 =
    if c >= 65 {
        if c <= 90 { 90 - (c - 65) }
        else if c >= 97 {
            if c <= 122 { 122 - (c - 97) }
            else { c }
        } else { c }
    } else { c };

fn atbash_sum(arr: i64, pos: i64, acc: i64) -> i64 =
    if pos >= vec_len(arr) { acc }
    else { atbash_sum(arr, pos + 1, acc + atbash_char(vec_get(arr, pos))) };

// Rail fence cipher: count chars on each rail (2 rails)
// Rail 0: positions 0, 2, 4, ...   Rail 1: positions 1, 3, 5, ...
fn rail_count(len: i64, rail: i64) -> i64 =
    if rail == 0 { (len + 1) / 2 }
    else { len / 2 };

// Rail fence with 3 rails: pattern is 0,1,2,1,0,1,2,1,...
fn rail3_count(len: i64, rail: i64) -> i64 = {
    let mut count = 0;
    let mut pos = 0;
    let mut cur = 0;
    let mut going_down = 1;
    loop {
        if pos >= len { break } else { () };
        count = if cur == rail { count + 1 } else { count };
        // Update direction
        if cur == 0 { going_down = 1 } else { () };
        if cur == 2 { going_down = 0 } else { () };
        cur = if going_down == 1 { cur + 1 } else { cur - 1 };
        pos = pos + 1
    };
    count
    };

// Convert number to hex digit sum (manual division by 16)
fn hex_digit_val(n: i64) -> i64 =
    n - (n / 16) * 16;

fn hex_digit_sum(n: i64) -> i64 =
    if n < 16 { n }
    else { hex_digit_val(n) + hex_digit_sum(n / 16) };

// Count hex digits
fn hex_digit_count(n: i64) -> i64 =
    if n < 16 { 1 }
    else { 1 + hex_digit_count(n / 16) };

// Double-encode: Caesar(3) then Atbash on a single char
fn double_encode_char(c: i64) -> i64 =
    atbash_char(caesar_char(c, 3));

fn main() -> i64 = {
    // --- ROT13 tests ---
    // 'A'=65 -> rot13 -> 'N'=78
    let _p1 = println(rot13_char(65));   // 78

    // 'N'=78 -> rot13 -> 'A'=65 (ROT13 is self-inverse)
    let _p2 = println(rot13_char(78));   // 65

    // 'a'=97 -> rot13 -> 'n'=110
    let _p3 = println(rot13_char(97));   // 110

    // ROT13 sum of "AB" = [65,66] -> [78,79] -> 78+79 = 157
    let r1 = vec_new();
    let _rp = vec_push(r1, 65);
    let _rp = vec_push(r1, 66);
    let _p4 = println(rot13_sum(r1, 0, 0));  // 157

    // --- XOR cipher tests ---
    // XOR [10, 20, 30] with key=0xFF (255)
    // 10 XOR 255 = 245, 20 XOR 255 = 235, 30 XOR 255 = 225
    // sum = 245+235+225 = 705
    let x1 = vec_new();
    let _xp = vec_push(x1, 10);
    let _xp = vec_push(x1, 20);
    let _xp = vec_push(x1, 30);
    let _p5 = println(xor_cipher_sum(x1, 255, 0, 0));  // 705

    // XOR with key=0 should be identity: 10+20+30=60
    let _p6 = println(xor_cipher_sum(x1, 0, 0, 0));  // 60

    // --- Caesar cipher tests ---
    // Caesar shift 3: 'A'=65 -> 'D'=68
    let _p7 = println(caesar_char(65, 3));  // 68

    // Caesar shift 3: 'Z'=90 -> 'C'=67 (wrap around)
    let _p8 = println(caesar_char(90, 3));  // 67

    // Caesar sum of "ABC"=[65,66,67] with shift=1 -> [66,67,68] -> 66+67+68=201
    let c1 = vec_new();
    let _cp = vec_push(c1, 65);
    let _cp = vec_push(c1, 66);
    let _cp = vec_push(c1, 67);
    let _p9 = println(caesar_sum(c1, 1, 0, 0));  // 201

    // --- Atbash cipher tests ---
    // 'A'=65 -> 'Z'=90
    let _p10 = println(atbash_char(65));  // 90

    // 'Z'=90 -> 'A'=65
    let _p11 = println(atbash_char(90));  // 65

    // 'M'=77 -> 'N'=78 (Atbash: 90 - (77-65) = 90-12 = 78)
    let _p12 = println(atbash_char(77));  // 78

    // Atbash sum of "AB"=[65,66] -> [90,89] -> 90+89=179
    let _p13 = println(atbash_sum(r1, 0, 0));  // 179

    // --- Rail fence tests ---
    // 2 rails, length 7: rail 0 has 4, rail 1 has 3
    let _p14 = println(rail_count(7, 0));  // 4
    let _p15 = println(rail_count(7, 1));  // 3

    // 3 rails, length 7: pattern 0,1,2,1,0,1,2 -> rail0:2, rail1:3, rail2:2
    let _p16 = println(rail3_count(7, 0));  // 2
    let _p17 = println(rail3_count(7, 1));  // 3
    let _p18 = println(rail3_count(7, 2));  // 2

    // --- Hex encoding tests ---
    // 255 in hex = FF -> digit sum = 15+15 = 30
    let _p19 = println(hex_digit_sum(255));  // 30

    // 256 in hex = 100 -> digit sum = 1+0+0 = 1
    let _p20 = println(hex_digit_sum(256));  // 1

    // 4095 in hex = FFF -> digit sum = 15+15+15 = 45
    let _p21 = println(hex_digit_sum(4095));  // 45

    // Hex digit count: 255 = FF (2 digits)
    let _p22 = println(hex_digit_count(255));  // 2

    // Hex digit count: 4096 = 1000 (4 digits)
    let _p23 = println(hex_digit_count(4096));  // 4

    // --- Double-encode test ---
    // 'A'=65 -> Caesar(3) -> 'D'=68 -> Atbash -> 90-(68-65)=87='W'
    let _p24 = println(double_encode_char(65));  // 87

    let _f1 = vec_free(r1);
    let _f2 = vec_free(x1);
    let _f3 = vec_free(c1);
    0
    };

// Golden Test: Dutch National Flag Sort — 3-way partition variations
// Multiple pivot strategies and verification of partition invariants

fn swap(v: i64, i: i64, j: i64) -> i64 = {
    let tmp = vec_get(v, i);
    vec_set(v, i, vec_get(v, j));
    vec_set(v, j, tmp);
    0
};

// Standard Dutch National Flag: partition into <, ==, > pivot
// Returns lo * 10000 + mid (encoded pair)
fn dnf_partition(arr: i64, n: i64, pivot: i64) -> i64 = {
    let mut lo = 0;
    let mut mid = 0;
    let mut hi = n - 1;
    loop {
        if mid > hi { break } else { () };
        let val = vec_get(arr, mid);
        if val < pivot {
            let _s = swap(arr, lo, mid);
            lo = lo + 1;
            mid = mid + 1
        } else if val == pivot {
            mid = mid + 1
        } else {
            let _s = swap(arr, mid, hi);
            hi = hi - 1
        }
    };
    lo * 10000 + mid
};

// Verify partition: all elements in [0, lo) < pivot, [lo, mid) == pivot, [mid, n) > pivot
fn verify_partition(arr: i64, n: i64, lo: i64, mid: i64, pivot: i64) -> i64 = {
    let mut ok = 1;
    for i in 0..lo {
        if vec_get(arr, i) >= pivot { ok = 0 } else { () }
    };
    for i in lo..mid {
        if vec_get(arr, i) != pivot { ok = 0 } else { () }
    };
    for i in mid..n {
        if vec_get(arr, i) <= pivot { ok = 0 } else { () }
    };
    ok
};

// Sort an array of 0s, 1s, and 2s using DNF
fn sort_012(arr: i64, n: i64) -> i64 = {
    let _r = dnf_partition(arr, n, 1);
    0
};

// Count occurrences of a value
fn count_val(arr: i64, n: i64, val: i64) -> i64 = {
    let mut c = 0;
    for i in 0..n {
        if vec_get(arr, i) == val { c = c + 1 } else { () }
    };
    c
};

// Print array elements
fn print_arr(arr: i64, n: i64) -> i64 = {
    for i in 0..n {
        println(vec_get(arr, i))
    };
    0
};

// 4-way partition: <a, [a,b), [b,c), >=c
// Returns three boundary indices encoded as b1*100000000 + b2*10000 + b3
fn four_way(arr: i64, n: i64, a: i64, b: i64, c: i64) -> i64 = {
    // First partition around a
    let r1 = dnf_partition(arr, n, a);
    let lo1 = r1 / 10000;
    // Now arr[0..lo1) < a, arr[lo1..] >= a
    // We need to further partition arr[lo1..n) around b
    // Create sub-view starting at lo1
    let sub_len = n - lo1;
    let sub = vec_new();
    for i in lo1..n {
        vec_push(sub, vec_get(arr, i))
    };
    let r2 = dnf_partition(sub, sub_len, b);
    let lo2 = r2 / 10000;
    let mid2 = r2 - lo2 * 10000;
    // Copy back
    for i in 0..sub_len {
        vec_set(arr, lo1 + i, vec_get(sub, i))
    };
    vec_free(sub);
    // Boundaries: lo1, lo1+lo2, lo1+mid2
    // But we also need to handle the >= c part within [lo1+mid2..n)
    lo1 * 100000000 + (lo1 + lo2) * 10000 + (lo1 + mid2)
};

fn main() -> i64 = {
    // Test 1: Classic 0-1-2 sorting
    // [2, 0, 1, 2, 1, 0, 0, 2, 1]
    let a1 = vec_new();
    vec_push(a1, 2); vec_push(a1, 0); vec_push(a1, 1); vec_push(a1, 2);
    vec_push(a1, 1); vec_push(a1, 0); vec_push(a1, 0); vec_push(a1, 2); vec_push(a1, 1);
    let n1 = 9;
    let _s = sort_012(a1, n1);
    // After sort: [0,0,0,1,1,1,2,2,2]
    let _p1 = println(vec_get(a1, 0));   // 0
    let _p2 = println(vec_get(a1, 3));   // 1
    let _p3 = println(vec_get(a1, 6));   // 2
    let _p4 = println(count_val(a1, n1, 0)); // 3
    let _p5 = println(count_val(a1, n1, 1)); // 3
    let _p6 = println(count_val(a1, n1, 2)); // 3

    // Test 2: Partition [5,3,8,5,1,5,9,2,5] around pivot=5
    let a2 = vec_new();
    vec_push(a2, 5); vec_push(a2, 3); vec_push(a2, 8); vec_push(a2, 5);
    vec_push(a2, 1); vec_push(a2, 5); vec_push(a2, 9); vec_push(a2, 2); vec_push(a2, 5);
    let n2 = 9;
    let r2 = dnf_partition(a2, n2, 5);
    let lo2 = r2 / 10000;
    let mid2 = r2 - lo2 * 10000;
    let _p7 = println(lo2);             // 3 (three elements < 5: 1,2,3)
    let _p8 = println(mid2 - lo2);      // 4 (four elements == 5)
    let _p9 = println(n2 - mid2);       // 2 (two elements > 5: 8,9)
    let _p10 = println(verify_partition(a2, n2, lo2, mid2, 5)); // 1

    // Test 3: All same elements [7,7,7,7]
    let a3 = vec_new();
    vec_push(a3, 7); vec_push(a3, 7); vec_push(a3, 7); vec_push(a3, 7);
    let r3 = dnf_partition(a3, 4, 7);
    let lo3 = r3 / 10000;
    let mid3 = r3 - lo3 * 10000;
    let _p11 = println(lo3);            // 0 (none less)
    let _p12 = println(mid3);           // 4 (all equal)

    // Test 4: Pivot not in array [1,3,5] pivot=2
    let a4 = vec_new();
    vec_push(a4, 1); vec_push(a4, 3); vec_push(a4, 5);
    let r4 = dnf_partition(a4, 3, 2);
    let lo4 = r4 / 10000;
    let mid4 = r4 - lo4 * 10000;
    let _p13 = println(lo4);            // 1 (only 1 < 2)
    let _p14 = println(mid4 - lo4);     // 0 (no elements == 2)
    let _p15 = println(3 - mid4);       // 2 (3 and 5 > 2)

    // Test 5: Reverse sorted [9,7,5,3,1] pivot=5
    let a5 = vec_new();
    vec_push(a5, 9); vec_push(a5, 7); vec_push(a5, 5); vec_push(a5, 3); vec_push(a5, 1);
    let r5 = dnf_partition(a5, 5, 5);
    let lo5 = r5 / 10000;
    let mid5 = r5 - lo5 * 10000;
    let _p16 = println(verify_partition(a5, 5, lo5, mid5, 5)); // 1
    let _p17 = println(lo5);            // 2 (1 and 3)
    let _p18 = println(mid5 - lo5);     // 1 (just 5)

    // Test 6: Single element [42] pivot=42
    let a6 = vec_new();
    vec_push(a6, 42);
    let r6 = dnf_partition(a6, 1, 42);
    let lo6 = r6 / 10000;
    let mid6 = r6 - lo6 * 10000;
    let _p19 = println(lo6);            // 0
    let _p20 = println(mid6);           // 1

    vec_free(a1); vec_free(a2); vec_free(a3);
    vec_free(a4); vec_free(a5); vec_free(a6);
    0
};

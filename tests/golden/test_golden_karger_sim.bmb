// Golden Test: Simulated Karger-like min-cut via deterministic edge contraction
// Uses adjacency list (flat vec) with union-find for vertex contraction
// Deterministic: always pick the first available cross-component edge

// Union-Find
fn uf_find(parent: i64, x: i64) -> i64 = {
    let p = vec_get(parent, x);
    if p == x { x }
    else {
        let root = uf_find(parent, p);
        vec_set(parent, x, root);
        root
    }
    };

fn uf_union(parent: i64, rank_arr: i64, a: i64, b: i64) -> i64 = {
    let ra = uf_find(parent, a);
    let rb = uf_find(parent, b);
    if ra == rb { 0 }
    else {
        let _x = if vec_get(rank_arr, ra) < vec_get(rank_arr, rb) {
            vec_set(parent, ra, rb);
            0
        } else if vec_get(rank_arr, ra) > vec_get(rank_arr, rb) {
            vec_set(parent, rb, ra);
            0
        } else {
            vec_set(parent, rb, ra);
            vec_set(rank_arr, ra, vec_get(rank_arr, ra) + 1);
            0
        };
        1
    }
    };

// Count distinct components
fn count_components(parent: i64, n: i64) -> i64 = {
    let mut count = 0;
    for i in 0..n {
        let _x = if uf_find(parent, i) == i {
            set count = count + 1;
            0
        } else { 0 }
    };
    count
    };

// Edge list: pairs of (u, v) stored as flat vec [u0, v0, u1, v1, ...]
fn edge_count(edges: i64) -> i64 =
    vec_len(edges) / 2;

fn edge_u(edges: i64, idx: i64) -> i64 =
    vec_get(edges, idx * 2);

fn edge_v(edges: i64, idx: i64) -> i64 =
    vec_get(edges, idx * 2 + 1);

// Count edges crossing component boundary (the cut)
fn count_cut_edges(edges: i64, parent: i64) -> i64 = {
    let ne = edge_count(edges);
    let mut cut = 0;
    for i in 0..ne {
        let ru = uf_find(parent, edge_u(edges, i));
        let rv = uf_find(parent, edge_v(edges, i));
        let _x = if ru != rv {
            set cut = cut + 1;
            0
        } else { 0 }
    };
    cut
    };

// Contract one step: find first cross-component edge and merge
// Returns 1 if contraction happened, 0 if no cross-edge found
fn contract_step(edges: i64, parent: i64, rank_arr: i64) -> i64 = {
    let ne = edge_count(edges);
    let mut found = 0;
    for i in 0..ne {
        let _x = if found == 0 {
            let ru = uf_find(parent, edge_u(edges, i));
            let rv = uf_find(parent, edge_v(edges, i));
            if ru != rv {
                let _m = uf_union(parent, rank_arr, ru, rv);
                set found = 1;
                0
            } else { 0 }
        } else { 0 }
    };
    found
    };

// Contract until only target_components remain
fn contract_to(edges: i64, parent: i64, rank_arr: i64, n: i64, target: i64) -> i64 = {
    let mut comps = count_components(parent, n);
    let mut steps = 0;
    loop {
        if comps <= target { break } else { () };
        let did = contract_step(edges, parent, rank_arr);
        let _x = if did == 1 {
            set comps = comps - 1;
            set steps = steps + 1;
            0
        } else {
            // No more cross-edges, force exit
            set comps = 0;
            0
        };
        0
    };
    steps
    };

fn make_iota(n: i64) -> i64 = {
    let v = vec_new();
    for i in 0..n { vec_push(v, i) };
    v
    };

fn make_zeros(n: i64) -> i64 = {
    let v = vec_new();
    for _i in 0..n { vec_push(v, 0) };
    v
    };

// Check which component a node belongs to (for verification)
fn same_component(parent: i64, a: i64, b: i64) -> i64 =
    if uf_find(parent, a) == uf_find(parent, b) { 1 } else { 0 };

fn main() -> i64 = {
    // Graph 1: Simple 4-node cycle (0-1-2-3-0)
    // Edges: 0-1, 1-2, 2-3, 3-0
    // Min cut = 2 (remove any 2 adjacent edges)
    let e1 = vec_new();
    vec_push(e1, 0); vec_push(e1, 1);
    vec_push(e1, 1); vec_push(e1, 2);
    vec_push(e1, 2); vec_push(e1, 3);
    vec_push(e1, 3); vec_push(e1, 0);

    let _p1 = println(edge_count(e1)); // 4

    let p1 = make_iota(4);
    let r1 = make_zeros(4);
    let _p2 = println(count_components(p1, 4)); // 4
    let _p3 = println(count_cut_edges(e1, p1)); // 4 (all edges cross different components)

    // Contract to 2 components
    let steps1 = contract_to(e1, p1, r1, 4, 2);
    let _p4 = println(steps1); // 2 (contract 2 edges to get 2 components)
    let _p5 = println(count_cut_edges(e1, p1)); // 2 (the cut)
    let _p6 = println(count_components(p1, 4));  // 2

    // Graph 2: Complete K4 (all pairs connected)
    // Edges: 0-1, 0-2, 0-3, 1-2, 1-3, 2-3
    // Min cut = 3 (remove all edges incident to one vertex)
    let e2 = vec_new();
    vec_push(e2, 0); vec_push(e2, 1);
    vec_push(e2, 0); vec_push(e2, 2);
    vec_push(e2, 0); vec_push(e2, 3);
    vec_push(e2, 1); vec_push(e2, 2);
    vec_push(e2, 1); vec_push(e2, 3);
    vec_push(e2, 2); vec_push(e2, 3);

    let p2 = make_iota(4);
    let r2 = make_zeros(4);
    let _p7 = println(edge_count(e2));            // 6
    let _p8 = println(count_cut_edges(e2, p2));   // 6

    let steps2 = contract_to(e2, p2, r2, 4, 2);
    let _p9 = println(steps2);                     // 2
    let _p10 = println(count_cut_edges(e2, p2));   // cut value (deterministic)
    let _p11 = println(count_components(p2, 4));   // 2

    // Graph 3: Path graph 0-1-2-3-4
    // Edges: 0-1, 1-2, 2-3, 3-4
    // Min cut = 1
    let e3 = vec_new();
    vec_push(e3, 0); vec_push(e3, 1);
    vec_push(e3, 1); vec_push(e3, 2);
    vec_push(e3, 2); vec_push(e3, 3);
    vec_push(e3, 3); vec_push(e3, 4);

    let p3 = make_iota(5);
    let r3 = make_zeros(5);
    let steps3 = contract_to(e3, p3, r3, 5, 2);
    let _p12 = println(steps3);                     // 3
    let _p13 = println(count_cut_edges(e3, p3));    // 1 (path: min cut is 1)

    // After contracting path, 0,1,2,3 should be same component
    let _p14 = println(same_component(p3, 0, 3));  // 1
    let _p15 = println(same_component(p3, 0, 4));  // 0 (4 is in other component)

    // Graph 4: Star graph (0 connected to 1,2,3,4)
    // Min cut = 1 (remove any edge)
    let e4 = vec_new();
    vec_push(e4, 0); vec_push(e4, 1);
    vec_push(e4, 0); vec_push(e4, 2);
    vec_push(e4, 0); vec_push(e4, 3);
    vec_push(e4, 0); vec_push(e4, 4);

    let p4 = make_iota(5);
    let r4 = make_zeros(5);
    let steps4 = contract_to(e4, p4, r4, 5, 2);
    let _p16 = println(steps4);                     // 3
    let _p17 = println(count_cut_edges(e4, p4));    // cut edges remaining

    // Single edge graph
    let e5 = vec_new();
    vec_push(e5, 0); vec_push(e5, 1);
    let p5 = make_iota(2);
    let r5 = make_zeros(2);
    let _p18 = println(count_cut_edges(e5, p5)); // 1
    let steps5 = contract_to(e5, p5, r5, 2, 1);
    let _p19 = println(steps5);                   // 1
    let _p20 = println(count_components(p5, 2));  // 1

    0
    };

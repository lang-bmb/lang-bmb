// Golden Test: BST validation by checking sorted inorder
// Simulate BST using array-based tree, verify inorder is sorted

// Tree stored as arrays: val[], left[], right[] (index-based)
// -1 means no child, root is index 0

fn inorder_collect(val: i64, left: i64, right: i64, node: i64, out: i64) -> i64 = {
    if node < 0 { return 0 } else { () };
    let _l = inorder_collect(val, left, right, vec_get(left, node), out);
    vec_push(out, vec_get(val, node));
    let _r = inorder_collect(val, left, right, vec_get(right, node), out);
    0
};

// Check if array is sorted (non-decreasing)
fn is_sorted(arr: i64) -> i64 = {
    let n = vec_len(arr);
    if n <= 1 { return 1 } else { () };
    let mut i = 1;
    loop {
        if i >= n { break } else { () };
        if vec_get(arr, i) < vec_get(arr, i - 1) {
            return 0
        } else { () };
        i = i + 1
    };
    1
};

// Check if tree is a valid BST
fn is_bst(val: i64, left: i64, right: i64) -> i64 = {
    let out = vec_new();
    let _c = inorder_collect(val, left, right, 0, out);
    let result = is_sorted(out);
    vec_free(out);
    result
};

fn main() -> i64 = {
    // Test 1: Valid BST
    //       4
    //      / \
    //     2   6
    //    / \ / \
    //   1  3 5  7
    // Nodes: 0=4, 1=2, 2=6, 3=1, 4=3, 5=5, 6=7
    let v1 = vec_new();
    vec_push(v1, 4); vec_push(v1, 2); vec_push(v1, 6);
    vec_push(v1, 1); vec_push(v1, 3); vec_push(v1, 5); vec_push(v1, 7);
    let l1 = vec_new();
    vec_push(l1, 1); vec_push(l1, 3); vec_push(l1, 5);
    vec_push(l1, 0 - 1); vec_push(l1, 0 - 1); vec_push(l1, 0 - 1); vec_push(l1, 0 - 1);
    let r1 = vec_new();
    vec_push(r1, 2); vec_push(r1, 4); vec_push(r1, 6);
    vec_push(r1, 0 - 1); vec_push(r1, 0 - 1); vec_push(r1, 0 - 1); vec_push(r1, 0 - 1);
    let _p1 = println(is_bst(v1, l1, r1));  // 1

    // Verify inorder: 1 2 3 4 5 6 7
    let out1 = vec_new();
    let _c1 = inorder_collect(v1, l1, r1, 0, out1);
    let _p2 = println(vec_get(out1, 0));  // 1
    let _p3 = println(vec_get(out1, 3));  // 4
    let _p4 = println(vec_get(out1, 6));  // 7

    // Test 2: Invalid BST (swap 3 and 6)
    //       4
    //      / \
    //     2   3  <- should be > 4
    //    / \
    //   1  6    <- should be < 4
    let v2 = vec_new();
    vec_push(v2, 4); vec_push(v2, 2); vec_push(v2, 3);
    vec_push(v2, 1); vec_push(v2, 6);
    let l2 = vec_new();
    vec_push(l2, 1); vec_push(l2, 3); vec_push(l2, 0 - 1);
    vec_push(l2, 0 - 1); vec_push(l2, 0 - 1);
    let r2 = vec_new();
    vec_push(r2, 2); vec_push(r2, 4); vec_push(r2, 0 - 1);
    vec_push(r2, 0 - 1); vec_push(r2, 0 - 1);
    let _p5 = println(is_bst(v2, l2, r2));  // 0

    // Test 3: Single node -> valid BST
    let v3 = vec_new(); vec_push(v3, 42);
    let l3 = vec_new(); vec_push(l3, 0 - 1);
    let r3 = vec_new(); vec_push(r3, 0 - 1);
    let _p6 = println(is_bst(v3, l3, r3));  // 1

    // Test 4: Left-skewed tree (valid BST)
    //   3
    //  /
    // 2
    //  /
    // 1
    let v4 = vec_new(); vec_push(v4, 3); vec_push(v4, 2); vec_push(v4, 1);
    let l4 = vec_new(); vec_push(l4, 1); vec_push(l4, 2); vec_push(l4, 0 - 1);
    let r4 = vec_new(); vec_push(r4, 0 - 1); vec_push(r4, 0 - 1); vec_push(r4, 0 - 1);
    let _p7 = println(is_bst(v4, l4, r4));  // 1

    // Test 5: is_sorted tests
    let s1 = vec_new(); vec_push(s1, 1); vec_push(s1, 2); vec_push(s1, 3);
    let _p8 = println(is_sorted(s1));  // 1

    let s2 = vec_new(); vec_push(s2, 3); vec_push(s2, 1); vec_push(s2, 2);
    let _p9 = println(is_sorted(s2));  // 0

    let s3 = vec_new(); vec_push(s3, 5); vec_push(s3, 5); vec_push(s3, 5);
    let _p10 = println(is_sorted(s3));  // 1 (non-decreasing allows equal)

    vec_free(v1); vec_free(l1); vec_free(r1); vec_free(out1);
    vec_free(v2); vec_free(l2); vec_free(r2);
    vec_free(v3); vec_free(l3); vec_free(r3);
    vec_free(v4); vec_free(l4); vec_free(r4);
    vec_free(s1); vec_free(s2); vec_free(s3);
    0
};

// Golden Test: Expression evaluator (recursive descent)
// Evaluates arithmetic expressions encoded as integer tokens
// Grammar: expr = term ((PLUS|MINUS) term)*
//          term = factor ((MUL|DIV) factor)*
//          factor = NUM | LPAREN expr RPAREN
// Tokens: positive = number, -1=+, -2=-, -3=*, -4=/, -5=(, -6=)

fn eval_expr(tokens: i64, pos: i64) -> i64 = {
    let left = eval_term(tokens, pos);
    let mut result = left;
    let mut cont = 1;
    while cont == 1 {
        let p = vec_get(pos, 0);
        let _x = if p < vec_len(tokens) {
            let op = vec_get(tokens, p);
            let _y = if op == 0 - 1 {
                vec_set(pos, 0, p + 1);
                let right = eval_term(tokens, pos);
                set result = result + right;
                0
            } else if op == 0 - 2 {
                vec_set(pos, 0, p + 1);
                let right = eval_term(tokens, pos);
                set result = result - right;
                0
            } else {
                set cont = 0;
                0
            };
            0
        } else {
            set cont = 0;
            0
        }
    };
    result
};

fn eval_term(tokens: i64, pos: i64) -> i64 = {
    let left = eval_factor(tokens, pos);
    let mut result = left;
    let mut cont = 1;
    while cont == 1 {
        let p = vec_get(pos, 0);
        let _x = if p < vec_len(tokens) {
            let op = vec_get(tokens, p);
            let _y = if op == 0 - 3 {
                vec_set(pos, 0, p + 1);
                let right = eval_factor(tokens, pos);
                set result = result * right;
                0
            } else if op == 0 - 4 {
                vec_set(pos, 0, p + 1);
                let right = eval_factor(tokens, pos);
                set result = result / right;
                0
            } else {
                set cont = 0;
                0
            };
            0
        } else {
            set cont = 0;
            0
        }
    };
    result
};

fn eval_factor(tokens: i64, pos: i64) -> i64 = {
    let p = vec_get(pos, 0);
    let tok = vec_get(tokens, p);
    if tok == 0 - 5 {
        // LPAREN
        vec_set(pos, 0, p + 1);
        let result = eval_expr(tokens, pos);
        // Skip RPAREN
        vec_set(pos, 0, vec_get(pos, 0) + 1);
        result
    } else {
        // Number
        vec_set(pos, 0, p + 1);
        tok
    }
};

fn evaluate(tokens: i64) -> i64 = {
    let pos = vec_new();
    let _p = vec_push(pos, 0);
    eval_expr(tokens, pos)
};

fn main() -> () = {
    // Test 1: 3 + 4 => tokens: [3, -1, 4]
    let t1 = vec_new();
    let _p = vec_push(t1, 3); let _p = vec_push(t1, 0 - 1); let _p = vec_push(t1, 4);
    print_str("3+4="); let _r = println(evaluate(t1));

    // Test 2: 2 * 3 + 4 => [2, -3, 3, -1, 4] = 10
    let t2 = vec_new();
    let _p = vec_push(t2, 2); let _p = vec_push(t2, 0 - 3);
    let _p = vec_push(t2, 3); let _p = vec_push(t2, 0 - 1);
    let _p = vec_push(t2, 4);
    print_str("2*3+4="); let _r = println(evaluate(t2));

    // Test 3: 2 + 3 * 4 => [2, -1, 3, -3, 4] = 14
    let t3 = vec_new();
    let _p = vec_push(t3, 2); let _p = vec_push(t3, 0 - 1);
    let _p = vec_push(t3, 3); let _p = vec_push(t3, 0 - 3);
    let _p = vec_push(t3, 4);
    print_str("2+3*4="); let _r = println(evaluate(t3));

    // Test 4: (2 + 3) * 4 => [-5, 2, -1, 3, -6, -3, 4] = 20
    let t4 = vec_new();
    let _p = vec_push(t4, 0 - 5); let _p = vec_push(t4, 2);
    let _p = vec_push(t4, 0 - 1); let _p = vec_push(t4, 3);
    let _p = vec_push(t4, 0 - 6); let _p = vec_push(t4, 0 - 3);
    let _p = vec_push(t4, 4);
    print_str("(2+3)*4="); let _r = println(evaluate(t4));

    // Test 5: 10 / 2 - 3 => [10, -4, 2, -2, 3] = 2
    let t5 = vec_new();
    let _p = vec_push(t5, 10); let _p = vec_push(t5, 0 - 4);
    let _p = vec_push(t5, 2); let _p = vec_push(t5, 0 - 2);
    let _p = vec_push(t5, 3);
    print_str("10/2-3="); let _r = println(evaluate(t5))
};

// Golden test: DFA state equivalence detection
// Expected output: 22

// DFA: 6 states, binary alphabet
// Find which states are equivalent using partition refinement

fn get_transition(state: i64, input: i64) -> i64 = {
// Hardcoded DFA: states 0-5
// State 0: on 0->1, on 1->2
// State 1: on 0->1, on 1->3
// State 2: on 0->2, on 1->4
// State 3: on 0->1, on 1->3 (equiv to state 1)
// State 4: on 0->2, on 1->4 (equiv to state 2)
// State 5: on 0->5, on 1->5

    if state == 0 {
        if input == 0 { 1 } else { 2 }
    } else if state == 1 {
    if input == 0 { 1 } else { 3 }
    } else if state == 2 {
    if input == 0 { 2 } else { 4 }
    } else if state == 3 {
    if input == 0 { 1 } else { 3 }
    } else if state == 4 {
    if input == 0 { 2 } else { 4 }
    } else {
    5
    }
    };

fn is_accepting(state: i64) -> i64 = {
    if state == 3 { 1 }
    else if state == 4 { 1 }
    else { 0 }
    };

fn get_partition(state: i64) -> i64 = {
// Initial partition: accepting vs non-accepting
    is_accepting(state)
    };

fn states_equivalent(s1: i64, s2: i64) -> i64 = {
// Simplified: check if both have same acceptance and transitions
    if get_partition(s1) != get_partition(s2) {
        0
    } else {
    let t0_s1 = get_transition(s1, 0);
    let t0_s2 = get_transition(s2, 0);
    let t1_s1 = get_transition(s1, 1);
    let t1_s2 = get_transition(s2, 1);

    if t0_s1 == t0_s2 {
        if t1_s1 == t1_s2 { 1 } else { 0 }
    } else { 0 }
    }
    };

fn find_equivalences() -> i64 = {
    let count = [0; 1];

// Check all pairs
    let i = [0; 1];
    while i[0] < 6 {
        let j = [0; 1];
        set j[0] = i[0] + 1;
        while j[0] < 6 {
            if states_equivalent(i[0], j[0]) == 1 {
                println(i[0]);
                println(j[0]);
                set count[0] = count[0] + 1;
            } else { };
        set j[0] = j[0] + 1;
    };
    set i[0] = i[0] + 1;
    };

    count[0]
    };

fn main() -> i64 = {
// Test individual state behaviors
    let i = [0; 1];
    while i[0] < 6 {
        let acc = is_accepting(i[0]);
        println(acc);
        set i[0] = i[0] + 1;
    };

// Test transitions
    println(get_transition(1, 0)); // 1
    println(get_transition(1, 1)); // 3
    println(get_transition(3, 0)); // 1
    println(get_transition(3, 1)); // 3

    println(get_transition(2, 0)); // 2
    println(get_transition(2, 1)); // 4
    println(get_transition(4, 0)); // 2
    println(get_transition(4, 1)); // 4

// Check equivalence
    let eq13 = states_equivalent(1, 3);
    println(eq13);

    let eq24 = states_equivalent(2, 4);
    println(eq24);

// Find all equivalences
    let equiv_count = find_equivalences();
    println(equiv_count);

// Sum: 0+0+0+1+1+0 + 1+3+1+3 + 2+4+2+4 + 0+0+0 = 22
    0
    };

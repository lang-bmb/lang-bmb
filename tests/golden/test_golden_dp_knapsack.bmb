// Golden Test: 0/1 Knapsack with vec-based DP
// Items defined as parallel vecs: weights and values
// DP table: dp[i] = max value achievable with capacity i

fn make_zeros(n: i64) -> i64 = {
    let v = vec_new();
    for _i in 0..n { let _p = vec_push(v, 0); 0 };
    v
    };

fn make_vec2(a: i64, b: i64) -> i64 = {
    let v = vec_new();
    let _p0 = vec_push(v, a);
    let _p1 = vec_push(v, b);
    v
    };

fn make_vec3(a: i64, b: i64, c: i64) -> i64 = {
    let v = vec_new();
    let _p0 = vec_push(v, a);
    let _p1 = vec_push(v, b);
    let _p2 = vec_push(v, c);
    v
    };

fn make_vec4(a: i64, b: i64, c: i64, d: i64) -> i64 = {
    let v = vec_new();
    let _p0 = vec_push(v, a);
    let _p1 = vec_push(v, b);
    let _p2 = vec_push(v, c);
    let _p3 = vec_push(v, d);
    v
    };

fn make_vec5(a: i64, b: i64, c: i64, d: i64, e: i64) -> i64 = {
    let v = vec_new();
    let _p0 = vec_push(v, a);
    let _p1 = vec_push(v, b);
    let _p2 = vec_push(v, c);
    let _p3 = vec_push(v, d);
    let _p4 = vec_push(v, e);
    v
    };

// Fill DP table for one item (0/1 knapsack: iterate capacity downward)
fn knapsack_item(dp: i64, cap: i64, w: i64, v: i64, j: i64) -> i64 =
    if j < w { 0 }
    else {
        let candidate = vec_get(dp, j - w) + v;
        if candidate > vec_get(dp, j) { let _s = vec_set(dp, j, candidate); 0 } else { 0 };
        knapsack_item(dp, cap, w, v, j - 1)
    };

    // Process all items

fn knapsack_items(dp: i64, cap: i64, weights: i64, values: i64, n: i64, i: i64) -> i64 =
    if i >= n { 0 }
    else {
        let _u = knapsack_item(dp, cap, vec_get(weights, i), vec_get(values, i), cap);
        knapsack_items(dp, cap, weights, values, n, i + 1)
    };

    // Solve 0/1 knapsack: returns max value

fn knapsack(weights: i64, values: i64, n: i64, cap: i64) -> i64 = {
    let dp = make_zeros(cap + 1);
    let _f = knapsack_items(dp, cap, weights, values, n, 0);
    let result = vec_get(dp, cap);
    let _fr = vec_free(dp);
    result
    };

// Unbounded knapsack: each item can be used multiple times (iterate upward)
fn unbounded_item(dp: i64, cap: i64, w: i64, v: i64, j: i64) -> i64 =
    if j > cap { 0 }
    else {
        if j >= w {
            let candidate = vec_get(dp, j - w) + v;
            if candidate > vec_get(dp, j) { let _s = vec_set(dp, j, candidate); 0 } else { 0 }
        } else { 0 };
    unbounded_item(dp, cap, w, v, j + 1)
    };

fn unbounded_items(dp: i64, cap: i64, weights: i64, values: i64, n: i64, i: i64) -> i64 =
    if i >= n { 0 }
    else {
        let _u = unbounded_item(dp, cap, vec_get(weights, i), vec_get(values, i), 0);
        unbounded_items(dp, cap, weights, values, n, i + 1)
    };

fn unbounded_knapsack(weights: i64, values: i64, n: i64, cap: i64) -> i64 = {
    let dp = make_zeros(cap + 1);
    let _f = unbounded_items(dp, cap, weights, values, n, 0);
    let result = vec_get(dp, cap);
    let _fr = vec_free(dp);
    result
    };

fn main() -> i64 = {
// Classic 0/1 knapsack: capacity=10
// items: (w=2,v=6),(w=2,v=10),(w=3,v=12),(w=5,v=15),(w=7,v=13)
    let w1 = make_vec5(2, 2, 3, 5, 7);
    let v1 = make_vec5(6, 10, 12, 15, 13);
    let _r1 = println(knapsack(w1, v1, 5, 10));   // 37

// Simple 3-item knapsack capacity=5
// (w=1,v=1),(w=2,v=6),(w=3,v=10)
    let w2 = make_vec3(1, 2, 3);
    let v2 = make_vec3(1, 6, 10);
    let _r2 = println(knapsack(w2, v2, 3, 5));  // 16

// Capacity 0 yields 0
    let _r3 = println(knapsack(w2, v2, 3, 0));  // 0

// Single item tests
    let w3 = vec_new();
    let _pw3 = vec_push(w3, 3);
    let v3 = vec_new();
    let _pv3 = vec_push(v3, 10);
    let _r4 = println(knapsack(w3, v3, 1, 5));  // 10 (item fits)
    let _r5 = println(knapsack(w3, v3, 1, 2));  // 0  (item doesn't fit)

// Unbounded knapsack: can reuse items
// items: (w=1,v=1),(w=3,v=4),(w=4,v=5), cap=7
    let w4 = make_vec3(1, 3, 4);
    let v4 = make_vec3(1, 4, 5);
    let _r6 = println(unbounded_knapsack(w4, v4, 3, 7));  // 9

// Unbounded: (w=2,v=5),(w=4,v=9), cap=8
    let w5 = make_vec2(2, 4);
    let v5 = make_vec2(5, 9);
    let _r7 = println(unbounded_knapsack(w5, v5, 2, 8));  // 20

// 0/1 knapsack capacity 15
// items: (w=1,v=1),(w=2,v=6),(w=3,v=10),(w=5,v=16)
    let w6 = make_vec4(1, 2, 3, 5);
    let v6 = make_vec4(1, 6, 10, 16);
    let _r8 = println(knapsack(w6, v6, 4, 15));  // 33

    0
    };

// Golden Test: Nested function call patterns
// Tests optimization of deeply nested call chains

fn add(a: i64, b: i64) -> i64 = a + b;
fn mul(a: i64, b: i64) -> i64 = a * b;
fn sub(a: i64, b: i64) -> i64 = a - b;

fn nested_arith(x: i64) -> i64 =
    add(mul(x, 2), sub(x, 1));

fn triple_nest(x: i64) -> i64 =
    add(mul(add(x, 1), 2), sub(mul(x, 3), 1));

fn fibonacci_pair(n: i64) -> i64 = {
    let mut a = 0;
    let mut b = 1;
    let mut i = 0;
    loop {
        if i >= n { break } else { () };
        let c = a + b;
        a = b;
        b = c;
        i = i + 1
    };
    a
    };

fn chain_calls(x: i64) -> i64 = {
    let a = add(x, 1);
    let b = mul(a, 2);
    let c = sub(b, 3);
    let d = add(c, mul(x, x));
    d
    };

fn main() -> i64 = {
    let _p1 = println(nested_arith(5));     // 5*2 + (5-1) = 14
    let _p2 = println(nested_arith(10));    // 10*2 + (10-1) = 29
    let _p3 = println(triple_nest(3));      // (3+1)*2 + (3*3-1) = 8+8 = 16
    let _p4 = println(triple_nest(5));      // (5+1)*2 + (5*3-1) = 12+14 = 26
    let _p5 = println(fibonacci_pair(10));  // 55
    let _p6 = println(fibonacci_pair(20));  // 6765
    let _p7 = println(chain_calls(3));      // (3+1)*2-3 + 3*3 = 5+9 = 14
    let _p8 = println(chain_calls(5));      // (5+1)*2-3 + 5*5 = 9+25 = 34
    0
    };

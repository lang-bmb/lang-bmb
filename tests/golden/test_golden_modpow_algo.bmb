// Golden Test: Modular Exponentiation
// Compute (base^exp) mod m using fast exponentiation (binary method)

// Modular exponentiation: (base^exp) % m
fn modpow(base: i64, exp: i64, m: i64) -> i64 = {
    let mut result = 1;
    let mut b = base - base / m * m;
    let mut e = exp;
    loop {
        if e <= 0 { break } else { () };
        // If exp is odd, multiply result by base
        if e - e / 2 * 2 == 1 {
            result = result * b;
            result = result - result / m * m
        } else { () };
        e = e / 2;
        b = b * b;
        b = b - b / m * m
    };
    result
};

// Modular inverse using Fermat's little theorem (only works when m is prime)
// a^(-1) mod p = a^(p-2) mod p
fn mod_inv(a: i64, p: i64) -> i64 = {
    modpow(a, p - 2, p)
};

// Check if n is a Fermat probable prime to base a
// a^(n-1) mod n should be 1 if n is prime
fn fermat_test(n: i64, a: i64) -> i64 = {
    if n <= 1 { return 0 } else { () };
    if n == 2 { return 1 } else { () };
    if modpow(a, n - 1, n) == 1 { 1 } else { 0 }
};

fn main() -> i64 = {
    // Test 1: 2^10 mod 1000 = 1024 mod 1000 = 24
    let _p1 = println(modpow(2, 10, 1000));  // 24

    // Test 2: 3^13 mod 100 = 1594323 mod 100 = 23
    // 3^1=3, 3^2=9, 3^4=81, 3^8=6561 mod 100=61
    // 3^13=3^8*3^4*3^1=61*81*3 mod 100
    // 61*81=4941 mod 100=41, 41*3=123 mod 100=23
    let _p2 = println(modpow(3, 13, 100));  // 23

    // Test 3: 7^256 mod 13
    // 7^1=7, 7^2=49mod13=10, 7^4=100mod13=9, 7^8=81mod13=3
    // 7^16=9, 7^32=81mod13=3, 7^64=9, 7^128=81mod13=3, 7^256=9
    let _p3 = println(modpow(7, 256, 13));  // 9

    // Test 4: 2^0 mod 5 = 1
    let _p4 = println(modpow(2, 0, 5));  // 1

    // Test 5: 5^1 mod 7 = 5
    let _p5 = println(modpow(5, 1, 7));  // 5

    // Test 6: Modular inverse of 3 mod 7 = 3^5 mod 7
    // 3*x mod 7 = 1, x=5 (since 3*5=15, 15 mod 7=1)
    let _p6 = println(mod_inv(3, 7));  // 5

    // Test 7: Modular inverse of 2 mod 13 = 2^11 mod 13
    // 2*x mod 13 = 1, x=7 (since 2*7=14, 14 mod 13=1)
    let _p7 = println(mod_inv(2, 13));  // 7

    // Test 8: Fermat test for prime 17
    let _p8 = println(fermat_test(17, 2));  // 1

    // Test 9: Fermat test for composite 15
    // 2^14 mod 15: 2^1=2,2^2=4,2^4=16mod15=1,2^8=1,2^14=2^8*2^4*2^2=1*1*4=4
    // 4 != 1, so not prime
    let _p9 = println(fermat_test(15, 2));  // 0

    // Test 10: Fermat test for prime 101
    let _p10 = println(fermat_test(101, 2));  // 1

    // Test 11: Large modpow: 123^456 mod 789
    // This tests the algorithm handles larger numbers
    let _p11 = println(modpow(123, 456, 789));  // 699

    // Test 12: 10^9 mod 7 = compute
    // 10 mod 7 = 3, 3^9 mod 7
    // 3^1=3, 3^2=2, 3^4=4, 3^8=2, 3^9=3^8*3^1=6
    let _p12 = println(modpow(10, 9, 7));  // 6

    0
};

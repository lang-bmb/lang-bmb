// Golden Test: Levenshtein Distance (Edit Distance)
// DP computation of minimum edit distance between two integer sequences

fn levenshtein(a: i64, na: i64, b: i64, nb: i64) -> i64 = {
    // dp[i][j] = edit distance between a[0..i) and b[0..j)
    let cols = nb + 1;
    let dp = vec_new();
    let mut i = 0;
    while i < (na + 1) * cols {
        let _p = vec_push(dp, 0);
        set i = i + 1
    };
    // Base cases
    set i = 0;
    while i <= na {
        vec_set(dp, i * cols + 0, i);
        set i = i + 1
    };
    let mut j = 0;
    while j <= nb {
        vec_set(dp, 0 * cols + j, j);
        set j = j + 1
    };
    // Fill DP table
    set i = 1;
    while i <= na {
        set j = 1;
        while j <= nb {
            let cost = if vec_get(a, i - 1) == vec_get(b, j - 1) { 0 } else { 1 };
            let del = vec_get(dp, (i - 1) * cols + j) + 1;
            let ins = vec_get(dp, i * cols + (j - 1)) + 1;
            let sub = vec_get(dp, (i - 1) * cols + (j - 1)) + cost;
            let m1 = if del < ins { del } else { ins };
            let m2 = if m1 < sub { m1 } else { sub };
            vec_set(dp, i * cols + j, m2);
            set j = j + 1
        };
        set i = i + 1
    };
    vec_get(dp, na * cols + nb)
};

fn main() -> () = {
    // Test 1: [1,2,3] vs [1,2,3] -> 0
    let a1 = vec_new();
    let _p = vec_push(a1, 1); let _p = vec_push(a1, 2); let _p = vec_push(a1, 3);
    let b1 = vec_new();
    let _p = vec_push(b1, 1); let _p = vec_push(b1, 2); let _p = vec_push(b1, 3);
    print_str("d1="); let _r = println(levenshtein(a1, 3, b1, 3));

    // Test 2: [1,2,3] vs [1,2,4] -> 1 (substitute)
    let b2 = vec_new();
    let _p = vec_push(b2, 1); let _p = vec_push(b2, 2); let _p = vec_push(b2, 4);
    print_str("d2="); let _r = println(levenshtein(a1, 3, b2, 3));

    // Test 3: [1,2,3] vs [1,3] -> 1 (delete 2)
    let b3 = vec_new();
    let _p = vec_push(b3, 1); let _p = vec_push(b3, 3);
    print_str("d3="); let _r = println(levenshtein(a1, 3, b3, 2));

    // Test 4: [] vs [1,2,3] -> 3 (insert all)
    let a4 = vec_new();
    print_str("d4="); let _r = println(levenshtein(a4, 0, a1, 3));

    // Test 5: [1,2,3,4,5] vs [2,3,4,5,6] -> 2 (delete 1, insert 6)
    let a5 = vec_new();
    let _p = vec_push(a5, 1); let _p = vec_push(a5, 2);
    let _p = vec_push(a5, 3); let _p = vec_push(a5, 4);
    let _p = vec_push(a5, 5);
    let b5 = vec_new();
    let _p = vec_push(b5, 2); let _p = vec_push(b5, 3);
    let _p = vec_push(b5, 4); let _p = vec_push(b5, 5);
    let _p = vec_push(b5, 6);
    print_str("d5="); let _r = println(levenshtein(a5, 5, b5, 5));

    // Test 6: Completely different
    let a6 = vec_new();
    let _p = vec_push(a6, 1); let _p = vec_push(a6, 3); let _p = vec_push(a6, 5);
    let b6 = vec_new();
    let _p = vec_push(b6, 2); let _p = vec_push(b6, 4); let _p = vec_push(b6, 6);
    print_str("d6="); let _r = println(levenshtein(a6, 3, b6, 3))
};

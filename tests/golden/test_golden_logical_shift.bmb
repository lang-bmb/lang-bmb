// Golden Test: Logical Right Shift (>>>) and Shift Operations
// Tests zero-fill right shift vs arithmetic right shift

fn main() -> i64 = {
    // Basic left shift
    let _p1 = println(1 << 0);     // 1
    let _p2 = println(1 << 3);     // 8
    let _p3 = println(1 << 10);    // 1024
    let _p4 = println(5 << 2);     // 20

    // Arithmetic right shift (sign-extending)
    let _p5 = println(8 >> 1);     // 4
    let _p6 = println(1024 >> 3);  // 128
    let _p7 = println(255 >> 4);   // 15

    // Negative numbers with arithmetic shift (sign-extends)
    let neg = 0 - 16;
    let _p8 = println(neg >> 1);   // -8

    // Logical right shift (zero-fill) on positive numbers
    let _p9 = println(8 >>> 1);    // 4
    let _p10 = println(1024 >>> 3); // 128

    // Logical right shift on negative numbers — zero-fills from left
    // -1 in 64-bit = 0xFFFFFFFFFFFFFFFF
    // >>> 63 should give 1 (not -1 like >>)
    let neg1 = 0 - 1;
    let _p11 = println(neg1 >>> 63); // 1
    let _p12 = println(neg1 >> 63);  // -1

    // More logical shift tests
    let _p13 = println(neg >>> 1);  // 9223372036854775800

    0
};

// Golden Test: Greedy graph coloring on adjacency matrix
// Assigns colors to nodes so no two adjacent nodes share a color
// Uses vec as n*n adjacency matrix

// Helper: create a vec of n zeros
fn make_zeros(n: i64) -> i64 = {
    let v = vec_new();
    for _i in 0..n { let _p = vec_push(v, 0); 0 };
    v
    };

// Check if color c is safe for node v (no adjacent node has color c)
fn color_safe(adj: i64, n: i64, colors: i64, v: i64, c: i64, j: i64) -> i64 =
    if j >= n { 1 }
    else if vec_get(adj, v * n + j) != 0 and vec_get(colors, j) == c { 0 }
    else { color_safe(adj, n, colors, v, c, j + 1) };

    // Find the smallest safe color for node v (starting from color 1)

fn find_color(adj: i64, n: i64, colors: i64, v: i64, c: i64) -> i64 =
    if color_safe(adj, n, colors, v, c, 0) == 1 { c }
    else { find_color(adj, n, colors, v, c + 1) };

    // Assign colors greedily to all nodes starting from node i

fn greedy_color(adj: i64, n: i64, colors: i64, i: i64) -> i64 =
    if i >= n { colors }
    else {
        let c = find_color(adj, n, colors, i, 1);
        let _s = vec_set(colors, i, c);
        greedy_color(adj, n, colors, i + 1)
    };

    // Count distinct colors used (max color value)

fn max_color(colors: i64, i: i64, mx: i64, size: i64) -> i64 =
    if i >= size { mx }
    else {
        let m = if vec_get(colors, i) > mx { vec_get(colors, i) } else { mx };
        max_color(colors, i + 1, m, size)
    };

    // Sum all colors assigned

fn sum_colors(colors: i64, i: i64, acc: i64, size: i64) -> i64 =
    if i >= size { acc }
    else { sum_colors(colors, i + 1, acc + vec_get(colors, i), size) };

    // Verify coloring is valid: no two adjacent nodes share a color

fn verify_edge(adj: i64, n: i64, colors: i64, i: i64, j: i64) -> i64 =
    if i >= n { 1 }
    else if j >= n { verify_edge(adj, n, colors, i + 1, 0) }
    else if vec_get(adj, i * n + j) != 0 and vec_get(colors, i) == vec_get(colors, j) { 0 }
    else { verify_edge(adj, n, colors, i, j + 1) };

    // Build adjacency matrix helpers

fn make_adj4_cycle() -> i64 = {
// 4-node cycle graph: 0-1-2-3-0
    let v = vec_new();

// Row 0: 0,1,0,1
    let _p00 = vec_push(v, 0); let _p01 = vec_push(v, 1); let _p02 = vec_push(v, 0); let _p03 = vec_push(v, 1);

// Row 1: 1,0,1,0
    let _p10 = vec_push(v, 1); let _p11 = vec_push(v, 0); let _p12 = vec_push(v, 1); let _p13 = vec_push(v, 0);

// Row 2: 0,1,0,1
    let _p20 = vec_push(v, 0); let _p21 = vec_push(v, 1); let _p22 = vec_push(v, 0); let _p23 = vec_push(v, 1);

// Row 3: 1,0,1,0
    let _p30 = vec_push(v, 1); let _p31 = vec_push(v, 0); let _p32 = vec_push(v, 1); let _p33 = vec_push(v, 0);
    v
    };

fn make_adj3_complete() -> i64 = {
// 3-node complete graph: K3
    let v = vec_new();
    let _p00 = vec_push(v, 0); let _p01 = vec_push(v, 1); let _p02 = vec_push(v, 1);
    let _p10 = vec_push(v, 1); let _p11 = vec_push(v, 0); let _p12 = vec_push(v, 1);
    let _p20 = vec_push(v, 1); let _p21 = vec_push(v, 1); let _p22 = vec_push(v, 0);
    v
    };

fn make_adj5_star() -> i64 = {
// 5-node star graph: center=0 connects to 1,2,3,4
    let v = vec_new();

// Row 0: 0,1,1,1,1
    let _p00 = vec_push(v, 0); let _p01 = vec_push(v, 1); let _p02 = vec_push(v, 1); let _p03 = vec_push(v, 1); let _p04 = vec_push(v, 1);

// Row 1: 1,0,0,0,0
    let _p10 = vec_push(v, 1); let _p11 = vec_push(v, 0); let _p12 = vec_push(v, 0); let _p13 = vec_push(v, 0); let _p14 = vec_push(v, 0);

// Row 2: 1,0,0,0,0
    let _p20 = vec_push(v, 1); let _p21 = vec_push(v, 0); let _p22 = vec_push(v, 0); let _p23 = vec_push(v, 0); let _p24 = vec_push(v, 0);

// Row 3: 1,0,0,0,0
    let _p30 = vec_push(v, 1); let _p31 = vec_push(v, 0); let _p32 = vec_push(v, 0); let _p33 = vec_push(v, 0); let _p34 = vec_push(v, 0);

// Row 4: 1,0,0,0,0
    let _p40 = vec_push(v, 1); let _p41 = vec_push(v, 0); let _p42 = vec_push(v, 0); let _p43 = vec_push(v, 0); let _p44 = vec_push(v, 0);
    v
    };

fn make_adj3_independent() -> i64 = {
// Independent graph (no edges)
    let v = vec_new();
    let _p00 = vec_push(v, 0); let _p01 = vec_push(v, 0); let _p02 = vec_push(v, 0);
    let _p10 = vec_push(v, 0); let _p11 = vec_push(v, 0); let _p12 = vec_push(v, 0);
    let _p20 = vec_push(v, 0); let _p21 = vec_push(v, 0); let _p22 = vec_push(v, 0);
    v
    };

fn main() -> i64 = {
// 4-node cycle graph: 0-1-2-3-0
    let adj4 = make_adj4_cycle();
    let c4 = make_zeros(4);
    let r4 = greedy_color(adj4, 4, c4, 0);
    let _p1 = println(vec_get(r4, 0));                     // 1
    let _p2 = println(vec_get(r4, 1));                     // 2
    let _p3 = println(vec_get(r4, 2));                     // 1
    let _p4 = println(vec_get(r4, 3));                     // 2
    let _p5 = println(max_color(r4, 0, 0, 4));             // 2
    let _p6 = println(verify_edge(adj4, 4, r4, 0, 0));     // 1 (valid)

// 3-node complete graph: K3
    let adj3 = make_adj3_complete();
    let c3 = make_zeros(3);
    let r3 = greedy_color(adj3, 3, c3, 0);
    let _p7 = println(vec_get(r3, 0));                     // 1
    let _p8 = println(vec_get(r3, 1));                     // 2
    let _p9 = println(vec_get(r3, 2));                     // 3
    let _p10 = println(max_color(r3, 0, 0, 3));            // 3
    let _p11 = println(verify_edge(adj3, 3, r3, 0, 0));    // 1 (valid)

// 5-node star graph: center=0 connects to 1,2,3,4
    let adj5 = make_adj5_star();
    let c5 = make_zeros(5);
    let r5 = greedy_color(adj5, 5, c5, 0);
    let _p12 = println(max_color(r5, 0, 0, 5));             // 2
    let _p13 = println(sum_colors(r5, 0, 0, 5));            // 9 (1+2+2+2+2)
    let _p14 = println(verify_edge(adj5, 5, r5, 0, 0));     // 1

// Independent graph (no edges): all get color 1
    let adj_ind = make_adj3_independent();
    let c_ind = make_zeros(3);
    let r_ind = greedy_color(adj_ind, 3, c_ind, 0);
    let _p15 = println(max_color(r_ind, 0, 0, 3));          // 1
    let _p16 = println(sum_colors(r_ind, 0, 0, 3));         // 3

    0
    };

// Golden Test: Floyd-Warshall all-pairs shortest paths
// Computes shortest path between every pair of vertices in a weighted graph
// Uses dynamic programming with O(V^3) time complexity
// INF = 999999 represents no direct edge

fn floyd_warshall(dist: i64, n: i64) -> () = {
    // dist is a flat n*n matrix stored in a vec
    // dist[i*n+j] = weight of edge from i to j (or INF if no edge)
    let mut k = 0;
    while k < n {
        let mut i = 0;
        while i < n {
            let mut j = 0;
            while j < n {
                let ij = vec_get(dist, i * n + j);
                let ik = vec_get(dist, i * n + k);
                let kj = vec_get(dist, k * n + j);
                let _x = if ik < 999999 and kj < 999999 {
                    let via_k = ik + kj;
                    let _y = if via_k < ij {
                        vec_set(dist, i * n + j, via_k);
                        0
                    } else { 0 };
                    0
                } else { 0 };
                set j = j + 1
            };
            set i = i + 1
        };
        set k = k + 1
    }
};

fn print_matrix(dist: i64, n: i64) -> () = {
    let mut i = 0;
    while i < n {
        let mut j = 0;
        while j < n {
            let _sp = if j > 0 { print_str(" "); 0 } else { 0 };
            let v = vec_get(dist, i * n + j);
            let _x = if v >= 999999 { print_str("INF"); 0 } else { print(v); 0 };
            set j = j + 1
        };
        let _nl = print_str("\n");
        set i = i + 1
    }
};

fn main() -> () = {
    // Test 1: 4-node graph
    //   0 --3--> 1
    //   0 --8--> 2
    //   1 --1--> 3
    //   2 --1--> 1
    //   3 --2--> 0
    //   3 --1--> 2
    let n = 4;
    let dist = vec_new();
    // Row 0: 0->0=0, 0->1=3, 0->2=8, 0->3=INF
    let _p = vec_push(dist, 0); let _p = vec_push(dist, 3); let _p = vec_push(dist, 8); let _p = vec_push(dist, 999999);
    // Row 1: 1->0=INF, 1->1=0, 1->2=INF, 1->3=1
    let _p = vec_push(dist, 999999); let _p = vec_push(dist, 0); let _p = vec_push(dist, 999999); let _p = vec_push(dist, 1);
    // Row 2: 2->0=INF, 2->1=1, 2->2=0, 2->3=INF
    let _p = vec_push(dist, 999999); let _p = vec_push(dist, 1); let _p = vec_push(dist, 0); let _p = vec_push(dist, 999999);
    // Row 3: 3->0=2, 3->1=INF, 3->2=1, 3->3=0
    let _p = vec_push(dist, 2); let _p = vec_push(dist, 999999); let _p = vec_push(dist, 1); let _p = vec_push(dist, 0);

    floyd_warshall(dist, n);
    print_str("4-node:\n");
    print_matrix(dist, n);

    // Test 2: 3-node complete graph
    let dist2 = vec_new();
    let _p = vec_push(dist2, 0); let _p = vec_push(dist2, 1); let _p = vec_push(dist2, 10);
    let _p = vec_push(dist2, 1); let _p = vec_push(dist2, 0); let _p = vec_push(dist2, 1);
    let _p = vec_push(dist2, 10); let _p = vec_push(dist2, 1); let _p = vec_push(dist2, 0);

    floyd_warshall(dist2, 3);
    print_str("3-node:\n");
    print_matrix(dist2, 3)
};

// Golden test: Count distinct paths in DAG using topological order + DP
// Graph stored as flat n*n adjacency matrix (1=edge, 0=no edge)
// Uses Kahn's algorithm for topological sort, then DP forward pass

fn adj_get(adj: i64, n: i64, u: i64, v: i64) -> i64 =
    vec_get(adj, u * n + v);

// Compute in-degree of each node
fn compute_indeg_inner(adj: i64, n: i64, indeg: i64, v: i64, u: i64, deg: i64) -> i64 =
    if u >= n {
        let _s = vec_set(indeg, v, deg);
        0
    } else {
        let inc = if adj_get(adj, n, u, v) > 0 { 1 } else { 0 };
        compute_indeg_inner(adj, n, indeg, v, u + 1, deg + inc)
    };

fn compute_indeg(adj: i64, n: i64, indeg: i64, v: i64) -> i64 =
    if v >= n { 0 }
    else {
        let _ci = compute_indeg_inner(adj, n, indeg, v, 0, 0);
        compute_indeg(adj, n, indeg, v + 1)
    };

// Kahn's topological sort: BFS-based, returns order vec
fn kahn_enqueue(indeg: i64, n: i64, queue: i64, i: i64) -> i64 =
    if i >= n { 0 }
    else {
        let _e = if vec_get(indeg, i) == 0 {
            let _q = vec_push(queue, i);
            0
        } else { 0 };
        kahn_enqueue(indeg, n, queue, i + 1)
    };

fn kahn_reduce(adj: i64, n: i64, indeg: i64, queue: i64, u: i64, v: i64) -> i64 =
    if v >= n { 0 }
    else {
        let _r = if adj_get(adj, n, u, v) > 0 {
            let nd = vec_get(indeg, v) - 1;
            let _s = vec_set(indeg, v, nd);
            let _e = if nd == 0 { let _q = vec_push(queue, v); 0 } else { 0 };
            0
        } else { 0 };
        kahn_reduce(adj, n, indeg, queue, u, v + 1)
    };

fn kahn_loop(adj: i64, n: i64, indeg: i64, queue: i64, order: i64, head: i64) -> i64 =
    if head >= vec_len(queue) { order }
    else {
        let u = vec_get(queue, head);
        let _o = vec_push(order, u);
        let _kr = kahn_reduce(adj, n, indeg, queue, u, 0);
        kahn_loop(adj, n, indeg, queue, order, head + 1)
    };

fn topo_sort(adj: i64, n: i64) -> i64 = {
    let indeg = vec_new();
    for _i in 0..n { let _p = vec_push(indeg, 0); 0 };
    let _ci = compute_indeg(adj, n, indeg, 0);
    let queue = vec_new();
    let _ke = kahn_enqueue(indeg, n, queue, 0);
    let order = vec_new();
    let result = kahn_loop(adj, n, indeg, queue, order, 0);
    let _f1 = vec_free(indeg);
    let _f2 = vec_free(queue);
    result
};

// DP: count paths from src. paths[src] = 1, for each u in topo order, paths[v] += paths[u] for edges u->v
fn dp_propagate(adj: i64, n: i64, paths: i64, u: i64, pu: i64, v: i64) -> i64 =
    if v >= n { 0 }
    else {
        let _upd = if adj_get(adj, n, u, v) > 0 {
            let _s = vec_set(paths, v, vec_get(paths, v) + pu);
            0
        } else { 0 };
        dp_propagate(adj, n, paths, u, pu, v + 1)
    };

fn dp_loop(adj: i64, n: i64, paths: i64, order: i64, idx: i64, order_len: i64) -> i64 =
    if idx >= order_len { 0 }
    else {
        let u = vec_get(order, idx);
        let pu = vec_get(paths, u);
        let _dp = if pu > 0 {
            dp_propagate(adj, n, paths, u, pu, 0)
        } else { 0 };
        dp_loop(adj, n, paths, order, idx + 1, order_len)
    };

fn count_paths(adj: i64, n: i64, src: i64) -> i64 = {
    let order = topo_sort(adj, n);
    let paths = vec_new();
    for _i in 0..n { let _p = vec_push(paths, 0); 0 };
    let _s = vec_set(paths, src, 1);
    let order_len = vec_len(order);
    let _dp = dp_loop(adj, n, paths, order, 0, order_len);
    let _fo = vec_free(order);
    paths
};

// Longest path: same DP but track max distance instead of count
fn lp_propagate(adj: i64, n: i64, dist: i64, u: i64, du: i64, v: i64) -> i64 =
    if v >= n { 0 }
    else {
        let _upd = if adj_get(adj, n, u, v) > 0 {
            let new_d = du + 1;
            let _s = if new_d > vec_get(dist, v) {
                vec_set(dist, v, new_d)
            } else { () };
            0
        } else { 0 };
        lp_propagate(adj, n, dist, u, du, v + 1)
    };

fn lp_loop(adj: i64, n: i64, dist: i64, order: i64, idx: i64, order_len: i64) -> i64 =
    if idx >= order_len { 0 }
    else {
        let u = vec_get(order, idx);
        let du = vec_get(dist, u);
        let _lp = if du >= 0 {
            lp_propagate(adj, n, dist, u, du, 0)
        } else { 0 };
        lp_loop(adj, n, dist, order, idx + 1, order_len)
    };

fn find_max(dist: i64, n: i64, i: i64, best: i64) -> i64 =
    if i >= n { best }
    else {
        let di = vec_get(dist, i);
        let nb = if di > best { di } else { best };
        find_max(dist, n, i + 1, nb)
    };

fn longest_path(adj: i64, n: i64, src: i64) -> i64 = {
    let order = topo_sort(adj, n);
    let dist = vec_new();
    for _i in 0..n { let _p = vec_push(dist, -1); 0 };
    let _sv = vec_set(dist, src, 0);
    let order_len = vec_len(order);
    let _lp = lp_loop(adj, n, dist, order, 0, order_len);
    let result = find_max(dist, n, 0, 0);
    let _fo = vec_free(order);
    let _fd = vec_free(dist);
    result
};

fn make_zeros(sz: i64) -> i64 = {
    let v = vec_new();
    for _i in 0..sz { let _p = vec_push(v, 0); 0 };
    v
};

fn set_edge(adj: i64, n: i64, u: i64, v: i64) -> i64 = {
    let _s = vec_set(adj, u * n + v, 1);
    0
};

fn main() -> i64 = {
    // Test 1: Simple chain 0->1->2->3
    let adj1 = make_zeros(16);
    let _e1 = set_edge(adj1, 4, 0, 1);
    let _e2 = set_edge(adj1, 4, 1, 2);
    let _e3 = set_edge(adj1, 4, 2, 3);
    let p1 = count_paths(adj1, 4, 0);
    let _p1 = println(vec_get(p1, 3)); // 1 (only path 0->1->2->3)
    let _p2 = println(vec_get(p1, 0)); // 1 (source to itself)
    let _f1 = vec_free(p1);

    // Test 2: Diamond DAG: 0->1, 0->2, 1->3, 2->3
    let adj2 = make_zeros(16);
    let _e4 = set_edge(adj2, 4, 0, 1);
    let _e5 = set_edge(adj2, 4, 0, 2);
    let _e6 = set_edge(adj2, 4, 1, 3);
    let _e7 = set_edge(adj2, 4, 2, 3);
    let p2 = count_paths(adj2, 4, 0);
    let _p3 = println(vec_get(p2, 3)); // 2 (0->1->3 and 0->2->3)
    let _p4 = println(vec_get(p2, 1)); // 1
    let _p5 = println(vec_get(p2, 2)); // 1
    let _f2 = vec_free(p2);

    // Test 3: Fan-out then merge: 0->1, 0->2, 0->3, 1->4, 2->4, 3->4
    let adj3 = make_zeros(25);
    let _e8 = set_edge(adj3, 5, 0, 1);
    let _e9 = set_edge(adj3, 5, 0, 2);
    let _e10 = set_edge(adj3, 5, 0, 3);
    let _e11 = set_edge(adj3, 5, 1, 4);
    let _e12 = set_edge(adj3, 5, 2, 4);
    let _e13 = set_edge(adj3, 5, 3, 4);
    let p3 = count_paths(adj3, 5, 0);
    let _p6 = println(vec_get(p3, 4)); // 3 (via 1, via 2, via 3)
    let _f3 = vec_free(p3);

    // Test 4: Layered DAG
    // 0->1, 0->2, 1->3, 1->4, 2->3, 2->4, 3->5, 4->5
    let adj4 = make_zeros(36);
    let _e14 = set_edge(adj4, 6, 0, 1);
    let _e15 = set_edge(adj4, 6, 0, 2);
    let _e16 = set_edge(adj4, 6, 1, 3);
    let _e17 = set_edge(adj4, 6, 1, 4);
    let _e18 = set_edge(adj4, 6, 2, 3);
    let _e19 = set_edge(adj4, 6, 2, 4);
    let _e20 = set_edge(adj4, 6, 3, 5);
    let _e21 = set_edge(adj4, 6, 4, 5);
    let p4 = count_paths(adj4, 6, 0);
    let _p7 = println(vec_get(p4, 5)); // 4
    let _p8 = println(vec_get(p4, 3)); // 2
    let _p9 = println(vec_get(p4, 4)); // 2
    let _f4 = vec_free(p4);

    // Test 5: Source in middle of chain (src=2 in chain 0->1->2->3)
    let p5 = count_paths(adj1, 4, 2);
    let _p10 = println(vec_get(p5, 0)); // 0 (unreachable backwards)
    let _p11 = println(vec_get(p5, 3)); // 1 (2->3)
    let _f5 = vec_free(p5);

    // Test 6: Longest path in chain = 3
    let _p12 = println(longest_path(adj1, 4, 0)); // 3

    // Test 7: Longest path in diamond = 2
    let _p13 = println(longest_path(adj2, 4, 0)); // 2

    // Test 8: Longest path in layered = 3
    let _p14 = println(longest_path(adj4, 6, 0)); // 3

    // Test 9: Single node graph
    let adj5 = make_zeros(1);
    let p6 = count_paths(adj5, 1, 0);
    let _p15 = println(vec_get(p6, 0)); // 1
    let _f6 = vec_free(p6);
    let _f7 = vec_free(adj5);

    let _fa = vec_free(adj1);
    let _fb = vec_free(adj2);
    let _fc = vec_free(adj3);
    let _fd = vec_free(adj4);
    0
};

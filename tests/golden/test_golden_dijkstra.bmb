// Golden Test: Dijkstra shortest path
// Single-source shortest path using priority queue (linear scan)
// Weighted directed graph with adjacency list

fn dijkstra(adj_w: i64, adj_size: i64, n: i64, src: i64) -> i64 = {
    let dist = vec_new();
    let visited = vec_new();
    let mut i = 0;
    while i < n {
        let _p = vec_push(dist, 999999);
        let _p = vec_push(visited, 0);
        set i = i + 1
    };
    vec_set(dist, src, 0);

    set i = 0;
    while i < n {
        // Find unvisited node with minimum distance
        let mut min_d = 999999;
        let mut u = 0 - 1;
        let mut j = 0;
        while j < n {
            let _x = if vec_get(visited, j) == 0 and vec_get(dist, j) < min_d {
                set min_d = vec_get(dist, j);
                set u = j;
                0
            } else { 0 };
            set j = j + 1
        };
        let _x = if u == 0 - 1 {
            set i = n;
            0
        } else {
            vec_set(visited, u, 1);
            // Relax neighbors
            let deg = vec_get(adj_size, u);
            let base = u * n * 2;
            set j = 0;
            while j < deg {
                let v = vec_get(adj_w, base + j * 2);
                let w = vec_get(adj_w, base + j * 2 + 1);
                let new_dist = vec_get(dist, u) + w;
                let _y = if new_dist < vec_get(dist, v) {
                    vec_set(dist, v, new_dist);
                    0
                } else { 0 };
                set j = j + 1
            };
            0
        };
        set i = i + 1
    };
    dist
};

fn add_edge(adj_w: i64, adj_size: i64, n: i64, from: i64, to: i64, weight: i64) -> () = {
    let deg = vec_get(adj_size, from);
    let base = from * n * 2;
    vec_set(adj_w, base + deg * 2, to);
    vec_set(adj_w, base + deg * 2 + 1, weight);
    vec_set(adj_size, from, deg + 1)
};

fn main() -> () = {
    // Test 1: 5-node graph
    let n = 5;
    let adj = vec_new();
    let adj_size = vec_new();
    let mut i = 0;
    while i < n * n * 2 {
        let _p = vec_push(adj, 0);
        set i = i + 1
    };
    set i = 0;
    while i < n {
        let _p = vec_push(adj_size, 0);
        set i = i + 1
    };
    add_edge(adj, adj_size, n, 0, 1, 10);
    add_edge(adj, adj_size, n, 0, 3, 5);
    add_edge(adj, adj_size, n, 1, 2, 1);
    add_edge(adj, adj_size, n, 1, 3, 2);
    add_edge(adj, adj_size, n, 2, 4, 4);
    add_edge(adj, adj_size, n, 3, 1, 3);
    add_edge(adj, adj_size, n, 3, 2, 9);
    add_edge(adj, adj_size, n, 3, 4, 2);
    add_edge(adj, adj_size, n, 4, 2, 6);

    let dist = dijkstra(adj, adj_size, n, 0);
    print_str("dist from 0:");
    set i = 0;
    while i < n {
        print_str(" "); print(vec_get(dist, i));
        set i = i + 1
    };
    print_str("
");

    // Test 2: Disconnected
    let n2 = 3;
    let adj2 = vec_new();
    let adj_size2 = vec_new();
    set i = 0;
    while i < n2 * n2 * 2 {
        let _p = vec_push(adj2, 0);
        set i = i + 1
    };
    set i = 0;
    while i < n2 {
        let _p = vec_push(adj_size2, 0);
        set i = i + 1
    };
    add_edge(adj2, adj_size2, n2, 0, 1, 5);
    let dist2 = dijkstra(adj2, adj_size2, n2, 0);
    print_str("dist2:");
    set i = 0;
    while i < n2 {
        print_str(" "); print(vec_get(dist2, i));
        set i = i + 1
    };
    let _nl = print_str("
")
};

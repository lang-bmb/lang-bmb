// Golden Test: Suffix array construction (simple O(n^2 log n))
// Simulates suffix array for integer sequences using comparison-based sorting

// Compare suffix starting at i vs suffix starting at j in arr of length n
// Returns negative if suffix_i < suffix_j, 0 if equal, positive if suffix_i > suffix_j
fn compare_suffix(arr: i64, n: i64, i: i64, j: i64) -> i64 = {
    let mut pi = i;
    let mut pj = j;
    let mut result = 0;
    let mut done = 0;
    loop {
        if done == 1 { break } else { () };
        if pi >= n {
            if pj >= n { result = 0; done = 1 }
            else { result = 0 - 1; done = 1 }
        } else if pj >= n {
            result = 1; done = 1
        } else {
            let a = vec_get(arr, pi);
            let b = vec_get(arr, pj);
            if a < b { result = 0 - 1; done = 1 }
            else if a > b { result = 1; done = 1 }
            else {
                pi = pi + 1;
                pj = pj + 1
            }
        }
    };
    result
};

// Insertion sort on suffix array indices
fn sort_suffixes(arr: i64, n: i64, sa: i64) -> i64 = {
    for i in 1..n {
        let key = vec_get(sa, i);
        let mut j = i - 1;
        let mut done = 0;
        loop {
            if done == 1 { break } else { () };
            if j < 0 { done = 1 }
            else {
                let cmp = compare_suffix(arr, n, vec_get(sa, j), key);
                if cmp > 0 {
                    vec_set(sa, j + 1, vec_get(sa, j));
                    j = j - 1
                } else {
                    done = 1
                }
            }
        };
        vec_set(sa, j + 1, key)
    };
    0
};

// Build suffix array: returns vec of sorted suffix indices
fn build_suffix_array(arr: i64, n: i64) -> i64 = {
    let sa = vec_new();
    for i in 0..n {
        vec_push(sa, i)
    };
    let _s = sort_suffixes(arr, n, sa);
    sa
};

// Compute LCP (Longest Common Prefix) between suffix at sa[i] and sa[i-1]
fn compute_lcp(arr: i64, n: i64, sa: i64, idx: i64) -> i64 = {
    if idx == 0 { return 0 } else { () };
    let s1 = vec_get(sa, idx - 1);
    let s2 = vec_get(sa, idx);
    let mut len = 0;
    let mut p1 = s1;
    let mut p2 = s2;
    loop {
        if p1 >= n { break } else { () };
        if p2 >= n { break } else { () };
        if vec_get(arr, p1) == vec_get(arr, p2) {
            len = len + 1;
            p1 = p1 + 1;
            p2 = p2 + 1
        } else { break }
    };
    len
};

fn main() -> i64 = {
    // Test 1: Simple array [2, 1, 3, 1, 2]
    // Suffixes:
    //   0: [2,1,3,1,2]
    //   1: [1,3,1,2]
    //   2: [3,1,2]
    //   3: [1,2]
    //   4: [2]
    // Sorted: [1,2] < [1,3,1,2] < [2] < [2,1,3,1,2] < [3,1,2]
    // SA: [3, 1, 4, 0, 2]
    let a1 = vec_new();
    vec_push(a1, 2); vec_push(a1, 1); vec_push(a1, 3); vec_push(a1, 1); vec_push(a1, 2);
    let sa1 = build_suffix_array(a1, 5);
    let _p1 = println(vec_get(sa1, 0));   // 3
    let _p2 = println(vec_get(sa1, 1));   // 1
    let _p3 = println(vec_get(sa1, 2));   // 4
    let _p4 = println(vec_get(sa1, 3));   // 0
    let _p5 = println(vec_get(sa1, 4));   // 2

    // Test 2: LCP array for [2,1,3,1,2]
    // Sorted suffixes: [1,2], [1,3,1,2], [2], [2,1,3,1,2], [3,1,2]
    // LCP[0] = 0 (no predecessor)
    // LCP[1] = 1 (1 matches between [1,2] and [1,3,1,2])
    // LCP[2] = 0 ([2] vs [1,3,1,2])
    // LCP[3] = 1 ([2,1,3,1,2] vs [2])
    // LCP[4] = 0 ([3,1,2] vs [2,1,3,1,2])
    let _p6 = println(compute_lcp(a1, 5, sa1, 0));  // 0
    let _p7 = println(compute_lcp(a1, 5, sa1, 1));  // 1
    let _p8 = println(compute_lcp(a1, 5, sa1, 2));  // 0
    let _p9 = println(compute_lcp(a1, 5, sa1, 3));  // 1
    let _p10 = println(compute_lcp(a1, 5, sa1, 4)); // 0

    // Test 3: All same elements [5,5,5]
    // Suffixes: [5,5,5], [5,5], [5]
    // Sorted: [5] < [5,5] < [5,5,5]
    // SA: [2, 1, 0]
    let a3 = vec_new();
    vec_push(a3, 5); vec_push(a3, 5); vec_push(a3, 5);
    let sa3 = build_suffix_array(a3, 3);
    let _p11 = println(vec_get(sa3, 0));  // 2
    let _p12 = println(vec_get(sa3, 1));  // 1
    let _p13 = println(vec_get(sa3, 2));  // 0

    // LCP for all-same: [5] vs [5,5] = 1, [5,5] vs [5,5,5] = 2
    let _p14 = println(compute_lcp(a3, 3, sa3, 1)); // 1
    let _p15 = println(compute_lcp(a3, 3, sa3, 2)); // 2

    // Test 4: Already sorted [1,2,3,4]
    // SA: [0, 1, 2, 3] (already in order)
    let a4 = vec_new();
    vec_push(a4, 1); vec_push(a4, 2); vec_push(a4, 3); vec_push(a4, 4);
    let sa4 = build_suffix_array(a4, 4);
    let _p16 = println(vec_get(sa4, 0));  // 0
    let _p17 = println(vec_get(sa4, 3));  // 3

    // Test 5: Single element [42]
    let a5 = vec_new();
    vec_push(a5, 42);
    let sa5 = build_suffix_array(a5, 1);
    let _p18 = println(vec_get(sa5, 0));  // 0

    vec_free(a1); vec_free(sa1);
    vec_free(a3); vec_free(sa3);
    vec_free(a4); vec_free(sa4);
    vec_free(a5); vec_free(sa5);
    0
};

// Golden Test: Kadane algorithm — Maximum subarray sum
// Finds contiguous subarray with largest sum
// Returns [max_sum, start, end]

fn kadane(arr: i64) -> i64 = {
    let n = vec_len(arr);
    let result = vec_new();
    let mut max_sum = vec_get(arr, 0);
    let mut current_sum = vec_get(arr, 0);
    let mut start = 0;
    let mut end_idx = 0;
    let mut temp_start = 0;
    let mut i = 1;
    while i < n {
        let val = vec_get(arr, i);
        let _x = if current_sum + val > val {
            set current_sum = current_sum + val;
            0
        } else {
            set current_sum = val;
            set temp_start = i;
            0
        };
        let _y = if current_sum > max_sum {
            set max_sum = current_sum;
            set start = temp_start;
            set end_idx = i;
            0
        } else { 0 };
        set i = i + 1
    };
    let _p = vec_push(result, max_sum);
    let _p = vec_push(result, start);
    let _p = vec_push(result, end_idx);
    result
};

fn main() -> () = {
    // Test 1: Mixed
    let arr1 = vec_new();
    let _p = vec_push(arr1, -2); let _p = vec_push(arr1, 1); let _p = vec_push(arr1, -3);
    let _p = vec_push(arr1, 4); let _p = vec_push(arr1, -1); let _p = vec_push(arr1, 2);
    let _p = vec_push(arr1, 1); let _p = vec_push(arr1, -5); let _p = vec_push(arr1, 4);
    let r1 = kadane(arr1);
    print_str("max="); print(vec_get(r1, 0));
    print_str(" start="); print(vec_get(r1, 1));
    print_str(" end="); let _r = println(vec_get(r1, 2));

    // Test 2: All positive
    let arr2 = vec_new();
    let _p = vec_push(arr2, 1); let _p = vec_push(arr2, 2); let _p = vec_push(arr2, 3);
    let _p = vec_push(arr2, 4); let _p = vec_push(arr2, 5);
    let r2 = kadane(arr2);
    print_str("max="); print(vec_get(r2, 0));
    print_str(" start="); print(vec_get(r2, 1));
    print_str(" end="); let _r = println(vec_get(r2, 2));

    // Test 3: All negative
    let arr3 = vec_new();
    let _p = vec_push(arr3, -5); let _p = vec_push(arr3, -2); let _p = vec_push(arr3, -8);
    let _p = vec_push(arr3, -1); let _p = vec_push(arr3, -4);
    let r3 = kadane(arr3);
    print_str("max="); print(vec_get(r3, 0));
    print_str(" start="); print(vec_get(r3, 1));
    print_str(" end="); let _r = println(vec_get(r3, 2));

    // Test 4: Single
    let arr4 = vec_new();
    let _p = vec_push(arr4, 42);
    let r4 = kadane(arr4);
    print_str("max="); let _r = println(vec_get(r4, 0))
};

// Golden Test: Histogram / frequency counting
// Count occurrences, mode, median of sorted data, range queries

// Build frequency histogram: count[val] for values in [0, max_val]
fn build_histogram(v: i64, n: i64, hist: i64, max_val: i64) -> i64 = {
    // Initialize histogram to 0
    for i in 0..max_val + 1 {
        vec_set(hist, i, 0)
    };
    // Count occurrences
    for i in 0..n {
        let val = vec_get(v, i);
        if val >= 0 && val <= max_val {
            let c = vec_get(hist, val);
            vec_set(hist, val, c + 1)
        } else { () }
    };
    0
};

// Find the mode (most frequent value). Ties: smallest value wins.
fn find_mode(hist: i64, max_val: i64) -> i64 = {
    let mut best_val = 0;
    let mut best_count = 0;
    for i in 0..max_val + 1 {
        let c = vec_get(hist, i);
        if c > best_count {
            best_count = c;
            best_val = i
        } else { () }
    };
    best_val
};

// Count distinct values
fn count_distinct(hist: i64, max_val: i64) -> i64 = {
    let mut count = 0;
    for i in 0..max_val + 1 {
        if vec_get(hist, i) > 0 {
            count = count + 1
        } else { () }
    };
    count
};

// Range frequency: count elements in [lo, hi]
fn range_count(hist: i64, lo: i64, hi: i64) -> i64 = {
    let mut total = 0;
    let mut i = lo;
    loop {
        if i > hi { break } else { () };
        total = total + vec_get(hist, i);
        i = i + 1
    };
    total
};

// Find median from histogram (given total count n)
fn find_median(hist: i64, max_val: i64, n: i64) -> i64 = {
    let target = (n + 1) / 2;
    let mut cumulative = 0;
    let mut result = 0;
    let mut found = 0;
    for i in 0..max_val + 1 {
        if found == 0 {
            cumulative = cumulative + vec_get(hist, i);
            if cumulative >= target {
                result = i;
                found = 1
            } else { () }
        } else { () }
    };
    result
};

// Create vec with capacity filled with zeros
fn make_zeros_vec(cap: i64) -> i64 = {
    let v = vec_new();
    for _i in 0..cap {
        vec_push(v, 0)
    };
    v
};

fn main() -> i64 = {
    // Data: [3, 1, 4, 1, 5, 9, 2, 6, 5, 3, 5]
    let data = vec_new();
    vec_push(data, 3); vec_push(data, 1); vec_push(data, 4); vec_push(data, 1);
    vec_push(data, 5); vec_push(data, 9); vec_push(data, 2); vec_push(data, 6);
    vec_push(data, 5); vec_push(data, 3); vec_push(data, 5);
    let n = 11;
    let max_val = 10;

    let hist = make_zeros_vec(max_val + 1);
    let _b = build_histogram(data, n, hist, max_val);

    // Frequency of each value present
    let _p1 = println(vec_get(hist, 1));  // 2 (two 1s)
    let _p2 = println(vec_get(hist, 3));  // 2 (two 3s)
    let _p3 = println(vec_get(hist, 5));  // 3 (three 5s)
    let _p4 = println(vec_get(hist, 9));  // 1 (one 9)
    let _p5 = println(vec_get(hist, 7));  // 0 (no 7s)

    // Mode
    let _p6 = println(find_mode(hist, max_val));  // 5 (appears 3 times)

    // Distinct count
    let _p7 = println(count_distinct(hist, max_val));  // 7 (1,2,3,4,5,6,9)

    // Range queries
    let _p8 = println(range_count(hist, 1, 3));   // 2+1+2 = 5 (values 1..3)
    let _p9 = println(range_count(hist, 4, 6));   // 1+3+1 = 5 (values 4..6)
    let _p10 = println(range_count(hist, 7, 10)); // 0+0+1+0 = 1 (values 7..10)

    // Median (sorted: 1,1,2,3,3,4,5,5,5,6,9 -> median = 4)
    let _p11 = println(find_median(hist, max_val, n));  // 4

    // Second test: uniform data [2, 2, 2, 2]
    let data2 = vec_new();
    vec_push(data2, 2); vec_push(data2, 2); vec_push(data2, 2); vec_push(data2, 2);
    let hist2 = make_zeros_vec(max_val + 1);
    let _b2 = build_histogram(data2, 4, hist2, max_val);
    let _p12 = println(find_mode(hist2, max_val));     // 2
    let _p13 = println(count_distinct(hist2, max_val)); // 1
    let _p14 = println(find_median(hist2, max_val, 4)); // 2

    0
};

// Golden Test: Largest Rectangle in Histogram
// Stack-based O(n) approach

fn make_zeros(n: i64) -> i64 = {
    let v = vec_new();
    let mut i = 0;
    loop {
        if i >= n { break } else { () };
        let _p = vec_push(v, 0);
        set i = i + 1
    };
    v
};

// Largest rectangle in histogram using stack-based approach
// heights: vec of bar heights, n: number of bars
fn largest_rect(heights: i64, n: i64) -> i64 = {
    let stack = make_zeros(n + 1);  // stack of indices
    let mut top = 0 - 1;  // stack top pointer
    let mut max_area = 0;
    let mut i = 0;

    loop {
        if i > n { break } else { () };

        // Current height: use 0 as sentinel after last bar
        let cur_h = if i < n { vec_get(heights, i) } else { 0 };

        loop {
            // While stack not empty and current bar shorter than stack top
            if top < 0 { break } else { () };
            let top_idx = vec_get(stack, top);
            let top_h = vec_get(heights, top_idx);
            if top_h <= cur_h { break } else { () };

            // Pop
            set top = top - 1;

            // Width calculation
            let width = if top < 0 { i } else { i - vec_get(stack, top) - 1 };
            let area = top_h * width;
            set max_area = if area > max_area { area } else { max_area }
        };

        // Push current index
        set top = top + 1;
        let _s = vec_set(stack, top, i);
        set i = i + 1
    };

    let _f = vec_free(stack);
    max_area
};

// Brute force for verification (O(n^2))
fn largest_rect_brute(heights: i64, n: i64) -> i64 = {
    let mut max_area = 0;
    for i in 0..n {
        let mut min_h = vec_get(heights, i);
        for j in i..n {
            let h = vec_get(heights, j);
            set min_h = if h < min_h { h } else { min_h };
            let area = min_h * (j - i + 1);
            set max_area = if area > max_area { area } else { max_area }
        };
        0
    };
    max_area
};

// Max water trapped between bars (trapping rain water)
fn trap_water(heights: i64, n: i64) -> i64 = {
    if n <= 2 { return 0 } else { () };
    let left_max = make_zeros(n);
    let right_max = make_zeros(n);

    // Build left max array
    let _s = vec_set(left_max, 0, vec_get(heights, 0));
    let mut i = 1;
    loop {
        if i >= n { break } else { () };
        let prev = vec_get(left_max, i - 1);
        let cur = vec_get(heights, i);
        let _s = vec_set(left_max, i, if cur > prev { cur } else { prev });
        set i = i + 1
    };

    // Build right max array
    let _s = vec_set(right_max, n - 1, vec_get(heights, n - 1));
    set i = n - 2;
    loop {
        if i < 0 { break } else { () };
        let nxt = vec_get(right_max, i + 1);
        let cur = vec_get(heights, i);
        let _s = vec_set(right_max, i, if cur > nxt { cur } else { nxt });
        set i = i - 1
    };

    // Calculate water
    let mut water = 0;
    for j in 0..n {
        let lm = vec_get(left_max, j);
        let rm = vec_get(right_max, j);
        let bound = if lm < rm { lm } else { rm };
        let h = vec_get(heights, j);
        let w = if bound > h { bound - h } else { 0 };
        set water = water + w
    };

    let _f1 = vec_free(left_max);
    let _f2 = vec_free(right_max);
    water
};

fn main() -> i64 = {
    // Test 1: Classic histogram [2,1,5,6,2,3]
    // Largest rect: 5*2=10 (bars at index 2,3 with heights 5,6)
    let h1 = vec_new();
    let _p = vec_push(h1, 2);
    let _p = vec_push(h1, 1);
    let _p = vec_push(h1, 5);
    let _p = vec_push(h1, 6);
    let _p = vec_push(h1, 2);
    let _p = vec_push(h1, 3);
    let _r1 = println(largest_rect(h1, 6));        // 10
    let _r2 = println(largest_rect_brute(h1, 6));  // 10

    // Test 2: All same height [3,3,3,3]
    let h2 = vec_new();
    let _p = vec_push(h2, 3);
    let _p = vec_push(h2, 3);
    let _p = vec_push(h2, 3);
    let _p = vec_push(h2, 3);
    let _r3 = println(largest_rect(h2, 4));  // 12

    // Test 3: Ascending [1,2,3,4,5]
    let h3 = vec_new();
    let _p = vec_push(h3, 1);
    let _p = vec_push(h3, 2);
    let _p = vec_push(h3, 3);
    let _p = vec_push(h3, 4);
    let _p = vec_push(h3, 5);
    let _r4 = println(largest_rect(h3, 5));  // 9 (3*3)

    // Test 4: Descending [5,4,3,2,1]
    let h4 = vec_new();
    let _p = vec_push(h4, 5);
    let _p = vec_push(h4, 4);
    let _p = vec_push(h4, 3);
    let _p = vec_push(h4, 2);
    let _p = vec_push(h4, 1);
    let _r5 = println(largest_rect(h4, 5));  // 9 (3*3)

    // Test 5: Single bar [7]
    let h5 = vec_new();
    let _p = vec_push(h5, 7);
    let _r6 = println(largest_rect(h5, 1));  // 7

    // Test 6: Two bars [2, 4]
    let h6 = vec_new();
    let _p = vec_push(h6, 2);
    let _p = vec_push(h6, 4);
    let _r7 = println(largest_rect(h6, 2));  // 4 (either 2*2=4 or 4*1=4)

    // Test 7: Valley [5,1,5]
    let h7 = vec_new();
    let _p = vec_push(h7, 5);
    let _p = vec_push(h7, 1);
    let _p = vec_push(h7, 5);
    let _r8 = println(largest_rect(h7, 3));  // 5

    // Test 8: Trapping rain water [0,1,0,2,1,0,1,3,2,1,2,1]
    let w1 = vec_new();
    let _p = vec_push(w1, 0);
    let _p = vec_push(w1, 1);
    let _p = vec_push(w1, 0);
    let _p = vec_push(w1, 2);
    let _p = vec_push(w1, 1);
    let _p = vec_push(w1, 0);
    let _p = vec_push(w1, 1);
    let _p = vec_push(w1, 3);
    let _p = vec_push(w1, 2);
    let _p = vec_push(w1, 1);
    let _p = vec_push(w1, 2);
    let _p = vec_push(w1, 1);
    let _r9 = println(trap_water(w1, 12));  // 6

    // Test 9: No water [1,2,3,4,5]
    let _r10 = println(trap_water(h3, 5));  // 0

    // Test 10: Water in valley [3,0,3]
    let w2 = vec_new();
    let _p = vec_push(w2, 3);
    let _p = vec_push(w2, 0);
    let _p = vec_push(w2, 3);
    let _r11 = println(trap_water(w2, 3));  // 3

    let _f = vec_free(h1);
    let _f = vec_free(h2);
    let _f = vec_free(h3);
    let _f = vec_free(h4);
    let _f = vec_free(h5);
    let _f = vec_free(h6);
    let _f = vec_free(h7);
    let _f = vec_free(w1);
    let _f = vec_free(w2);
    0
};

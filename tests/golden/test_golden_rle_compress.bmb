// Golden Test: Run-Length Encoding (RLE) compression/decompression

fn rle_encode(data: i64) -> i64 = {
    let n = vec_len(data);
    let encoded = vec_new();
    let _x = if n == 0 { 0 } else {
        let mut i = 0;
        while i < n {
            let val = vec_get(data, i);
            let mut count = 1;
            while i + count < n and vec_get(data, i + count) == val {
                set count = count + 1
            };
            let _p = vec_push(encoded, val);
            let _p = vec_push(encoded, count);
            set i = i + count
        };
        0
    };
    encoded
};

fn rle_decode(encoded: i64) -> i64 = {
    let decoded = vec_new();
    let mut i = 0;
    while i < vec_len(encoded) {
        let val = vec_get(encoded, i);
        let count = vec_get(encoded, i + 1);
        let mut j = 0;
        while j < count {
            let _p = vec_push(decoded, val);
            set j = j + 1
        };
        set i = i + 2
    };
    decoded
};

fn print_arr(arr: i64) -> () = {
    let mut i = 0;
    while i < vec_len(arr) {
        let _sp = if i > 0 { print_str(" "); 0 } else { 0 };
        print(vec_get(arr, i));
        set i = i + 1
    };
    let _nl = print_str("\n")
};

fn arrays_equal(a: i64, b: i64) -> i64 = {
    if vec_len(a) != vec_len(b) { 0 }
    else {
        let mut i = 0;
        let mut eq = 1;
        while i < vec_len(a) {
            let _y = if vec_get(a, i) != vec_get(b, i) { set eq = 0; 0 } else { 0 };
            set i = i + 1
        };
        eq
    }
};

fn main() -> () = {
    // Test 1: AAABBC -> [(1,3),(2,2),(3,1)]
    let d1 = vec_new();
    let _p = vec_push(d1, 1); let _p = vec_push(d1, 1); let _p = vec_push(d1, 1);
    let _p = vec_push(d1, 2); let _p = vec_push(d1, 2);
    let _p = vec_push(d1, 3);
    let e1 = rle_encode(d1);
    print_str("encoded: "); print_arr(e1);
    let dec1 = rle_decode(e1);
    print_str("roundtrip: "); let _r = println(arrays_equal(d1, dec1));

    // Test 2: All same
    let d2 = vec_new();
    let _p = vec_push(d2, 7); let _p = vec_push(d2, 7); let _p = vec_push(d2, 7);
    let _p = vec_push(d2, 7); let _p = vec_push(d2, 7);
    let e2 = rle_encode(d2);
    print_str("encoded: "); print_arr(e2);

    // Test 3: No repeats
    let d3 = vec_new();
    let _p = vec_push(d3, 1); let _p = vec_push(d3, 2); let _p = vec_push(d3, 3);
    let _p = vec_push(d3, 4); let _p = vec_push(d3, 5);
    let e3 = rle_encode(d3);
    print_str("encoded: "); print_arr(e3);
    print_str("len: "); let _r = println(vec_len(e3));

    // Test 4: Empty
    let d4 = vec_new();
    let e4 = rle_encode(d4);
    print_str("empty len: "); let _r = println(vec_len(e4));

    // Compression ratio
    print_str("original="); print(vec_len(d1));
    print_str(" compressed="); let _r = println(vec_len(e1))
};

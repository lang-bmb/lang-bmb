// Golden test: Hash table simulation with open addressing
// Uses vecs as fixed-size hash tables with linear probing
// Probing: (hash(key) + attempt) % size

// Helper: create a vec of n copies of val
fn make_filled(n: i64, val: i64) -> i64 = {
    let v = vec_new();
    for _i in 0..n { let _p = vec_push(v, val); 0 };
    v
    };

// Hash function: key mod table_size
fn hash_fn(key: i64, size: i64) -> i64 =
    if key < 0 { (0 - key) - ((0 - key) / size) * size }
    else { key - (key / size) * size };

    // Probe index: (hash(key) + attempt) % size

fn probe_idx(key: i64, attempt: i64, size: i64) -> i64 = {
    let base = hash_fn(key, size);
    let idx = base + attempt;
    if idx >= size { idx - (idx / size) * size } else { idx }
    };

// Insert into hash table (linear probing, -1 = empty)
// Does NOT insert duplicates
fn ht_insert(table: i64, key: i64, size: i64, attempt: i64) -> i64 =
    if attempt >= size { table }
    else {
        let idx = probe_idx(key, attempt, size);
        if vec_get(table, idx) == key { table }           // already exists
        else if vec_get(table, idx) == 0 - 1 {
            let _s = vec_set(table, idx, key);
            table
        }
    else { ht_insert(table, key, size, attempt + 1) }
    };

    // Lookup: returns 1 if found, 0 if not

fn ht_lookup(table: i64, key: i64, size: i64, attempt: i64) -> i64 =
    if attempt >= size { 0 }
    else {
        let idx = probe_idx(key, attempt, size);
        if vec_get(table, idx) == key { 1 }
        else if vec_get(table, idx) == 0 - 1 { 0 }
        else { ht_lookup(table, key, size, attempt + 1) }
    };

    // Count non-empty slots

fn ht_count(table: i64, pos: i64, count: i64, size: i64) -> i64 =
    if pos >= size { count }
    else {
        let inc = if vec_get(table, pos) != 0 - 1 { 1 } else { 0 };
        ht_count(table, pos + 1, count + inc, size)
    };

    // Insert multiple values from array

fn ht_insert_all(table: i64, arr: i64, pos: i64, arr_size: i64, tbl_size: i64) -> i64 =
    if pos >= arr_size { table }
    else {
        let t = ht_insert(table, vec_get(arr, pos), tbl_size, 0);
        ht_insert_all(t, arr, pos + 1, arr_size, tbl_size)
    };

    // Compute load factor * 100 (percentage)

fn load_factor_pct(table: i64, size: i64) -> i64 = {
    let used = ht_count(table, 0, 0, size);
    used * 100 / size
    };

// Find probe length for a key
fn probe_len(table: i64, key: i64, size: i64, attempt: i64) -> i64 =
    if attempt >= size { attempt }
    else {
        let idx = probe_idx(key, attempt, size);
        if vec_get(table, idx) == key { attempt + 1 }
        else if vec_get(table, idx) == 0 - 1 { 0 }
        else { probe_len(table, key, size, attempt + 1) }
    };

fn max_probe_len(table: i64, pos: i64, size: i64, best: i64) -> i64 =
    if pos >= size { best }
    else if vec_get(table, pos) == 0 - 1 { max_probe_len(table, pos + 1, size, best) }
    else {
        let pl = probe_len(table, vec_get(table, pos), size, 0);
        let nb = if pl > best { pl } else { best };
        max_probe_len(table, pos + 1, size, nb)
    };

fn main() -> i64 = {
// Create table of size 7 (all -1)
    let empty = make_filled(7, 0 - 1);

// Insert values
    let t1 = ht_insert(empty, 10, 7, 0);    // hash(10)=3
    let t2 = ht_insert(t1, 20, 7, 0);       // hash(20)=6
    let t3 = ht_insert(t2, 15, 7, 0);       // hash(15)=1
    let t4 = ht_insert(t3, 3, 7, 0);        // hash(3)=3 -> probe to 4
    let t5 = ht_insert(t4, 17, 7, 0);       // hash(17)=3 -> probe to 5

// Count
    let _p1 = println(ht_count(t5, 0, 0, 7));  // 5

// Lookups
    let _p2 = println(ht_lookup(t5, 10, 7, 0));  // 1
    let _p3 = println(ht_lookup(t5, 20, 7, 0));  // 1
    let _p4 = println(ht_lookup(t5, 15, 7, 0));  // 1
    let _p5 = println(ht_lookup(t5, 3, 7, 0));   // 1
    let _p6 = println(ht_lookup(t5, 99, 7, 0));  // 0

// Load factor
    let _p7 = println(load_factor_pct(t5, 7));  // 71

// Count unique: [1, 2, 3, 2, 1, 4, 3, 5] -> 5 unique
    let arr = vec_new();
    let _ar0 = vec_push(arr, 1);
    let _ar1 = vec_push(arr, 2);
    let _ar2 = vec_push(arr, 3);
    let _ar3 = vec_push(arr, 2);
    let _ar4 = vec_push(arr, 1);
    let _ar5 = vec_push(arr, 4);
    let _ar6 = vec_push(arr, 3);
    let _ar7 = vec_push(arr, 5);
    let ht2 = make_filled(11, 0 - 1);
    let filled = ht_insert_all(ht2, arr, 0, 8, 11);
    let _p8 = println(ht_count(filled, 0, 0, 11));  // 5 unique

// Duplicate insert does nothing
    let t6 = ht_insert(t5, 10, 7, 0);  // 10 already exists
    let _p9 = println(ht_count(t6, 0, 0, 7));  // still 5

// Hash function tests
    let _p10 = println(hash_fn(0, 7));    // 0
    let _p11 = println(hash_fn(7, 7));    // 0
    let _p12 = println(hash_fn(10, 7));   // 3
    let _p13 = println(hash_fn(100, 7));  // 2

// Max probe length
    let _p14 = println(max_probe_len(t5, 0, 7, 0));

    0
    };

// Test: postcondition enables bounds check elimination at caller
// clamp_index has post ret >= 0 and ret < 5, so using result as index is safe

fn clamp_index(x: i64) -> i64
    post ret >= 0 and ret < 5
= if x < 0 { 0 } else if x >= 5 { 4 } else { x };

fn main() -> i64 = {
    let arr: [i64; 5] = [10, 20, 30, 40, 50];
    let idx = clamp_index(3);
    // idx is guaranteed 0 <= idx < 5 by postcondition
    // In --safe mode, bounds check should be eliminable by LLVM
    let val = arr[idx];
    let _u = println(val);
    0
};

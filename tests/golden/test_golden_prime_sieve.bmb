// Golden test: Prime number sieve and related algorithms
// Tests complex loop patterns with vec mutation

// Mark multiples of p starting from p*p
fn sieve_mark(arr: i64, p: i64, pos: i64) -> i64 =
    if pos >= vec_len(arr) { 0 }
    else {
        vec_set(arr, pos, 0);
        sieve_mark(arr, p, pos + p)
    };

    // Sieve step: find next prime and mark multiples

fn sieve_step(arr: i64, p: i64) -> i64 =
    if p * p >= vec_len(arr) { 0 }
    else if vec_get(arr, p) == 1 {
        let _marked = sieve_mark(arr, p, p * p);
        sieve_step(arr, p + 1)
    }
    else { sieve_step(arr, p + 1) };

    // Count primes in sieved array

fn count_primes(arr: i64, pos: i64, count: i64) -> i64 =
    if pos >= vec_len(arr) { count }
    else {
        let inc = if vec_get(arr, pos) == 1 { 1 } else { 0 };
        count_primes(arr, pos + 1, count + inc)
    };

    // Initialize sieve array: set all to 1, then 0 and 1 to 0

fn init_sieve(arr: i64, pos: i64) -> i64 =
    if pos >= vec_len(arr) { 0 }
    else {
        let val = if pos < 2 { 0 } else { 1 };
        vec_set(arr, pos, val);
        init_sieve(arr, pos + 1)
    };

    // Get nth prime from sieved array

fn nth_prime(arr: i64, pos: i64, count: i64, target: i64) -> i64 =
    if pos >= vec_len(arr) { 0 - 1 }
    else if vec_get(arr, pos) == 1 {
        if count + 1 == target { pos }
        else { nth_prime(arr, pos + 1, count + 1, target) }
    }
    else { nth_prime(arr, pos + 1, count, target) };

    // Sum of first n primes

fn my_sum_first_primes(arr: i64, pos: i64, count: i64, target: i64, acc: i64) -> i64 =
    if pos >= vec_len(arr) or count >= target { acc }
    else if vec_get(arr, pos) == 1 { my_sum_first_primes(arr, pos + 1, count + 1, target, acc + pos) }
    else { my_sum_first_primes(arr, pos + 1, count, target, acc) };

    // GCD-based coprimality test

fn gcd(a: i64, b: i64) -> i64 =
    if b == 0 { a }
    else { gcd(b, a - (a / b) * b) };

fn euler_totient(n: i64, k: i64, count: i64) -> i64 =
    if k >= n { count }
    else {
        let inc = if gcd(n, k) == 1 { 1 } else { 0 };
        euler_totient(n, k + 1, count + inc)
    };

    // Helper: create a vec of n zeros

fn make_zeros(n: i64) -> i64 = {
    let v = vec_new();
    let mut i = 0;
    loop {
        if i >= n { break } else { 0 };
        vec_push(v, 0);
        i = i + 1
    };
    v
    };

fn main() -> i64 = {
// Create and run sieve up to 50
    let arr = make_zeros(50);
    let _init = init_sieve(arr, 0);
    let _sieve = sieve_step(arr, 2);

// Count primes up to 49
    let _p1 = println(count_primes(arr, 0, 0));  // 15 primes below 50

// Nth prime
    let _p2 = println(nth_prime(arr, 0, 0, 1));   // 2 (1st prime)
    let _p3 = println(nth_prime(arr, 0, 0, 5));   // 11 (5th prime)
    let _p4 = println(nth_prime(arr, 0, 0, 10));  // 29 (10th prime)

// Sum of first 5 primes: 2+3+5+7+11 = 28
    let _p5 = println(my_sum_first_primes(arr, 0, 0, 5, 0));

// Check specific values
    let _p6 = println(vec_get(arr, 2));   // 1 (prime)
    let _p7 = println(vec_get(arr, 4));   // 0 (not prime)
    let _p8 = println(vec_get(arr, 47));  // 1 (prime)

// Euler totient
    let _p9 = println(euler_totient(12, 1, 0));   // 4 (1,5,7,11)
    let _p10 = println(euler_totient(7, 1, 0));   // 6 (prime -> n-1)
    let _p11 = println(euler_totient(10, 1, 0));  // 4 (1,3,7,9)

    vec_free(arr);
    0
    };

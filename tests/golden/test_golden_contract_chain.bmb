// Golden Test: Contract Chaining Patterns
// Demonstrates pre/post conditions composed across multiple function calls.
// Each function's post-condition feeds into the next function's pre-condition.

// 1. clamp: bounds x into [lo, hi]
//    pre  lo <= hi  (valid range)
//    post ret >= lo and ret <= hi
fn clamp(x: i64, lo: i64, hi: i64) -> i64
    pre lo <= hi
    post ret >= lo and ret <= hi
= if x < lo { lo }
  else if x > hi { hi }
  else { x };

// 2. safe_index: clamps an array index into [0, len-1]
//    Relies on clamp's post-condition to satisfy its own post-condition.
//    pre  len > 0  (non-empty array)
//    post ret >= 0 and ret < len
fn safe_index(idx: i64, len: i64) -> i64
    pre len > 0
    post ret >= 0 and ret < len
= clamp(idx, 0, len - 1);

// 3. normalize: maps x (clamped to [0, max_val]) onto [0, 100]
//    pre  max_val > 0  (valid scale)
//    post ret >= 0 and ret <= 100
fn normalize(x: i64, max_val: i64) -> i64
    pre max_val > 0
    post ret >= 0 and ret <= 100
= {
    let clamped = clamp(x, 0, max_val);
    (clamped * 100) / max_val
};

// 4. compose_clamp_norm: clamp x to [lo, hi] then normalize that sub-range to [0, 100]
//    Chains clamp (post: value in [lo,hi]) into normalize (pre: max > 0).
//    pre  lo <= hi  (valid clamp range)
//    post ret >= 0 and ret <= 100
fn compose_clamp_norm(x: i64, lo: i64, hi: i64) -> i64
    pre lo <= hi
    post ret >= 0 and ret <= 100
= {
    let clamped = clamp(x, lo, hi);
    let shifted = clamped - lo;
    let range = hi - lo;
    if range == 0 { 0 } else { normalize(shifted, range) }
};

// 5. abs_val: absolute value
//    post ret >= 0
fn abs_val(x: i64) -> i64
    post ret >= 0
= if x < 0 { 0 - x } else { x };

// 6. distance: non-negative distance between two i64 values
//    Relies on abs_val's post-condition to satisfy its own post-condition.
//    post ret >= 0
fn distance(a: i64, b: i64) -> i64
    post ret >= 0
= abs_val(a - b);

fn main() -> i64 = {
    // clamp tests
    let _p1  = println(clamp(5, 0, 10));       // 5  — in range, unchanged
    let _p2  = println(clamp(0 - 3, 0, 10));   // 0  — below lo, clamped to lo
    let _p3  = println(clamp(15, 0, 10));       // 10 — above hi, clamped to hi
    let _p4  = println(clamp(0, 0, 0));         // 0  — lo == hi == 0
    let _p5  = println(clamp(7, 5, 5));         // 5  — lo == hi == 5

    // safe_index tests (index clamped to [0, len-1])
    let _p6  = println(safe_index(0, 5));       // 0  — first valid index
    let _p7  = println(safe_index(4, 5));       // 4  — last valid index
    let _p8  = println(safe_index(7, 5));       // 4  — out of bounds, clamped to len-1
    let _p9  = println(safe_index(0 - 1, 5));  // 0  — negative, clamped to 0
    let _p10 = println(safe_index(3, 10));      // 3  — in range, unchanged

    // normalize tests (value mapped to [0, 100])
    let _p11 = println(normalize(50, 100));     // 50  — halfway
    let _p12 = println(normalize(0, 100));      // 0   — at minimum
    let _p13 = println(normalize(100, 100));    // 100 — at maximum
    let _p14 = println(normalize(25, 200));     // 12  — 25*100/200=12
    let _p15 = println(normalize(80, 200));     // 40  — 80*100/200=40

    // compose_clamp_norm tests (clamp then normalize to [0, 100])
    let _p16 = println(compose_clamp_norm(5, 0, 20));      // 25  — 5 in [0,20] → 5/20*100=25
    let _p17 = println(compose_clamp_norm(0 - 5, 0, 10)); // 0   — below lo, clamps to 0
    let _p18 = println(compose_clamp_norm(15, 0, 10));     // 100 — above hi, clamps to 10
    let _p19 = println(compose_clamp_norm(3, 0, 4));       // 75  — 3 in [0,4] → 3/4*100=75

    // abs_val tests
    let _p20 = println(abs_val(42));            // 42  — already positive
    let _p21 = println(abs_val(0 - 7));         // 7   — negated
    let _p22 = println(abs_val(0));             // 0
    let _p23 = println(abs_val(0 - 100));       // 100 — negated

    // distance tests (uses abs_val internally)
    let _p24 = println(distance(10, 3));        // 7  — |10-3|
    let _p25 = println(distance(3, 10));        // 7  — |3-10|, symmetric
    let _p26 = println(distance(5, 5));         // 0  — same point

    0
};

// Golden Test: Euler tour of a tree
// DFS-based traversal recording entry and exit times
// Tree stored as adjacency list using parallel vecs

fn make_zeros(n: i64) -> i64 = {
    let v = vec_new();
    for _i in 0..n { let _p = vec_push(v, 0); 0 };
    v
};

fn make_neg_ones(n: i64) -> i64 = {
    let v = vec_new();
    for _i in 0..n { let _p = vec_push(v, 0 - 1); 0 };
    v
};

// Add directed edge u -> v to adjacency list
// adj_head[u] = index of first edge from u (linked list head)
// edge_to[idx] = destination of edge idx
// edge_next[idx] = next edge in linked list (or -1)
fn add_edge(adj_head: i64, edge_to: i64, edge_next: i64, u: i64, v: i64) -> i64 = {
    let idx = vec_len(edge_to);
    let _p1 = vec_push(edge_to, v);
    let _p2 = vec_push(edge_next, vec_get(adj_head, u));
    let _s = vec_set(adj_head, u, idx);
    0
};

// Add undirected edge (both directions)
fn add_undirected(adj_head: i64, edge_to: i64, edge_next: i64, u: i64, v: i64) -> i64 = {
    let _e1 = add_edge(adj_head, edge_to, edge_next, u, v);
    let _e2 = add_edge(adj_head, edge_to, edge_next, v, u);
    0
};

// Iterative DFS for Euler tour using explicit stack
// Records tin (entry time) and tout (exit time) for each node
// Stack stores: node*2 if first visit, node*2+1 if returning
fn euler_tour_dfs(adj_head: i64, edge_to: i64, edge_next: i64, n: i64, root: i64, tin: i64, tout: i64) -> i64 = {
    let visited = make_zeros(n);
    let stack = vec_new();
    let mut timer = 0;

    // Push root (first visit)
    let _p = vec_push(stack, root * 2);

    while vec_len(stack) > 0 {
        let top = vec_get(stack, vec_len(stack) - 1);
        let _pop = vec_pop(stack);
        let node = top / 2;
        let is_return = top - node * 2;

        let _c = if is_return == 1 {
            // Returning from node: record exit time
            let _s = vec_set(tout, node, timer);
            set timer = timer + 1;
            ()
        } else {
            // First visit
            let _c2 = if vec_get(visited, node) == 0 {
                let _sv = vec_set(visited, node, 1);
                let _st = vec_set(tin, node, timer);
                set timer = timer + 1;

                // Push return marker
                let _pr = vec_push(stack, node * 2 + 1);

                // Push all unvisited children (in reverse order for correct DFS order)
                // First, collect children
                let children = vec_new();
                let mut eidx = vec_get(adj_head, node);
                while eidx >= 0 {
                    let dest = vec_get(edge_to, eidx);
                    let _c3 = if vec_get(visited, dest) == 0 {
                        let _pc = vec_push(children, dest);
                        ()
                    } else { () };
                    set eidx = vec_get(edge_next, eidx)
                };
                // Push children in reverse so first child is processed first
                let mut ci = vec_len(children) - 1;
                while ci >= 0 {
                    let _ps = vec_push(stack, vec_get(children, ci) * 2);
                    set ci = ci - 1
                };
                let _fc = vec_free(children);
                ()
            } else { () }
        }
    };

    let _fv = vec_free(visited);
    let _fs = vec_free(stack);
    timer
};

// Compute subtree sizes using tin/tout
// subtree_size[v] = (tout[v] - tin[v] + 1) / 2
fn subtree_size(tin: i64, tout: i64, v: i64) -> i64 =
    (vec_get(tout, v) - vec_get(tin, v) + 1) / 2;

// Check if u is ancestor of v using Euler tour times
fn is_ancestor(tin: i64, tout: i64, u: i64, v: i64) -> i64 =
    if vec_get(tin, u) <= vec_get(tin, v) {
        if vec_get(tout, u) >= vec_get(tout, v) { 1 } else { 0 }
    } else { 0 };

fn main() -> i64 = {
    // === Test 1: Simple tree with 5 nodes ===
    //       0
    //      / \
    //     1   2
    //    / \
    //   3   4
    let _p = println_str("=== Test 1: tree with 5 nodes ===");
    let n1 = 5;
    let adj1 = make_neg_ones(n1);
    let to1 = vec_new();
    let next1 = vec_new();
    let _e = add_undirected(adj1, to1, next1, 0, 1);
    let _e = add_undirected(adj1, to1, next1, 0, 2);
    let _e = add_undirected(adj1, to1, next1, 1, 3);
    let _e = add_undirected(adj1, to1, next1, 1, 4);

    let tin1 = make_zeros(n1);
    let tout1 = make_zeros(n1);
    let _t = euler_tour_dfs(adj1, to1, next1, n1, 0, tin1, tout1);

    let _p = println_str("tin:");
    for i in 0..n1 { let _p = println(vec_get(tin1, i)); 0 };
    let _p = println_str("tout:");
    for i in 0..n1 { let _p = println(vec_get(tout1, i)); 0 };

    // Subtree sizes
    let _p = println_str("subtree sizes:");
    for i in 0..n1 {
        let _p = println(subtree_size(tin1, tout1, i));
        0
    };

    // Ancestor checks
    let _p = println_str("ancestor checks:");
    // 0 is ancestor of all
    let _p = println(is_ancestor(tin1, tout1, 0, 3));  // 1
    let _p = println(is_ancestor(tin1, tout1, 0, 4));  // 1
    // 1 is ancestor of 3 and 4
    let _p = println(is_ancestor(tin1, tout1, 1, 3));  // 1
    let _p = println(is_ancestor(tin1, tout1, 1, 4));  // 1
    // 2 is not ancestor of 3
    let _p = println(is_ancestor(tin1, tout1, 2, 3));  // 0
    // 3 is not ancestor of 1
    let _p = println(is_ancestor(tin1, tout1, 3, 1));  // 0

    // === Test 2: Linear chain 0-1-2-3 ===
    let _p = println_str("=== Test 2: chain 0-1-2-3 ===");
    let n2 = 4;
    let adj2 = make_neg_ones(n2);
    let to2 = vec_new();
    let next2 = vec_new();
    let _e = add_undirected(adj2, to2, next2, 0, 1);
    let _e = add_undirected(adj2, to2, next2, 1, 2);
    let _e = add_undirected(adj2, to2, next2, 2, 3);

    let tin2 = make_zeros(n2);
    let tout2 = make_zeros(n2);
    let _t = euler_tour_dfs(adj2, to2, next2, n2, 0, tin2, tout2);

    let _p = println_str("tin:");
    for i in 0..n2 { let _p = println(vec_get(tin2, i)); 0 };
    let _p = println_str("tout:");
    for i in 0..n2 { let _p = println(vec_get(tout2, i)); 0 };

    // Every node is ancestor of all nodes below it
    let _p = println_str("chain ancestor:");
    let _p = println(is_ancestor(tin2, tout2, 0, 3));  // 1
    let _p = println(is_ancestor(tin2, tout2, 1, 3));  // 1
    let _p = println(is_ancestor(tin2, tout2, 3, 0));  // 0

    // === Test 3: Star graph 0 -> {1,2,3,4,5} ===
    let _p = println_str("=== Test 3: star graph ===");
    let n3 = 6;
    let adj3 = make_neg_ones(n3);
    let to3 = vec_new();
    let next3 = vec_new();
    let _e = add_undirected(adj3, to3, next3, 0, 1);
    let _e = add_undirected(adj3, to3, next3, 0, 2);
    let _e = add_undirected(adj3, to3, next3, 0, 3);
    let _e = add_undirected(adj3, to3, next3, 0, 4);
    let _e = add_undirected(adj3, to3, next3, 0, 5);

    let tin3 = make_zeros(n3);
    let tout3 = make_zeros(n3);
    let _t = euler_tour_dfs(adj3, to3, next3, n3, 0, tin3, tout3);

    let _p = println_str("subtree sizes:");
    // Root has size 6, each leaf has size 1
    let _p = println(subtree_size(tin3, tout3, 0));  // 6
    for i in 1..n3 {
        let _p = println(subtree_size(tin3, tout3, i));
        0
    };

    // No leaf is ancestor of another leaf
    let _p = println_str("leaf non-ancestry:");
    let _p = println(is_ancestor(tin3, tout3, 1, 2));  // 0
    let _p = println(is_ancestor(tin3, tout3, 3, 5));  // 0

    // Cleanup
    let _f = vec_free(adj1); let _f = vec_free(to1); let _f = vec_free(next1);
    let _f = vec_free(tin1); let _f = vec_free(tout1);
    let _f = vec_free(adj2); let _f = vec_free(to2); let _f = vec_free(next2);
    let _f = vec_free(tin2); let _f = vec_free(tout2);
    let _f = vec_free(adj3); let _f = vec_free(to3); let _f = vec_free(next3);
    let _f = vec_free(tin3); let _f = vec_free(tout3);
    0
};

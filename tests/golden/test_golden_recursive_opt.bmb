// Golden Test: Recursive functions with optimization
// Tests that optimizations preserve correct recursive behavior

fn factorial(n: i64) -> i64 =
    if n <= 1 { 1 } else { n * factorial(n - 1) };

fn fib(n: i64) -> i64 =
    if n <= 1 { n } else { fib(n - 1) + fib(n - 2) };

fn sum_to(n: i64) -> i64 =
    if n <= 0 { 0 } else { n + sum_to(n - 1) };

fn gcd(a: i64, b: i64) -> i64 =
    if b == 0 { a } else { gcd(b, a - (a / b) * b) };

fn power(base: i64, exp: i64) -> i64 =
    if exp == 0 { 1 } else { base * power(base, exp - 1) };

fn main() -> i64 = {
    let _p1 = println(factorial(5));    // 120
    let _p2 = println(factorial(10));   // 3628800
    let _p3 = println(fib(10));         // 55
    let _p4 = println(fib(15));         // 610
    let _p5 = println(sum_to(100));     // 5050
    let _p6 = println(gcd(48, 18));     // 6
    let _p7 = println(gcd(100, 75));    // 25
    let _p8 = println(power(2, 10));    // 1024
    let _p9 = println(power(3, 5));     // 243
    0
    };

// Golden Test: Functional programming patterns
// Tests closures as values, map/filter/reduce logic, composition, pipelines

// ---- Helpers ----

fn make_vec3(a: i64, b: i64, c: i64) -> i64 = {
    let v = vec_new();
    let _p1 = vec_push(v, a);
    let _p2 = vec_push(v, b);
    let _p3 = vec_push(v, c);
    v
    };

fn make_vec4(a: i64, b: i64, c: i64, d: i64) -> i64 = {
    let v = vec_new();
    let _p1 = vec_push(v, a);
    let _p2 = vec_push(v, b);
    let _p3 = vec_push(v, c);
    let _p4 = vec_push(v, d);
    v
    };

fn make_vec6(a: i64, b: i64, c: i64, d: i64, e: i64, f: i64) -> i64 = {
    let v = vec_new();
    let _p1 = vec_push(v, a);
    let _p2 = vec_push(v, b);
    let _p3 = vec_push(v, c);
    let _p4 = vec_push(v, d);
    let _p5 = vec_push(v, e);
    let _p6 = vec_push(v, f);
    v
    };

fn print_vec(v: i64) -> i64 = {
    let n = vec_len(v);
    for i in 0..n {
        let _p = println(vec_get(v, i));
        0
    };
    0
    };

// ---- Test functions ----

// 1. Apply: apply a closure to a value
fn test_apply() -> i64 = {
    let triple = fn |x: i64| { x * 3 };
    let result = triple(7);
    let _p = println(result);  // 21
    0
    };

// 2. Map: apply closure to each element of vec, build new vec
fn test_map() -> i64 = {
    let src = make_vec3(2, 3, 5);
    let square = fn |x: i64| { x * x };
    let dst = vec_new();
    for i in 0..vec_len(src) {
        let _p = vec_push(dst, square(vec_get(src, i)));
        0
    };
    // dst = [4, 9, 25]
    let _p1 = println(vec_get(dst, 0));  // 4
    let _p2 = println(vec_get(dst, 1));  // 9
    let _p3 = println(vec_get(dst, 2));  // 25
    let _f1 = vec_free(src);
    let _f2 = vec_free(dst);
    0
    };

// 3. Filter: select elements matching predicate
fn test_filter() -> i64 = {
    let src = make_vec6(1, 5, 2, 8, 3, 7);
    let dst = vec_new();
    for i in 0..vec_len(src) {
        let val = vec_get(src, i);
        if val > 3 {
            let _p = vec_push(dst, val);
            0
        } else { 0 }
    };
    // dst = [5, 8, 7]
    let _p1 = println(vec_len(dst));     // 3
    let _p2 = println(vec_get(dst, 0));  // 5
    let _p3 = println(vec_get(dst, 1));  // 8
    let _p4 = println(vec_get(dst, 2));  // 7
    let _f1 = vec_free(src);
    let _f2 = vec_free(dst);
    0
    };

// 4. Reduce/fold: accumulate with closure
fn test_reduce() -> i64 = {
    let src = make_vec4(10, 20, 30, 40);
    let add = fn |acc: i64, x: i64| { acc + x };
    let mut result = 0;
    for i in 0..vec_len(src) {
        result = add(result, vec_get(src, i))
    };
    let _p = println(result);  // 100
    let _f = vec_free(src);
    0
    };

// 5. Function composition: apply two closures in sequence
fn test_compose() -> i64 = {
    let inc = fn |x: i64| { x + 1 };
    let dbl = fn |x: i64| { x * 2 };
    // compose: first inc, then dbl => (5 + 1) * 2 = 12
    let result = dbl(inc(5));
    let _p = println(result);  // 12
    0
    };

// 6. Pipeline: chain of transformations on a value
fn test_pipeline() -> i64 = {
    let add3 = fn |x: i64| { x + 3 };
    let mul2 = fn |x: i64| { x * 2 };
    let sub1 = fn |x: i64| { x - 1 };
    // pipeline: 10 -> add3 -> 13 -> mul2 -> 26 -> sub1 -> 25
    let result = sub1(mul2(add3(10)));
    let _p = println(result);  // 25
    0
    };

// 7. Count_if: count elements satisfying predicate
fn test_count_if() -> i64 = {
    let src = make_vec6(1, 7, 3, 9, 2, 6);
    let mut count = 0;
    for i in 0..vec_len(src) {
        if vec_get(src, i) > 4 {
            count = count + 1
        } else { () }
    };
    let _p = println(count);  // 3  (7, 9, 6)
    let _f = vec_free(src);
    0
    };

// 8. Any_match: check if any element equals target
fn test_any_match() -> i64 = {
    let src = make_vec4(3, 1, 5, 7);
    let target = 5;
    let mut found = 0;
    for i in 0..vec_len(src) {
        if vec_get(src, i) == target {
            found = 1
        } else { () }
    };
    let _p = println(found);  // 1
    let _f = vec_free(src);
    0
    };

// 9. All_match: check if all elements satisfy predicate
fn test_all_match() -> i64 = {
    // All positive in [3, 1, 5, 7] => 1
    let v1 = make_vec4(3, 1, 5, 7);
    let mut all_pos = 1;
    for i in 0..vec_len(v1) {
        if vec_get(v1, i) <= 0 {
            all_pos = 0
        } else { () }
    };
    let _p1 = println(all_pos);  // 1

    // All positive in [3, 0, 5, 7] => 0
    let v2 = make_vec4(3, 0, 5, 7);
    let mut all_pos2 = 1;
    for i in 0..vec_len(v2) {
        if vec_get(v2, i) <= 0 {
            all_pos2 = 0
        } else { () }
    };
    let _p2 = println(all_pos2);  // 0
    let _f1 = vec_free(v1);
    let _f2 = vec_free(v2);
    0
    };

// 10. Find_first: first element matching predicate
fn test_find_first() -> i64 = {
    let src = make_vec6(1, 3, 5, 7, 2, 9);
    let mut found = 0 - 1;  // sentinel: -1 means not found
    for i in 0..vec_len(src) {
        let val = vec_get(src, i);
        if found == 0 - 1 {
            if val > 4 {
                found = val
            } else { () }
        } else { () }
    };
    let _p = println(found);  // 5
    let _f = vec_free(src);
    0
    };

// 11. Transform and sum: sum of f(x) for each element
fn test_transform_sum() -> i64 = {
    let src = make_vec3(2, 3, 4);
    let square = fn |x: i64| { x * x };
    let mut sum = 0;
    for i in 0..vec_len(src) {
        sum = sum + square(vec_get(src, i))
    };
    let _p = println(sum);  // 4 + 9 + 16 = 29
    let _f = vec_free(src);
    0
    };

// 12. Partition count: count elements in two categories
fn test_partition_count() -> i64 = {
    let src = make_vec6(1, 2, 3, 4, 5, 6);
    let mut evens = 0;
    let mut odds = 0;
    for i in 0..vec_len(src) {
        let val = vec_get(src, i);
        if val - (val / 2) * 2 == 0 {
            evens = evens + 1
        } else {
            odds = odds + 1
        }
    };
    let _p1 = println(evens);  // 3
    let _p2 = println(odds);   // 3
    let _f = vec_free(src);
    0
    };

// 13. Closure with captured state for accumulation
fn test_closure_capture() -> i64 = {
    let base = 100;
    let scale = 3;
    let transform = fn |x: i64| { base + x * scale };
    let _p1 = println(transform(5));   // 100 + 15 = 115
    let _p2 = println(transform(10));  // 100 + 30 = 130
    0
    };

fn main() -> i64 = {
    let _t1 = test_apply();
    let _t2 = test_map();
    let _t3 = test_filter();
    let _t4 = test_reduce();
    let _t5 = test_compose();
    let _t6 = test_pipeline();
    let _t7 = test_count_if();
    let _t8 = test_any_match();
    let _t9 = test_all_match();
    let _t10 = test_find_first();
    let _t11 = test_transform_sum();
    let _t12 = test_partition_count();
    let _t13 = test_closure_capture();
    0
    };

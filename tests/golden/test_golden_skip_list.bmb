// Golden Test: Skip list simulation using layered arrays
// Level 0: full sorted list, Level 1: every ~2nd element, Level 2: every ~4th
// Demonstrates multi-level search for O(log n) approximation

// Create a sorted base layer
fn make_base() -> i64 = {
    let v = vec_new();
    // Sorted values: 3, 7, 12, 18, 25, 33, 42, 50, 61, 75, 88, 95
    let _p = vec_push(v, 3);
    let _p = vec_push(v, 7);
    let _p = vec_push(v, 12);
    let _p = vec_push(v, 18);
    let _p = vec_push(v, 25);
    let _p = vec_push(v, 33);
    let _p = vec_push(v, 42);
    let _p = vec_push(v, 50);
    let _p = vec_push(v, 61);
    let _p = vec_push(v, 75);
    let _p = vec_push(v, 88);
    let _p = vec_push(v, 95);
    v
    };

// Level 1: every other element (indices 0,2,4,6,8,10 -> values 3,12,25,42,61,88)
fn make_level1() -> i64 = {
    let v = vec_new();
    let _p = vec_push(v, 3);
    let _p = vec_push(v, 12);
    let _p = vec_push(v, 25);
    let _p = vec_push(v, 42);
    let _p = vec_push(v, 61);
    let _p = vec_push(v, 88);
    v
    };

// Level 1 index mapping: level1[i] corresponds to base[i*2]
// Level 2: every 4th element (indices 0,4,8 -> values 3,25,61)
fn make_level2() -> i64 = {
    let v = vec_new();
    let _p = vec_push(v, 3);
    let _p = vec_push(v, 25);
    let _p = vec_push(v, 61);
    v
    };

// Find position in a level where target could be (last element <= target)
// Returns index of last element <= target, or -1 if all greater
fn find_pos(level: i64, target: i64, pos: i64, best: i64) -> i64 =
    if pos >= vec_len(level) { best }
    else if vec_get(level, pos) <= target { find_pos(level, target, pos + 1, pos) }
    else { best };

// Skip list search: start from top level, narrow down
// Returns 1 if found, 0 if not
fn skip_search(base: i64, l1: i64, l2: i64, target: i64) -> i64 = {
    // Start at level 2
    let l2_pos = find_pos(l2, target, 0, 0 - 1);
    // Map to level 1 range: l2[i] maps to l1[i*2]
    let l1_start = if l2_pos < 0 { 0 } else { l2_pos * 2 };
    let l1_end = if l2_pos + 1 < vec_len(l2) { (l2_pos + 1) * 2 + 1 } else { vec_len(l1) };

    // Search level 1 in range
    let l1_pos = find_pos_range(l1, target, l1_start, l1_end, 0 - 1);

    // Map to base range: l1[i] maps to base[i*2]
    let b_start = if l1_pos < 0 { 0 } else { l1_pos * 2 };
    let b_end = if l1_pos + 1 < vec_len(l1) { (l1_pos + 1) * 2 + 1 } else { vec_len(base) };

    // Linear search in base range
    linear_search_range(base, target, b_start, b_end)
    };

fn find_pos_range(level: i64, target: i64, start: i64, end_pos: i64, best: i64) -> i64 =
    if start >= end_pos { best }
    else if vec_get(level, start) <= target { find_pos_range(level, target, start + 1, end_pos, start) }
    else { best };

fn linear_search_range(arr: i64, target: i64, start: i64, end_pos: i64) -> i64 =
    if start >= end_pos { 0 }
    else if vec_get(arr, start) == target { 1 }
    else { linear_search_range(arr, target, start + 1, end_pos) };

// Count comparisons in naive linear search
fn count_linear(arr: i64, target: i64, pos: i64) -> i64 =
    if pos >= vec_len(arr) { pos }
    else if vec_get(arr, pos) == target { pos + 1 }
    else { count_linear(arr, target, pos + 1) };

// Find index in base array
fn find_index(arr: i64, target: i64, pos: i64) -> i64 =
    if pos >= vec_len(arr) { 0 - 1 }
    else if vec_get(arr, pos) == target { pos }
    else { find_index(arr, target, pos + 1) };

fn main() -> i64 = {
    let base = make_base();
    let l1 = make_level1();
    let l2 = make_level2();

    // Test 1: Base layer size = 12
    let _p1 = println(vec_len(base));

    // Test 2: Level 1 size = 6
    let _p2 = println(vec_len(l1));

    // Test 3: Level 2 size = 3
    let _p3 = println(vec_len(l2));

    // Test 4: Search for 42 (exists) = 1
    let _p4 = println(skip_search(base, l1, l2, 42));

    // Test 5: Search for 99 (not exists) = 0
    let _p5 = println(skip_search(base, l1, l2, 99));

    // Test 6: Search for 3 (first element) = 1
    let _p6 = println(skip_search(base, l1, l2, 3));

    // Test 7: Search for 95 (last element) = 1
    let _p7 = println(skip_search(base, l1, l2, 95));

    // Test 8: Index of 50 in base = 7
    let _p8 = println(find_index(base, 50, 0));

    // Test 9: Linear search comparisons to find 88 = 11 (index 10, +1)
    let _p9 = println(count_linear(base, 88, 0));

    // Test 10: Search for 18 (exists, in the middle) = 1
    let _p10 = println(skip_search(base, l1, l2, 18));

    let _f1 = vec_free(base);
    let _f2 = vec_free(l1);
    let _f3 = vec_free(l2);
    0
    };

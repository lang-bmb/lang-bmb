// Golden test: String building and transformation patterns
// Tests string concatenation, slicing, and character processing

// Build a string of repeated characters
fn repeat_char(ch: i64, n: i64, acc: String) -> String =
    if n <= 0 { acc }
    else { repeat_char(ch, n - 1, acc + chr(ch)) };

    // Count occurrences of a character in a string

fn count_char(s: String, ch: i64, pos: i64, count: i64) -> i64 =
    if pos >= s.len() { count }
    else {
        let inc = if s.byte_at(pos) == ch { 1 } else { 0 };
        count_char(s, ch, pos + 1, count + inc)
    };

    // Find first occurrence of character, return -1 if not found

fn find_char(s: String, ch: i64, pos: i64) -> i64 =
    if pos >= s.len() { 0 - 1 }
    else if s.byte_at(pos) == ch { pos }
    else { find_char(s, ch, pos + 1) };

    // Check if string is a palindrome (integer result)

fn is_palindrome_check(s: String, lo: i64, hi: i64) -> i64 =
    if lo >= hi { 1 }
    else if s.byte_at(lo) != s.byte_at(hi) { 0 }
    else { is_palindrome_check(s, lo + 1, hi - 1) };

fn is_palindrome(s: String) -> i64 =
    if s.len() <= 1 { 1 }
    else { is_palindrome_check(s, 0, s.len() - 1) };

    // Count words (separated by spaces, char 32)

fn count_words(s: String, pos: i64, in_word: i64, count: i64) -> i64 =
    if pos >= s.len() { if in_word == 1 { count + 1 } else { count } }
    else if s.byte_at(pos) == 32 {
        if in_word == 1 { count_words(s, pos + 1, 0, count + 1) }
        else { count_words(s, pos + 1, 0, count) }
    }
    else { count_words(s, pos + 1, 1, count) };

    // Sum ASCII values of all characters

fn ascii_sum(s: String, pos: i64, acc: i64) -> i64 =
    if pos >= s.len() { acc }
    else { ascii_sum(s, pos + 1, acc + s.byte_at(pos)) };

    // Check if all characters are digits (48-57)

fn all_digits(s: String, pos: i64) -> i64 =
    if pos >= s.len() { 1 }
    else {
        let ch = s.byte_at(pos);
        if ch >= 48 and ch <= 57 { all_digits(s, pos + 1) }
        else { 0 }
    };

    // Count lowercase letters (97-122)

fn count_lower(s: String, pos: i64, count: i64) -> i64 =
    if pos >= s.len() { count }
    else {
        let ch = s.byte_at(pos);
        let inc = if ch >= 97 and ch <= 122 { 1 } else { 0 };
        count_lower(s, pos + 1, count + inc)
    };

fn main() -> i64 = {
// Repeat char
    let stars = repeat_char(42, 5, "");  // '*' = 42
    let _p1 = println(stars.len());  // 5

// Count char
    let hello = "hello world";
    let _p2 = println(count_char(hello, 108, 0, 0));  // 'l' = 108, count 3
    let _p3 = println(count_char(hello, 111, 0, 0));  // 'o' = 111, count 2

// Find char
    let _p4 = println(find_char(hello, 119, 0));   // 'w' = 119, position 6
    let _p5 = println(find_char(hello, 122, 0));   // 'z' = 122, not found = -1

// Palindrome
    let _p6 = println(is_palindrome("abcba"));  // 1
    let _p7 = println(is_palindrome("abcd"));   // 0
    let _p8 = println(is_palindrome("a"));      // 1
    let _p9 = println(is_palindrome("racecar")); // 1

// Word count
    let _p10 = println(count_words("hello world", 0, 0, 0));   // 2
    let _p11 = println(count_words("one two three", 0, 0, 0)); // 3
    let _p12 = println(count_words("  spaces  ", 0, 0, 0));    // 1

// ASCII sum
    let _p13 = println(ascii_sum("ABC", 0, 0));   // 65+66+67 = 198
    let _p14 = println(ascii_sum("abc", 0, 0));   // 97+98+99 = 294

// All digits
    let _p15 = println(all_digits("12345", 0));   // 1
    let _p16 = println(all_digits("123a5", 0));   // 0

// Count lowercase
    let _p17 = println(count_lower("Hello World!", 0, 0));  // 8 (e,l,l,o,o,r,l,d)

// String length operations
    let _p18 = println("".len());        // 0
    let _p19 = println("test".len());    // 4

    0
    };

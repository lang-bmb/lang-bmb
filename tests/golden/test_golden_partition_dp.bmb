// Golden Test: Partition number, subset sum, equal partition check
// Using vec-based DP

fn min2(a: i64, b: i64) -> i64 = if a < b { a } else { b };

fn make_zeros(n: i64) -> i64 = {
    let v = vec_new();
    for _i in 0..n { let _p = vec_push(v, 0); 0 };
    v
    };

fn make_vec4(a: i64, b: i64, c: i64, d: i64) -> i64 = {
    let v = vec_new();
    let _p0 = vec_push(v, a);
    let _p1 = vec_push(v, b);
    let _p2 = vec_push(v, c);
    let _p3 = vec_push(v, d);
    v
    };

fn make_vec5(a: i64, b: i64, c: i64, d: i64, e: i64) -> i64 = {
    let v = vec_new();
    let _p0 = vec_push(v, a);
    let _p1 = vec_push(v, b);
    let _p2 = vec_push(v, c);
    let _p3 = vec_push(v, d);
    let _p4 = vec_push(v, e);
    v
    };

fn make_vec6(a: i64, b: i64, c: i64, d: i64, e: i64, f: i64) -> i64 = {
    let v = vec_new();
    let _p0 = vec_push(v, a);
    let _p1 = vec_push(v, b);
    let _p2 = vec_push(v, c);
    let _p3 = vec_push(v, d);
    let _p4 = vec_push(v, e);
    let _p5 = vec_push(v, f);
    v
    };

// Partition number: p(n) = number of ways to write n as sum of positive integers
// dp[j] += dp[j-k] for k = 1..n
fn partition_fill(dp: i64, n: i64, k: i64) -> i64 =
    if k > n { 0 }
    else {
        let _u = partition_inner(dp, n, k, k);
        partition_fill(dp, n, k + 1)
    };

fn partition_inner(dp: i64, n: i64, k: i64, j: i64) -> i64 =
    if j > n { 0 }
    else {
        let _s = vec_set(dp, j, vec_get(dp, j) + vec_get(dp, j - k));
        partition_inner(dp, n, k, j + 1)
    };

fn partition_number(n: i64) -> i64 = {
    let dp = make_zeros(60);
    let _s0 = vec_set(dp, 0, 1);
    let _pf = partition_fill(dp, n, 1);
    let result = vec_get(dp, n);
    let _fd = vec_free(dp);
    result
    };

// Subset sum: can we pick elements from arr that sum to target?
// dp[j] = 1 if sum j is achievable, 0 otherwise
fn subset_sum_item(dp: i64, val: i64, j: i64) -> i64 =
    if j < val { 0 }
    else {
        if vec_get(dp, j) == 0 and vec_get(dp, j - val) == 1 {
            let _s = vec_set(dp, j, 1);
            0
        } else { 0 };
    subset_sum_item(dp, val, j - 1)
    };

fn subset_sum_all(dp: i64, arr: i64, i: i64, n: i64, target: i64) -> i64 =
    if i >= n { 0 }
    else {
        let _u = subset_sum_item(dp, vec_get(arr, i), target);
        subset_sum_all(dp, arr, i + 1, n, target)
    };

fn subset_sum(arr: i64, n: i64, target: i64) -> i64 = {
    let dp = make_zeros(60);
    let _s0 = vec_set(dp, 0, 1);
    let _sa = subset_sum_all(dp, arr, 0, n, target);
    let result = vec_get(dp, target);
    let _fd = vec_free(dp);
    result
    };

// Sum of vec
fn arr_sum(arr: i64, n: i64, i: i64, acc: i64) -> i64 =
    if i >= n { acc }
    else { arr_sum(arr, n, i + 1, acc + vec_get(arr, i)) };

    // Equal partition: can array be split into two subsets with equal sum?
    // Possible only if total sum is even, then check subset_sum(arr, sum/2)

fn can_partition(arr: i64, n: i64) -> i64 = {
    let s = arr_sum(arr, n, 0, 0);
    let half = s / 2;
    if s != half * 2 { 0 }
    else { subset_sum(arr, n, half) }
    };

// Count subsets that sum to target
fn count_subsets_item(dp: i64, val: i64, j: i64) -> i64 =
    if j < val { 0 }
    else {
        let _s = vec_set(dp, j, vec_get(dp, j) + vec_get(dp, j - val));
        count_subsets_item(dp, val, j - 1)
    };

fn count_subsets_all(dp: i64, arr: i64, i: i64, n: i64, target: i64) -> i64 =
    if i >= n { 0 }
    else {
        let _u = count_subsets_item(dp, vec_get(arr, i), target);
        count_subsets_all(dp, arr, i + 1, n, target)
    };

fn count_subsets(arr: i64, n: i64, target: i64) -> i64 = {
    let dp = make_zeros(60);
    let _s0 = vec_set(dp, 0, 1);
    let _ca = count_subsets_all(dp, arr, 0, n, target);
    let result = vec_get(dp, target);
    let _fd = vec_free(dp);
    result
    };

fn main() -> i64 = {
// Partition numbers p(n)
    let _p1 = println(partition_number(0));    // 1 (empty partition)
    let _p2 = println(partition_number(1));    // 1
    let _p3 = println(partition_number(2));    // 2 (2, 1+1)
    let _p4 = println(partition_number(5));    // 7
    let _p5 = println(partition_number(10));   // 42
    let _p6 = println(partition_number(15));   // 176

// Subset sum
    let arr1 = make_vec6(3, 34, 4, 12, 5, 2);
    let _p7 = println(subset_sum(arr1, 6, 9));    // 1 (3+4+2 or 4+5)
    let _p8 = println(subset_sum(arr1, 6, 30));   // 0 (no subset sums to 30)
    let _p9 = println(subset_sum(arr1, 6, 7));    // 1 (3+4 or 5+2)

    let arr2 = make_vec5(1, 2, 3, 4, 5);
    let _p10 = println(subset_sum(arr2, 5, 10));  // 1 (1+2+3+4 or 1+4+5 etc)
    let _p11 = println(subset_sum(arr2, 5, 15));  // 1 (1+2+3+4+5)
    let _p12 = println(subset_sum(arr2, 5, 16));  // 0 (sum is only 15)

// Equal partition
    let arr2b = make_vec5(1, 2, 3, 4, 5);
    let _p13 = println(can_partition(arr2b, 5));    // 0 (sum=15, odd)
    let arr3 = make_vec4(1, 5, 11, 5);
    let _p14 = println(can_partition(arr3, 4));    // 1 (sum=22, {1,5,5}=11 and {11})
    let arr4 = make_vec4(1, 2, 3, 5);
    let _p15 = println(can_partition(arr4, 4));    // 0 (sum=11, odd)

// Count subsets
    let arr5 = make_vec5(1, 2, 3, 4, 5);
    let _p16 = println(count_subsets(arr5, 5, 5)); // 3: {5}, {2,3}, {1,4}

    0
    };

// Golden Test: Disjoint Intervals — merge overlapping intervals
// Input: list of [start, end] intervals
// Output: merged non-overlapping intervals

// Intervals stored as parallel arrays: starts[], ends[]
// Sort intervals by start time using bubble sort
fn sort_intervals(starts: i64, ends: i64, n: i64) -> i64 = {
    for i in 0..n {
        for j in 0..(n - i - 1) {
            let s1 = vec_get(starts, j);
            let s2 = vec_get(starts, j + 1);
            let _x = if s1 > s2 {
                // Swap starts
                vec_set(starts, j, s2);
                vec_set(starts, j + 1, s1);
                // Swap ends
                let e1 = vec_get(ends, j);
                let e2 = vec_get(ends, j + 1);
                vec_set(ends, j, e2);
                vec_set(ends, j + 1, e1);
                0
            } else { 0 };
        };
    };
    0
};

// Merge overlapping intervals
// Returns number of merged intervals (stored back in starts/ends arrays as result_starts/result_ends)
fn merge_intervals(starts: i64, ends: i64, n: i64, result_starts: i64, result_ends: i64) -> i64 = {
    if n == 0 { 0 }
    else {
        let _s = sort_intervals(starts, ends, n);
        let mut cur_start = vec_get(starts, 0);
        let mut cur_end = vec_get(ends, 0);
        let mut count = 0;

        for i in 1..n {
            let s = vec_get(starts, i);
            let e = vec_get(ends, i);
            let _x = if s <= cur_end {
                // Overlapping or adjacent: extend current interval
                let _y = if e > cur_end {
                    set cur_end = e;
                    0
                } else { 0 };
                0
            } else {
                // No overlap: save current, start new
                vec_push(result_starts, cur_start);
                vec_push(result_ends, cur_end);
                set count = count + 1;
                set cur_start = s;
                set cur_end = e;
                0
            };
        };
        // Save last interval
        vec_push(result_starts, cur_start);
        vec_push(result_ends, cur_end);
        count + 1
    }
};

// Check if a point is covered by any interval
fn point_covered(starts: i64, ends: i64, n: i64, point: i64) -> i64 = {
    let mut covered = 0;
    for i in 0..n {
        let _x = if point >= vec_get(starts, i) and point <= vec_get(ends, i) {
            set covered = 1;
            0
        } else { 0 };
    };
    covered
};

// Total coverage length
fn total_coverage(starts: i64, ends: i64, n: i64) -> i64 = {
    let mut total = 0;
    for i in 0..n {
        set total = total + vec_get(ends, i) - vec_get(starts, i) + 1;
    };
    total
};

// Count gaps between merged intervals
fn count_gaps(starts: i64, ends: i64, n: i64) -> i64 = {
    let mut gaps = 0;
    for i in 1..n {
        let gap = vec_get(starts, i) - vec_get(ends, i - 1) - 1;
        let _x = if gap > 0 {
            set gaps = gaps + gap;
            0
        } else { 0 };
    };
    gaps
};

fn main() -> i64 = {
    // Test 1: Overlapping intervals
    // Input: [1,3], [2,6], [8,10], [15,18]
    let s1 = vec_new();
    let e1 = vec_new();
    vec_push(s1, 1);  vec_push(e1, 3);
    vec_push(s1, 2);  vec_push(e1, 6);
    vec_push(s1, 8);  vec_push(e1, 10);
    vec_push(s1, 15); vec_push(e1, 18);

    let rs1 = vec_new();
    let re1 = vec_new();
    let n1 = merge_intervals(s1, e1, 4, rs1, re1);
    let _p1 = println(n1);  // 3 (merged: [1,6], [8,10], [15,18])

    // Print merged intervals
    for i in 0..n1 {
        let _ps = println(vec_get(rs1, i));
        let _pe = println(vec_get(re1, i));
    };
    // 1 6 8 10 15 18

    // Test 2: All overlapping
    let s2 = vec_new();
    let e2 = vec_new();
    vec_push(s2, 1);  vec_push(e2, 10);
    vec_push(s2, 2);  vec_push(e2, 5);
    vec_push(s2, 3);  vec_push(e2, 8);
    let rs2 = vec_new();
    let re2 = vec_new();
    let n2 = merge_intervals(s2, e2, 3, rs2, re2);
    let _p2 = println(n2);  // 1
    let _p3 = println(vec_get(rs2, 0));  // 1
    let _p4 = println(vec_get(re2, 0));  // 10

    // Test 3: No overlapping
    let s3 = vec_new();
    let e3 = vec_new();
    vec_push(s3, 1);  vec_push(e3, 2);
    vec_push(s3, 5);  vec_push(e3, 6);
    vec_push(s3, 9);  vec_push(e3, 10);
    let rs3 = vec_new();
    let re3 = vec_new();
    let n3 = merge_intervals(s3, e3, 3, rs3, re3);
    let _p5 = println(n3);  // 3

    // Test 4: Point coverage
    let _p6 = println(point_covered(rs1, re1, n1, 5));   // 1 (in [1,6])
    let _p7 = println(point_covered(rs1, re1, n1, 7));   // 0 (gap)
    let _p8 = println(point_covered(rs1, re1, n1, 9));   // 1 (in [8,10])
    let _p9 = println(point_covered(rs1, re1, n1, 16));  // 1 (in [15,18])

    // Test 5: Total coverage
    let _p10 = println(total_coverage(rs1, re1, n1));  // 6+3+4 = 13

    // Test 6: Gap size
    let _p11 = println(count_gaps(rs1, re1, n1));  // (8-6-1)+(15-10-1) = 1+4 = 5

    // Test 7: Adjacent intervals [1,5], [6,10]
    let s4 = vec_new();
    let e4 = vec_new();
    vec_push(s4, 1);  vec_push(e4, 5);
    vec_push(s4, 6);  vec_push(e4, 10);
    let rs4 = vec_new();
    let re4 = vec_new();
    let n4 = merge_intervals(s4, e4, 2, rs4, re4);
    let _p12 = println(n4);  // 2 (not merged: 6 > 5)

    vec_free(s1); vec_free(e1); vec_free(rs1); vec_free(re1);
    vec_free(s2); vec_free(e2); vec_free(rs2); vec_free(re2);
    vec_free(s3); vec_free(e3); vec_free(rs3); vec_free(re3);
    vec_free(s4); vec_free(e4); vec_free(rs4); vec_free(re4);
    0
};

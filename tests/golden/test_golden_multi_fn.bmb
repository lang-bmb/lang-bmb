// Golden Test: Multi-Function Computation
// Tests function composition, parameter passing, and computation patterns

fn square(x: i64) -> i64 = x * x;
fn cube(x: i64) -> i64 = x * x * x;
fn is_positive(x: i64) -> i64 = if x > 0 { 1 } else { 0 };
fn is_zero(x: i64) -> i64 = if x == 0 { 1 } else { 0 };

fn sum_of_squares(n: i64) -> i64 = {
    let s = 0;
    for i in 1..=n { s = s + square(i); };
    s
};

fn sum_of_cubes(n: i64) -> i64 = {
    let s = 0;
    for i in 1..=n { s = s + cube(i); };
    s
};

fn collatz_steps(n: i64) -> i64 = {
    let x = n;
    let steps = 0;
    loop {
        if x <= 1 { break } else { () };
        if x % 2 == 0 { x = x / 2 }
        else { x = 3 * x + 1 };
        steps = steps + 1;
    };
    steps
};

fn digital_root(n: i64) -> i64 = {
    let x = n;
    loop {
        if x < 10 { break } else { () };
        let s = 0;
        let tmp = x;
        loop {
            if tmp == 0 { break } else { () };
            s = s + tmp % 10;
            tmp = tmp / 10;
        };
        x = s;
    };
    x
};

fn main() -> i64 = {
    // Basic function calls
    let _p1 = println(square(7));  // 49
    let _p2 = println(cube(4));    // 64

    // Predicate functions
    let _p3 = println(is_positive(5));    // 1
    let _p4 = println(is_positive(0 - 3)); // 0
    let _p5 = println(is_zero(0));        // 1
    let _p6 = println(is_zero(1));        // 0

    // Sum of squares: 1^2+2^2+...+10^2 = 385
    let _p7 = println(sum_of_squares(10));  // 385

    // Sum of cubes: 1^3+2^3+...+5^3 = 225
    let _p8 = println(sum_of_cubes(5));  // 225

    // Collatz sequence
    let _p9 = println(collatz_steps(27));  // 111
    let _p10 = println(collatz_steps(1));  // 0

    // Digital root
    let _p11 = println(digital_root(12345));  // 6
    let _p12 = println(digital_root(9999));   // 9
    let _p13 = println(digital_root(7));      // 7

    // Nested function calls
    let _p14 = println(square(cube(2)));  // 64

    0
};

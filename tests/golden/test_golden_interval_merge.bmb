// Golden Test: Interval merging
// Sort by start, greedily merge overlapping intervals

fn sort_intervals(starts: i64, ends: i64) -> () = {
    let n = vec_len(starts);
    let mut i = 1;
    while i < n {
        let ks = vec_get(starts, i);
        let ke = vec_get(ends, i);
        let mut j = i - 1;
        let mut done = 0;
        while j >= 0 and done == 0 {
            let _x = if vec_get(starts, j) > ks {
                vec_set(starts, j + 1, vec_get(starts, j));
                vec_set(ends, j + 1, vec_get(ends, j));
                set j = j - 1; 0
            } else { set done = 1; 0 };
            0
        };
        vec_set(starts, j + 1, ks);
        vec_set(ends, j + 1, ke);
        set i = i + 1
    }
};

fn merge_intervals(starts: i64, ends: i64) -> i64 = {
    let n = vec_len(starts);
    let ms = vec_new();
    let me = vec_new();
    let result = vec_new();
    let _p = vec_push(result, ms);
    let _p = vec_push(result, me);
    sort_intervals(starts, ends);
    let _x = if n == 0 { 0 } else {
        let mut cur_s = vec_get(starts, 0);
        let mut cur_e = vec_get(ends, 0);
        let mut i = 1;
        while i < n {
            let _y = if vec_get(starts, i) <= cur_e {
                let _z = if vec_get(ends, i) > cur_e { set cur_e = vec_get(ends, i); 0 } else { 0 };
                0
            } else {
                let _p = vec_push(ms, cur_s);
                let _p = vec_push(me, cur_e);
                set cur_s = vec_get(starts, i);
                set cur_e = vec_get(ends, i);
                0
            };
            set i = i + 1
        };
        let _p = vec_push(ms, cur_s);
        let _p = vec_push(me, cur_e);
        0
    };
    result
};

fn print_intervals(result: i64) -> () = {
    let ms = vec_get(result, 0);
    let me = vec_get(result, 1);
    let mut i = 0;
    while i < vec_len(ms) {
        print_str("["); print(vec_get(ms, i)); print_str(","); print(vec_get(me, i)); print_str("]");
        let _sp = if i < vec_len(ms) - 1 { print_str(" "); 0 } else { 0 };
        set i = i + 1
    };
    let _nl = print_str("
")
};

fn main() -> () = {
    // Test 1: [[1,3],[2,6],[8,10],[15,18]] -> [[1,6],[8,10],[15,18]]
    let s1 = vec_new(); let e1 = vec_new();
    let _p = vec_push(s1, 1); let _p = vec_push(e1, 3);
    let _p = vec_push(s1, 2); let _p = vec_push(e1, 6);
    let _p = vec_push(s1, 8); let _p = vec_push(e1, 10);
    let _p = vec_push(s1, 15); let _p = vec_push(e1, 18);
    let r1 = merge_intervals(s1, e1);
    print_intervals(r1);

    // Test 2: [[1,4],[4,5]] -> [[1,5]]
    let s2 = vec_new(); let e2 = vec_new();
    let _p = vec_push(s2, 1); let _p = vec_push(e2, 4);
    let _p = vec_push(s2, 4); let _p = vec_push(e2, 5);
    let r2 = merge_intervals(s2, e2);
    print_intervals(r2);

    // Test 3: Non-overlapping
    let s3 = vec_new(); let e3 = vec_new();
    let _p = vec_push(s3, 1); let _p = vec_push(e3, 2);
    let _p = vec_push(s3, 5); let _p = vec_push(e3, 6);
    let _p = vec_push(s3, 9); let _p = vec_push(e3, 10);
    let r3 = merge_intervals(s3, e3);
    print_intervals(r3);

    // Test 4: All merge
    let s4 = vec_new(); let e4 = vec_new();
    let _p = vec_push(s4, 1); let _p = vec_push(e4, 10);
    let _p = vec_push(s4, 2); let _p = vec_push(e4, 5);
    let _p = vec_push(s4, 3); let _p = vec_push(e4, 7);
    let r4 = merge_intervals(s4, e4);
    print_intervals(r4);

    print_str("count: "); let _r = println(vec_len(vec_get(r1, 0)))
};

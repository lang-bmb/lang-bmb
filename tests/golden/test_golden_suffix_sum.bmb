// Golden Test: Suffix Sum + Prefix Sum + Range Sum Queries
// Demonstrates efficient preprocessing for O(1) range queries

// Build prefix sum array: prefix[i] = sum(arr[0..i])
fn build_prefix_sum(arr: i64, n: i64) -> i64 = {
    let prefix = vec_new();
    vec_push(prefix, 0);  // prefix[0] = 0
    for i in 0..n {
        let prev = vec_get(prefix, i);
        vec_push(prefix, prev + vec_get(arr, i));
    };
    prefix
};

// Range sum query: sum(arr[l..r]) using prefix sums
fn range_sum(prefix: i64, l: i64, r: i64) -> i64 =
    vec_get(prefix, r + 1) - vec_get(prefix, l);

// Build suffix sum array: suffix[i] = sum(arr[i..n])
fn build_suffix_sum(arr: i64, n: i64) -> i64 = {
    let suffix = vec_new();
    for _i in 0..(n + 1) {
        vec_push(suffix, 0);
    };
    let mut i = n - 1;
    loop {
        if i < 0 { break } else { () };
        vec_set(suffix, i, vec_get(arr, i) + vec_get(suffix, i + 1));
        set i = i - 1;
    };
    suffix
};

// Find index where prefix_sum == suffix_sum (equilibrium index)
fn find_equilibrium(arr: i64, n: i64) -> i64 = {
    let prefix = build_prefix_sum(arr, n);
    let suffix = build_suffix_sum(arr, n);
    let mut result = 0 - 1;
    for i in 0..n {
        // Left sum = prefix[i], right sum = suffix[i+1]
        let left = vec_get(prefix, i);
        let right = vec_get(suffix, i + 1);
        let _x = if left == right and result < 0 {
            set result = i;
            0
        } else { 0 };
    };
    vec_free(prefix);
    vec_free(suffix);
    result
};

// Maximum subarray sum using prefix sums (Kadane-like via prefix)
fn max_subarray_prefix(arr: i64, n: i64) -> i64 = {
    let prefix = build_prefix_sum(arr, n);
    let mut min_prefix = 0;
    let mut max_sum = vec_get(arr, 0);
    for i in 1..(n + 1) {
        let cur_sum = vec_get(prefix, i) - min_prefix;
        let _x = if cur_sum > max_sum {
            set max_sum = cur_sum;
            0
        } else { 0 };
        let _y = if vec_get(prefix, i) < min_prefix {
            set min_prefix = vec_get(prefix, i);
            0
        } else { 0 };
    };
    vec_free(prefix);
    max_sum
};

// Count subarrays with sum equal to target
fn count_subarrays_sum(arr: i64, n: i64, target: i64) -> i64 = {
    let prefix = build_prefix_sum(arr, n);
    let mut count = 0;
    for i in 0..n {
        for j in i..n {
            let s = vec_get(prefix, j + 1) - vec_get(prefix, i);
            let _x = if s == target {
                set count = count + 1;
                0
            } else { 0 };
        };
    };
    vec_free(prefix);
    count
};

fn main() -> i64 = {
    // Array: [1, 3, 5, 7, 9]
    let arr = vec_new();
    vec_push(arr, 1);
    vec_push(arr, 3);
    vec_push(arr, 5);
    vec_push(arr, 7);
    vec_push(arr, 9);

    // Test 1: Prefix sums
    let prefix = build_prefix_sum(arr, 5);
    let _p1 = println(vec_get(prefix, 0));  // 0
    let _p2 = println(vec_get(prefix, 3));  // 9 (1+3+5)
    let _p3 = println(vec_get(prefix, 5));  // 25 (total)

    // Test 2: Range sum queries
    let _p4 = println(range_sum(prefix, 0, 4));  // 25 (full array)
    let _p5 = println(range_sum(prefix, 1, 3));  // 15 (3+5+7)
    let _p6 = println(range_sum(prefix, 2, 2));  // 5 (single element)
    let _p7 = println(range_sum(prefix, 0, 0));  // 1 (first element)

    // Test 3: Suffix sums
    let suffix = build_suffix_sum(arr, 5);
    let _p8 = println(vec_get(suffix, 0));  // 25 (total)
    let _p9 = println(vec_get(suffix, 2));  // 21 (5+7+9)
    let _p10 = println(vec_get(suffix, 4)); // 9 (last element)
    let _p11 = println(vec_get(suffix, 5)); // 0

    // Test 4: Equilibrium index
    // Array: [1, 3, 5, 2, 2]
    let arr2 = vec_new();
    vec_push(arr2, 1);
    vec_push(arr2, 3);
    vec_push(arr2, 5);
    vec_push(arr2, 2);
    vec_push(arr2, 2);
    // left_sum[0]=0, right_sum[1]=12; left_sum[1]=1, right_sum[2]=9
    // left_sum[2]=4, right_sum[3]=4 -> equilibrium at index 2
    let eq = find_equilibrium(arr2, 5);
    let _p12 = println(eq);  // 2

    // Test 5: No equilibrium
    let arr3 = vec_new();
    vec_push(arr3, 1);
    vec_push(arr3, 2);
    vec_push(arr3, 3);
    let eq2 = find_equilibrium(arr3, 3);
    let _p13 = println(eq2);  // -1

    // Test 6: Max subarray sum
    // Array: [-2, 1, -3, 4, -1, 2, 1, -5, 4]
    let arr4 = vec_new();
    vec_push(arr4, 0 - 2);
    vec_push(arr4, 1);
    vec_push(arr4, 0 - 3);
    vec_push(arr4, 4);
    vec_push(arr4, 0 - 1);
    vec_push(arr4, 2);
    vec_push(arr4, 1);
    vec_push(arr4, 0 - 5);
    vec_push(arr4, 4);
    let ms = max_subarray_prefix(arr4, 9);
    let _p14 = println(ms);  // 6 (subarray [4,-1,2,1])

    // Test 7: Count subarrays with sum = 8
    let count = count_subarrays_sum(arr, 5, 8);
    let _p15 = println(count);  // 1 ([3,5] = 8)

    vec_free(arr);
    vec_free(prefix);
    vec_free(suffix);
    vec_free(arr2);
    vec_free(arr3);
    vec_free(arr4);
    0
};

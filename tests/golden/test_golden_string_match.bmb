// Golden Test: String matching algorithms
// Tests: naive pattern search, count occurrences, longest common prefix

// Check if pattern matches text starting at position pos
fn match_at(text: String, pat: String, tpos: i64, ppos: i64) -> i64 =
    if ppos >= pat.len() { 1 }
    else if tpos >= text.len() { 0 }
    else if text.byte_at(tpos) != pat.byte_at(ppos) { 0 }
    else { match_at(text, pat, tpos + 1, ppos + 1) };

    // Find first occurrence of pattern in text (returns index, -1 if not found)

fn find_first(text: String, pat: String, pos: i64) -> i64 =
    if pos + pat.len() > text.len() { 0 - 1 }
    else if match_at(text, pat, pos, 0) == 1 { pos }
    else { find_first(text, pat, pos + 1) };

    // Count all occurrences of pattern in text

fn count_occurrences(text: String, pat: String, pos: i64, count: i64) -> i64 =
    if pos + pat.len() > text.len() { count }
    else if match_at(text, pat, pos, 0) == 1 {
        count_occurrences(text, pat, pos + 1, count + 1)
    }
    else { count_occurrences(text, pat, pos + 1, count) };

    // Longest common prefix length of two strings

fn lcp_len(s1: String, s2: String, pos: i64) -> i64 =
    if pos >= s1.len() { pos }
    else if pos >= s2.len() { pos }
    else if s1.byte_at(pos) != s2.byte_at(pos) { pos }
    else { lcp_len(s1, s2, pos + 1) };

    // Check if text starts with prefix

fn starts_with(text: String, prefix: String) -> i64 =
    if lcp_len(text, prefix, 0) >= prefix.len() { 1 } else { 0 };

    // Check if text ends with suffix

fn ends_with(text: String, suffix: String) -> i64 = {
    let offset = text.len() - suffix.len();
    if offset < 0 { 0 }
    else { match_at(text, suffix, offset, 0) }
    };

// Count characters matching byte value c in string
fn count_char(s: String, c: i64, pos: i64, count: i64) -> i64 =
    if pos >= s.len() { count }
    else {
        let inc = if s.byte_at(pos) == c { 1 } else { 0 };
        count_char(s, c, pos + 1, count + inc)
    };

    // Compare two strings: returns 0 if equal, -1 if s1<s2, 1 if s1>s2

fn str_compare(s1: String, s2: String, pos: i64) -> i64 =
    if pos >= s1.len() and pos >= s2.len() { 0 }
    else if pos >= s1.len() { 0 - 1 }
    else if pos >= s2.len() { 1 }
    else if s1.byte_at(pos) < s2.byte_at(pos) { 0 - 1 }
    else if s1.byte_at(pos) > s2.byte_at(pos) { 1 }
    else { str_compare(s1, s2, pos + 1) };

fn main() -> i64 = {
// find_first
    let _r1 = println(find_first("hello world", "world", 0));  // 6
    let _r2 = println(find_first("hello world", "hello", 0));  // 0
    let _r3 = println(find_first("hello world", "xyz", 0));    // -1
    let _r4 = println(find_first("abcabcabc", "abc", 0));      // 0
    let _r5 = println(find_first("abcabcabc", "bca", 0));      // 1

// count_occurrences
    let _r6 = println(count_occurrences("abcabcabc", "abc", 0, 0));  // 3
    let _r7 = println(count_occurrences("aaaaa", "aa", 0, 0));       // 4
    let _r8 = println(count_occurrences("hello", "xyz", 0, 0));      // 0
    let _r9 = println(count_occurrences("banana", "an", 0, 0));      // 2

// lcp_len
    let _r10 = println(lcp_len("hello", "help", 0));    // 3 (hel)
    let _r11 = println(lcp_len("abc", "abc", 0));       // 3 (full)
    let _r12 = println(lcp_len("abc", "xyz", 0));       // 0

// starts_with
    let _r13 = println(starts_with("hello world", "hello"));  // 1
    let _r14 = println(starts_with("hello world", "world"));  // 0

// ends_with
    let _r15 = println(ends_with("hello world", "world"));  // 1
    let _r16 = println(ends_with("hello world", "hello"));  // 0

// count_char
    let _r17 = println(count_char("banana", 97, 0, 0));    // 3 ('a'=97)
    let _r18 = println(count_char("mississippi", 115, 0, 0));  // 4 ('s'=115)

// str_compare
    let _r19 = println(str_compare("abc", "abc", 0));   // 0
    let _r20 = println(str_compare("abc", "abd", 0));   // -1
    let _r21 = println(str_compare("abd", "abc", 0));   // 1

    0
    };

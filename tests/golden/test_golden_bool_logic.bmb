// Golden Test: Complex boolean expressions
// Tests and, or, not, short-circuit evaluation, nested boolean logic

// De Morgan's law: not (a and b) == (not a) or (not b)
fn de_morgan_and(a: bool, b: bool) -> i64 =
    if (not (a and b)) == ((not a) or (not b)) { 1 } else { 0 };

// De Morgan's law: not (a or b) == (not a) and (not b)
fn de_morgan_or(a: bool, b: bool) -> i64 =
    if (not (a or b)) == ((not a) and (not b)) { 1 } else { 0 };

// XOR via boolean ops: (a or b) and not (a and b)
fn bool_xor(a: bool, b: bool) -> i64 =
    if (a or b) and not (a and b) { 1 } else { 0 };

// Implication: a => b is equivalent to (not a) or b
fn bool_implies(a: bool, b: bool) -> i64 =
    if (not a) or b { 1 } else { 0 };

// Three-way majority vote: true if 2 or more are true
fn majority(a: bool, b: bool, c: bool) -> i64 =
    if (a and b) or (b and c) or (a and c) { 1 } else { 0 };

// Nested boolean: at least one pair of adjacent equals in a,b,c,d
fn has_adjacent_equal(a: i64, b: i64, c: i64, d: i64) -> i64 =
    if a == b or b == c or c == d { 1 } else { 0 };

// All different: no two values are equal
fn all_different(a: i64, b: i64, c: i64) -> i64 =
    if a != b and b != c and a != c { 1 } else { 0 };

// Boolean to int conversion pattern
fn bool_count(a: bool, b: bool, c: bool, d: bool) -> i64 = {
    let mut count = 0;
    if a { count = count + 1 } else { () };
    if b { count = count + 1 } else { () };
    if c { count = count + 1 } else { () };
    if d { count = count + 1 } else { () };
    count
    };

// Complex nested condition: classify a number
fn number_class(n: i64) -> i64 = {
    let is_pos = n > 0;
    let is_even = n - (n / 2) * 2 == 0;
    let is_small = n > 0 - 10 and n < 10;
    // Return bitmask: bit 0 = positive, bit 1 = even, bit 2 = small
    let mut result = 0;
    if is_pos { result = result + 1 } else { () };
    if is_even { result = result + 2 } else { () };
    if is_small { result = result + 4 } else { () };
    result
    };

fn main() -> i64 = {
    // De Morgan's and - all 4 combinations should return 1
    let _p1 = println(de_morgan_and(true, true));    // 1
    let _p2 = println(de_morgan_and(true, false));   // 1
    let _p3 = println(de_morgan_and(false, true));   // 1
    let _p4 = println(de_morgan_and(false, false));  // 1

    // De Morgan's or - all 4 combinations should return 1
    let _p5 = println(de_morgan_or(true, true));     // 1
    let _p6 = println(de_morgan_or(true, false));    // 1
    let _p7 = println(de_morgan_or(false, true));    // 1
    let _p8 = println(de_morgan_or(false, false));   // 1

    // XOR
    let _p9 = println(bool_xor(true, true));    // 0
    let _p10 = println(bool_xor(true, false));  // 1
    let _p11 = println(bool_xor(false, true));  // 1
    let _p12 = println(bool_xor(false, false)); // 0

    // Implication
    let _p13 = println(bool_implies(true, true));    // 1
    let _p14 = println(bool_implies(true, false));   // 0
    let _p15 = println(bool_implies(false, true));   // 1
    let _p16 = println(bool_implies(false, false));  // 1

    // Majority
    let _p17 = println(majority(true, true, true));    // 1
    let _p18 = println(majority(true, true, false));   // 1
    let _p19 = println(majority(true, false, false));  // 0
    let _p20 = println(majority(false, false, false)); // 0

    // has_adjacent_equal
    let _p21 = println(has_adjacent_equal(1, 2, 3, 4));  // 0
    let _p22 = println(has_adjacent_equal(1, 1, 3, 4));  // 1
    let _p23 = println(has_adjacent_equal(1, 2, 2, 4));  // 1
    let _p24 = println(has_adjacent_equal(1, 2, 3, 3));  // 1

    // all_different
    let _p25 = println(all_different(1, 2, 3));  // 1
    let _p26 = println(all_different(1, 1, 3));  // 0
    let _p27 = println(all_different(1, 2, 1));  // 0

    // bool_count
    let _p28 = println(bool_count(true, true, true, true));     // 4
    let _p29 = println(bool_count(true, false, true, false));   // 2
    let _p30 = println(bool_count(false, false, false, false)); // 0

    // number_class: positive+even+small = 1+2+4 = 7
    let _p31 = println(number_class(4));     // 7 (positive, even, small)
    let _p32 = println(number_class(3));     // 5 (positive, odd, small)
    let _p33 = println(number_class(20));    // 3 (positive, even, not small)
    let _p34 = println(number_class(0 - 4)); // 6 (negative, even, small)
    let _p35 = println(number_class(0 - 3)); // 4 (negative, odd, small)
    let _p36 = println(number_class(100));   // 3 (positive, even, not small)
    0
    };

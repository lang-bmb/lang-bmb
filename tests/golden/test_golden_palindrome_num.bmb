// Golden Test: Palindrome number checks
// Check if number is palindrome, find next palindrome, etc.

fn reverse_num(n: i64) -> i64 = {
    let mut x = n;
    let mut rev = 0;
    loop {
        if x <= 0 { break } else { () };
        rev = rev * 10 + x % 10;
        x = x / 10
    };
    rev
};

fn is_palindrome(n: i64) -> i64 = {
    if n < 0 { return 0 } else { () };
    if n < 10 { return 1 } else { () };
    if n == reverse_num(n) { 1 } else { 0 }
};

// Count digits
fn num_digits(n: i64) -> i64 = {
    if n == 0 { return 1 } else { () };
    let mut x = n;
    let mut c = 0;
    loop {
        if x <= 0 { break } else { () };
        c = c + 1;
        x = x / 10
    };
    c
};

// Find next palindrome > n
fn next_palindrome(n: i64) -> i64 = {
    let mut candidate = n + 1;
    loop {
        if is_palindrome(candidate) == 1 { break } else { () };
        candidate = candidate + 1
    };
    candidate
};

// Count palindromes in range [lo, hi]
fn count_palindromes(lo: i64, hi: i64) -> i64 = {
    let mut cnt = 0;
    let mut i = lo;
    loop {
        if i > hi { break } else { () };
        if is_palindrome(i) == 1 { cnt = cnt + 1 } else { () };
        i = i + 1
    };
    cnt
};

// Largest palindrome product of two 2-digit numbers (10-99)
fn largest_palindrome_product_2digit() -> i64 = {
    let mut best = 0;
    let mut i = 10;
    loop {
        if i > 99 { break } else { () };
        let mut j = i;
        loop {
            if j > 99 { break } else { () };
            let prod = i * j;
            if prod > best {
                if is_palindrome(prod) == 1 {
                    best = prod
                } else { () }
            } else { () };
            j = j + 1
        };
        i = i + 1
    };
    best
};

fn main() -> i64 = {
    // Test 1-4: is_palindrome
    let _p1 = println(is_palindrome(121));     // 1
    let _p2 = println(is_palindrome(12321));   // 1
    let _p3 = println(is_palindrome(123));     // 0
    let _p4 = println(is_palindrome(1));       // 1

    // Test 5: Single digit
    let _p5 = println(is_palindrome(7));       // 1

    // Test 6-7: next_palindrome
    let _p6 = println(next_palindrome(123));   // 131
    let _p7 = println(next_palindrome(99));    // 101

    // Test 8: next palindrome after 1000
    let _p8 = println(next_palindrome(1000));  // 1001

    // Test 9: Count palindromes from 1 to 100
    // 1-9 (9) + 11,22,33,44,55,66,77,88,99 (9) = 18
    let _p9 = println(count_palindromes(1, 100));  // 18

    // Test 10: Count palindromes from 100 to 200
    // 101, 111, 121, 131, 141, 151, 161, 171, 181, 191 = 10
    let _p10 = println(count_palindromes(100, 200));  // 10

    // Test 11: reverse number
    let _p11 = println(reverse_num(12345));  // 54321

    // Test 12: Largest palindrome product of two 2-digit numbers
    // 91 * 99 = 9009
    let _p12 = println(largest_palindrome_product_2digit());  // 9009

    0
};

// Golden test: Generic functions in real algorithms (binary search, recursive scan)
// v0.97.4: Tests generics with recursion, while loops, array processing
// Expected output: 42 -1 3 30 -1 3 0 7 -1

enum Option<T> {
    Some(T),
    None
}

fn get_or<T>(opt: Option<T>, default: T) -> T =
    match opt {
        Option::Some(v) => v,
        Option::None => default
    };

fn find_first_nonzero(arr: [i64; 8], idx: i64) -> Option<i64> =
    if idx >= 8 { Option::None }
    else if arr[idx] != 0 { Option::Some(arr[idx]) }
    else { find_first_nonzero(arr, idx + 1) };

fn count_positive(vals: [i64; 5]) -> i64 = {
    let mut count = 0;
    let mut i = 0;
    while i < 5 {
        let opt = if vals[i] > 0 { Option::Some(vals[i]) } else { Option::None };
        count = count + (if get_or(opt, 0) > 0 { 1 } else { 0 });
        i = i + 1;
    };
    count
};

fn binary_search(arr: [i64; 8], len: i64, target: i64) -> Option<i64> = {
    let mut lo = 0;
    let mut hi = len - 1;
    let mut result: Option<i64> = Option::None;
    while lo <= hi {
        let mid = (lo + hi) / 2;
        if arr[mid] == target {
            result = Option::Some(mid);
            lo = hi + 1;
        } else if arr[mid] < target {
            lo = mid + 1;
        } else {
            hi = mid - 1;
        };
    };
    result
};

fn main() -> i64 = {
    let arr: [i64; 8] = [0, 0, 0, 42, 0, 0, 0, 0];
    let _u1 = println(get_or(find_first_nonzero(arr, 0), 0 - 1));

    let arr2: [i64; 8] = [0, 0, 0, 0, 0, 0, 0, 0];
    let _u2 = println(get_or(find_first_nonzero(arr2, 0), 0 - 1));

    let vals: [i64; 5] = [3, 0, 7, 0, 1];
    let _u3 = println(count_positive(vals));

    let data: [i64; 8] = [10, 20, 30, 0, 0, 0, 0, 0];
    let _u4 = println(get_or(Option::Some(data[2]), 0 - 1));
    let _u5 = println(get_or(Option::None, 0 - 1));

    let sorted: [i64; 8] = [1, 3, 5, 7, 9, 11, 13, 15];
    let _u6 = println(get_or(binary_search(sorted, 8, 7), 0 - 1));
    let _u7 = println(get_or(binary_search(sorted, 8, 1), 0 - 1));
    let _u8 = println(get_or(binary_search(sorted, 8, 15), 0 - 1));
    let _u9 = println(get_or(binary_search(sorted, 8, 6), 0 - 1));

    0
};

// Golden Test: Complex conditional patterns
// Tests multi-condition branches and compound logic

fn is_leap_year(y: i64) -> i64 =
    if y - (y / 400) * 400 == 0 { 1 }
    else if y - (y / 100) * 100 == 0 { 0 }
    else if y - (y / 4) * 4 == 0 { 1 }
    else { 0 };

fn days_in_month(m: i64, leap: i64) -> i64 =
    if m == 2 { if leap == 1 { 29 } else { 28 } }
    else if m == 4 or m == 6 or m == 9 or m == 11 { 30 }
    else { 31 };

fn fizzbuzz_val(n: i64) -> i64 =
    // Return: 15 if divisible by both 3&5, 3 if by 3, 5 if by 5, else n
    if n - (n / 15) * 15 == 0 { 15 }
    else if n - (n / 3) * 3 == 0 { 3 }
    else if n - (n / 5) * 5 == 0 { 5 }
    else { n };

fn range_check(x: i64, lo: i64, hi: i64) -> i64 =
    if x >= lo and x <= hi { 1 } else { 0 };

fn multi_and(a: i64, b: i64, c: i64) -> i64 =
    if a > 0 and b > 0 and c > 0 { 1 } else { 0 };

fn multi_or(a: i64, b: i64, c: i64) -> i64 =
    if a > 0 or b > 0 or c > 0 { 1 } else { 0 };

fn main() -> i64 = {
    let _p1 = println(is_leap_year(2000));   // 1
    let _p2 = println(is_leap_year(1900));   // 0
    let _p3 = println(is_leap_year(2024));   // 1
    let _p4 = println(is_leap_year(2023));   // 0
    let _p5 = println(days_in_month(2, 1));  // 29
    let _p6 = println(days_in_month(2, 0));  // 28
    let _p7 = println(days_in_month(4, 0));  // 30
    let _p8 = println(days_in_month(1, 0));  // 31
    let _p9 = println(fizzbuzz_val(15));     // 15
    let _p10 = println(fizzbuzz_val(9));     // 3
    let _p11 = println(fizzbuzz_val(10));    // 5
    let _p12 = println(fizzbuzz_val(7));     // 7
    let _p13 = println(range_check(5, 1, 10)); // 1
    let _p14 = println(range_check(15, 1, 10)); // 0
    let _p15 = println(multi_and(1, 2, 3));  // 1
    let _p16 = println(multi_and(1, 0, 3));  // 0
    let _p17 = println(multi_or(0, 0, 0));   // 0
    let _p18 = println(multi_or(0, 1, 0));   // 1
    0
    };

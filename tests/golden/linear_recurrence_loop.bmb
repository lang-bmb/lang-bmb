// Golden test: LinearRecurrenceToLoop optimization
// Double-recursive fibonacci f(n) = f(n-1) + f(n-2) -> iterative O(n) loop

fn fib(n: i64) -> i64 =
    if n <= 1 { n }
    else { fib(n - 1) + fib(n - 2) };

fn main() -> i64 = {
    // fib(0) = 0
    println(fib(0));
    // fib(1) = 1
    println(fib(1));
    // fib(10) = 55
    println(fib(10));
    // fib(20) = 6765
    println(fib(20));
    // fib(30) = 832040
    println(fib(30));
    0
};

// Golden Test: Accumulator patterns
// Tests various accumulation strategies in loops

fn dot_product_sim(n: i64) -> i64 = {
// Simulate dot product of [1,2,...,n] . [n,n-1,...,1]
    let mut sum = 0;
    for i in 0..n {
        sum = sum + (i + 1) * (n - i)
    };
    sum
    };

fn alternating_sum(n: i64) -> i64 = {
// 1 - 2 + 3 - 4 + ... +/- n
    let mut sum = 0;
    for i in 1..n {
        if i - (i / 2) * 2 == 1 { sum = sum + i }
        else { sum = sum - i }
    };

// add the last term (n itself)
    if n - (n / 2) * 2 == 1 { sum + n }
    else { sum - n }
    };

fn running_max(a: i64, b: i64, c: i64, d: i64, e: i64) -> i64 = {
    let mut mx = a;
    if b > mx { mx = b } else { () };
    if c > mx { mx = c } else { () };
    if d > mx { mx = d } else { () };
    if e > mx { mx = e } else { () };
    mx
    };

fn geometric_sum(base: i64, terms: i64) -> i64 = {
// 1 + base + base^2 + ... + base^(terms-1)
    let mut sum = 0;
    let mut power = 1;
    for _i in 0..terms {
        sum = sum + power;
        power = power * base
    };
    sum
    };

fn weighted_sum(n: i64) -> i64 = {
// sum of i * i for i in 1..n+1  (sum of squares)
    let mut sum = 0;
    for i in 1..n {
        sum = sum + i * i
    };
    sum + n * n
    };

fn main() -> i64 = {
    let _p1 = println(dot_product_sim(4));       // 1*4+2*3+3*2+4*1 = 20
    let _p2 = println(dot_product_sim(5));       // 1*5+2*4+3*3+4*2+5*1 = 35
    let _p3 = println(alternating_sum(6));       // 1-2+3-4+5-6 = -3
    let _p4 = println(alternating_sum(7));       // 1-2+3-4+5-6+7 = 4
    let _p5 = println(running_max(3, 7, 2, 9, 1)); // 9
    let _p6 = println(running_max(10, 5, 3, 1, 8)); // 10
    let _p7 = println(geometric_sum(2, 5));      // 1+2+4+8+16 = 31
    let _p8 = println(geometric_sum(3, 4));      // 1+3+9+27 = 40
    let _p9 = println(weighted_sum(4));          // 1+4+9+16 = 30
    let _p10 = println(weighted_sum(5));         // 1+4+9+16+25 = 55
    0
    };

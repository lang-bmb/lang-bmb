// Golden Test: Matrix transpose and properties
// Tests row/col transpose, double transpose identity, determinant of 2x2

// Flat matrix helpers: mat[r*cols + c]
fn mat_new(rows: i64, cols: i64) -> i64 = {
    let v = vec_new();
    for _i in 0..(rows * cols) {
        let _p = vec_push(v, 0);
        0
    };
    v
    };

fn mat_get(m: i64, cols: i64, r: i64, c: i64) -> i64 =
    vec_get(m, r * cols + c);

fn mat_set(m: i64, cols: i64, r: i64, c: i64, val: i64) -> () =
    vec_set(m, r * cols + c, val);

// Transpose: rows x cols -> cols x rows (new matrix)
fn mat_transpose(src: i64, rows: i64, cols: i64) -> i64 = {
    let dst = mat_new(cols, rows);
    for r in 0..rows {
        for c in 0..cols {
            let _s = mat_set(dst, rows, c, r, mat_get(src, cols, r, c));
            0
        };
        0
    };
    dst
    };

// Row sum: sum of elements in row r
fn row_sum(m: i64, cols: i64, r: i64, c: i64, acc: i64) -> i64 =
    if c >= cols { acc }
    else { row_sum(m, cols, r, c + 1, acc + mat_get(m, cols, r, c)) };

// Col sum: sum of elements in column c
fn col_sum(m: i64, cols: i64, rows: i64, c: i64, r: i64, acc: i64) -> i64 =
    if r >= rows { acc }
    else { col_sum(m, cols, rows, c, r + 1, acc + mat_get(m, cols, r, c)) };

// Check if two matrices are equal
fn mat_equal(a: i64, b: i64, n: i64, pos: i64) -> i64 =
    if pos >= n { 1 }
    else if vec_get(a, pos) != vec_get(b, pos) { 0 }
    else { mat_equal(a, b, n, pos + 1) };

// 2x2 determinant: ad - bc for [[a,b],[c,d]]
fn det2x2(m: i64) -> i64 =
    mat_get(m, 2, 0, 0) * mat_get(m, 2, 1, 1) - mat_get(m, 2, 0, 1) * mat_get(m, 2, 1, 0);

fn main() -> i64 = {
    // Build a 2x3 matrix:
    // [1 2 3]
    // [4 5 6]
    let m = mat_new(2, 3);
    let _s = mat_set(m, 3, 0, 0, 1);
    let _s = mat_set(m, 3, 0, 1, 2);
    let _s = mat_set(m, 3, 0, 2, 3);
    let _s = mat_set(m, 3, 1, 0, 4);
    let _s = mat_set(m, 3, 1, 1, 5);
    let _s = mat_set(m, 3, 1, 2, 6);

    // Test 1: Row 0 sum = 1+2+3 = 6
    let _p1 = println(row_sum(m, 3, 0, 0, 0));

    // Test 2: Row 1 sum = 4+5+6 = 15
    let _p2 = println(row_sum(m, 3, 1, 0, 0));

    // Transpose to 3x2:
    // [1 4]
    // [2 5]
    // [3 6]
    let t = mat_transpose(m, 2, 3);

    // Test 3: t[0][0] = 1
    let _p3 = println(mat_get(t, 2, 0, 0));

    // Test 4: t[0][1] = 4
    let _p4 = println(mat_get(t, 2, 0, 1));

    // Test 5: t[2][0] = 3
    let _p5 = println(mat_get(t, 2, 2, 0));

    // Test 6: t[2][1] = 6
    let _p6 = println(mat_get(t, 2, 2, 1));

    // Test 7: Double transpose of m should equal m
    let tt = mat_transpose(t, 3, 2);
    let _p7 = println(mat_equal(m, tt, 6, 0));

    // Test 8: Col sum of original col 1 = 2+5 = 7
    let _p8 = println(col_sum(m, 3, 2, 1, 0, 0));

    // 2x2 determinant test
    // [[3 8] [4 6]] -> det = 3*6 - 8*4 = 18 - 32 = -14
    let d = mat_new(2, 2);
    let _s = mat_set(d, 2, 0, 0, 3);
    let _s = mat_set(d, 2, 0, 1, 8);
    let _s = mat_set(d, 2, 1, 0, 4);
    let _s = mat_set(d, 2, 1, 1, 6);

    // Test 9: det = -14
    let _p9 = println(det2x2(d));

    // Test 10: det of transpose should equal det of original
    let dt = mat_transpose(d, 2, 2);
    let _p10 = println(det2x2(dt));

    let _f1 = vec_free(m);
    let _f2 = vec_free(t);
    let _f3 = vec_free(tt);
    let _f4 = vec_free(d);
    let _f5 = vec_free(dt);
    0
    };

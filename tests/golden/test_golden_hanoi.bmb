// Golden Test: Tower of Hanoi
// Recursive solution that prints moves
// Also counts total moves (should be 2^n - 1)

fn hanoi(n: i64, from: i64, to: i64, aux: i64, count: i64) -> () = {
    let _x = if n > 0 {
        hanoi(n - 1, from, aux, to, count);
        // Print move
        print(from); print_str("->"); let _r = println(to);
        vec_set(count, 0, vec_get(count, 0) + 1);
        hanoi(n - 1, aux, to, from, count);
        0
    } else { 0 }
};

fn main() -> () = {
    // Test 1: n=3 (7 moves)
    let count1 = vec_new();
    let _p = vec_push(count1, 0);
    print_str("n=3:
");
    hanoi(3, 1, 3, 2, count1);
    print_str("moves="); let _r = println(vec_get(count1, 0));

    // Test 2: n=4 (15 moves, just count)
    let count2 = vec_new();
    let _p = vec_push(count2, 0);
    hanoi(4, 1, 3, 2, count2);
    print_str("n=4 moves="); let _r = println(vec_get(count2, 0));

    // Test 3: n=1 (1 move)
    let count3 = vec_new();
    let _p = vec_push(count3, 0);
    print_str("n=1:
");
    hanoi(1, 1, 3, 2, count3);
    print_str("moves="); let _r = println(vec_get(count3, 0))
};

// Golden Test: Merge two sorted arrays
// Various merge operations on sorted sequences

// Merge two sorted vecs into a new sorted vec
fn merge_two(a: i64, b: i64) -> i64 = {
    let na = vec_len(a);
    let nb = vec_len(b);
    let result = vec_new();
    let mut ia = 0;
    let mut ib = 0;
    loop {
        if ia >= na {
            if ib >= nb { break } else { () }
        } else { () };
        if ia >= na {
            vec_push(result, vec_get(b, ib));
            ib = ib + 1
        } else if ib >= nb {
            vec_push(result, vec_get(a, ia));
            ia = ia + 1
        } else if vec_get(a, ia) <= vec_get(b, ib) {
            vec_push(result, vec_get(a, ia));
            ia = ia + 1
        } else {
            vec_push(result, vec_get(b, ib));
            ib = ib + 1
        }
    };
    result
};

// Intersect two sorted vecs (common elements)
fn intersect_sorted(a: i64, b: i64) -> i64 = {
    let na = vec_len(a);
    let nb = vec_len(b);
    let result = vec_new();
    let mut ia = 0;
    let mut ib = 0;
    loop {
        if ia >= na { break } else { () };
        if ib >= nb { break } else { () };
        let va = vec_get(a, ia);
        let vb = vec_get(b, ib);
        if va == vb {
            vec_push(result, va);
            ia = ia + 1;
            ib = ib + 1
        } else if va < vb {
            ia = ia + 1
        } else {
            ib = ib + 1
        }
    };
    result
};

// Difference: elements in a but not in b (both sorted)
fn diff_sorted(a: i64, b: i64) -> i64 = {
    let na = vec_len(a);
    let nb = vec_len(b);
    let result = vec_new();
    let mut ia = 0;
    let mut ib = 0;
    loop {
        if ia >= na { break } else { () };
        let va = vec_get(a, ia);
        if ib >= nb {
            vec_push(result, va);
            ia = ia + 1
        } else {
            let vb = vec_get(b, ib);
            if va < vb {
                vec_push(result, va);
                ia = ia + 1
            } else if va == vb {
                ia = ia + 1;
                ib = ib + 1
            } else {
                ib = ib + 1
            }
        }
    };
    result
};

fn main() -> i64 = {
    // Merge [1,3,5,7] and [2,4,6,8]
    let a1 = vec_new();
    vec_push(a1, 1); vec_push(a1, 3); vec_push(a1, 5); vec_push(a1, 7);
    let b1 = vec_new();
    vec_push(b1, 2); vec_push(b1, 4); vec_push(b1, 6); vec_push(b1, 8);
    let m1 = merge_two(a1, b1);
    let _p1 = println(vec_len(m1));      // 8
    let _p2 = println(vec_get(m1, 0));   // 1
    let _p3 = println(vec_get(m1, 7));   // 8

    // Merge [1,2,3] and [] (empty)
    let a2 = vec_new();
    vec_push(a2, 1); vec_push(a2, 2); vec_push(a2, 3);
    let b2 = vec_new();
    let m2 = merge_two(a2, b2);
    let _p4 = println(vec_len(m2));      // 3
    let _p5 = println(vec_get(m2, 2));   // 3

    // Intersect [1,2,3,4,5] and [2,4,6]
    let a3 = vec_new();
    vec_push(a3, 1); vec_push(a3, 2); vec_push(a3, 3); vec_push(a3, 4); vec_push(a3, 5);
    let b3 = vec_new();
    vec_push(b3, 2); vec_push(b3, 4); vec_push(b3, 6);
    let i1 = intersect_sorted(a3, b3);
    let _p6 = println(vec_len(i1));      // 2
    let _p7 = println(vec_get(i1, 0));   // 2
    let _p8 = println(vec_get(i1, 1));   // 4

    // Diff [1,2,3,4,5] - [2,4] = [1,3,5]
    let b4 = vec_new();
    vec_push(b4, 2); vec_push(b4, 4);
    let d1 = diff_sorted(a3, b4);
    let _p9 = println(vec_len(d1));      // 3
    let _p10 = println(vec_get(d1, 0));  // 1
    let _p11 = println(vec_get(d1, 1));  // 3
    let _p12 = println(vec_get(d1, 2));  // 5

    vec_free(a1); vec_free(b1); vec_free(m1);
    vec_free(a2); vec_free(b2); vec_free(m2);
    vec_free(a3); vec_free(b3); vec_free(i1);
    vec_free(b4); vec_free(d1);
    0
};

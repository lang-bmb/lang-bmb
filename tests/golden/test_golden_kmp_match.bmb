// Golden Test: KMP (Knuth-Morris-Pratt) string matching
// Computes failure function and uses it for efficient pattern matching
// Works on integer arrays (character codes)

fn make_zeros(n: i64) -> i64 = {
    let v = vec_new();
    for _i in 0..n { let _p = vec_push(v, 0); 0 };
    v
};

// Compute KMP failure function (partial match table)
// fail[i] = length of longest proper prefix of pattern[0..i] that is also a suffix
fn compute_failure(pat: i64) -> i64 = {
    let m = vec_len(pat);
    let fail = make_zeros(m);
    // fail[0] = 0 by definition
    let mut k = 0;
    let mut i = 1;
    while i < m {
        // Try to extend the match
        let mut cont = 1;
        while cont == 1 {
            let _c = if k > 0 {
                let _c2 = if vec_get(pat, k) != vec_get(pat, i) {
                    set k = vec_get(fail, k - 1);
                    ()
                } else {
                    set cont = 0;
                    ()
                };
                ()
            } else {
                set cont = 0;
                ()
            }
        };
        let _c3 = if vec_get(pat, k) == vec_get(pat, i) {
            set k = k + 1;
            ()
        } else { () };
        let _s = vec_set(fail, i, k);
        set i = i + 1
    };
    fail
};

// KMP search: find all occurrences of pattern in text
// Returns vec of starting positions
fn kmp_search(text: i64, pat: i64) -> i64 = {
    let n = vec_len(text);
    let m = vec_len(pat);
    let fail = compute_failure(pat);
    let results = vec_new();
    let mut j = 0;
    let mut i = 0;
    while i < n {
        // Try to match
        let mut cont = 1;
        while cont == 1 {
            let _c = if j > 0 {
                let _c2 = if vec_get(pat, j) != vec_get(text, i) {
                    set j = vec_get(fail, j - 1);
                    ()
                } else {
                    set cont = 0;
                    ()
                };
                ()
            } else {
                set cont = 0;
                ()
            }
        };
        let _c3 = if vec_get(pat, j) == vec_get(text, i) {
            set j = j + 1;
            ()
        } else { () };
        let _c4 = if j == m {
            // Found a match at position i - m + 1
            let _p = vec_push(results, i - m + 1);
            set j = vec_get(fail, j - 1);
            ()
        } else { () };
        set i = i + 1
    };
    let _f = vec_free(fail);
    results
};

fn print_vec(v: i64) -> i64 = {
    let n = vec_len(v);
    for i in 0..n {
        let _p = println(vec_get(v, i));
        0
    };
    0
};

fn main() -> i64 = {
    // === Test 1: Failure function for "ABABAC" (as integers: 1,2,1,2,1,3) ===
    let _p = println_str("=== Test 1: failure function ===");
    let pat1 = vec_new();
    let _p = vec_push(pat1, 1); let _p = vec_push(pat1, 2);
    let _p = vec_push(pat1, 1); let _p = vec_push(pat1, 2);
    let _p = vec_push(pat1, 1); let _p = vec_push(pat1, 3);
    let f1 = compute_failure(pat1);
    // Expected: [0, 0, 1, 2, 3, 0]
    let _pv = print_vec(f1);

    // === Test 2: Failure function for "AAAA" (1,1,1,1) ===
    let _p = println_str("=== Test 2: all same ===");
    let pat2 = vec_new();
    let _p = vec_push(pat2, 1); let _p = vec_push(pat2, 1);
    let _p = vec_push(pat2, 1); let _p = vec_push(pat2, 1);
    let f2 = compute_failure(pat2);
    // Expected: [0, 1, 2, 3]
    let _pv = print_vec(f2);

    // === Test 3: Failure function for "ABCABD" (1,2,3,1,2,4) ===
    let _p = println_str("=== Test 3: partial match ===");
    let pat3 = vec_new();
    let _p = vec_push(pat3, 1); let _p = vec_push(pat3, 2);
    let _p = vec_push(pat3, 3); let _p = vec_push(pat3, 1);
    let _p = vec_push(pat3, 2); let _p = vec_push(pat3, 4);
    let f3 = compute_failure(pat3);
    // Expected: [0, 0, 0, 1, 2, 0]
    let _pv = print_vec(f3);

    // === Test 4: KMP search - find [1,2] in [3,1,2,4,1,2,1,2] ===
    let _p = println_str("=== Test 4: search [1,2] ===");
    let txt1 = vec_new();
    let _p = vec_push(txt1, 3); let _p = vec_push(txt1, 1);
    let _p = vec_push(txt1, 2); let _p = vec_push(txt1, 4);
    let _p = vec_push(txt1, 1); let _p = vec_push(txt1, 2);
    let _p = vec_push(txt1, 1); let _p = vec_push(txt1, 2);
    let sp = vec_new();
    let _p = vec_push(sp, 1); let _p = vec_push(sp, 2);
    let r1 = kmp_search(txt1, sp);
    let _p = print_str("count: ");
    let _p = println(vec_len(r1));
    let _p = println_str("positions:");
    let _pv = print_vec(r1);

    // === Test 5: Overlapping pattern [1,1] in [1,1,1,1] ===
    let _p = println_str("=== Test 5: overlapping ===");
    let txt2 = vec_new();
    let _p = vec_push(txt2, 1); let _p = vec_push(txt2, 1);
    let _p = vec_push(txt2, 1); let _p = vec_push(txt2, 1);
    let sp2 = vec_new();
    let _p = vec_push(sp2, 1); let _p = vec_push(sp2, 1);
    let r2 = kmp_search(txt2, sp2);
    let _p = print_str("count: ");
    let _p = println(vec_len(r2));
    let _p = println_str("positions:");
    let _pv = print_vec(r2);

    // === Test 6: No match ===
    let _p = println_str("=== Test 6: no match ===");
    let txt3 = vec_new();
    let _p = vec_push(txt3, 1); let _p = vec_push(txt3, 2);
    let _p = vec_push(txt3, 3);
    let sp3 = vec_new();
    let _p = vec_push(sp3, 5); let _p = vec_push(sp3, 6);
    let r3 = kmp_search(txt3, sp3);
    let _p = print_str("count: ");
    let _p = println(vec_len(r3));

    // === Test 7: Pattern longer than text ===
    let _p = println_str("=== Test 7: pattern longer ===");
    let txt4 = vec_new();
    let _p = vec_push(txt4, 1);
    let sp4 = vec_new();
    let _p = vec_push(sp4, 1); let _p = vec_push(sp4, 2);
    let _p = vec_push(sp4, 3);
    let r4 = kmp_search(txt4, sp4);
    let _p = print_str("count: ");
    let _p = println(vec_len(r4));

    // Cleanup
    let _f = vec_free(pat1); let _f = vec_free(f1);
    let _f = vec_free(pat2); let _f = vec_free(f2);
    let _f = vec_free(pat3); let _f = vec_free(f3);
    let _f = vec_free(txt1); let _f = vec_free(sp); let _f = vec_free(r1);
    let _f = vec_free(txt2); let _f = vec_free(sp2); let _f = vec_free(r2);
    let _f = vec_free(txt3); let _f = vec_free(sp3); let _f = vec_free(r3);
    let _f = vec_free(txt4); let _f = vec_free(sp4); let _f = vec_free(r4);
    0
};

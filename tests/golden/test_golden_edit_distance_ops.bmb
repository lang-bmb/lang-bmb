// Golden Test: Edit distance with operation breakdown (insert/delete/substitute counts)
// Uses Wagner-Fischer DP + backtracking to count each operation type
// dp[i][j] = min edit distance between seq1[0..i-1] and seq2[0..j-1]
// ops[i][j] encodes which operation led to optimal: 0=match, 1=substitute, 2=insert, 3=delete

fn make_zeros(n: i64) -> i64 = {
    let v = vec_new();
    for _i in 0..n { let _p = vec_push(v, 0); 0 };
    v
};

fn min2(a: i64, b: i64) -> i64 = if a < b { a } else { b };
fn min3(a: i64, b: i64, c: i64) -> i64 = min2(a, min2(b, c));

// Compute edit distance and operation counts
// Returns a vec of 4 values: [distance, inserts, deletes, substitutes]
fn edit_dist_ops(s1: i64, s2: i64) -> i64 = {
    let n = vec_len(s1);
    let m = vec_len(s2);
    let cols = m + 1;
    let rows = n + 1;
    let dp = make_zeros(rows * cols);
    let ops = make_zeros(rows * cols);  // 0=match, 1=sub, 2=ins, 3=del

    // Initialize first row: all insertions
    for j in 0..cols {
        let _s = vec_set(dp, j, j);
        let _c = if j > 0 {
            let _s2 = vec_set(ops, j, 2);  // insert
            ()
        } else { () }
    };
    // Initialize first column: all deletions
    for i in 0..rows {
        let _s = vec_set(dp, i * cols, i);
        let _c = if i > 0 {
            let _s2 = vec_set(ops, i * cols, 3);  // delete
            ()
        } else { () }
    };

    // Fill DP table
    for i in 1..rows {
        for j in 1..cols {
            let cost = if vec_get(s1, i - 1) == vec_get(s2, j - 1) { 0 } else { 1 };
            let sub_cost = vec_get(dp, (i - 1) * cols + (j - 1)) + cost;
            let ins_cost = vec_get(dp, i * cols + (j - 1)) + 1;
            let del_cost = vec_get(dp, (i - 1) * cols + j) + 1;
            let best = min3(sub_cost, ins_cost, del_cost);
            let _s = vec_set(dp, i * cols + j, best);
            // Record which operation was used (prefer match/sub > ins > del)
            let op = if best == sub_cost {
                if cost == 0 { 0 } else { 1 }  // match or substitute
            } else if best == ins_cost { 2 }
            else { 3 };
            let _s2 = vec_set(ops, i * cols + j, op);
            0
        };
        0
    };

    // Backtrack to count operations
    let mut ins_count = 0;
    let mut del_count = 0;
    let mut sub_count = 0;
    let mut ci = n;
    let mut cj = m;
    let mut cont = 1;
    while cont == 1 {
        let _c = if ci == 0 {
            let _c2 = if cj == 0 {
                set cont = 0;
                ()
            } else {
                // remaining are insertions
                set ins_count = ins_count + cj;
                set cj = 0;
                set cont = 0;
                ()
            };
            ()
        } else if cj == 0 {
            // remaining are deletions
            set del_count = del_count + ci;
            set ci = 0;
            set cont = 0;
            ()
        } else {
            let op = vec_get(ops, ci * cols + cj);
            let _c3 = if op == 0 {
                // match: move diag, no cost
                set ci = ci - 1;
                set cj = cj - 1;
                ()
            } else if op == 1 {
                // substitute
                set sub_count = sub_count + 1;
                set ci = ci - 1;
                set cj = cj - 1;
                ()
            } else if op == 2 {
                // insert
                set ins_count = ins_count + 1;
                set cj = cj - 1;
                ()
            } else {
                // delete
                set del_count = del_count + 1;
                set ci = ci - 1;
                ()
            };
            ()
        }
    };

    let dist = vec_get(dp, n * cols + m);
    let _f1 = vec_free(dp);
    let _f2 = vec_free(ops);

    let result = vec_new();
    let _p = vec_push(result, dist);
    let _p = vec_push(result, ins_count);
    let _p = vec_push(result, del_count);
    let _p = vec_push(result, sub_count);
    result
};

fn print_result(r: i64) -> i64 = {
    let _p = print_str("distance: ");
    let _p = println(vec_get(r, 0));
    let _p = print_str("inserts: ");
    let _p = println(vec_get(r, 1));
    let _p = print_str("deletes: ");
    let _p = println(vec_get(r, 2));
    let _p = print_str("substitutes: ");
    let _p = println(vec_get(r, 3));
    0
};

fn main() -> i64 = {
    // === Test 1: [1,2,3] vs [1,3,3] ===
    // Change 2->3: 1 substitution
    let _p = println_str("=== Test 1: [1,2,3] vs [1,3,3] ===");
    let a1 = vec_new();
    let _p = vec_push(a1, 1); let _p = vec_push(a1, 2); let _p = vec_push(a1, 3);
    let b1 = vec_new();
    let _p = vec_push(b1, 1); let _p = vec_push(b1, 3); let _p = vec_push(b1, 3);
    let r1 = edit_dist_ops(a1, b1);
    let _pr = print_result(r1);

    // === Test 2: [1,2,3,4] vs [1,2,4] ===
    // Delete 3: 1 deletion
    let _p = println_str("=== Test 2: [1,2,3,4] vs [1,2,4] ===");
    let a2 = vec_new();
    let _p = vec_push(a2, 1); let _p = vec_push(a2, 2);
    let _p = vec_push(a2, 3); let _p = vec_push(a2, 4);
    let b2 = vec_new();
    let _p = vec_push(b2, 1); let _p = vec_push(b2, 2); let _p = vec_push(b2, 4);
    let r2 = edit_dist_ops(a2, b2);
    let _pr = print_result(r2);

    // === Test 3: [] vs [1,2,3] ===
    // 3 insertions
    let _p = println_str("=== Test 3: [] vs [1,2,3] ===");
    let a3 = vec_new();
    let b3 = vec_new();
    let _p = vec_push(b3, 1); let _p = vec_push(b3, 2); let _p = vec_push(b3, 3);
    let r3 = edit_dist_ops(a3, b3);
    let _pr = print_result(r3);

    // === Test 4: [1,2,3] vs [] ===
    // 3 deletions
    let _p = println_str("=== Test 4: [1,2,3] vs [] ===");
    let a4 = vec_new();
    let _p = vec_push(a4, 1); let _p = vec_push(a4, 2); let _p = vec_push(a4, 3);
    let b4 = vec_new();
    let r4 = edit_dist_ops(a4, b4);
    let _pr = print_result(r4);

    // === Test 5: [1,2,3] vs [1,2,3] (identical) ===
    let _p = println_str("=== Test 5: identical ===");
    let a5 = vec_new();
    let _p = vec_push(a5, 1); let _p = vec_push(a5, 2); let _p = vec_push(a5, 3);
    let b5 = vec_new();
    let _p = vec_push(b5, 1); let _p = vec_push(b5, 2); let _p = vec_push(b5, 3);
    let r5 = edit_dist_ops(a5, b5);
    let _pr = print_result(r5);

    // === Test 6: [1,2,3,4,5] vs [2,3,4,5,6] ===
    // sub 1->2, del/ins pattern: depends on DP choice
    // Optimal: substitute first element 1->2, shift: actually sub 1->2 at start and insert 6 at end and delete...
    // Or: delete 1, then 2345 match, insert 6 = distance 2 (1 del + 1 ins)
    // Or: sub 1->2, sub 2->3, sub 3->4, sub 4->5, sub 5->6 = 5 subs (distance 5) - worse
    // Best: distance 2 (delete 1, insert 6)
    let _p = println_str("=== Test 6: shift by one ===");
    let a6 = vec_new();
    let _p = vec_push(a6, 1); let _p = vec_push(a6, 2);
    let _p = vec_push(a6, 3); let _p = vec_push(a6, 4);
    let _p = vec_push(a6, 5);
    let b6 = vec_new();
    let _p = vec_push(b6, 2); let _p = vec_push(b6, 3);
    let _p = vec_push(b6, 4); let _p = vec_push(b6, 5);
    let _p = vec_push(b6, 6);
    let r6 = edit_dist_ops(a6, b6);
    let _pr = print_result(r6);

    // === Test 7: [5,4,3,2,1] vs [1,2,3,4,5] (reverse) ===
    let _p = println_str("=== Test 7: reverse ===");
    let a7 = vec_new();
    let _p = vec_push(a7, 5); let _p = vec_push(a7, 4);
    let _p = vec_push(a7, 3); let _p = vec_push(a7, 2);
    let _p = vec_push(a7, 1);
    let b7 = vec_new();
    let _p = vec_push(b7, 1); let _p = vec_push(b7, 2);
    let _p = vec_push(b7, 3); let _p = vec_push(b7, 4);
    let _p = vec_push(b7, 5);
    let r7 = edit_dist_ops(a7, b7);
    let _pr = print_result(r7);

    // Cleanup
    let _f = vec_free(a1); let _f = vec_free(b1); let _f = vec_free(r1);
    let _f = vec_free(a2); let _f = vec_free(b2); let _f = vec_free(r2);
    let _f = vec_free(a3); let _f = vec_free(b3); let _f = vec_free(r3);
    let _f = vec_free(a4); let _f = vec_free(b4); let _f = vec_free(r4);
    let _f = vec_free(a5); let _f = vec_free(b5); let _f = vec_free(r5);
    let _f = vec_free(a6); let _f = vec_free(b6); let _f = vec_free(r6);
    let _f = vec_free(a7); let _f = vec_free(b7); let _f = vec_free(r7);
    0
};

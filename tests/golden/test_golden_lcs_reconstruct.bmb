// Golden Test: Longest common subsequence with DP table reconstruction
// Uses integer sequences (stored as vecs) instead of strings
// dp[i*(m+1)+j] = length of LCS of seq1[0..i] and seq2[0..j]

fn lcs_length(seq1: i64, seq2: i64) -> i64 = {
    let n = vec_len(seq1);
    let m = vec_len(seq2);
    let sz = (n + 1) * (m + 1);
    let dp = vec_new();
    for _k in 0..sz { vec_push(dp, 0) };

    // Fill DP table
    for i in 1..(n + 1) {
        for j in 1..(m + 1) {
            let v1 = vec_get(seq1, i - 1);
            let v2 = vec_get(seq2, j - 1);
            let val = if v1 == v2 {
                vec_get(dp, (i - 1) * (m + 1) + (j - 1)) + 1
            } else {
                let up = vec_get(dp, (i - 1) * (m + 1) + j);
                let left = vec_get(dp, i * (m + 1) + (j - 1));
                if up > left { up } else { left }
            };
            vec_set(dp, i * (m + 1) + j, val)
        }
    };

    let result = vec_get(dp, n * (m + 1) + m);
    vec_free(dp);
    result
    };

// Reconstruct the LCS itself and return as a vec
fn lcs_reconstruct(seq1: i64, seq2: i64) -> i64 = {
    let n = vec_len(seq1);
    let m = vec_len(seq2);
    let sz = (n + 1) * (m + 1);
    let dp = vec_new();
    for _k in 0..sz { vec_push(dp, 0) };

    // Fill DP table
    for i in 1..(n + 1) {
        for j in 1..(m + 1) {
            let v1 = vec_get(seq1, i - 1);
            let v2 = vec_get(seq2, j - 1);
            let val = if v1 == v2 {
                vec_get(dp, (i - 1) * (m + 1) + (j - 1)) + 1
            } else {
                let up = vec_get(dp, (i - 1) * (m + 1) + j);
                let left = vec_get(dp, i * (m + 1) + (j - 1));
                if up > left { up } else { left }
            };
            vec_set(dp, i * (m + 1) + j, val)
        }
    };

    // Backtrack to reconstruct
    let lcs = vec_new();
    let mut i = n;
    let mut j = m;
    loop {
        if i == 0 { break } else { 0 };
        if j == 0 { break } else { 0 };
        let v1 = vec_get(seq1, i - 1);
        let v2 = vec_get(seq2, j - 1);
        if v1 == v2 {
            vec_push(lcs, v1);
            set i = i - 1;
            set j = j - 1
        } else {
            let up = vec_get(dp, (i - 1) * (m + 1) + j);
            let left = vec_get(dp, i * (m + 1) + (j - 1));
            if up > left {
                set i = i - 1
            } else {
                set j = j - 1
            }
        }
    };

    vec_free(dp);

    // Reverse the LCS (it was built backwards)
    let lcs_len = vec_len(lcs);
    let reversed = vec_new();
    let mut k = lcs_len - 1;
    loop {
        if k < 0 { break } else { 0 };
        vec_push(reversed, vec_get(lcs, k));
        set k = k - 1
    };
    vec_free(lcs);
    reversed
    };

// Print all elements of a vec
fn print_vec(v: i64) -> i64 = {
    let n = vec_len(v);
    for i in 0..n {
        println(vec_get(v, i))
    };
    0
    };

fn main() -> i64 = {
    // Test 1: Basic LCS
    // seq1 = [1, 3, 4, 1, 2, 3]
    // seq2 = [3, 1, 4, 2, 3]
    // LCS length = 4
    let s1 = vec_new();
    vec_push(s1, 1); vec_push(s1, 3); vec_push(s1, 4);
    vec_push(s1, 1); vec_push(s1, 2); vec_push(s1, 3);

    let s2 = vec_new();
    vec_push(s2, 3); vec_push(s2, 1); vec_push(s2, 4);
    vec_push(s2, 2); vec_push(s2, 3);

    println(lcs_length(s1, s2));  // 4

    let lcs1 = lcs_reconstruct(s1, s2);
    println(vec_len(lcs1));  // 4
    print_vec(lcs1);  // the reconstructed LCS elements

    vec_free(s1); vec_free(s2); vec_free(lcs1);

    // Test 2: Identical sequences
    // seq1 = seq2 = [5, 10, 15]
    let s3 = vec_new();
    vec_push(s3, 5); vec_push(s3, 10); vec_push(s3, 15);
    let s4 = vec_new();
    vec_push(s4, 5); vec_push(s4, 10); vec_push(s4, 15);

    println(lcs_length(s3, s4));  // 3

    let lcs2 = lcs_reconstruct(s3, s4);
    print_vec(lcs2);  // 5 10 15

    vec_free(s3); vec_free(s4); vec_free(lcs2);

    // Test 3: No common elements
    // seq1 = [1, 2, 3], seq2 = [4, 5, 6]
    let s5 = vec_new();
    vec_push(s5, 1); vec_push(s5, 2); vec_push(s5, 3);
    let s6 = vec_new();
    vec_push(s6, 4); vec_push(s6, 5); vec_push(s6, 6);

    println(lcs_length(s5, s6));  // 0

    let lcs3 = lcs_reconstruct(s5, s6);
    println(vec_len(lcs3));  // 0

    vec_free(s5); vec_free(s6); vec_free(lcs3);

    // Test 4: One element in common
    // seq1 = [1, 2, 3], seq2 = [4, 2, 5]
    let s7 = vec_new();
    vec_push(s7, 1); vec_push(s7, 2); vec_push(s7, 3);
    let s8 = vec_new();
    vec_push(s8, 4); vec_push(s8, 2); vec_push(s8, 5);

    println(lcs_length(s7, s8));  // 1

    let lcs4 = lcs_reconstruct(s7, s8);
    println(vec_len(lcs4));  // 1
    print_vec(lcs4);  // 2

    vec_free(s7); vec_free(s8); vec_free(lcs4);

    // Test 5: Classic binary example
    // seq1 = [1, 0, 0, 1, 0, 1, 0, 1]
    // seq2 = [0, 1, 0, 1, 1, 0, 1, 1, 0]
    // LCS length = 6
    let s9 = vec_new();
    vec_push(s9, 1); vec_push(s9, 0); vec_push(s9, 0); vec_push(s9, 1);
    vec_push(s9, 0); vec_push(s9, 1); vec_push(s9, 0); vec_push(s9, 1);

    let s10 = vec_new();
    vec_push(s10, 0); vec_push(s10, 1); vec_push(s10, 0); vec_push(s10, 1);
    vec_push(s10, 1); vec_push(s10, 0); vec_push(s10, 1); vec_push(s10, 1);
    vec_push(s10, 0);

    println(lcs_length(s9, s10));  // 6

    vec_free(s9); vec_free(s10);

    // Test 6: Empty sequence
    let s11 = vec_new();
    let s12 = vec_new();
    vec_push(s12, 1); vec_push(s12, 2);

    println(lcs_length(s11, s12));  // 0
    println(lcs_length(s12, s11));  // 0

    vec_free(s11); vec_free(s12);

    // Test 7: Subsequence at the end
    // seq1 = [7, 8, 9], seq2 = [1, 2, 7, 8, 9]
    let s13 = vec_new();
    vec_push(s13, 7); vec_push(s13, 8); vec_push(s13, 9);
    let s14 = vec_new();
    vec_push(s14, 1); vec_push(s14, 2); vec_push(s14, 7);
    vec_push(s14, 8); vec_push(s14, 9);

    println(lcs_length(s13, s14));  // 3

    let lcs7 = lcs_reconstruct(s13, s14);
    print_vec(lcs7);  // 7 8 9

    vec_free(s13); vec_free(s14); vec_free(lcs7);

    0
    };

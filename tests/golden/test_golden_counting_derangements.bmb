// Golden Test: Counting Derangements (Subfactorial)
// D(n) = number of permutations with no fixed points
// D(n) = (n-1) * (D(n-1) + D(n-2))
// Also: D(n) = n! * sum_{k=0}^{n} (-1)^k / k!

// Factorial
fn factorial(n: i64) -> i64 =
    if n <= 1 { 1 }
    else { n * factorial(n - 1) };

// Derangement count using recurrence D(n) = (n-1)*(D(n-1) + D(n-2))
// D(0) = 1, D(1) = 0
fn derangement(n: i64) -> i64 = {
    if n == 0 { return 1 } else { () };
    if n == 1 { return 0 } else { () };
    let mut d_prev2 = 1;  // D(0)
    let mut d_prev1 = 0;  // D(1)
    let mut i = 2;
    loop {
        if i > n { break } else { () };
        let d = (i - 1) * (d_prev1 + d_prev2);
        d_prev2 = d_prev1;
        d_prev1 = d;
        i = i + 1
    };
    d_prev1
};

// Verify using inclusion-exclusion: D(n) = sum_{k=0}^{n} (-1)^k * C(n,k) * (n-k)!
fn derangement_ie(n: i64) -> i64 = {
    let mut sum = 0;
    let mut k = 0;
    loop {
        if k > n { break } else { () };
        let sign = if k - 2 * (k / 2) == 0 { 1 } else { 0 - 1 };
        let binom = binomial(n, k);
        let fact = factorial(n - k);
        sum = sum + sign * binom * fact;
        k = k + 1
    };
    sum
};

// Binomial coefficient C(n, k)
fn binomial(n: i64, k: i64) -> i64 = {
    if k > n { return 0 } else { () };
    if k == 0 or k == n { return 1 } else { () };
    // Use iterative multiplication to avoid overflow
    let mut result = 1;
    let kk = if k > n - k { n - k } else { k };
    let mut i = 0;
    loop {
        if i >= kk { break } else { () };
        result = result * (n - i) / (i + 1);
        i = i + 1
    };
    result
};

// Probability that no one gets their own hat (scaled by 10000)
// P = D(n) / n! * 10000
fn derangement_prob(n: i64) -> i64 = {
    let d = derangement(n);
    let f = factorial(n);
    d * 10000 / f
};

// Number of permutations with exactly k fixed points
// = C(n,k) * D(n-k)
fn fixed_point_count(n: i64, k: i64) -> i64 = {
    let binom = binomial(n, k);
    let d = derangement(n - k);
    binom * d
};

// Check: sum of fixed_point_count(n, k) for k=0..n should equal n!
fn verify_sum(n: i64) -> i64 = {
    let mut sum = 0;
    let mut k = 0;
    loop {
        if k > n { break } else { () };
        sum = sum + fixed_point_count(n, k);
        k = k + 1
    };
    sum
};

fn main() -> i64 = {
    // Derangements: D(0)=1, D(1)=0, D(2)=1, D(3)=2, D(4)=9, D(5)=44, D(6)=265, D(7)=1854
    let _p1 = println(derangement(0));    // 1
    let _p2 = println(derangement(1));    // 0
    let _p3 = println(derangement(2));    // 1
    let _p4 = println(derangement(3));    // 2
    let _p5 = println(derangement(4));    // 9
    let _p6 = println(derangement(5));    // 44
    let _p7 = println(derangement(7));    // 1854

    // Verify with inclusion-exclusion
    let _p8 = println(derangement_ie(4));  // 9 (same as D(4))
    let _p9 = println(derangement_ie(5));  // 44

    // Probability of derangement (scaled * 10000)
    // As n grows, this converges to 1/e ≈ 0.3679 → 3679
    let _p10 = println(derangement_prob(3));  // 3333 (2/6 * 10000)
    let _p11 = println(derangement_prob(5));  // 3666 (44/120 * 10000)
    let _p12 = println(derangement_prob(7));  // 3678 (1854/5040 * 10000)

    // Fixed point counts for n=4
    // k=0: D(4)=9, k=1: C(4,1)*D(3)=4*2=8, k=2: C(4,2)*D(2)=6*1=6
    // k=3: C(4,3)*D(1)=4*0=0, k=4: C(4,4)*D(0)=1*1=1
    let _p13 = println(fixed_point_count(4, 0));  // 9
    let _p14 = println(fixed_point_count(4, 1));  // 8
    let _p15 = println(fixed_point_count(4, 2));  // 6
    let _p16 = println(fixed_point_count(4, 3));  // 0

    // Verify: sum over k=0..n of fixed_point_count(n,k) = n!
    let _p17 = println(verify_sum(4));    // 24 (= 4!)
    let _p18 = println(verify_sum(5));    // 120 (= 5!)

    0
};

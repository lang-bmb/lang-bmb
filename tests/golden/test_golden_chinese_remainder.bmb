// Golden Test: Chinese Remainder Theorem
// Solve system of congruences: x = r_i (mod m_i)
// Uses extended GCD for modular inverse

// Extended GCD: returns gcd(a, b)
// Also computes x such that a*x + b*y = gcd(a,b)
// We store x in a global-like approach using recursion
fn gcd(a: i64, b: i64) -> i64 = {
    if b == 0 { a } else { gcd(b, a % b) }
};

// Modular inverse of a mod m using extended Euclidean algorithm
// Returns x such that (a * x) % m = 1
// Iterative version
fn mod_inverse(a: i64, m: i64) -> i64 = {
    let mut old_r = a;
    let mut r = m;
    let mut old_s = 1;
    let mut s = 0;
    loop {
        if r == 0 { break } else { () };
        let q = old_r / r;
        let temp_r = r;
        set r = old_r - q * r;
        set old_r = temp_r;
        let temp_s = s;
        set s = old_s - q * s;
        set old_s = temp_s
    };
    // Make result positive
    let result = old_s % m;
    if result < 0 { result + m } else { result }
};

// CRT for two congruences: x = r1 (mod m1), x = r2 (mod m2)
// Requires gcd(m1, m2) = 1
fn crt2(r1: i64, m1: i64, r2: i64, m2: i64) -> i64 = {
    let m = m1 * m2;
    let inv = mod_inverse(m1, m2);
    // x = r1 + m1 * ((r2 - r1) * inv mod m2)
    let diff = ((r2 - r1) % m2 + m2) % m2;
    let x = r1 + m1 * ((diff * inv) % m2);
    (x % m + m) % m
};

// CRT for three congruences
fn crt3(r1: i64, m1: i64, r2: i64, m2: i64, r3: i64, m3: i64) -> i64 = {
    let x12 = crt2(r1, m1, r2, m2);
    let m12 = m1 * m2;
    crt2(x12, m12, r3, m3)
};

fn main() -> i64 = {
    // Test 1: gcd computations
    let _p1 = println(gcd(12, 8));     // 4
    let _p2 = println(gcd(35, 15));    // 5
    let _p3 = println(gcd(7, 13));     // 1 (coprime)

    // Test 2: modular inverse
    // 3 * x = 1 (mod 7) => x = 5 (since 3*5=15=2*7+1)
    let _p4 = println(mod_inverse(3, 7));    // 5
    // 2 * x = 1 (mod 5) => x = 3 (since 2*3=6=1*5+1)
    let _p5 = println(mod_inverse(2, 5));    // 3

    // Test 3: Classic CRT example
    // x = 2 (mod 3), x = 3 (mod 5) => x = 8 (mod 15)
    let _p6 = println(crt2(2, 3, 3, 5));    // 8

    // Test 4: x = 1 (mod 2), x = 2 (mod 3) => x = 5 (mod 6)
    let _p7 = println(crt2(1, 2, 2, 3));    // 5

    // Test 5: Three congruences (classic puzzle)
    // x = 2 (mod 3), x = 3 (mod 5), x = 2 (mod 7)
    // x = 23 (mod 105)
    let _p8 = println(crt3(2, 3, 3, 5, 2, 7));  // 23

    // Test 6: x = 1 (mod 2), x = 2 (mod 3), x = 3 (mod 5)
    // x = 23 (mod 30)
    let _p9 = println(crt3(1, 2, 2, 3, 3, 5));   // 23

    // Test 7: Verification - check that solutions satisfy all congruences
    let sol1 = crt3(2, 3, 3, 5, 2, 7);
    let _p10 = println(sol1 % 3);   // 2
    let _p11 = println(sol1 % 5);   // 3
    let _p12 = println(sol1 % 7);   // 2

    0
};

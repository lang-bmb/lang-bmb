// Golden Test: Expression tree evaluation using flat arrays
// Tests: build expression trees, recursive evaluation, tree height
// Nodes stored in flat arrays: value[], left[], right[], is_op[]
// is_op: 0=number, 1=add, 2=sub, 3=mul, 4=div

// Allocate a tree with capacity for n nodes
// Returns a meta vec containing [values, lefts, rights, ops, next_id]
fn tree_new() -> i64 = {
    let meta = vec_new();
    let values = vec_new();
    let lefts = vec_new();
    let rights = vec_new();
    let ops = vec_new();
    let _p = vec_push(meta, values);
    let _p = vec_push(meta, lefts);
    let _p = vec_push(meta, rights);
    let _p = vec_push(meta, ops);
    // next_id stored at index 4
    let _p = vec_push(meta, 0);
    meta
};

fn tree_values(t: i64) -> i64 = vec_get(t, 0);
fn tree_lefts(t: i64) -> i64 = vec_get(t, 1);
fn tree_rights(t: i64) -> i64 = vec_get(t, 2);
fn tree_ops(t: i64) -> i64 = vec_get(t, 3);
fn tree_next_id(t: i64) -> i64 = vec_get(t, 4);

fn tree_set_next_id(t: i64, id: i64) -> i64 = {
    let _p = vec_set(t, 4, id);
    0
};

// Add a number leaf node, returns node id
fn tree_add_num(t: i64, val: i64) -> i64 = {
    let id = tree_next_id(t);
    let _p = vec_push(tree_values(t), val);
    let _p = vec_push(tree_lefts(t), 0 - 1);
    let _p = vec_push(tree_rights(t), 0 - 1);
    let _p = vec_push(tree_ops(t), 0);
    let _p = tree_set_next_id(t, id + 1);
    id
};

// Add an operator node with left and right children, returns node id
// op: 1=add, 2=sub, 3=mul, 4=div
fn tree_add_op(t: i64, op: i64, left: i64, right: i64) -> i64 = {
    let id = tree_next_id(t);
    let _p = vec_push(tree_values(t), 0);
    let _p = vec_push(tree_lefts(t), left);
    let _p = vec_push(tree_rights(t), right);
    let _p = vec_push(tree_ops(t), op);
    let _p = tree_set_next_id(t, id + 1);
    id
};

// Evaluate the expression tree rooted at node id
fn tree_eval(t: i64, id: i64) -> i64 = {
    let op = vec_get(tree_ops(t), id);
    if op == 0 {
        // Leaf: return value
        vec_get(tree_values(t), id)
    } else {
        let lval = tree_eval(t, vec_get(tree_lefts(t), id));
        let rval = tree_eval(t, vec_get(tree_rights(t), id));
        if op == 1 { lval + rval }
        else if op == 2 { lval - rval }
        else if op == 3 { lval * rval }
        else { lval / rval }
    }
};

// Compute height of tree rooted at node id
fn tree_height(t: i64, id: i64) -> i64 = {
    let op = vec_get(tree_ops(t), id);
    if op == 0 {
        // Leaf
        0
    } else {
        let lh = tree_height(t, vec_get(tree_lefts(t), id));
        let rh = tree_height(t, vec_get(tree_rights(t), id));
        let mx = if lh > rh { lh } else { rh };
        1 + mx
    }
};

// Count nodes in tree rooted at id
fn tree_count(t: i64, id: i64) -> i64 = {
    let op = vec_get(tree_ops(t), id);
    if op == 0 {
        1
    } else {
        1 + tree_count(t, vec_get(tree_lefts(t), id)) + tree_count(t, vec_get(tree_rights(t), id))
    }
};

fn tree_free(t: i64) -> i64 = {
    let _f = vec_free(tree_values(t));
    let _f = vec_free(tree_lefts(t));
    let _f = vec_free(tree_rights(t));
    let _f = vec_free(tree_ops(t));
    let _f = vec_free(t);
    0
};

fn main() -> i64 = {
    // === Test 1: (3 + 4) * (2 - 1) = 7 * 1 = 7 ===
    let t1 = tree_new();
    let n3 = tree_add_num(t1, 3);     // id 0
    let n4 = tree_add_num(t1, 4);     // id 1
    let add1 = tree_add_op(t1, 1, n3, n4);  // id 2: 3+4
    let n2 = tree_add_num(t1, 2);     // id 3
    let n1 = tree_add_num(t1, 1);     // id 4
    let sub1 = tree_add_op(t1, 2, n2, n1);  // id 5: 2-1
    let mul1 = tree_add_op(t1, 3, add1, sub1);  // id 6: (3+4)*(2-1)

    let _p = println_str("=== (3 + 4) * (2 - 1) ===");
    let _p = print_str("result = ");
    let _p = println(tree_eval(t1, mul1));  // 7
    let _p = print_str("height = ");
    let _p = println(tree_height(t1, mul1));  // 2
    let _p = print_str("nodes = ");
    let _p = println(tree_count(t1, mul1));  // 7

    // === Test 2: (10 / 2) + (3 * 5) = 5 + 15 = 20 ===
    let t2 = tree_new();
    let n10 = tree_add_num(t2, 10);   // id 0
    let n2b = tree_add_num(t2, 2);    // id 1
    let div1 = tree_add_op(t2, 4, n10, n2b);  // id 2: 10/2
    let n3b = tree_add_num(t2, 3);    // id 3
    let n5 = tree_add_num(t2, 5);     // id 4
    let mul2 = tree_add_op(t2, 3, n3b, n5);   // id 5: 3*5
    let add2 = tree_add_op(t2, 1, div1, mul2); // id 6: (10/2)+(3*5)

    let _p = println_str("");
    let _p = println_str("=== (10 / 2) + (3 * 5) ===");
    let _p = print_str("result = ");
    let _p = println(tree_eval(t2, add2));  // 20
    let _p = print_str("height = ");
    let _p = println(tree_height(t2, add2));  // 2
    let _p = print_str("nodes = ");
    let _p = println(tree_count(t2, add2));  // 7

    // === Test 3: ((1 + 2) * (3 + 4)) - ((5 - 6) * (7 + 8)) ===
    // = (3 * 7) - ((-1) * 15) = 21 - (-15) = 36
    let t3 = tree_new();
    let na = tree_add_num(t3, 1);
    let nb = tree_add_num(t3, 2);
    let add_ab = tree_add_op(t3, 1, na, nb);    // 1+2=3
    let nc = tree_add_num(t3, 3);
    let nd = tree_add_num(t3, 4);
    let add_cd = tree_add_op(t3, 1, nc, nd);    // 3+4=7
    let mul_left = tree_add_op(t3, 3, add_ab, add_cd);  // 3*7=21
    let ne = tree_add_num(t3, 5);
    let nf = tree_add_num(t3, 6);
    let sub_ef = tree_add_op(t3, 2, ne, nf);    // 5-6=-1
    let ng = tree_add_num(t3, 7);
    let nh = tree_add_num(t3, 8);
    let add_gh = tree_add_op(t3, 1, ng, nh);    // 7+8=15
    let mul_right = tree_add_op(t3, 3, sub_ef, add_gh); // -1*15=-15
    let root3 = tree_add_op(t3, 2, mul_left, mul_right); // 21-(-15)=36

    let _p = println_str("");
    let _p = println_str("=== ((1+2)*(3+4)) - ((5-6)*(7+8)) ===");
    let _p = print_str("result = ");
    let _p = println(tree_eval(t3, root3));  // 36
    let _p = print_str("height = ");
    let _p = println(tree_height(t3, root3));  // 3
    let _p = print_str("nodes = ");
    let _p = println(tree_count(t3, root3));  // 15

    // === Test 4: Single number tree ===
    let t4 = tree_new();
    let single = tree_add_num(t4, 42);

    let _p = println_str("");
    let _p = println_str("=== Single node: 42 ===");
    let _p = print_str("result = ");
    let _p = println(tree_eval(t4, single));  // 42
    let _p = print_str("height = ");
    let _p = println(tree_height(t4, single));  // 0
    let _p = print_str("nodes = ");
    let _p = println(tree_count(t4, single));  // 1

    // === Test 5: Left-skewed tree: ((((5 + 3) - 2) * 4) / 6) ===
    // = ((8 - 2) * 4) / 6 = (6 * 4) / 6 = 24 / 6 = 4
    let t5 = tree_new();
    let n5a = tree_add_num(t5, 5);
    let n3a = tree_add_num(t5, 3);
    let op1 = tree_add_op(t5, 1, n5a, n3a);   // 5+3=8
    let n2a = tree_add_num(t5, 2);
    let op2 = tree_add_op(t5, 2, op1, n2a);   // 8-2=6
    let n4a = tree_add_num(t5, 4);
    let op3 = tree_add_op(t5, 3, op2, n4a);   // 6*4=24
    let n6a = tree_add_num(t5, 6);
    let op4 = tree_add_op(t5, 4, op3, n6a);   // 24/6=4

    let _p = println_str("");
    let _p = println_str("=== ((((5+3)-2)*4)/6) ===");
    let _p = print_str("result = ");
    let _p = println(tree_eval(t5, op4));  // 4
    let _p = print_str("height = ");
    let _p = println(tree_height(t5, op4));  // 4
    let _p = print_str("nodes = ");
    let _p = println(tree_count(t5, op4));  // 9

    // Cleanup
    let _f = tree_free(t1);
    let _f = tree_free(t2);
    let _f = tree_free(t3);
    let _f = tree_free(t4);
    let _f = tree_free(t5);
    0
};

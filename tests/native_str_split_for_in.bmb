// Test: str_split + for-in-svec native (Cycle 2887)
// Expected output: 5 (sum of lengths: hello=5, world=5 → but "foo" too; a,b,c → 3 items, 1+1+1=3)
// Using "a,bb,ccc" → lengths 1+2+3 = 6

fn main() -> i64 = {
    let parts = str_split("a,bb,ccc", ",");
    let total = [0; 1];
    for p in parts {
        set total[0] = total[0] + str_len(p);
    };
    println(total[0]);   // 6
    svec_free(parts);
    total[0]
};

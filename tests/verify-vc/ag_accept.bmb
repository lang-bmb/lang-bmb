// R2 machine-int acceptance — now SOUND under T-BV (Cycle 3582).
// Originally (C3576) the abstain-guard emitted "unsupported" for mul/div/mod
// because SMT modelled Int as unbounded while i64 wraps. T-BV models i64 as
// signed (_ BitVec 64), so wrap is faithful: the multiplicative ops are
// re-enabled with genuine verdicts and +/- are sound too. This fixture now pins
// the sound behaviour (the oracle of record is tests/verify-vc/EXPECTED.md):
//   ag_mul  -> refuted    (x*2 overflows; witness x=2^62 -> it=i64::MIN)
//   ag_div  -> verified   (x>=0 => x/2 >= 0, bvsdiv)
//   ag_mod  -> verified   (x>=0 => x%3 in [0,2], bvsrem)
//   ag_add  -> refuted    (THE headline soundness fix: x=i64::MAX => x+1 wraps <0)
//   ag_sub  -> verified   (x>=5 => x-5 >= 0, now sound — was idealized)
//   ag_leaf -> verified   (no arithmetic)

fn ag_mul(x: i64) -> i64
  pre x >= 0
  post it >= 0
= x * 2;

fn ag_div(x: i64) -> i64
  pre x >= 0
  post it >= 0
= x / 2;

fn ag_mod(x: i64) -> i64
  pre x >= 0
  post it >= 0
= x % 3;

fn ag_add(x: i64) -> i64
  pre x >= 0
  post it >= 0
= x + 1;

fn ag_sub(x: i64) -> i64
  pre x >= 5
  post it >= 0
= x - 5;

fn ag_leaf(x: i64) -> i64
  pre x >= 5
  post it >= 5
= x;
